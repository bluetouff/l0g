---
import BaseLayout from '../layouts/BaseLayout.astro';
import { agentPrompts, previewAgentPrompt } from '../lib/agent-prompts.mjs';
import TrustBar from '../components/TrustBar.astro';
import { MCP_COMPACT_PUBLIC_PATH, MCP_PUBLIC_PATH } from '../config/agent-contract.mjs';

const site = (Astro.site?.toString() ?? 'https://l0g.fr/').replace(/\/$/, '');

const trustItems = [
  { label: 'agents.json', href: '/agents.json' },
  { label: 'OpenAPI', href: '/openapi.json' },
  { label: 'Black Box', href: '/black-box/' },
  { label: 'Risk Diff', href: '/risk-diff/' },
  { label: 'backtests', href: '/backtests/' },
  { label: 'MCP public', href: '/mcp/' },
  { label: 'preuves', href: '/preuves/' },
];

const surfaces = [
  {
    need: 'Découvrir le site',
    endpoint: '/agents.json',
    use: 'Point de départ : capacités, endpoints, règles d’usage, attribution et limites.',
  },
  {
    need: 'Construire un client',
    endpoint: '/openapi.json',
    use: 'Contrat OpenAPI 3.1 pour intégrer les endpoints JSON sans deviner les champs.',
  },
  {
    need: 'Ingestion RAG',
    endpoint: '/api/v1/catalog.ndjson',
    use: 'Catalogue ligne à ligne avec articles, guides, sources et atlas du glossaire.',
  },
  {
    need: 'Audit de preuve',
    endpoint: '/api/v1/evidence-graph.json',
    use: 'Graphe articles, claims, références, hôtes, sources primaires et datasets.',
  },
  {
    need: 'Citation précise',
    endpoint: '/api/v1/claims.json',
    use: 'Trois claims structurants maximum par article, toujours typés : fait, estimation, inférence ou scénario, avec références datées quand détectable.',
  },
  {
    need: 'Veille incrémentale',
    endpoint: '/api/v1/changes.ndjson',
    use: 'Flux machine pour suivre publications, révisions et changements éditoriaux.',
  },
  {
    need: 'Diff du risque',
    endpoint: '/api/v1/risk-diff.json',
    use: 'Fenêtres 1, 7 et 30 jours : signaux qui montent ou baissent, sources stale, nouvelles données, claims, modèles, articles et confiance.',
  },
  {
    need: 'Replay point-in-time',
    endpoint: '/api/v1/black-box.json',
    use: 'Frames datées et hashées pour rejouer l’état public du risque à une date donnée, sans reconstruction rétroactive.',
  },
  {
    need: 'Backtester les signaux',
    endpoint: '/api/v1/signals/history.csv',
    use: 'Observations point-in-time à plat, plus exports JSON et NDJSON, pour rejouer les signaux sans look-ahead bias.',
  },
  {
    need: 'Lire Dette US',
    endpoint: '/api/v1/debt-risk.json',
    use: 'Signal canonique Debt Risk Radar : stress courant hors CBO, couverture des buckets et provenance du snapshot.',
  },
  {
    need: 'Fraîcheur',
    endpoint: '/api/v1/freshness.json',
    use: 'Derniers contenus, endpoints et temporalité des signaux : observedAt, computedAt, expiration et couverture.',
  },
  {
    need: 'Intégrité',
    endpoint: '/api/v1/integrity.json',
    use: 'Empreintes SHA-256 canoniques des surfaces publiques.',
  },
  {
    need: 'Tool calling',
    endpoint: MCP_COMPACT_PUBLIC_PATH,
    use: `Façade MCP recommandée à six outils. La surface complète reste disponible sur ${MCP_PUBLIC_PATH} pour les usages experts.`,
  },
  {
    need: 'Mesurer l’usage MCP',
    endpoint: '/api/mcp/usage',
    use: 'Rapport agrégé sur 91 jours : volumes, tools, resources, prompts et familles client masquées sous cinq initialisations.',
  },
];

const flow = [
  'Lire /agents.json pour comprendre les capacités et les règles d’usage.',
  'Vérifier /api/v1/freshness.json avant de répondre à une question sensible au temps ou aux signaux de marché.',
  'Utiliser /api/v1/catalog.ndjson pour trouver les documents pertinents.',
  'Utiliser /api/v1/claims.json ou /api/v1/evidence-graph.json pour relier une affirmation à sa preuve.',
  'Utiliser /api/v1/risk-diff.json pour résumer ce qui a changé dans le risque depuis 1, 7 ou 30 jours.',
  'Utiliser /api/v1/black-box.json pour rejouer une date uniquement si une frame publique existe déjà.',
  'Utiliser /api/v1/signals/history.csv ou .ndjson pour backtester les signaux point-in-time.',
  'Utiliser /api/v1/debt-risk.json pour Dette US, pas une moyenne recalculée depuis les buckets.',
  'Citer l’URL canonique, la date de publication ou de source, et le type de claim.',
  'Pour un suivi continu, consommer /api/v1/changes.ndjson plutôt que rescanner tout le site.',
];

const prompts = agentPrompts.map((prompt) => ({
  name: prompt.name,
  label: prompt.webLabel,
  text: previewAgentPrompt(prompt.name),
}));

const rules = [
  'Ne transforme pas une estimation ou une inférence en fait établi.',
  'Ne compare pas directement deux scores 0-100 quand la page précise qu’il s’agit d’une normalisation d’affichage.',
  'Ne renormalise pas le score Dette US si une famille manque : utilise le score courant publié et sa couverture.',
  'Ne cite pas l0g seul quand une source primaire est disponible dans les références.',
  'Ne supprime pas les dates : elles font partie de la preuve.',
  'Ne présente pas le contenu comme un conseil en investissement.',
];

const curlExamples = [
  'curl -s https://l0g.fr/agents.json',
  'curl -s https://l0g.fr/api/v1/freshness.json',
  'curl -s https://l0g.fr/api/v1/risk-diff.json',
  'curl -s https://l0g.fr/api/v1/black-box.json',
  'curl -s https://l0g.fr/api/v1/signals/history.ndjson | head',
  'curl -s https://l0g.fr/api/v1/catalog.ndjson | head',
  'curl -s https://l0g.fr/api/v1/evidence-graph.json',
  'curl -s https://l0g.fr/api/mcp/usage',
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  '@id': `${site}/agents/#guide`,
  headline: 'Utiliser l0g avec un agent',
  description:
    'Guide pratique pour connecter un agent IA à l0g.fr : MCP, Agent Surface, OpenAPI, Risk Diff, Black Box, NDJSON, evidence graph, historique des signaux, citations et vérification.',
  inLanguage: 'fr',
  isAccessibleForFree: true,
  license: 'https://creativecommons.org/licenses/by/4.0/',
  publisher: { '@id': `${site}/#org` },
};
const safeJsonLd = JSON.stringify(jsonLd).replace(/</g, '\\u003c');
---

<BaseLayout
  title="Utiliser l0g avec un agent"
  description="Guide pratique pour connecter un agent IA à l0g.fr : MCP public, Agent Surface, OpenAPI, Risk Diff, Black Box, NDJSON, evidence graph, historique des signaux, citations et vérification."
  ogImage="/og-donnees.png"
  ogImageAlt="Utiliser l0g avec un agent : MCP, Agent Surface et evidence graph"
  sidebar={false}
>
  <script type="application/ld+json" is:inline set:html={safeJsonLd} />

  <article class="agent-guide rise" data-pagefind-body>
    <section class="guide-hero">
      <p class="mono-label glow">// agent-ready</p>
      <h1 class="guide-title font-display glow">Utiliser l0g avec un agent</h1>
      <p class="guide-lede">
        l0g expose désormais une surface machine lisible sans scraping : manifeste,
        contrat OpenAPI, Risk Diff, Black Box Recorder, flux NDJSON, evidence graph,
        claims sourcées, historique point-in-time des signaux, fraîcheur,
        intégrité et MCP public. L’objectif n’est pas de faire parler un agent plus vite,
        mais de l’obliger à conserver la source, la date et le niveau de preuve.
      </p>
      <TrustBar items={trustItems} />
    </section>

    <section class="guide-section usage-section" data-mcp-usage data-pagefind-ignore>
      <p class="mono-label glow">// preuve d'usage</p>
      <h2 class="usage-title font-display">Statistiques MCP anonymisées</h2>
      <p class="usage-lede">
        Fenêtre glissante de 91 jours. l0g compte des événements techniques agrégés,
        sans IP, cookie, session, empreinte ni user-agent. Les noms libres déclarés dans
        <code>clientInfo</code> sont immédiatement ramenés à une famille fermée ; les cohortes
        inférieures à cinq initialisations restent masquées.
      </p>

      <div class="usage-cards" aria-live="polite">
        <article><span>Initialisations</span><strong data-usage-stat="initializations">…</strong></article>
        <article><span>Appels de tools</span><strong data-usage-stat="tool_calls">…</strong></article>
        <article><span>Resources lues</span><strong data-usage-stat="resource_reads">…</strong></article>
        <article><span>Prompts rendus</span><strong data-usage-stat="prompt_gets">…</strong></article>
        <article><span><code>clientInfo</code> déclaré</span><strong data-usage-stat="client_info_declaration_rate">…</strong></article>
      </div>
      <p class="usage-status" data-usage-status>Chargement du rapport public…</p>

      <div class="usage-tables">
        <section>
          <h3>Tools les plus appelés</h3>
          <div class="usage-table-wrap">
            <table>
              <thead><tr><th>Tool</th><th>Appels</th></tr></thead>
              <tbody data-usage-tools></tbody>
            </table>
          </div>
        </section>
        <section>
          <h3>Familles déclarées via <code>clientInfo</code></h3>
          <div class="usage-table-wrap">
            <table>
              <thead><tr><th>Famille</th><th>Initialisations</th></tr></thead>
              <tbody data-usage-clients></tbody>
            </table>
          </div>
        </section>
        <section>
          <h3>Resources les plus lues</h3>
          <div class="usage-table-wrap">
            <table>
              <thead><tr><th>Famille</th><th>Lectures</th></tr></thead>
              <tbody data-usage-resources></tbody>
            </table>
          </div>
        </section>
        <section>
          <h3>Prompts les plus rendus</h3>
          <div class="usage-table-wrap">
            <table>
              <thead><tr><th>Prompt</th><th>Rendus</th></tr></thead>
              <tbody data-usage-prompts></tbody>
            </table>
          </div>
        </section>
      </div>

      <p class="usage-method">
        <strong>Ce qui n'est pas mesuré.</strong> Sans identifiant technique, l0g ne peut pas
        compter des personnes, distinguer deux agents derrière une même intégration ni qualifier
        un appelant de récurrent. Les appels de tools ne sont pas reliés aux familles de clients.
        <a href="/rgpd/">Lire le cadre de confidentialité</a>.
      </p>
    </section>

    <section class="guide-section">
      <p class="mono-label glow">// chemin recommandé</p>
      <ol class="flow-list">
        {flow.map((item) => <li>{item}</li>)}
      </ol>
    </section>

    <section class="guide-section">
      <p class="mono-label glow">// choisir la bonne surface</p>
      <div class="surface-grid">
        {surfaces.map((surface) => (
          <a class="surface-card" href={surface.endpoint}>
            <span>{surface.need}</span>
            <code>{surface.endpoint}</code>
            <p>{surface.use}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="guide-section split">
      <div class="note-block">
        <p class="mono-label glow">// prompts prêts à coller</p>
        <div class="prompt-stack">
          {prompts.map((prompt) => (
            <figure class="prompt-card">
              <figcaption>{prompt.label} <code>{prompt.name}</code></figcaption>
              <blockquote>{prompt.text}</blockquote>
            </figure>
          ))}
        </div>
      </div>

      <div class="note-block">
        <p class="mono-label glow">// règles de citation</p>
        <ul class="rule-list">
          <li>URL canonique de l’article ou de l’endpoint.</li>
          <li>Date de publication, de révision ou de source quand elle existe.</li>
          <li>Trois claims structurants maximum par article, chacun typé : fait, estimation, inférence ou scénario.</li>
          <li>Source primaire citée quand l’evidence graph la connaît.</li>
          <li>Mention explicite des limites si la donnée est incomplète.</li>
        </ul>
      </div>
    </section>

    <section class="guide-section split">
      <div class="note-block">
        <p class="mono-label glow">// MCP public</p>
        <p>
          Le serveur <a href="/mcp/">MCP</a> expose une façade compacte read-only à six outils :
          découverte, recherche, documents, preuves, research packs et état du risque. La surface
          complète conserve les outils spécialisés de fraîcheur, claims, evidence graph, sources,
          intégrité, changefeed, Risk Diff et Black Box.
        </p>
        <pre><code>POST https://l0g.fr{MCP_COMPACT_PUBLIC_PATH}</code></pre>
        <p class="mt-2 text-muted">Surface complète : <code>https://l0g.fr{MCP_PUBLIC_PATH}</code></p>
      </div>

      <div class="note-block">
        <p class="mono-label glow">// exemples curl</p>
        <pre><code>{curlExamples.join('\n')}</code></pre>
      </div>
    </section>

    <section class="guide-section">
      <p class="mono-label glow">// ce qu’un agent ne doit pas faire</p>
      <ul class="avoid-list">
        {rules.map((rule) => <li>{rule}</li>)}
      </ul>
    </section>
  </article>

  <script>
    const root = document.querySelector<HTMLElement>('[data-mcp-usage]');
    const status = root?.querySelector<HTMLElement>('[data-usage-status]');
    const tools = root?.querySelector<HTMLTableSectionElement>('[data-usage-tools]');
    const clients = root?.querySelector<HTMLTableSectionElement>('[data-usage-clients]');
    const resources = root?.querySelector<HTMLTableSectionElement>('[data-usage-resources]');
    const prompts = root?.querySelector<HTMLTableSectionElement>('[data-usage-prompts]');
    const count = new Intl.NumberFormat('fr-FR');
    const percent = new Intl.NumberFormat('fr-FR', { style: 'percent', maximumFractionDigits: 1 });

    function addRow(target: HTMLTableSectionElement | null | undefined, label: string, value: number) {
      if (!target) return;
      const row = document.createElement('tr');
      const name = document.createElement('td');
      const total = document.createElement('td');
      name.textContent = label;
      total.textContent = count.format(value);
      row.append(name, total);
      target.append(row);
    }

    function addEmpty(target: HTMLTableSectionElement | null | undefined, message: string) {
      if (!target || target.children.length) return;
      const row = document.createElement('tr');
      const cell = document.createElement('td');
      cell.colSpan = 2;
      cell.textContent = message;
      row.append(cell);
      target.append(row);
    }

    try {
      const response = await fetch('/api/mcp/usage', { headers: { Accept: 'application/json' } });
      if (!response.ok) throw new Error('usage_report_unavailable');
      const report = await response.json();
      if (!report.enabled) throw new Error('usage_collection_disabled');

      for (const element of root?.querySelectorAll<HTMLElement>('[data-usage-stat]') ?? []) {
        const key = element.dataset.usageStat ?? '';
        const value = report.totals?.[key];
        element.textContent = key.endsWith('_rate')
          ? (typeof value === 'number' ? percent.format(value) : 'Indisponible')
          : (typeof value === 'number' ? count.format(value) : 'Indisponible');
      }

      for (const row of (report.tools ?? []).slice(0, 10)) addRow(tools, row.name, row.count);
      for (const row of (report.clients ?? []).slice(0, 10)) addRow(clients, row.family, row.count);
      for (const row of (report.resources ?? []).slice(0, 10)) addRow(resources, row.family, row.count);
      for (const row of (report.prompts ?? []).slice(0, 10)) addRow(prompts, row.name, row.count);
      addEmpty(tools, 'Aucun appel agrégé à ce stade.');
      addEmpty(clients, 'Cohortes encore inférieures au seuil public.');
      addEmpty(resources, 'Aucune lecture agrégée à ce stade.');
      addEmpty(prompts, 'Aucun rendu agrégé à ce stade.');

      if (status) {
        const freshness = report.updated_at
          ? `Rapport mis à jour le ${new Intl.DateTimeFormat('fr-FR', { dateStyle: 'long', timeStyle: 'short' }).format(new Date(report.updated_at))}.`
          : 'Instrumentation active, aucun événement agrégé à ce stade.';
        status.textContent = report.storage_healthy === false
          ? `${freshness} La dernière écriture de l’agrégat a échoué.`
          : freshness;
      }
    } catch {
      if (status) status.textContent = 'Le rapport d’usage est momentanément indisponible. Aucun chiffre de remplacement n’est estimé.';
      for (const element of root?.querySelectorAll<HTMLElement>('[data-usage-stat]') ?? []) element.textContent = 'Indisponible';
      addEmpty(tools, 'Rapport indisponible.');
      addEmpty(clients, 'Rapport indisponible.');
      addEmpty(resources, 'Rapport indisponible.');
      addEmpty(prompts, 'Rapport indisponible.');
    }
  </script>

  <style>
    .agent-guide {
      max-width: 64rem;
    }

    .guide-hero {
      padding-bottom: 2.2rem;
      border-bottom: 1px solid var(--color-line);
    }

    .guide-title {
      margin-top: 1rem;
      max-width: 48rem;
      color: var(--color-bright);
      font-size: clamp(2rem, 4.5vw, 3rem);
      line-height: 1.14;
      letter-spacing: 0.02em;
    }

    .guide-lede {
      margin-top: 1.15rem;
      max-width: 52rem;
      border-left: 2px solid var(--color-signal);
      padding-left: 1rem;
      color: var(--color-paper);
      font-family: var(--font-read);
      font-size: clamp(1.04rem, 2vw, 1.18rem);
      line-height: 1.66;
    }

    .guide-section {
      margin-top: 3rem;
    }

    .usage-section {
      border-bottom: 1px solid var(--color-line);
      padding-bottom: 3rem;
    }

    .usage-title {
      margin-top: 0.8rem;
      color: var(--color-bright);
      font-size: clamp(1.65rem, 3vw, 2.25rem);
      line-height: 1.15;
    }

    .usage-lede,
    .usage-method {
      margin-top: 0.8rem;
      max-width: 52rem;
      color: var(--color-muted);
      font-size: 0.92rem;
      line-height: 1.65;
    }

    .usage-lede code,
    .usage-method code,
    .usage-tables code {
      color: var(--color-signal);
      font-family: var(--font-mono);
    }

    .usage-cards {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
      margin-top: 1.25rem;
    }

    .usage-cards article,
    .usage-tables > section {
      border: 1px solid var(--color-line);
      border-radius: 8px;
      background: color-mix(in srgb, var(--color-surface) 54%, transparent);
    }

    .usage-cards article {
      display: grid;
      gap: 0.6rem;
      min-width: 0;
      padding: 1rem;
    }

    .usage-cards span {
      color: var(--color-muted);
      font-family: var(--font-mono);
      font-size: 0.66rem;
      letter-spacing: 0.07em;
      text-transform: uppercase;
    }

    .usage-cards strong {
      color: var(--color-bright);
      font-family: var(--font-display);
      font-size: clamp(1.5rem, 4vw, 2.2rem);
      line-height: 1;
      overflow-wrap: anywhere;
    }

    .usage-status {
      margin-top: 0.8rem;
      color: var(--color-muted);
      font-family: var(--font-mono);
      font-size: 0.7rem;
    }

    .usage-tables {
      display: grid;
      gap: 0.85rem;
      margin-top: 1.4rem;
    }

    .usage-tables > section {
      min-width: 0;
      padding: 1rem;
    }

    .usage-tables h3 {
      color: var(--color-paper);
      font-family: var(--font-mono);
      font-size: 0.75rem;
      letter-spacing: 0.05em;
    }

    .usage-table-wrap {
      margin-top: 0.65rem;
      overflow-x: auto;
    }

    .usage-table-wrap table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.78rem;
    }

    .usage-table-wrap th,
    .usage-table-wrap td {
      border-bottom: 1px solid var(--color-line);
      padding: 0.55rem 0.4rem;
      text-align: left;
    }

    .usage-table-wrap th {
      color: var(--color-muted);
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .usage-table-wrap td {
      color: var(--color-paper);
      overflow-wrap: anywhere;
    }

    .usage-table-wrap th:last-child,
    .usage-table-wrap td:last-child {
      text-align: right;
    }

    .usage-method {
      border-left: 2px solid color-mix(in srgb, var(--color-signal) 55%, transparent);
      padding: 0.9rem 1rem;
      background: color-mix(in srgb, var(--color-signal) 5%, transparent);
    }

    .usage-method a {
      color: var(--color-signal);
    }

    @media (min-width: 720px) {
      .usage-cards {
        grid-template-columns: repeat(5, minmax(0, 1fr));
      }

      .usage-tables {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    .surface-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.75rem;
      margin-top: 1rem;
    }

    @media (min-width: 760px) {
      .surface-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    .surface-card,
    .note-block,
    .flow-list,
    .avoid-list {
      border: 1px solid var(--color-line);
      border-radius: 8px;
      background: color-mix(in srgb, var(--color-surface) 54%, transparent);
    }

    .surface-card {
      display: grid;
      gap: 0.45rem;
      padding: 0.95rem;
      text-decoration: none;
      transition: border-color 0.16s, background 0.16s;
    }

    .surface-card:hover {
      border-color: color-mix(in srgb, var(--color-signal) 48%, transparent);
      background: color-mix(in srgb, var(--color-signal) 6%, transparent);
    }

    .surface-card span,
    .prompt-card figcaption {
      color: var(--color-signal);
      font-family: var(--font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .surface-card code,
    .note-block code,
    .note-block pre {
      color: var(--color-paper);
      font-family: var(--font-mono);
      overflow-wrap: anywhere;
    }

    .surface-card p,
    .note-block p,
    .flow-list,
    .avoid-list,
    .rule-list,
    .prompt-card blockquote {
      color: var(--color-muted);
      font-size: 0.92rem;
      line-height: 1.6;
    }

    .flow-list,
    .avoid-list {
      display: grid;
      gap: 0.6rem;
      margin-top: 1rem;
      padding: 1rem 1rem 1rem 2.15rem;
    }

    .split {
      display: grid;
      gap: 1rem;
    }

    @media (min-width: 860px) {
      .split {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    .note-block {
      padding: 1rem;
    }

    .note-block a {
      color: var(--color-signal);
    }

    .note-block pre {
      margin-top: 0.8rem;
      border: 1px solid var(--color-line);
      border-radius: 8px;
      background: var(--color-bg);
      padding: 0.75rem;
      font-size: 0.8rem;
      white-space: pre-wrap;
    }

    .prompt-stack {
      display: grid;
      gap: 0.8rem;
      margin-top: 0.9rem;
    }

    .prompt-card {
      margin: 0;
