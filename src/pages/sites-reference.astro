---
import BaseLayout from '../layouts/BaseLayout.astro';

const categories = [
  {
    "titre": "Risque systémique, macro & opacité financière",
    "accent": "var(--color-signal)",
    "sources": [
      {
        "nom": "Naked Capitalism",
        "auteur": "Yves Smith",
        "desc": "Analyses très approfondies et critiques sur la finance, les risques systémiques, la régulation et les zones d'opacité.",
        "url": "https://www.nakedcapitalism.com/"
      },
      {
        "nom": "Wolf Street",
        "auteur": "Wolf Richter",
        "desc": "Travail data-driven sur la macro, la dette corporate, le crédit et les déséquilibres systémiques.",
        "url": "https://wolfstreet.com/"
      },
      {
        "nom": "Calculated Risk",
        "auteur": "Bill McBride",
        "desc": "Référence historique sur les données macro, le logement et les cycles économiques.",
        "url": "https://www.calculatedriskblog.com/"
      },
      {
        "nom": "FT Alphaville",
        "auteur": "Financial Times",
        "desc": "Analyses de haut niveau sur les marchés, la finance structurée, les risques et les narratifs vs réalité.",
        "url": "https://www.ft.com/alphaville"
      },
      {
        "nom": "Abnormal Returns",
        "auteur": null,
        "desc": "Veille quotidienne et commentaires sur la macro, les marchés et les flux.",
        "url": "https://abnormalreturns.com/"
      },
      {
        "nom": "Credit Bubble Bulletin",
        "auteur": "Doug Noland",
        "desc": "Analyses indépendantes sur les bulles de crédit, la liquidité mondiale et les risques de contagion.",
        "url": "https://creditbubblebulletin.blogspot.com/"
      },
      {
        "nom": "The Financial Investigator",
        "auteur": "Marc Rubinstein",
        "desc": "Enquêtes et analyses approfondies sur les dysfonctionnements des marchés financiers et les risques cachés.",
        "url": "https://www.netinterest.co/"
      }
    ]
  },
  {
    "titre": "Shadow banking, liquidité & infrastructure financière",
    "accent": "var(--color-accent)",
    "sources": [
      {
        "nom": "Bank for International Settlements (BIS)",
        "auteur": null,
        "desc": "Référence mondiale sur les risques systémiques, le shadow banking, les marchés de crédit et la stabilité financière.",
        "url": "https://www.bis.org/"
      },
      {
        "nom": "Office of Financial Research (OFR)",
        "auteur": null,
        "desc": "Créé après la crise de 2008 pour surveiller les vulnérabilités systémiques du système financier américain.",
        "url": "https://www.financialresearch.gov/"
      },
      {
        "nom": "Financial Stability Board (FSB)",
        "auteur": null,
        "desc": "Suivi mondial des banques systémiques, du shadow banking et des risques émergents.",
        "url": "https://www.fsb.org/"
      },
      {
        "nom": "New York Fed · Liberty Street Economics",
        "auteur": null,
        "desc": "Publications de référence sur les money market funds, les marchés repo et la stabilité financière.",
        "url": "https://libertystreeteconomics.newyorkfed.org/"
      }
    ]
  },
  {
    "titre": "Crédit privé & marchés de crédit",
    "accent": "var(--color-amber)",
    "sources": [
      {
        "nom": "Without Warning Research",
        "auteur": "Steven Kelly",
        "desc": "Analyses indépendantes et très pointues sur le private credit et les risques systémiques associés.",
        "url": "https://www.withoutwarningresearch.com/"
      },
      {
        "nom": "Alpha Architect",
        "auteur": null,
        "desc": "Articles académiques et pratiques sur les stratégies institutionnelles, les flux et les limites des données financières.",
        "url": "https://alphaarchitect.com/"
      },
      {
        "nom": "Verdad Capital Research",
        "auteur": null,
        "desc": "Analyses quantitatives approfondies sur le private equity, le private credit et les effets de flux.",
        "url": "https://verdadcap.com/archive"
      },
      {
        "nom": "AQR Research",
        "auteur": null,
        "desc": "Travaux de référence sur les facteurs de marché, les flux institutionnels et les biais comportementaux.",
        "url": "https://www.aqr.com/Insights/Research"
      },
      {
        "nom": "Research Affiliates",
        "auteur": null,
        "desc": "Études quantitatives sur les ETF, les valorisations, les facteurs et les comportements de marché.",
        "url": "https://www.researchaffiliates.com/home"
      }
    ]
  },
  {
    "titre": "Flux institutionnels & 13F / confluence",
    "accent": "#7aa2f7",
    "sources": [
      {
        "nom": "WhaleWisdom",
        "auteur": null,
        "desc": "Outil de référence pour tracker et analyser les filings 13F des hedge funds et investisseurs institutionnels.",
        "url": "https://whalewisdom.com/"
      },
      {
        "nom": "TIKR Blog",
        "auteur": null,
        "desc": "Guides et analyses sur l'exploitation des données institutionnelles et des filings réglementaires.",
        "url": "https://www.tikr.com/blog"
      },
      {
        "nom": "Dataroma",
        "auteur": null,
        "desc": "Suivi des portefeuilles des investisseurs « superinvestors » via les déclarations réglementaires.",
        "url": "https://www.dataroma.com/"
      },
      {
        "nom": "SEC EDGAR",
        "auteur": null,
        "desc": "Source primaire des filings réglementaires américains (13F, Form 4, 10-K, 8-K, etc.).",
        "url": "https://www.sec.gov/edgar"
      }
    ]
  },
  {
    "titre": "Géopolitique financière, commerce & sanctions",
    "accent": "var(--color-signal)",
    "sources": [
      {
        "nom": "The Wire China",
        "auteur": null,
        "desc": "Couverture haut de gamme sur la Chine, les chaînes de valeur mondiales, les sanctions et le découplage économique.",
        "url": "https://www.thewirechina.com/"
      },
      {
        "nom": "RANE Network",
        "auteur": "ex-Stratfor",
        "desc": "Analyse du risque géopolitique avec une forte orientation business et marchés.",
        "url": "https://www.ranenetwork.com/"
      },
      {
        "nom": "CSIS · Economics Program",
        "auteur": null,
        "desc": "Travaux sur la géoéconomie, les sanctions, les chaînes d'approvisionnement et la rivalité sino-américaine.",
        "url": "https://www.csis.org/programs/economics-program"
      },
      {
        "nom": "Atlantic Council · GeoEconomics Center",
        "auteur": null,
        "desc": "Analyses sur les sanctions financières, les monnaies, les flux internationaux et les infrastructures économiques.",
        "url": "https://www.atlanticcouncil.org/programs/geoeconomics-center/"
      }
    ]
  },
  {
    "titre": "Énergie, matières premières & impact marchés",
    "accent": "var(--color-amber)",
    "sources": [
      {
        "nom": "OilPrice.com",
        "auteur": null,
        "desc": "Couverture détaillée des marchés énergétiques, de la géopolitique pétrolière et des conséquences macroéconomiques.",
        "url": "https://oilprice.com/"
      },
      {
        "nom": "Energy Intelligence",
        "auteur": null,
        "desc": "Référence professionnelle sur le pétrole, le gaz, l'OPEP et les risques géopolitiques énergétiques.",
        "url": "https://www.energyintel.com/"
      },
      {
        "nom": "Kpler Insights",
        "auteur": null,
        "desc": "Analyses des flux pétroliers, du LNG, du transport maritime et des sanctions.",
        "url": "https://www.kpler.com/"
      },
      {
        "nom": "Bison Interests",
        "auteur": null,
        "desc": "Analyses très détaillées du secteur énergétique américain et du shale oil.",
        "url": "https://bisoninterests.com/"
      }
    ]
  },
  {
    "titre": "Crypto, stablecoins & infrastructure monétaire",
    "accent": "var(--color-accent)",
    "sources": [
      {
        "nom": "The Block",
        "auteur": null,
        "desc": "Référence sur la régulation crypto, les stablecoins et les infrastructures blockchain institutionnelles.",
        "url": "https://www.theblock.co/"
      },
      {
        "nom": "CoinDesk",
        "auteur": null,
        "desc": "Couverture large et de qualité sur la régulation, les marchés crypto et les stablecoins.",
        "url": "https://www.coindesk.com/"
      },
      {
        "nom": "Galaxy Research",
        "auteur": null,
        "desc": "Analyses institutionnelles sur les stablecoins, la tokenisation et les infrastructures financières numériques.",
        "url": "https://www.galaxy.com/insights/research/"
      },
      {
        "nom": "Castle Island Ventures Research",
        "auteur": null,
        "desc": "Travaux très sérieux sur les stablecoins, les paiements numériques et l'évolution monétaire.",
        "url": "https://castleisland.vc/"
      },
      {
        "nom": "Visa Crypto & Digital Currency Research",
        "auteur": null,
        "desc": "Études sur les paiements numériques, les stablecoins et l'adoption institutionnelle.",
        "url": "https://usa.visa.com/solutions/crypto.html"
      }
    ]
  },
  {
    "titre": "Données, recherche & sources primaires",
    "accent": "#7aa2f7",
    "sources": [
      {
        "nom": "FRED (Federal Reserve Economic Data)",
        "auteur": null,
        "desc": "La base de données macroéconomiques la plus utilisée au monde.",
        "url": "https://fred.stlouisfed.org/"
      },
      {
        "nom": "Federal Reserve",
        "auteur": null,
        "desc": "Communiqués, statistiques monétaires et publications officielles.",
        "url": "https://www.federalreserve.gov/"
      },
      {
        "nom": "IMF Data",
        "auteur": null,
        "desc": "Statistiques mondiales, dette souveraine, balance des paiements et risques financiers.",
        "url": "https://www.imf.org/en/Data"
      },
      {
        "nom": "World Bank Data",
        "auteur": null,
        "desc": "Indicateurs économiques mondiaux et données de développement.",
        "url": "https://data.worldbank.org/"
      },
      {
        "nom": "Treasury International Capital (TIC)",
        "auteur": null,
        "desc": "Flux internationaux de capitaux, détention de Treasuries et mouvements financiers globaux.",
        "url": "https://home.treasury.gov/data/treasury-international-capital-tic-system"
      }
    ]
  }
];

const slug = (s) => s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
const hostOf = (u) => { try { return new URL(u).hostname.replace(/^www\./, ''); } catch (e) { return u; } };
const total = categories.reduce((n, c) => n + c.sources.length, 0);
---

<BaseLayout
  title="Sites de référence"
  description="La bibliothèque de sources que l0g lit, recoupe et cite : sources primaires, institutions et analyses indépendantes, classées par domaine."
  sidebar={false}
>
  <section class="rise">
    <p class="mono-label glow" style="color: var(--color-signal)">// sites de référence</p>
    <h1 class="mt-3 font-display text-4xl leading-none tracking-wider glow sm:text-5xl">
      Sites de référence
    </h1>
    <p class="ref-lede">
      La bibliothèque de sources que l0g lit, recoupe et cite. Des sources primaires aux
      meilleures analyses indépendantes, classées par domaine. {total} références, sélection ouverte.
    </p>

    <div class="ref-tools">
      <div class="ref-search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="6"/><line x1="20" y1="20" x2="15.5" y2="15.5"/></svg>
        <input id="ref-q" type="search" placeholder="Filtrer les sources…  ( / )" autocomplete="off" spellcheck="false" aria-label="Filtrer les sources" />
        <button id="ref-clear" type="button" aria-label="Effacer le filtre">×</button>
      </div>
      <span id="ref-count" class="ref-count"></span>
    </div>

    <nav class="cat-nav" aria-label="Catégories">
      {categories.map((c) => (
        <a class="cat-chip" href={`#${slug(c.titre)}`} style={`--cat: ${c.accent}`}>{c.titre}</a>
      ))}
    </nav>
  </section>

  {categories.map((c) => (
    <section id={slug(c.titre)} class="ref-section" style={`--cat: ${c.accent}`}>
      <h2 class="cat-h mono-label">// {c.titre}</h2>
      <div class="ref-grid">
        {c.sources.map((s) => (
          <a class="ref-card" href={s.url} target="_blank" rel="noopener noreferrer" data-ref={(s.nom + ' ' + (s.auteur || '') + ' ' + s.desc + ' ' + hostOf(s.url) + ' ' + c.titre).toLowerCase()}>
            <div class="ref-head">
              <span class="ref-name">{s.nom}{s.auteur ? <span class="ref-auth"> · {s.auteur}</span> : null}</span>
              <svg class="ref-ext" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 5h5v5"/><path d="M19 5l-8 8"/><path d="M19 13.5V18a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1h4.5"/></svg>
            </div>
            <p class="ref-desc">{s.desc}</p>
            <span class="ref-host">{hostOf(s.url)}</span>
          </a>
        ))}
      </div>
    </section>
  ))}

  <hr class="hairline mt-12" />
  <a href="/" class="mono-label link-term inline-block mt-5">$ cd ..</a>

  <style>
    .ref-lede {
      margin-top: 1.5rem; max-width: 46rem;
      font-size: 1.12rem; line-height: 1.6; color: var(--color-paper);
      border-left: 2px solid color-mix(in srgb, var(--color-signal) 45%, transparent);
      padding-left: 0.9rem;
    }
    .cat-nav { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1.6rem; }
    .cat-chip {
      font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.05em;
      text-transform: uppercase; color: var(--color-muted);
      border: 1px solid var(--color-line); border-radius: 999px; padding: 0.3rem 0.75rem;
      text-decoration: none; transition: color 0.15s, border-color 0.15s, background 0.15s;
    }
    .cat-chip:hover {
      color: var(--cat);
      border-color: color-mix(in srgb, var(--cat) 50%, transparent);
      background: color-mix(in srgb, var(--cat) 8%, transparent);
    }

    .ref-section { margin-top: 3.2rem; scroll-margin-top: 1.5rem; }
    .cat-h {
      color: var(--cat);
      text-shadow: 0 0 16px color-mix(in srgb, var(--cat) 30%, transparent);
      margin-bottom: 1.1rem;
    }

    .ref-grid { display: grid; gap: 0.8rem; grid-template-columns: 1fr; }
    @media (min-width: 720px) { .ref-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    @media (min-width: 1080px) { .ref-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }

    .ref-card {
      display: flex; flex-direction: column; gap: 0.5rem;
      padding: 1rem 1.1rem; border: 1px solid var(--color-line); border-radius: 12px;
      background: var(--color-surface); text-decoration: none;
      transition: border-color 0.16s, background 0.16s, transform 0.16s;
    }
    .ref-card:hover {
      border-color: color-mix(in srgb, var(--cat) 42%, transparent);
      background: color-mix(in srgb, var(--cat) 5%, transparent);
      transform: translateY(-1px);
    }
    .ref-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.6rem; }
    .ref-name { color: var(--color-bright); font-weight: 600; font-size: 0.96rem; line-height: 1.3; }
    .ref-auth { color: var(--color-muted); font-weight: 400; font-size: 0.84rem; }
    .ref-ext { width: 15px; height: 15px; flex: none; color: var(--color-muted); margin-top: 0.15rem; transition: color 0.16s; }
    .ref-card:hover .ref-ext { color: var(--cat); }
    .ref-desc { flex: 1; color: var(--color-muted); font-size: 0.85rem; line-height: 1.55; }
    .ref-host {
      font-family: var(--font-mono); font-size: 0.69rem; letter-spacing: 0.04em;
      color: color-mix(in srgb, var(--cat) 70%, var(--color-muted));
    }
    .ref-tools {
      display: flex; flex-wrap: wrap; align-items: center; gap: 0.7rem 1.2rem;
      margin-top: 1.8rem;
    }
    .ref-search {
      display: inline-flex; align-items: center; gap: 0.5rem;
      flex: 1; min-width: 240px; max-width: 30rem;
      border: 1px solid var(--color-line); border-radius: 10px;
      background: var(--color-surface); padding: 0.55rem 0.8rem;
      transition: border-color 0.16s, box-shadow 0.16s;
    }
    .ref-search:focus-within {
      border-color: color-mix(in srgb, var(--color-signal) 55%, transparent);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-signal) 12%, transparent);
    }
    .ref-search svg { width: 15px; height: 15px; flex: none; color: var(--color-muted); }
    .ref-search input {
      flex: 1; min-width: 0; border: 0; background: transparent; outline: none;
      color: var(--color-bright); font-family: var(--font-mono); font-size: 0.85rem;
    }
    .ref-search input::placeholder { color: var(--color-muted); }
    .ref-search input::-webkit-search-cancel-button { display: none; }
    #ref-clear {
      border: 0; background: transparent; color: var(--color-muted); cursor: pointer;
      font-size: 1.15rem; line-height: 1; padding: 0 0.15rem; visibility: hidden;
    }
    #ref-clear:hover { color: var(--color-bright); }
    .ref-count {
      font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.05em;
      text-transform: uppercase; color: var(--color-muted); white-space: nowrap;
    }
  </style>
  <script>
    const q = document.getElementById('ref-q');
    if (q) {
      const cards = Array.from(document.querySelectorAll('.ref-card'));
      const sections = Array.from(document.querySelectorAll('.ref-section'));
      const chips = Array.from(document.querySelectorAll('.cat-chip'));
      const count = document.getElementById('ref-count');
      const clear = document.getElementById('ref-clear');
      const total = cards.length;
      const norm = (s) => s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');

      function apply() {
        const term = norm(q.value.trim());
        let shown = 0;
        cards.forEach((c) => {
          const hit = !term || norm(c.dataset.ref || '').includes(term);
          c.style.display = hit ? '' : 'none';
          if (hit) shown++;
        });
        sections.forEach((sec) => {
          let n = 0;
          sec.querySelectorAll('.ref-card').forEach((c) => { if (c.style.display !== 'none') n++; });
          sec.style.display = n ? '' : 'none';
        });
        chips.forEach((chip) => {
          const id = decodeURIComponent((chip.getAttribute('href') || '').slice(1));
          const sec = document.getElementById(id);
          chip.style.display = sec && sec.style.display !== 'none' ? '' : 'none';
        });
        count.textContent = term ? shown + ' / ' + total : total + ' références';
        clear.style.visibility = term ? 'visible' : 'hidden';
      }

      q.addEventListener('input', apply);
      clear.addEventListener('click', () => { q.value = ''; apply(); q.focus(); });
      document.addEventListener('keydown', (e) => {
        if (e.key === '/' && document.activeElement !== q) { e.preventDefault(); q.focus(); }
        else if (e.key === 'Escape' && document.activeElement === q) { q.value = ''; apply(); q.blur(); }
      });
      apply();
    }
  </script>
</BaseLayout>
