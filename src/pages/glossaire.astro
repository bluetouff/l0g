---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

import {
  glossaryAtlasEdgeCount,
  glossaryAtlasEntries,
  glossaryEntryBySlug,
  glossaryUpdatedIso,
  glossarySections as sections,
  totalGlossaryEntries,
} from '../config/glossary.ts';

const total = totalGlossaryEntries;
const atlasFeaturedSlugs = [
  'prime-de-terme',
  'credit-prive',
  'rwa',
  'stablecoin',
  'brent',
  'u3o8',
  'yen-carry',
  'repo',
  'bdc',
  'immobilier-tokenise',
  'chokepoint',
  'smr',
  'cot',
  'usdt',
  'spr',
];
const atlasPreview = atlasFeaturedSlugs
  .map((slug) => glossaryAtlasEntries.find((entry) => entry.slug === slug))
  .filter((entry): entry is (typeof glossaryAtlasEntries)[number] => Boolean(entry))
  .map((entry) => ({
    entry,
    related: (entry.atlas?.related ?? [])
      .map((slug) => glossaryEntryBySlug.get(slug))
      .filter(Boolean)
      .slice(0, 6),
  }));

// --- Structured data : le glossaire comme vocabulaire structure (DefinedTermSet) ---
const GSITE = (Astro.site?.toString() ?? 'https://l0g.fr/').replace(/\/$/, '');
const glossaryLd = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTermSet',
  '@id': `${GSITE}/glossaire/#glossary`,
  name: "Atlas de l'opacité financière",
  description:
    'Glossaire et graphe de connaissance l0g : sigles, concepts, sources, guides, signaux et datasets de risque financier.',
  inLanguage: 'fr',
  dateModified: glossaryUpdatedIso,
  hasDefinedTerm: glossaryAtlasEntries.map((entry) => ({
    '@id': `${GSITE}${entry.url}#term`,
  })),
};
const glossaryJsonLd = JSON.stringify(glossaryLd).replace(/</g, '\\u003c');
---

<BaseLayout
  title="Glossaire"
  description="Atlas de l'opacité financière : glossaire l0g, concepts voisins, articles, guides, sources primaires, datasets et signaux de risque reliés."
  alternateLinks={[
    { hreflang: 'fr', href: new URL('/glossaire/', Astro.site).toString() },
    { hreflang: 'en', href: new URL('/en/glossary/', Astro.site).toString() },
    { hreflang: 'x-default', href: new URL('/glossaire/', Astro.site).toString() },
  ]}
>
  <script type="application/ld+json" is:inline set:html={glossaryJsonLd} />
  <PageHero
    index="03"
    kicker="atlas du glossaire"
    title="Décoder les mots."
    highlight="Relier les mécanismes."
    description="Le glossaire devient une carte du risque : définitions courtes, concepts voisins, analyses, guides, sources primaires, datasets et signaux reliés."
    secondary="L’index reste volontairement compact. Chaque notion dispose d’une page dédiée avec ses références et son graphe documentaire."
    glyph="retrieve"
    accent="#7aa2f7"
    stats={[
      { value: total, label: 'entrées' },
      { value: glossaryAtlasEntries.length, label: 'nœuds enrichis' },
      { value: glossaryAtlasEdgeCount, label: 'relations conceptuelles' },
    ]}
  />

  {atlasPreview.length > 0 && (
    <section class="atlas-panel mt-10" aria-labelledby="atlas-title" data-pagefind-ignore>
      <div class="atlas-panel-head">
        <div>
          <p class="mono-label" style="color: var(--color-signal)">graphe navigable</p>
          <h2 id="atlas-title">Concepts reliés au risque</h2>
        </div>
        <a class="atlas-manual" href="/agents/">Surface agents</a>
      </div>
      <div class="atlas-grid">
        {atlasPreview.map(({ entry, related }) => (
          <article class="atlas-node" style={`--node:${entry.accent}`}>
            <a class="atlas-node-title" href={entry.url}>
              <span>{entry.sigle}</span>
              <small>{entry.nom}</small>
            </a>
            {entry.atlas?.whyNow && <p>{entry.atlas.whyNow}</p>}
            <div class="atlas-neighbors" aria-label={`Concepts voisins de ${entry.sigle}`}>
              {related.map((term) => (
                <a href={term!.url}>{term!.sigle}</a>
              ))}
            </div>
            <dl class="atlas-links">
              <div><dt>articles</dt><dd>{entry.atlas?.articles?.length ?? 0}</dd></div>
              <div><dt>guides</dt><dd>{entry.atlas?.guides?.length ?? 0}</dd></div>
              <div><dt>sources</dt><dd>{entry.atlas?.sources?.length ?? 0}</dd></div>
              <div><dt>données</dt><dd>{entry.atlas?.datasets?.length ?? 0}</dd></div>
            </dl>
          </article>
        ))}
      </div>
    </section>
  )}

  <div class="gloss-tools" data-pagefind-ignore>
    <div class="gloss-search">
      <span class="gloss-prompt" aria-hidden="true">/</span>
      <input
        id="gloss-filter"
        type="search"
        inputmode="search"
        autocomplete="off"
        spellcheck="false"
        placeholder="filtrer : sigle, terme, définition…"
        aria-label="Filtrer le glossaire"
      />
      <kbd class="gloss-kbd" aria-hidden="true">/</kbd>
    </div>
    <nav class="gloss-chips" aria-label="Sections du glossaire">
      {
        sections.map((s) => (
          <a class="gloss-chip" href={`#sec-${s.slug}`} data-chip={s.slug} style={`--c:${s.accent}`}>
            {s.titre}<span class="gloss-chip-n">{s.entries.length}</span>
          </a>
        ))
      }
    </nav>
  </div>

  <div id="gloss-root">
    {
      sections.map((s) => (
        <section class="gloss-sec mt-10" id={`sec-${s.slug}`} data-section={s.slug} data-pagefind-ignore>
          <h2 class="mono-label mb-4 text-lg" style={`color:${s.accent}`}>
            // {s.titre}<span class="gloss-sec-n">{s.entries.length}</span>
          </h2>
          <ul class="glossary-index">
            {s.entries.map((e) => (
              <li class="gentry" id={e.slug} data-term={(e.sigle + ' ' + e.nom + ' ' + (e.atlas?.related ?? []).join(' ')).toLowerCase()}>
                <a class="gentry-link" href={e.url}>
                  <span class="sigle" style={`color:${s.accent}`}>{e.sigle}</span>
                  <span class="nom">{e.nom}</span>
                  {e.atlas && <span class="atlas-tag">atlas</span>}
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>

  <p id="gloss-empty" class="gloss-empty" hidden>Aucune entrée pour ce filtre.</p>

  <style>
    .gloss-tools {
      position: sticky;
      top: 0;
      z-index: 20;
      padding: 0.7rem 0 0.75rem;
      margin-top: 1.75rem;
      background: color-mix(in srgb, var(--color-ink) 90%, transparent);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--color-line);
    }
    .gloss-search {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      border: 1px solid var(--color-line);
      border-radius: 10px;
      background: var(--color-surface);
      padding: 0.5rem 0.7rem;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .gloss-search:focus-within {
      border-color: color-mix(in srgb, var(--color-signal) 55%, transparent);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-signal) 12%, transparent);
    }
    .gloss-prompt { color: var(--color-signal); font-family: var(--font-mono); font-weight: 600; }
    #gloss-filter {
      flex: 1; min-width: 0;
      background: transparent; border: 0; outline: none;
      color: var(--color-paper); font-family: var(--font-mono); font-size: 0.95rem;
    }
    #gloss-filter::placeholder { color: var(--color-muted); }
    .gloss-kbd {
      font-family: var(--font-mono); font-size: 0.7rem; color: var(--color-muted);
      border: 1px solid var(--color-line); border-radius: 5px; padding: 1px 6px;
    }
    .gloss-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.65rem; }
    .gloss-chip {
      display: inline-flex; align-items: center; gap: 0.45rem;
      font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.04em; text-transform: uppercase;
      color: var(--color-muted); border: 1px solid var(--color-line); border-radius: 999px;
      padding: 0.28rem 0.7rem; transition: color 0.18s, border-color 0.18s, background 0.18s;
    }
    .gloss-chip:hover { color: var(--color-bright); border-color: color-mix(in srgb, var(--c) 55%, transparent); }
    .gloss-chip.is-active {
      color: var(--c);
      border-color: color-mix(in srgb, var(--c) 60%, transparent);
      background: color-mix(in srgb, var(--c) 10%, transparent);
    }
    .gloss-chip.is-empty { opacity: 0.3; pointer-events: none; }
    .gloss-chip-n { font-size: 0.66rem; color: color-mix(in srgb, var(--c) 75%, var(--color-muted)); }

    .gloss-sec { scroll-margin-top: 6rem; }
    .gloss-sec-n { font-size: 0.7rem; color: var(--color-muted); margin-left: 0.45rem; letter-spacing: normal; }

    .glossary-index {
      display: grid;
      gap: 0.4rem;
      grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
      list-style: none;
      margin: 0;
      padding: 0;
    }
    .gentry {
      border: 1px solid var(--color-line);
      border-radius: 8px;
      min-width: 0;
      transition: background 0.15s, border-color 0.15s;
    }
    .gentry:hover {
      background: rgba(255, 255, 255, 0.018);
      border-color: color-mix(in srgb, var(--color-signal) 35%, var(--color-line));
    }
    .gentry-link {
      align-items: baseline;
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
      min-height: 100%;
      padding: 0.6rem;
      text-decoration: none;
    }
    .gentry .sigle {
      font-family: var(--font-display); font-weight: 600; font-size: 0.92rem; letter-spacing: 0.02em;
      border: 1px solid color-mix(in srgb, currentColor 35%, transparent);
      border-radius: 6px; padding: 1px 8px;
      transition: border-color 0.18s, background 0.18s;
    }
    .gentry .sigle:hover { background: color-mix(in srgb, currentColor 10%, transparent); border-color: currentColor; }
    .gentry .nom { color: var(--color-bright); font-size: 0.9rem; transition: color 0.18s; }
    .gentry-link:hover .nom { color: var(--color-signal); }
    .gentry:target { background: color-mix(in srgb, var(--color-signal) 8%, transparent); }

    .gloss-empty { margin-top: 2rem; color: var(--color-muted); font-family: var(--font-mono); }
    .gloss-empty::before { content: "// "; color: var(--color-accent); }

    .atlas-panel {
      border-top: 1px solid var(--color-line);
      border-bottom: 1px solid var(--color-line);
      padding: 1.2rem 0;
    }
    .atlas-panel-head {
      align-items: end;
      display: flex;
      gap: 1rem;
      justify-content: space-between;
      margin-bottom: 1rem;
    }
    .atlas-panel h2 {
      color: var(--color-bright);
      font-family: var(--font-display);
      font-size: clamp(1.35rem, 2.4vw, 2rem);
      letter-spacing: 0;
      line-height: 1.15;
      margin-top: 0.35rem;
    }
    .atlas-manual {
      border: 1px solid var(--color-line);
      border-radius: 8px;
      color: var(--color-muted);
      font-family: var(--font-mono);
      font-size: 0.76rem;
      padding: 0.45rem 0.65rem;
      white-space: nowrap;
    }
    .atlas-manual:hover {
      border-color: color-mix(in srgb, var(--color-signal) 45%, transparent);
      color: var(--color-bright);
    }
    .atlas-grid {
      display: grid;
      gap: 0.85rem;
      grid-template-columns: repeat(auto-fit, minmax(245px, 1fr));
    }
    .atlas-node {
      background: color-mix(in srgb, var(--color-surface) 82%, transparent);
      border: 1px solid color-mix(in srgb, var(--node) 32%, var(--color-line));
      border-radius: 8px;
      display: grid;
      grid-template-rows: auto 1fr auto auto;
      min-height: 18rem;
      padding: 0.85rem;
    }
    .atlas-node-title {
      display: grid;
      gap: 0.2rem;
    }
    .atlas-node-title span {
      color: var(--node);
      font-family: var(--font-display);
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: 0;
    }
    .atlas-node-title small {
      color: var(--color-bright);
      font-size: 0.82rem;
      line-height: 1.35;
    }
    .atlas-node p {
      color: var(--color-muted);
      font-size: 0.86rem;
      line-height: 1.55;
      margin-top: 0.7rem;
    }
    .atlas-neighbors {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
      margin-top: 0.8rem;
    }
    .atlas-neighbors a {
      border: 1px solid var(--color-line);
      border-radius: 7px;
      color: var(--color-muted);
      font-family: var(--font-mono);
      font-size: 0.68rem;
      padding: 0.2rem 0.4rem;
    }
    .atlas-neighbors a:hover {
      border-color: color-mix(in srgb, var(--node) 55%, transparent);
      color: var(--color-bright);
    }
    .atlas-links {
      border-top: 1px solid var(--color-line);
      display: grid;
      gap: 0.35rem;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      margin-top: 0.85rem;
      padding-top: 0.65rem;
    }
    .atlas-links div {
      min-width: 0;
    }
    .atlas-links dt {
      color: var(--color-muted);
      font-family: var(--font-mono);
      font-size: 0.6rem;
      overflow-wrap: anywhere;
      text-transform: uppercase;
    }
    .atlas-links dd {
      color: var(--color-paper);
      font-family: var(--font-display);
      font-size: 1rem;
      margin: 0.1rem 0 0;
    }
    .atlas-tag {
      border: 1px solid color-mix(in srgb, var(--color-signal) 45%, transparent);
      border-radius: 7px;
      color: var(--color-signal);
      font-family: var(--font-mono);
      font-size: 0.64rem;
      letter-spacing: 0.04em;
      padding: 0.12rem 0.4rem;
      text-transform: uppercase;
    }
    .atlas-tag:hover {
      background: color-mix(in srgb, var(--color-signal) 9%, transparent);
      color: var(--color-bright);
    }

    @media (max-width: 640px) {
      .atlas-panel-head {
        align-items: start;
        display: grid;
      }
      .atlas-manual {
        width: fit-content;
      }
      .atlas-node {
        min-height: auto;
      }
    }
  </style>

  <script>
    // @ts-nocheck -- script navigateur autonome, validé sur le DOM construit.
    (() => {
      const input = document.getElementById('gloss-filter');
      const root = document.getElementById('gloss-root');
      const empty = document.getElementById('gloss-empty');
      if (!input || !root) return;
      const secs = Array.from(root.querySelectorAll('.gloss-sec'));
      const chips = Array.from(document.querySelectorAll('.gloss-chip'));
      const chipBySec = new Map(chips.map((c) => [c.dataset.chip, c]));
      const norm = (s) => s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');

      function apply() {
        const q = norm(input.value.trim());
        let total = 0;
        secs.forEach((sec) => {
          let shown = 0;
          sec.querySelectorAll('.gentry').forEach((el) => {
            const hit = !q || norm(el.dataset.term).indexOf(q) !== -1;
            el.hidden = !hit;
            if (hit) shown++;
          });
          sec.hidden = shown === 0;
          const chip = chipBySec.get(sec.dataset.section);
          if (chip) chip.classList.toggle('is-empty', shown === 0);
          total += shown;
        });
        if (empty) empty.hidden = total !== 0;
      }
      input.addEventListener('input', apply);

      document.addEventListener('keydown', (e) => {
        const tag = (document.activeElement && document.activeElement.tagName) || '';
        if (e.key === '/' && document.activeElement !== input && !/^(INPUT|TEXTAREA|SELECT)$/.test(tag)) {
          e.preventDefault(); input.focus();
        } else if (e.key === 'Escape' && document.activeElement === input) {
          input.value = ''; apply(); input.blur();
        }
      });

      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver((ents) => {
          ents.forEach((en) => {
            if (en.isIntersecting) {
              const id = en.target.dataset.section;
              chips.forEach((c) => c.classList.toggle('is-active', c.dataset.chip === id));
            }
          });
        }, { rootMargin: '-20% 0px -70% 0px' });
        secs.forEach((s) => io.observe(s));
      }
    })();
  </script>
</BaseLayout>
