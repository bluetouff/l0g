---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustBar from '../../components/TrustBar.astro';

const site = (Astro.site?.toString() ?? 'https://l0g.fr/').replace(/\/$/, '');
const agentFrUrl = new URL('/donnees/agents/', Astro.site).toString();
const agentEnUrl = new URL('/en/agent-surface/', Astro.site).toString();
const agentAlternateLinks = [
  { hreflang: 'fr', href: agentFrUrl },
  { hreflang: 'en', href: agentEnUrl },
  { hreflang: 'x-default', href: agentFrUrl },
];
const trustItems = [
  { label: 'Guide agent', href: '/agents/' },
  { label: 'JSON statique', href: '/agents.json' },
  { label: 'OpenAPI', href: '/openapi.json' },
  { label: 'SHA-256', href: '/api/v1/integrity.json' },
  { label: 'correction policy', href: '/protocole-editorial/' },
];

const endpoints = [
  {
    path: '/agents.json',
    label: 'Découverte',
    role: 'Manifeste des capacités, règles d’usage, endpoints et politique de preuve.',
  },
  {
    path: '/openapi.json',
    label: 'Contrat',
    role: 'Description OpenAPI 3.1 des endpoints consommables par agents et clients M2M.',
  },
  {
    path: '/api/v1/claims.json',
    label: 'Claims',
    role: 'Graphe affirmation-source : fait revu, estimation, inférence, scénario ou assertion non classée, avec références datées quand détectable.',
  },
  {
    path: '/api/v1/evidence-graph.json',
    label: 'Evidence graph',
    role: 'Graphe articles, claims, références, hôtes, sources primaires et datasets, exprimé en nœuds et arêtes.',
  },
  {
    path: '/api/v1/claims.ndjson',
    label: 'Claims NDJSON',
    role: 'Flux ligne à ligne des claims pour ingestion RAG, streaming ou traitement incrémental.',
  },
  {
    path: '/api/v1/catalog.ndjson',
    label: 'Catalogue NDJSON',
    role: 'Catalogue complet en lignes NDJSON : articles, guides, méthodes, glossaire et sources.',
  },
  {
    path: '/api/v1/sources.json',
    label: 'Sources',
    role: 'Registre des sources primaires et des hôtes effectivement cités dans les articles.',
  },
  {
    path: '/api/v1/freshness.json',
    label: 'Fraîcheur',
    role: 'Derniers contenus, endpoints, politique de fraîcheur et temporalité par signal de dashboard.',
  },
  {
    path: '/api/v1/integrity.json',
    label: 'Intégrité',
    role: 'Empreintes SHA-256 canoniques des surfaces M2M, pour vérifier un snapshot sans dépendre du timestamp de build.',
  },
  {
    path: '/api/v1/changes.json',
    label: 'Changefeed',
    role: 'Flux machine des publications, révisions et politiques, avec version courante, hash et statut de diff.',
  },
  {
    path: '/api/v1/risk-diff.json',
    label: 'Risk Diff',
    role: 'Diff du risque par fenêtre 1, 7 et 30 jours : signaux, sources, claims, modèles, articles et confiance.',
  },
  {
    path: '/api/v1/black-box.json',
    label: 'Black Box',
    role: 'Frames point-in-time hashées pour rejouer l’état public du risque à une date donnée, sans reconstruction rétroactive.',
  },
  {
    path: '/api/v1/signals/history.json',
    label: 'Signal history',
    role: 'Historique point-in-time des signaux : observations backtestables, alertes de seuil, couverture et politique.',
  },
  {
    path: '/api/v1/signals/history.ndjson',
    label: 'Signal NDJSON',
    role: 'Flux ligne à ligne des signaux pour agents, watchers et ingestion incrémentale.',
  },
  {
    path: '/api/v1/signals/history.csv',
    label: 'Signal CSV',
    role: 'Observations de signaux à plat pour pandas, R, DuckDB ou tableur.',
  },
  {
    path: '/api/v1/catalog.json',
    label: 'Catalogue',
    role: 'Carte bilingue du corpus avec language, canonicalId, translationOf, alternateUrl et translationStatus.',
  },
  {
    path: '/api/v1/search-index.json',
    label: 'Index partagé',
    role: 'Index de recherche bilingue canonique consommé par Agent Surface, MCP et WebMCP.',
  },
  {
    path: '/llms-full-en.txt',
    label: 'Corpus anglais',
    role: 'Texte complet des analyses et guides anglais, séparé du corpus français pour borner le contexte.',
  },
];

const flow = [
  'Découvrir la surface avec /agents.json.',
  'Lire /api/v1/freshness.json pour dater le corpus et les signaux de dashboards.',
  'Vérifier les empreintes avec /api/v1/integrity.json si la réponse dépend d’un corpus figé.',
  'Surveiller /api/v1/changes.json pour suivre les nouveaux contenus et révisions.',
  'Lire /api/v1/risk-diff.json pour analyser les changements de risque sur 1, 7 ou 30 jours.',
  'Lire /api/v1/black-box.json pour rejouer une date sans remplir les trous historiques.',
  'Lire /api/v1/signals/history.csv ou .ndjson pour rejouer les signaux point-in-time sans look-ahead bias.',
  'Utiliser /api/v1/evidence-graph.json quand il faut parcourir la relation article → claim → source.',
  'Basculer sur les variantes .ndjson pour une ingestion ligne à ligne.',
  'Chercher le contenu dans /api/v1/search-index.json, partagé avec MCP et WebMCP.',
  'Utiliser /llms-full.txt pour le français ou /llms-full-en.txt pour l’anglais sans charger les deux corpus.',
  'Citer une affirmation via /api/v1/claims.json quand la réponse dépend d’un fait précis.',
  'Pour une traduction anglaise, suivre evidenceRef vers les claims et preuves françaises canoniques.',
  'Conserver l’URL canonique, la date et le type de claim dans la réponse générée.',
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  '@id': `${site}/donnees/agents/#agent-surface`,
  headline: 'Agent Surface v1.13.0',
  description:
    'Documentation de la surface M2M de l0g.fr : agents.json, OpenAPI, Risk Diff, Black Box, claims, sources, fraîcheur et règles de citation.',
  inLanguage: 'fr',
  isAccessibleForFree: true,
  license: 'https://creativecommons.org/licenses/by/4.0/',
  publisher: { '@id': `${site}/#org` },
};
const safeJsonLd = JSON.stringify(jsonLd).replace(/</g, '\\u003c');
---

<BaseLayout
  title="Agent Surface v1.13.0"
  description="Documentation de la surface M2M de l0g.fr : manifeste agents.json, OpenAPI, Risk Diff, Black Box, evidence graph, NDJSON, claims sourcées, sources, fraîcheur, intégrité, changefeed et règles de citation."
  ogImage="/og-donnees.png"
  ogImageAlt="Agent Surface v1.13.0 l0g.fr : API bilingue, Agent Bench, evidence graph, claims et sources"
  sidebar={false}
  alternateLinks={agentAlternateLinks}
>
  <script type="application/ld+json" is:inline set:html={safeJsonLd} />

  <article class="agent-page rise" data-pagefind-body>
    <section class="agent-hero">
      <p class="mono-label glow">// agent surface v1.13.0</p>
      <h1 class="agent-title font-display glow">Une surface M2M pour lire l0g sans scraper.</h1>
      <p class="agent-lede">
        Agent Surface v1.13.0 expose le corpus français et anglais sous forme de JSON statique et NDJSON : catalogue,
        evidence graph, claims sourcées, sources primaires, fraîcheur, Risk Diff,
        Black Box Recorder, index de recherche partagé, historique des signaux, empreintes et contrat OpenAPI. Les traductions
        portent leur identifiant canonique, leur alternative et leur statut de fraîcheur. Les claims restent françaises et
        canoniques : une analyse anglaise pointe vers ses preuves via <code>evidenceRef</code>. La promesse est
        simple : un agent doit pouvoir citer une affirmation sans perdre la source, claimDate,
        observationDate, sourcePublicationDate, retrievedAt, indexedAt et le niveau de lecture.
        Pour les signaux de risque, le contrat conserve aussi les limites de modèle : Dette US publie
        un stress courant hors CBO et une couverture de buckets lorsque le snapshot amont la fournit.
      </p>
      <TrustBar items={trustItems} />
      <p class="mono-label mt-4" data-pagefind-ignore><a class="link-term" href="/en/agent-surface/">English Agent Surface documentation →</a></p>
      <p class="mono-label mt-2" data-pagefind-ignore><a class="link-term" href="/agent-bench/">l0g Agent Bench : résultats déterministes FR/EN →</a></p>
    </section>

    <section class="agent-section">
      <p class="mono-label glow">// endpoints</p>
      <div class="endpoint-grid">
        {endpoints.map((endpoint) => (
          <a class="endpoint-card" href={endpoint.path}>
            <span>{endpoint.label}</span>
            <code>{endpoint.path}</code>
            <p>{endpoint.role}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="agent-section split">
      <div class="note-block">
        <p class="mono-label glow">// flux conseillé</p>
        <ol class="flow-list">
          {flow.map((item) => <li>{item}</li>)}
        </ol>
      </div>
      <div class="note-block">
        <p class="mono-label glow">// garde-fous</p>
        <p>
          Les champs <code>kind</code>, <code>dateLabel</code>, <code>references</code> et
          <code>confidence</code> ne sont pas décoratifs. Ils évitent de transformer une
          estimation ou un scénario en fait observé, et rappellent qu’une relation extraite
          automatiquement reste vérifiable dans la page canonique.
        </p>
      </div>
    </section>

    <section class="agent-section">
      <p class="mono-label glow">// contrat minimal</p>
      <div class="contract-grid">
        <div><span>Attribution</span><strong>l0g.fr</strong></div>
        <div><span>Licence</span><strong>CC BY 4.0</strong></div>
        <div><span>Version</span><strong>v1.13.0</strong></div>
        <div><span>Format</span><strong>JSON + NDJSON</strong></div>
        <div><span>Preuve</span><strong>claim-source</strong></div>
        <div><span>Intégrité</span><strong>SHA-256</strong></div>
      </div>
    </section>

    <section class="agent-section split">
      <div class="note-block">
        <p class="mono-label glow">// exemple</p>
        <pre><code>curl -s https://l0g.fr/api/v1/claims.json</code></pre>
      </div>
      <div class="note-block">
        <p class="mono-label glow">// intégration</p>
        <p>
          Pour un agent RAG, utiliser <code>/api/v1/search-index.json</code> pour rechercher
          les documents français et anglais, puis <code>/api/v1/evidence-graph.json</code> ou
          <code>/api/v1/claims.ndjson</code> pour les assertions sensibles.
          <code>/api/v1/changes.ndjson</code> évite de rescanner tout le corpus.
          <code>/api/v1/risk-diff.json</code> résume les mouvements de risque,
          <code>/api/v1/black-box.json</code> rejoue les frames publiques disponibles,
          et <code>/api/v1/integrity.json</code> permet de vérifier les empreintes du snapshot.
          Pour une intégration typée, partir de <code>/openapi.json</code>.
        </p>
      </div>
    </section>
  </article>

  <style>
    .agent-page { max-width: 64rem; }
    .agent-hero {
      padding-bottom: 2.2rem;
      border-bottom: 1px solid var(--color-line);
    }
    .agent-title {
      margin-top: 1rem;
      max-width: 50rem;
      color: var(--color-bright);
      font-size: clamp(2rem, 4.5vw, 3rem);
      line-height: 1.14;
      letter-spacing: 0.02em;
    }
    .agent-lede {
      margin-top: 1.15rem;
      max-width: 48rem;
      border-left: 2px solid var(--color-signal);
      padding-left: 1rem;
      color: var(--color-paper);
      font-family: var(--font-read);
      font-size: clamp(1.05rem, 2vw, 1.2rem);
      line-height: 1.66;
    }
    .agent-section { margin-top: 3rem; }
    .endpoint-grid,
    .contract-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.75rem;
      margin-top: 1rem;
    }
    @media (min-width: 760px) {
      .endpoint-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .contract-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    }
    .endpoint-card,
    .contract-grid div,
    .note-block {
      border: 1px solid var(--color-line);
      border-radius: 8px;
      background: color-mix(in srgb, var(--color-surface) 54%, transparent);
      padding: 0.95rem;
    }
    .endpoint-card {
      display: grid;
      gap: 0.45rem;
      text-decoration: none;
      transition: border-color 0.16s, background 0.16s;
    }
    .endpoint-card:hover {
      border-color: color-mix(in srgb, var(--color-signal) 48%, transparent);
      background: color-mix(in srgb, var(--color-signal) 6%, transparent);
    }
    .endpoint-card span,
    .contract-grid span {
      color: var(--color-signal);
      font-family: var(--font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .endpoint-card code,
    .note-block code,
    .note-block pre {
      color: var(--color-paper);
      font-family: var(--font-mono);
      overflow-wrap: anywhere;
    }
    .endpoint-card p,
    .note-block p,
    .flow-list {
      color: var(--color-muted);
      font-size: 0.92rem;
      line-height: 1.6;
    }
    .flow-list {
      display: grid;
      gap: 0.55rem;
      margin-top: 0.8rem;
      padding-left: 1.25rem;
    }
    .contract-grid div {
      display: grid;
      gap: 0.3rem;
    }
    .contract-grid strong {
      color: var(--color-bright);
      font-family: var(--font-display);
      font-size: 1.15rem;
    }
    .split {
      display: grid;
      gap: 1rem;
    }
    @media (min-width: 760px) {
      .split { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    .note-block pre {
      margin-top: 0.8rem;
      border: 1px solid var(--color-line);
      border-radius: 8px;
      background: var(--color-bg);
      padding: 0.75rem;
      font-size: 0.82rem;
    }
  </style>
</BaseLayout>
