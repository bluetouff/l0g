---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustBar from '../components/TrustBar.astro';
import { editorialChangelog, editorialProtocol, editorialProtocolRelease } from '../config/editorial.ts';

const site = (Astro.site?.toString() ?? 'https://l0g.fr/').replace(/\/$/, '');
const latestChanges = editorialChangelog.slice(0, 4);
const releaseArtifacts = [
  { label: 'spécification normative', detail: 'EP-001 à EP-009', href: editorialProtocolRelease.specificationUrl },
  { label: 'schémas JSON', detail: 'article et paquet de preuves', href: editorialProtocolRelease.schemasUrl },
  { label: 'exemple complet', detail: 'article, claims et preuves', href: editorialProtocolRelease.exampleUrl },
  { label: 'tests de conformité', detail: 'validation déterministe', href: editorialProtocolRelease.testsUrl },
  { label: 'licences', detail: 'MIT et CC BY 4.0', href: editorialProtocolRelease.licenseUrl },
  { label: 'citation', detail: 'CITATION.cff', href: editorialProtocolRelease.citationUrl },
];

const trustItems = [
  { label: 'sources primaires', href: '/sources/' },
  { label: 'preuves', href: '/preuves/' },
  { label: 'données', href: '/donnees/' },
  { label: 'changelog éditorial', href: '/changelog-editorial/' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  '@id': `${site}/protocole-editorial/#protocol`,
  name: 'Protocole éditorial l0g',
  description:
    'Protocole éditorial de l0g.fr : sources, vérification, rédaction, niveaux de preuve, corrections et limites de lecture.',
  inLanguage: 'fr',
  isAccessibleForFree: true,
  version: editorialProtocolRelease.version,
  datePublished: editorialProtocolRelease.released,
  dateModified: editorialProtocol.updated,
  license: 'https://creativecommons.org/licenses/by/4.0/',
  creator: {
    '@type': 'Person',
    name: 'Olivier Laurelli',
    alternateName: 'bluetouff',
  },
  codeRepository: editorialProtocolRelease.repositoryUrl,
  sameAs: editorialProtocolRelease.releaseUrl,
  publisher: { '@id': `${site}/#org` },
  url: `${site}/protocole-editorial/`,
};
const safeJsonLd = JSON.stringify(jsonLd).replace(/</g, '\\u003c');
---

<BaseLayout
  title="Protocole éditorial"
  description="Protocole éditorial l0g : sources, vérification, rédaction, niveaux de preuve, corrections et limites de lecture."
  ogImage="/og-protocole-editorial.png"
  ogImageAlt="Protocole éditorial l0g : sources, vérification, preuve et correction"
  sidebar={false}

  alternateLinks={[{ hreflang: 'fr', href: new URL('/protocole-editorial/', Astro.site).toString() }, { hreflang: 'en', href: new URL('/en/editorial-protocol/', Astro.site).toString() }, { hreflang: 'x-default', href: new URL('/protocole-editorial/', Astro.site).toString() }]}>
  <p class="mono-label mt-2" data-pagefind-ignore style="color: var(--color-signal)">
    <a href="/en/editorial-protocol/" class="link-term">English version available →</a>
  </p>

  <script type="application/ld+json" is:inline set:html={safeJsonLd} />

  <article class="protocol-page rise" data-pagefind-body>
    <section class="protocol-hero">
      <p class="mono-label glow">// protocole éditorial</p>
      <h1 class="protocol-title font-display glow">Comment l0g transforme une source en analyse lisible.</h1>
      <p class="protocol-lede">
        Le protocole éditorial décrit la chaîne de travail attendue pour publier une analyse :
        repérer la source, vérifier les données, séparer les faits des hypothèses, exposer les
        limites et corriger publiquement ce qui doit l’être.
      </p>
      <TrustBar items={trustItems} />
      <p class="protocol-updated mono-label">
        version normative {editorialProtocolRelease.version} · {editorialProtocolRelease.status} ·
        <time datetime={editorialProtocol.updated}>{editorialProtocol.updated}</time>
      </p>
    </section>

    <section class="protocol-section">
      <p class="mono-label glow">// promesse</p>
      <div class="promise-box">
        <p>{editorialProtocol.promise}</p>
      </div>
    </section>

    <section class="protocol-section" id="release-stable">
      <p class="mono-label glow">// release normative stable</p>
      <div class="release-box">
        <div>
          <h2>{editorialProtocolRelease.title}</h2>
          <p>
            Cette page explique le protocole. La release versionnée dans le dépôt constitue la
            référence normative : elle fixe les obligations, les schémas, l'exemple conforme,
            les tests, les empreintes et les licences. La conformité structurelle ne remplace
            jamais la vérification factuelle des sources.
          </p>
          <a class="release-main" href={editorialProtocolRelease.releaseUrl} target="_blank" rel="noopener">
            ouvrir la release {editorialProtocolRelease.version}
          </a>
        </div>
        <div class="release-grid">
          {releaseArtifacts.map((artifact) => (
            <a href={artifact.href} target="_blank" rel="noopener">
              <strong>{artifact.label}</strong>
              <span>{artifact.detail}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="protocol-section">
      <p class="mono-label glow">// principes</p>
      <div class="principle-grid">
        {editorialProtocol.principles.map((principle, index) => (
          <article class="principle-card">
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h2>{principle.title}</h2>
            <p>{principle.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="protocol-section">
      <p class="mono-label glow">// chaîne de publication</p>
      <div class="step-list">
        {editorialProtocol.steps.map((step, index) => (
          <article class="step-row">
            <div class="step-index">{String(index + 1).padStart(2, '0')}</div>
            <div>
              <h2>{step.title}</h2>
              <ul>
                {step.checks.map((check) => <li>{check}</li>)}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="protocol-section">
      <p class="mono-label glow">// niveaux de preuve</p>
      <div class="depth-table" aria-label="Échelle de profondeur de preuve">
        <div class="depth-row depth-head">
          <span>Niveau</span>
          <span>Signification</span>
          <span>Statut</span>
        </div>
        {editorialProtocol.proofDepthLevels.map((level) => (
          <div class="depth-row">
            <strong>{level.label}</strong>
            <span class="depth-meaning">{level.meaning}</span>
            <em>{level.status}</em>
          </div>
        ))}
      </div>
    </section>

    <section class="protocol-section">
      <p class="mono-label glow">// illusion de précision</p>
      <div class="precision-box">
        <div>
          <h2>{editorialProtocol.precisionGuard.title}</h2>
          <p>{editorialProtocol.precisionGuard.summary}</p>
        </div>
        <ul>
          {editorialProtocol.precisionGuard.requirements.map((item) => <li>{item}</li>)}
        </ul>
        <p class="precision-warning">{editorialProtocol.precisionGuard.warning}</p>
      </div>
    </section>

    <section class="protocol-section">
      <p class="mono-label glow">// types de preuve</p>
      <div class="evidence-grid">
        {editorialProtocol.evidenceLevels.map((level) => (
          <article class="evidence-card">
            <span>{level.rank}</span>
            <h2>{level.label}</h2>
            <p>{level.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="protocol-section split">
      <div class="note-block">
        <p class="mono-label glow">// corrections</p>
        <h2>{editorialProtocol.correctionPolicy.title}</h2>
        <p>{editorialProtocol.correctionPolicy.summary}</p>
        <ul class="correction-list">
          {editorialProtocol.correctionPolicy.correctionTypes.map((item) => (
            <li>
              <strong>{item.label}</strong>
              <span>{item.description}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="note-block">
        <p class="mono-label glow">// historique des révisions</p>
        <ul class="revision-rules">
          {editorialProtocol.correctionPolicy.revisionRules.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>

    <section class="protocol-section">
      <div class="note-block">
        <p class="mono-label glow">// limites</p>
        <p>
          l0g ne publie pas de conseil en investissement. Les analyses documentent un état
          de lecture à une date donnée ; les sources publiques peuvent être révisées, retardées
          ou incomplètes.
        </p>
      </div>
    </section>

    <section class="protocol-section">
      <p class="mono-label glow">// derniers changements éditoriaux</p>
      <div class="change-list">
        {latestChanges.map((entry) => (
          <a class="change-row" href="/changelog-editorial/">
            <span>{entry.date}</span>
            <strong>{entry.title}</strong>
            <em>{entry.kind}</em>
          </a>
        ))}
      </div>
    </section>
  </article>

  <style>
    .protocol-page { max-width: 64rem; }
    .protocol-hero {
      padding-bottom: 2.2rem;
      border-bottom: 1px solid var(--color-line);
    }
    .protocol-title {
      margin-top: 1rem;
      max-width: 48rem;
      font-size: clamp(2rem, 4.5vw, 3rem);
      line-height: 1.14;
      letter-spacing: 0.02em;
      color: var(--color-bright);
    }
    .protocol-lede {
      margin-top: 1.15rem;
      max-width: 48rem;
      border-left: 2px solid var(--color-signal);
      padding-left: 1rem;
      font-family: var(--font-read);
      font-size: clamp(1.05rem, 2vw, 1.2rem);
      line-height: 1.66;
      color: var(--color-paper);
    }
    .protocol-updated {
      margin-top: 1rem;
      color: var(--color-muted);
    }
    .protocol-section { margin-top: 3rem; }
    .promise-box,
    .release-box,
    .principle-card,
    .step-row,
    .depth-table,
    .precision-box,
    .evidence-card,
    .note-block,
    .change-list {
      border: 1px solid var(--color-line);
      border-radius: 8px;
      background: color-mix(in srgb, var(--color-surface) 42%, transparent);
    }
    .promise-box {
      margin-top: 1rem;
      padding: 1.1rem;
      border-left: 2px solid var(--color-signal);
    }
    .release-box {
      display: grid;
      gap: 1rem;
      margin-top: 1rem;
      padding: 1rem;
      border-left: 2px solid var(--color-signal);
    }
    .release-box h2 {
      color: var(--color-bright);
      font-family: var(--font-display);
      font-size: 1.2rem;
    }
    .release-box p {
      margin-top: 0.6rem;
      color: var(--color-paper);
      line-height: 1.65;
    }
    .release-main {
      display: inline-flex;
      margin-top: 0.8rem;
      color: var(--color-signal);
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .release-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.6rem;
    }
    @media (min-width: 700px) {
      .release-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    .release-grid a {
      border: 1px solid var(--color-line);
      border-radius: 7px;
      padding: 0.7rem;
      background: color-mix(in srgb, var(--color-surface) 54%, transparent);
    }
    .release-grid strong,
    .release-grid span {
      display: block;
    }
    .release-grid strong {
      color: var(--color-signal);
      font-family: var(--font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .release-grid span {
      margin-top: 0.25rem;
      color: var(--color-muted);
      font-size: 0.84rem;
    }
    .promise-box p,
    .note-block p:not(.mono-label) {
      margin: 0;
      color: var(--color-paper);
      font-family: var(--font-read);
      line-height: 1.68;
    }
    .note-block h2 {
      margin-top: 0.45rem;
      color: var(--color-bright);
      font-family: var(--font-display);
      font-size: 1.05rem;
    }
    .principle-grid,
    .evidence-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.8rem;
      margin-top: 1rem;
    }
    @media (min-width: 760px) {
      .principle-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .evidence-grid { grid-template-columns: repeat(5, minmax(0, 1fr)); }
    }
    .principle-card,
    .evidence-card,
    .note-block {
      padding: 1rem;
    }
    .principle-card span,
    .evidence-card span,
    .change-row span,
    .change-row em {
      color: var(--color-signal);
      font-family: var(--font-mono);
      font-size: 0.68rem;
      font-style: normal;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .principle-card h2,
    .evidence-card h2,
    .step-row h2 {
      margin-top: 0.45rem;
      color: var(--color-bright);
      font-family: var(--font-display);
      font-size: 1rem;
    }
    .principle-card p,
    .evidence-card p {
      margin-top: 0.55rem;
      color: var(--color-muted);
      font-size: 0.92rem;
      line-height: 1.58;
    }
    .step-list {
      display: grid;
      gap: 0.75rem;
      margin-top: 1rem;
    }
    .step-row {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 0.9rem;
      padding: 1rem;
    }
    .step-index {
      width: 2.1rem;
      height: 2.1rem;
      display: grid;
      place-items: center;
      border: 1px solid color-mix(in srgb, var(--color-signal) 42%, transparent);
      border-radius: 999px;
      color: var(--color-signal);
      font-family: var(--font-mono);
      font-size: 0.72rem;
    }
    .step-row ul {
      margin: 0.65rem 0 0;
      padding-left: 1.1rem;
      color: var(--color-muted);
      line-height: 1.58;
    }
    .depth-table {
      display: grid;
      margin-top: 1rem;
      overflow: hidden;
    }
    .depth-row {
      display: grid;
      grid-template-columns: minmax(7rem, 0.75fr) minmax(0, 1.65fr) minmax(7rem, 0.6fr);
      gap: 0.8rem;
      align-items: start;
      border-bottom: 1px solid var(--color-line);
      padding: 0.82rem 0.95rem;
    }
    .depth-row:last-child { border-bottom: 0; }
    .depth-head span,
    .depth-row strong,
    .depth-row em {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      font-style: normal;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .depth-head span {
      color: var(--color-bright);
    }
    .depth-row strong {
      color: var(--color-signal);
    }
    .depth-meaning {
      color: var(--color-paper);
      font-size: 0.92rem;
      line-height: 1.5;
    }
    .depth-row em {
      color: var(--color-muted);
    }
    .precision-box {
      display: grid;
      gap: 1rem;
      margin-top: 1rem;
      border-left: 2px solid color-mix(in srgb, var(--color-amber) 65%, transparent);
      padding: 1rem;
      background: color-mix(in srgb, var(--color-amber) 5%, transparent);
    }
    .precision-box h2 {
      color: var(--color-bright);
      font-family: var(--font-display);
      font-size: 1.05rem;
    }
    .precision-box p {
      margin-top: 0.45rem;
      color: var(--color-paper);
      line-height: 1.62;
    }
    .precision-box ul {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.45rem;
      margin: 0;
      padding: 0;
      list-style: none;
    }
    @media (min-width: 680px) {
      .precision-box ul { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    }
    .precision-box li {
      border: 1px solid var(--color-line);
      border-radius: 8px;
      background: color-mix(in srgb, var(--color-surface) 42%, transparent);
      padding: 0.55rem 0.7rem;
      color: var(--color-muted);
      font-family: var(--font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .precision-box .precision-warning {
      margin: 0;
      color: var(--color-amber);
      font-family: var(--font-read);
    }
    .correction-list,
    .revision-rules {
      display: grid;
      gap: 0.6rem;
      margin-top: 0.8rem;
      padding: 0;
      list-style: none;
    }
    .correction-list li,
    .revision-rules li {
      border-top: 1px solid var(--color-line);
      padding-top: 0.6rem;
      color: var(--color-muted);
      line-height: 1.55;
    }
    .correction-list strong {
      display: block;
      color: var(--color-signal);
      font-family: var(--font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .correction-list span {
      display: block;
      margin-top: 0.25rem;
    }
    .split {
      display: grid;
      gap: 1rem;
    }
    @media (min-width: 760px) {
      .split { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    .change-list {
      margin-top: 1rem;
      overflow: hidden;
    }
    .change-row {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 0.75rem;
      align-items: center;
      border-bottom: 1px solid var(--color-line);
      padding: 0.75rem 0.85rem;
      text-decoration: none;
      transition: background 0.15s;
    }
    .change-row:last-child { border-bottom: 0; }
    .change-row:hover { background: color-mix(in srgb, var(--color-signal) 6%, transparent); }
    .change-row strong {
      color: var(--color-paper);
      font-size: 0.9rem;
      line-height: 1.4;
    }
    .change-row em { color: var(--color-muted); }
    @media (max-width: 640px) {
      .change-row { grid-template-columns: minmax(0, 1fr); gap: 0.35rem; }
      .evidence-grid { grid-template-columns: 1fr; }
      .depth-row { grid-template-columns: 1fr; gap: 0.35rem; }
    }
  </style>
</BaseLayout>
