---
import EnglishLayout from '../../../layouts/EnglishGuidesLayout.astro';
import CitationBox from '../../../components/CitationBox.astro';
import FreshnessBadge from '../../../components/FreshnessBadge.astro';
import { glossaryAtlasEn, glossaryAtlasEnBySlug } from '../../../config/glossary-atlas-en.ts';
import { glossaryUpdatedIso } from '../../../config/glossary.ts';

export function getStaticPaths() {
  return glossaryAtlasEn.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const atlas = entry.atlas;
const related = (atlas.related ?? [])
  .map((slug) => glossaryAtlasEnBySlug.get(slug))
  .filter(Boolean)
  .slice(0, 10);
const atlasLinkGroups = [
  { title: 'Related analyses', items: atlas.articles ?? [] },
  { title: 'Related guides', items: atlas.guides ?? [] },
  { title: 'Related datasets', items: atlas.datasets ?? [] },
  { title: 'Signals using it', items: atlas.signals ?? [] },
  { title: 'Primary sources', items: atlas.sources ?? [] },
].filter((group) => group.items.length > 0);
const atlasJsonLinks = [
  ...(atlas.articles ?? []),
  ...(atlas.guides ?? []),
  ...(atlas.datasets ?? []),
  ...(atlas.signals ?? []),
  ...(atlas.sources ?? []),
];

const SITE = (Astro.site?.toString() ?? 'https://l0g.fr/').replace(/\/$/, '');
const url = `/en/glossary/${entry.slug}/`;
const canonical = `${SITE}${url}`;
const frUrl = `${SITE}/glossaire/${entry.slug}/`;
const title = `${entry.sigle}: ${entry.nom}`;
const description = `${entry.sigle} (${entry.nom}): ${entry.def}`;
const alternateLinks = [
  { hreflang: 'en', href: canonical },
  { hreflang: 'fr', href: frUrl },
  { hreflang: 'x-default', href: frUrl },
];
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'DefinedTerm',
      '@id': `${canonical}#term`,
      name: entry.nom,
      termCode: entry.sigle,
      description: entry.def,
      url: canonical,
      inLanguage: 'en',
      dateModified: glossaryUpdatedIso,
      ...(atlas.formula ? { mathExpression: atlas.formula } : {}),
      ...(atlas.whyNow ? { disambiguatingDescription: atlas.whyNow } : {}),
      ...(atlasJsonLinks.length > 0
        ? {
            subjectOf: atlasJsonLinks.map((link) => ({
              '@type': 'CreativeWork',
              name: link.label,
              url: link.href.startsWith('/') ? `${SITE}${link.href}` : link.href,
              description: link.detail,
            })),
          }
        : {}),
      inDefinedTermSet: {
        '@type': 'DefinedTermSet',
        '@id': `${SITE}/en/glossary/#glossary`,
        name: 'Atlas of financial opacity (English fiches)',
        url: `${SITE}/en/glossary/`,
      },
    },
    {
      '@type': 'WebPage',
      '@id': `${canonical}#webpage`,
      url: canonical,
      name: title,
      description,
      inLanguage: 'en',
      mainEntity: { '@id': `${canonical}#term` },
      isPartOf: { '@id': `${SITE}/en/glossary/#glossary` },
      ...(related.length
        ? {
            mentions: related.map((term) => ({
              '@type': 'DefinedTerm',
              name: term!.nom,
              termCode: term!.sigle,
              url: `${SITE}/en/glossary/${term!.slug}/`,
            })),
          }
        : {}),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonical}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'l0g in English', item: `${SITE}/en/` },
        { '@type': 'ListItem', position: 2, name: 'Glossary', item: `${SITE}/en/glossary/` },
        { '@type': 'ListItem', position: 3, name: entry.sigle, item: canonical },
      ],
    },
  ],
};
const safeJsonLd = JSON.stringify(jsonLd).replace(/</g, '\\u003c');
---

<EnglishLayout
  title={title}
  description={description}
  ogType="article"
  canonical={canonical}
  alternateLinks={alternateLinks}
  ogImageAlt={`Definition of ${entry.sigle} on the l0g.fr glossary`}
>
  <script type="application/ld+json" is:inline set:html={safeJsonLd} />

  <nav class="term-breadcrumb mono-label" aria-label="Breadcrumb" data-pagefind-ignore>
    <a href="/en/">l0g</a>
    <span>/</span>
    <a href="/en/glossary/">glossary</a>
    <span>/</span>
    <span aria-current="page">{entry.slug}</span>
  </nav>

  <article class="term-page rise" data-pagefind-body>
    <p class="mono-label glow" style={`color:${entry.accent}`}>// definition</p>
    <header class="term-head">
      <div>
        <h1 id="term" class="font-display text-3xl leading-tight tracking-wider glow sm:text-4xl">
          {entry.sigle}
        </h1>
        <p class="term-name">{entry.nom}</p>
        <div class="term-freshness" data-pagefind-ignore>
          <FreshnessBadge date={glossaryUpdatedIso} />
        </div>
      </div>
      <span class="term-family" style={`--term-accent:${entry.accent}`}>
        {entry.sectionTitle}
      </span>
    </header>

    <section class="term-definition" aria-labelledby="definition-title">
      <h2 id="definition-title" class="mono-label">Short definition</h2>
      <p>{entry.def}</p>
    </section>

    <section class="term-atlas" aria-labelledby="atlas-title">
      <p class="mono-label" style={`color:${entry.accent}`}>risk atlas</p>
      <h2 id="atlas-title">Knowledge map</h2>
      <div class="atlas-brief">
        {atlas.intuition && (
          <section>
            <h3>Intuition</h3>
            <p>{atlas.intuition}</p>
          </section>
        )}
        {atlas.formula && (
          <section>
            <h3>Formula</h3>
            <code>{atlas.formula}</code>
          </section>
        )}
        {atlas.whyNow && (
          <section>
            <h3>Why it matters now</h3>
            <p>{atlas.whyNow}</p>
          </section>
        )}
      </div>

      {related.length > 0 && (
        <nav class="atlas-relations" aria-label={`Concepts related to ${entry.sigle}`}>
          {related.map((term) => (
            <a href={`/en/glossary/${term!.slug}/`} style={`--rel:${term!.accent}`}>
              <span>{term!.sigle}</span>
              <small>{term!.nom}</small>
            </a>
          ))}
        </nav>
      )}

      {atlasLinkGroups.length > 0 && (
        <div class="atlas-evidence">
          {atlasLinkGroups.map((group) => (
            <section>
              <h3>{group.title}</h3>
              <ul>
                {group.items.map((item) => (
                  <li>
                    <a href={item.href}>{item.label}</a>
                    {item.detail && <span>{item.detail}</span>}
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      )}
    </section>

    <div class="term-actions" data-pagefind-ignore>
      {entry.guide && <a class="term-action" href={entry.guide}>Read the full guide</a>}
      <a class="term-action ghost" href="/en/glossary/">Back to the glossary</a>
      <a class="term-action ghost" href={`/glossaire/${entry.slug}/`} hreflang="fr">Lire cette fiche en français</a>
    </div>

    <CitationBox title={title} url={canonical} kind="definition" updated={glossaryUpdatedIso} />
  </article>

  {related.length > 0 && (
    <section class="term-related mt-12" aria-labelledby="related-title" data-pagefind-ignore>
      <h2 id="related-title" class="mono-label mb-4" style={`color:${entry.accent}`}>
        // related terms
      </h2>
      <div class="related-grid">
        {related.map((item) => (
          <a class="related-term" href={`/en/glossary/${item!.slug}/`}>
            <span class="related-sigle" style={`color:${item!.accent}`}>{item!.sigle}</span>
            <span class="related-name">{item!.nom}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <style>
    .term-breadcrumb {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.45rem;
      color: var(--color-muted);
      margin-bottom: 2.5rem;
    }
    .term-breadcrumb a {
      color: var(--color-signal);
      transition: color 0.18s;
    }
    .term-breadcrumb a:hover { color: var(--color-bright); }

    .term-page {
      max-width: 780px;
    }
    .term-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1.25rem;
      margin-top: 0.8rem;
      padding-bottom: 1.25rem;
      border-bottom: 1px solid var(--color-line);
    }
    .term-name {
      margin-top: 0.45rem;
      color: var(--color-bright);
      font-size: 1.05rem;
      line-height: 1.5;
    }
    .term-freshness {
      display: flex;
      margin-top: 0.75rem;
    }
    .term-family {
      flex: 0 0 auto;
      margin-top: 0.25rem;
      border: 1px solid color-mix(in srgb, var(--term-accent) 45%, transparent);
      border-radius: 999px;
      color: var(--term-accent);
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.05em;
      line-height: 1.2;
      max-width: 18rem;
      padding: 0.35rem 0.7rem;
      text-transform: uppercase;
    }
    .term-definition {
      margin-top: 2rem;
    }
    .term-definition p {
      margin-top: 0.8rem;
      color: var(--color-paper);
      font-size: 1.08rem;
      line-height: 1.75;
      max-width: 66ch;
    }
    .term-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.7rem;
      margin-top: 2rem;
    }
    .term-action {
      border: 1px solid color-mix(in srgb, var(--color-signal) 50%, transparent);
      border-radius: 8px;
      color: var(--color-signal);
      font-family: var(--font-mono);
      font-size: 0.82rem;
      padding: 0.55rem 0.85rem;
      transition: background 0.18s, border-color 0.18s, color 0.18s;
    }
    .term-action:hover {
      background: color-mix(in srgb, var(--color-signal) 10%, transparent);
      border-color: var(--color-signal);
      color: var(--color-bright);
    }
    .term-action.ghost {
      border-color: var(--color-line);
      color: var(--color-muted);
    }
    .term-action.ghost:hover {
      border-color: color-mix(in srgb, var(--color-signal) 45%, transparent);
      color: var(--color-bright);
    }
    .related-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
      gap: 0;
      border-top: 1px solid var(--color-line);
    }
    .related-term {
      display: grid;
      gap: 0.25rem;
      padding: 0.85rem 0.65rem;
      border-bottom: 1px solid var(--color-line);
      border-radius: 8px;
      transition: background 0.18s;
    }
    .related-term:hover { background: rgba(255, 255, 255, 0.018); }
    .related-sigle {
      font-family: var(--font-display);
      font-size: 0.88rem;
      font-weight: 600;
      letter-spacing: 0.02em;
    }
    .related-name {
      color: var(--color-muted);
      font-size: 0.88rem;
      line-height: 1.45;
    }
    .term-atlas {
      border-top: 1px solid var(--color-line);
      margin-top: 2rem;
      padding-top: 1.4rem;
    }
    .term-atlas h2 {
      color: var(--color-bright);
      font-family: var(--font-display);
      font-size: clamp(1.4rem, 2.4vw, 2rem);
      letter-spacing: 0;
      line-height: 1.15;
      margin-top: 0.4rem;
    }
    .atlas-brief {
      display: grid;
      gap: 0.85rem;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      margin-top: 1rem;
    }
    .atlas-brief section {
      border: 1px solid var(--color-line);
      border-radius: 8px;
      padding: 0.85rem;
    }
    .atlas-brief h3,
    .atlas-evidence h3 {
      color: var(--color-muted);
      font-family: var(--font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .atlas-brief p {
      color: var(--color-paper);
      font-size: 0.93rem;
      line-height: 1.65;
      margin-top: 0.45rem;
    }
    .atlas-brief code {
      color: var(--color-signal);
      display: block;
      font-family: var(--font-mono);
      font-size: 0.84rem;
      line-height: 1.5;
      margin-top: 0.55rem;
      overflow-wrap: anywhere;
    }
    .atlas-relations {
      display: grid;
      gap: 0.55rem;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      margin-top: 1rem;
    }
    .atlas-relations a {
      border: 1px solid color-mix(in srgb, var(--rel) 36%, var(--color-line));
      border-radius: 8px;
      display: grid;
      gap: 0.18rem;
      min-height: 4.4rem;
      padding: 0.65rem;
      transition: background 0.18s, border-color 0.18s;
    }
    .atlas-relations a:hover {
      background: color-mix(in srgb, var(--rel) 8%, transparent);
      border-color: color-mix(in srgb, var(--rel) 70%, transparent);
    }
    .atlas-relations span {
      color: var(--rel);
      font-family: var(--font-display);
      font-size: 0.88rem;
      font-weight: 700;
      letter-spacing: 0;
    }
    .atlas-relations small {
      color: var(--color-muted);
      font-size: 0.75rem;
      line-height: 1.35;
    }
    .atlas-evidence {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      margin-top: 1.3rem;
    }
    .atlas-evidence section {
      border-top: 1px solid var(--color-line);
      padding-top: 0.75rem;
    }
    .atlas-evidence ul {
      display: grid;
      gap: 0.65rem;
      list-style: none;
      margin: 0.7rem 0 0;
      padding: 0;
    }
    .atlas-evidence li {
      display: grid;
      gap: 0.22rem;
    }
    .atlas-evidence a {
      color: var(--color-signal);
      font-family: var(--font-mono);
      font-size: 0.8rem;
      line-height: 1.4;
    }
    .atlas-evidence a:hover {
      color: var(--color-bright);
    }
    .atlas-evidence span {
      color: var(--color-muted);
      font-size: 0.82rem;
      line-height: 1.45;
    }

    @media (max-width: 640px) {
      .term-head {
        display: grid;
      }
      .term-family {
        width: fit-content;
        max-width: 100%;
      }
      .term-definition p {
        font-size: 1rem;
      }
    }
  </style>
</EnglishLayout>
