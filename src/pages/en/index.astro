---
import EnglishLayout from '../../layouts/EnglishGuidesLayout.astro';

const SITE = (Astro.site?.toString() ?? 'https://l0g.fr/').replace(/\/$/, '');
const cards = [
  { href: '/en/start/', k: 'start', title: 'Start here', text: 'A quick orientation page for non-French readers: what l0g is, what exists in English, and how to use it.' },
  { href: '/en/tour/', k: 'tour', title: 'Guided tour', text: 'A visual map of the site: guides, dashboards, API, MCP, evidence graph, glossary and risk surfaces.' },
  { href: '/en/guides/', k: 'guides', title: 'Reference guides', text: 'Long-form, sourced, durable guides on macro, markets, credit, crypto regulation and public data.' },
  { href: '/en/methodology/', k: 'method', title: 'Methodology', text: 'How l0g reads public data, separates observation from inference and avoids false precision.' },
  { href: '/en/sources/', k: 'sources', title: 'Sources', text: 'The primary-source hierarchy behind the project: central banks, statistical agencies, SEC filings, regulators and public datasets.' },
  { href: '/en/api/', k: 'api', title: 'API', text: 'Static JSON, NDJSON and CSV surfaces for risk signals, claims, evidence graph, catalog, freshness and integrity.' },
  { href: '/en/mcp/', k: 'mcp', title: 'MCP server', text: 'Read-only Model Context Protocol endpoint for agents that need structured access without scraping.' },
  { href: '/en/glossary/', k: 'glossary', title: 'Core glossary', text: 'A first English glossary for the terms that appear most often in the English guides and machine surfaces.' },
  { href: '/en/dashboards/', k: 'dashboards', title: 'Dashboards', text: 'A map of l0g monitoring tools: macro, debt, energy, yen carry, 13F/insider confluence and other risk monitors.' },
  { href: '/en/risk-diff/', k: 'diff', title: 'Risk Diff', text: 'What changed in public risk signals, sources, claims and model confidence across 1, 7 and 30 days.' },
  { href: '/en/black-box/', k: 'blackbox', title: 'Black Box', text: 'Point-in-time replay of public risk frames, with hashes and explicit historical gaps.' },
  { href: '/en/editorial-protocol/', k: 'protocol', title: 'Editorial protocol', text: 'Correction policy, evidence levels, source rules and the difference between fact, estimate, inference and scenario.' },
];
---

<EnglishLayout
  title="l0g in English"
  description="English entry points for l0g.fr: reference guides, methodology, sources, API, MCP, dashboards, glossary and risk replay surfaces."
  alternateLinks={[
    { hreflang: 'en', href: `${SITE}/en/` },
    { hreflang: 'fr', href: `${SITE}/` },
    { hreflang: 'x-default', href: `${SITE}/` },
  ]}
>
  <section class="en-hero rise" data-pagefind-body>
    <p class="mono-label glow" style="color: var(--color-signal)">$ cd /en</p>
    <h1 class="en-title font-display glow">English entry points for l0g.</h1>
    <p class="en-lede">
      l0g.fr is primarily a French risk-intelligence project. The English section exposes the durable parts of the site:
      reference guides, methodology, primary-source logic, API/MCP documentation, machine-readable data surfaces and selected risk tools.
    </p>
    <p class="en-note">
      This is a partial, explicit English layer. The full journal, most topic hubs and many exploratory notes remain French-only.
    </p>
  </section>

  <section class="en-grid" aria-label="English sections">
    {cards.map((card) => (
      <a class="en-card" href={card.href}>
        <span class="mono-label">// {card.k}</span>
        <strong>{card.title}</strong>
        <p>{card.text}</p>
      </a>
    ))}
  </section>
</EnglishLayout>

<style>
  .en-title { margin-top: .8rem; max-width: 52rem; font-size: clamp(2.4rem, 6vw, 4.9rem); line-height: .96; }
  .en-lede { margin-top: 1.2rem; max-width: 50rem; color: var(--color-paper); font-size: 1.08rem; line-height: 1.7; }
  .en-note { margin-top: 1rem; max-width: 46rem; color: var(--color-muted); font-size: .94rem; line-height: 1.6; }
  .en-grid { display: grid; grid-template-columns: 1fr; gap: 1rem; margin-top: 2.4rem; }
  .en-card { display: grid; gap: .45rem; border: 1px solid var(--color-line); border-radius: 10px; padding: 1rem; background: color-mix(in srgb, var(--color-surface) 64%, transparent); text-decoration: none; }
  .en-card:hover { border-color: color-mix(in srgb, var(--color-signal) 48%, transparent); background: color-mix(in srgb, var(--color-signal) 6%, transparent); }
  .en-card strong { color: var(--color-bright); font-size: 1.08rem; }
  .en-card p { color: var(--color-muted); font-size: .92rem; line-height: 1.55; }
  @media (min-width: 760px) { .en-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
</style>
