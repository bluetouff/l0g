---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import EnglishGuidesLayout from '../../../layouts/EnglishGuidesLayout.astro';
import { readingTime } from '../../../lib/reading-time.ts';

const CATEGORIES = [
  { key: 'macro',   label: 'Macro data',                         dir: 'macro',   accent: 'var(--color-signal)' },
  { key: 'fed',     label: 'Fed, debt & liquidity',              dir: 'fed',     accent: 'var(--color-amber)' },
  { key: 'marches', label: 'Markets, SEC filings & positioning', dir: 'markets', accent: 'var(--color-muted)' },
  { key: 'crypto',  label: 'Crypto & regulation',                dir: 'crypto',  accent: 'var(--color-accent)' },
];

const all = (await getCollection('guidesEn', ({ data }) => !data.draft)).sort((a, b) => {
  const da = (a.data.updatedDate ?? a.data.pubDate).getTime();
  const db = (b.data.updatedDate ?? b.data.pubDate).getTime();
  return db - da;
});

type GuideEntry = CollectionEntry<'guidesEn'>;

const fmt = (d: Date) => d.toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' });
const toItem = (g: GuideEntry) => ({
  id: g.id,
  title: g.data.title,
  description: g.data.description,
  date: g.data.updatedDate ?? g.data.pubDate,
  rt: readingTime(g.body),
});

const groups = CATEGORIES
  .map((c) => ({ ...c, items: all.filter((g) => g.data.category === c.key).map(toItem) }))
  .filter((g) => g.items.length > 0);

const known = new Set(CATEGORIES.map((c) => c.key));
const others = all.filter((g) => !g.data.category || !known.has(g.data.category)).map(toItem);
if (others.length) {
  groups.push({ key: 'other', label: 'Other', dir: 'other', accent: 'var(--color-muted)', items: others });
}

const total = all.length;
const canonical = new URL('/en/guides/', Astro.site).toString();
const alternateLinks = [
  { hreflang: 'en', href: canonical },
  { hreflang: 'fr', href: new URL('/guides/', Astro.site).toString() },
  { hreflang: 'x-default', href: new URL('/guides/', Astro.site).toString() },
];
---

<EnglishGuidesLayout
  title="English reference guides"
  description="English versions of selected l0g reference guides: long-form, sourced, durable pages on macro, liquidity, markets, SEC filings, crypto and regulation."
  canonical={canonical}
  alternateLinks={alternateLinks}
>
  <section class="rise border-b border-dashed border-line pb-10">
    <p class="mono-label" style="color: var(--color-signal)">$ ls /en/guides</p>
    <h1 class="mt-5 font-display text-[clamp(2.1rem,5vw,3.2rem)] leading-tight tracking-wider glow">
      English <span style="color: var(--color-accent)">reference guides</span>
    </h1>
    <p class="mt-5 max-w-xl text-muted">
      Long-form, sourced, durable guides translated from the French l0g corpus.
      This English section is intentionally limited to guides: the rest of l0g.fr remains primarily French.
      {total} {total === 1 ? 'guide is' : 'guides are'} currently available in English.
    </p>
  </section>

  {
    groups.length === 0 ? (
      <p class="mt-10 text-muted">No English guide is published yet.</p>
    ) : (
      groups.map((cat) => (
        <section class="cat rise">
          <header class="cat-head">
            <p class="mono-label cat-cmd" style={`color:${cat.accent}`}>
              $ ls /en/guides/{cat.dir}
            </p>
            <span class="mono-label cat-count">
              {cat.items.length} {cat.items.length > 1 ? 'guides' : 'guide'}
            </span>
          </header>
          <p class="cat-label">{cat.label}</p>
          {cat.items.map((g, i) => (
            <a href={`/en/guides/${g.id}/`} class="en-guide-card" style={`--a:${cat.accent}`}>
              <span class="en-guide-index mono-label" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <span class="en-guide-rail" aria-hidden="true"></span>
              <span class="en-guide-body">
                <span class="en-guide-meta mono-label">
                  <time datetime={g.date.toISOString()}>{fmt(g.date)}</time>
                  <span aria-hidden="true">·</span>
                  <span>{g.rt} min read</span>
                  <span class="topic-chip">guide</span>
                </span>
                <span class="en-guide-title">{g.title}</span>
                <span class="en-guide-desc">{g.description}</span>
              </span>
              <span class="en-guide-arrow" aria-hidden="true">›</span>
            </a>
          ))}
        </section>
      ))
    )
  }
</EnglishGuidesLayout>

<style>
  .cat { padding-top: 2.6rem; }
  .cat-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  .cat-count { color: var(--color-muted); }
  .cat-label {
    margin: 0.35rem 0 0.4rem;
    padding-bottom: 0.7rem;
    border-bottom: 1px dashed var(--color-line);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    color: var(--color-muted);
  }
  .en-guide-card {
    --a: var(--color-signal);
    display: grid;
    grid-template-columns: auto 2px 1fr auto;
    align-items: start;
    column-gap: 1rem;
    padding: 1.45rem 0.85rem 1.45rem 0.25rem;
    border-bottom: 1px solid var(--color-line);
    border-radius: 8px;
    transition: background 0.16s;
  }
  .en-guide-card:hover { background: color-mix(in srgb, var(--a) 7%, transparent); }
  .en-guide-index {
    min-width: 1.8rem;
    padding-top: 0.2rem;
    color: var(--color-line-strong);
    font-variant-numeric: tabular-nums;
    transition: color 0.16s;
  }
  .en-guide-card:hover .en-guide-index { color: var(--a); }
  .en-guide-rail {
    align-self: stretch;
    border-radius: 999px;
    background: color-mix(in srgb, var(--a) 30%, transparent);
    transition: background 0.16s;
  }
  .en-guide-card:hover .en-guide-rail { background: var(--a); }
  .en-guide-body { min-width: 0; }
  .en-guide-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 0.55rem; color: var(--a); }
  .topic-chip {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--a);
    padding: 0.1rem 0.45rem;
    border: 1px solid color-mix(in srgb, var(--a) 35%, transparent);
    background: color-mix(in srgb, var(--a) 12%, transparent);
    border-radius: 999px;
  }
  .en-guide-title {
    display: block;
    margin-top: 0.6rem;
    font-size: 1.18rem;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: var(--color-bright);
    transition: color 0.16s;
  }
  .en-guide-card:hover .en-guide-title { color: var(--a); }
  .en-guide-desc {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-top: 0.5rem;
    font-size: 0.88rem;
    line-height: 1.55;
    color: var(--color-muted);
  }
  .en-guide-arrow {
    align-self: center;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--color-line-strong);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.16s, transform 0.16s, color 0.16s;
  }
  .en-guide-card:hover .en-guide-arrow { opacity: 1; transform: translateX(0); color: var(--a); }
  @media (max-width: 640px) {
    .en-guide-card { grid-template-columns: auto 2px 1fr; }
    .en-guide-arrow { display: none; }
  }
</style>
