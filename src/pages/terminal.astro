---
import BaseLayout from '../layouts/BaseLayout.astro';
import { serializeInlineScriptData } from '../lib/security.ts';

const quickCommands = [
  'man',
  'risk today',
  'risk regime',
  'risk diff 7d',
  'proof map',
  'freshness check',
  'integrity hash',
  'signal history',
  'source debt',
  'method debt-risk',
  'claim uranium enrichment',
  'sources stale',
  'mcp tools',
];

const manualCommands = [
  {
    command: 'man',
    role: 'manuel complet du terminal, avec carte des commandes et garanties de sécurité.',
  },
  {
    command: 'risk today',
    role: 'snapshot public du risque, endpoints JSON, données et limites de fraîcheur.',
  },
  {
    command: 'risk regime',
    role: 'lecture des régimes et seuils : niveau courant, historique, changements de régime et limites de comparaison.',
  },
  {
    command: 'risk diff 1d | 7d | 30d',
    role: 'lecture des changements de risque par fenêtre : signaux, sources, claims, modèles, articles, confiance.',
  },
  {
    command: 'proof map',
    role: 'carte des preuves : claims, evidence graph, protocole éditorial, corrections et artefacts.',
  },
  {
    command: 'freshness check',
    role: 'fraîcheur du corpus : dates observées, calculées, récupérées, expirées et couverture.',
  },
  {
    command: 'integrity hash',
    role: 'empreintes, changefeed, Black Box Recorder et statut public des artefacts.',
  },
  {
    command: 'signal history',
    role: 'historique point-in-time des signaux, CSV, NDJSON, backtests et garde-fous anti look-ahead.',
  },
  {
    command: 'source debt',
    role: 'sources primaires liées à la dette US : Treasury Fiscal Data, TIC, CBO, FRED, méthodologie.',
  },
  {
    command: 'method debt-risk',
    role: 'méthode Debt Risk Radar : stress courant, structure CBO, pondérations, couverture et limites.',
  },
  {
    command: 'claim uranium enrichment',
    role: 'claims et articles l0g reliés à la chaîne uranium, sans réponse générée côté navigateur.',
  },
  {
    command: 'sources stale',
    role: 'sources, fraîcheur, limites de publication, statut et surfaces de vérification.',
  },
  {
    command: 'model limits',
    role: 'rappelle les limites des scores : couverture, incertitude, normalisation, seuils et révisions.',
  },
  {
    command: 'corrections',
    role: 'journal des corrections, changements de protocole et traçabilité éditoriale.',
  },
  {
    command: 'replay YYYY-MM-DD',
    role: 'renvoie vers le Black Box Recorder et ses frames point-in-time hashées.',
  },
  {
    command: 'guide treasuries',
    role: 'guide de lecture des Treasuries et articles de marché reliés.',
  },
  {
    command: 'opacity private-credit',
    role: 'dossier crédit privé : opacité, prix, gating, sources FSB/OFR et articles l0g.',
  },
  {
    command: 'scenario hormuz',
    role: 'dossier géopolitique énergie autour d’Ormuz, pétrole, flux, supply chains et scénarios.',
  },
  {
    command: 'mcp tools',
    role: 'outils MCP exposés en lecture seule pour agents : risk diff, black box, claims, evidence graph.',
  },
  {
    command: 'open <cible>',
    role: 'navigation interne allowlistée : api, agents, black-box, risk-diff, sources, guides, dashboards, status.',
  },
  {
    command: 'clear',
    role: 'nettoie uniquement l’affichage local du terminal.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': 'https://l0g.fr/terminal/#terminal',
      name: 'Terminal l0g',
      description:
        'Interface terminal de navigation dans l0g : commandes risk, sources, claims, guides, Black Box, Risk Diff, MCP et corpus machine.',
      inLanguage: 'fr',
      isAccessibleForFree: true,
      publisher: { '@id': 'https://l0g.fr/#org' },
      url: 'https://l0g.fr/terminal/',
      mainEntity: { '@id': 'https://l0g.fr/terminal/#app' },
    },
    {
      '@type': 'WebApplication',
      '@id': 'https://l0g.fr/terminal/#app',
      name: 'Terminal l0g',
      applicationCategory: 'FinanceApplication',
      operatingSystem: 'Web',
      isAccessibleForFree: true,
      featureList: manualCommands.map((item) => item.command),
      browserRequirements:
        'JavaScript optionnel pour le shell interactif ; le manuel des commandes reste lisible en HTML statique.',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
    },
    {
      '@type': 'TechArticle',
      '@id': 'https://l0g.fr/terminal/#man',
      headline: 'Manuel des commandes du terminal l0g',
      inLanguage: 'fr',
      about: ['risk intelligence', 'finance', 'MCP', 'sources primaires', 'point-in-time'],
      isAccessibleForFree: true,
      publisher: { '@id': 'https://l0g.fr/#org' },
      mainEntityOfPage: 'https://l0g.fr/terminal/',
    },
  ],
};
---

<BaseLayout
  title="Terminal"
  description="Terminal l0g : interface clavier pour explorer risques, sources, claims, guides, Risk Diff, Black Box Recorder, MCP et corpus machine."
  ogImage="/og-terminal.png"
  ogImageAlt="Terminal l0g : interface de navigation en ligne de commande"
  sidebar={false}
>
  <script type="application/ld+json" is:inline set:html={serializeInlineScriptData(jsonLd)} />

  <section class="terminal-page rise" data-pagefind-body>
    <div class="terminal-shell" id="terminal-shell" data-pagefind-ignore>
      <header class="terminal-bar">
        <span class="terminal-lights" aria-hidden="true">
          <span></span><span></span><span></span>
        </span>
        <span class="terminal-title">bluetouff@l0g:/risk</span>
        <span class="terminal-status">static · no tracker · strict allowlist</span>
      </header>

      <div class="terminal-screen" id="terminal-screen" aria-live="polite" aria-label="Sortie du terminal">
        <p><span class="prompt">bluetouff@l0g:~$</span> <span class="cmd">boot l0g</span></p>
        <p class="out">risk intelligence shell · build statique · sources publiques · clavier d’abord</p>
        <p class="out muted">tapez <span class="cmd">man</span> · historique avec ↑/↓ · autocomplétion avec Tab · clear avec Ctrl+L</p>
      </div>

      <form class="terminal-input" id="terminal-form" autocomplete="off">
        <label for="terminal-command" class="prompt">bluetouff@l0g:~$</label>
        <input
          id="terminal-command"
          name="command"
          type="text"
          inputmode="text"
          spellcheck="false"
          placeholder="man"
          aria-label="Commande terminal"
          maxlength="96"
        />
        <button type="submit">run</button>
      </form>
    </div>

    <div class="command-dock" aria-label="Commandes rapides" data-pagefind-ignore>
      {quickCommands.map((command) => (
        <button type="button" data-command={command}>{command}</button>
      ))}
    </div>

    <section class="terminal-man" id="man" aria-labelledby="terminal-man-title">
      <p class="mono-label glow">// man l0g-terminal</p>
      <h1 id="terminal-man-title">Manuel des commandes</h1>
      <p class="terminal-lede">
        Le terminal l0g est une interface de navigation clavier, pas un shell système. Les commandes
        déclenchent uniquement des réponses statiques ou des liens internes allowlistés vers les surfaces
        publiques : Risk Diff, Black Box Recorder, sources primaires, guides, claims et MCP.
      </p>

      <div class="man-grid">
        {manualCommands.map((item) => (
          <article class="man-command">
            <code>{item.command}</code>
            <p>{item.role}</p>
          </article>
        ))}
      </div>

      <div class="man-ops" aria-label="Garanties">
        <section>
          <h2>Sécurité</h2>
          <p>
            Aucune commande n’est évaluée. Le parseur accepte un jeu de caractères strict, borne la longueur,
            rejette les cibles inconnues et construit toutes les sorties avec <code>textContent</code> ou des
            liens internes définis en dur.
          </p>
        </section>
        <section>
          <h2>Performance</h2>
          <p>
            Le terminal ne charge pas de gros dataset dans le navigateur. L’historique visible est borné,
            les lignes anciennes sont purgées et les réponses renvoient vers les endpoints publics quand
            l’analyse exige de la donnée structurée.
          </p>
        </section>
        <section>
          <h2>Accès machine</h2>
          <p>
            Les mêmes surfaces restent lisibles par agents via <a href="/llms.txt">llms.txt</a>,
            <a href="/api/">l’API publique</a>, <a href="/mcp/">MCP</a>, <a href="/risk-diff/">Risk Diff</a>{' '}
            et <a href="/black-box/">Black Box Recorder</a>.
          </p>
        </section>
      </div>
    </section>

    <section class="terminal-links">
      <p class="mono-label glow">// accès directs</p>
      <div class="terminal-grid">
        <a href="/risk-diff/">
          <span>risk diff</span>
          <strong>mouvement de la connaissance</strong>
        </a>
        <a href="/black-box/">
          <span>black box</span>
          <strong>replay point-in-time</strong>
        </a>
        <a href="/mcp/">
          <span>mcp</span>
          <strong>tools pour agents</strong>
        </a>
        <a href="/api/">
          <span>api</span>
          <strong>données machine</strong>
        </a>
        <a href="/methodologie/">
          <span>méthodologie</span>
          <strong>formules et limites</strong>
        </a>
        <a href="/sources/">
          <span>sources</span>
          <strong>institutions primaires</strong>
        </a>
        <a href="/guides/">
          <span>guides</span>
          <strong>références de marché</strong>
        </a>
        <a href="/preuves/">
          <span>preuves</span>
          <strong>changelog et artefacts</strong>
        </a>
      </div>
    </section>
  </section>

  <script>
    // @ts-nocheck -- script navigateur autonome, validé sur le DOM construit.
    (function () {
      var shell = document.getElementById('terminal-shell');
      var screen = document.getElementById('terminal-screen');
      var form = document.getElementById('terminal-form');
      var input = document.getElementById('terminal-command');
      if (!shell || !screen || !form || !input) return;

      var MAX_LINES = 180;
      var MAX_HISTORY = 50;
      var MAX_COMMAND_LENGTH = 96;
      var SAFE_COMMAND = /^[a-z0-9][a-z0-9 ._-]{0,95}$/;

      var routes = Object.freeze({
        about: '/about/',
        agents: '/agents/',
        api: '/api/',
        'black-box': '/black-box/',
        backtests: '/backtests/',
        dashboards: '/dashboards/',
        donnees: '/donnees/',
        guides: '/guides/',
        journal: '/',
        manifeste: '/manifeste/',
        mcp: '/mcp/',
        methodologie: '/methodologie/',
        'protocole-editorial': '/protocole-editorial/',
        preuves: '/preuves/',
        recherche: '/recherche/',
        'risk-diff': '/risk-diff/',
        sources: '/sources/',
        'sources-reference': '/sites-reference/',
        status: '/status/',
        terminal: '/terminal/',
      });

      var suggestions = [
        'man',
        'help',
        'ls',
        'cat manifeste',
        'risk today',
        'risk regime',
        'risk diff 1d',
        'risk diff 7d',
        'risk diff 30d',
        'proof map',
        'freshness check',
        'integrity hash',
        'signal history',
        'source debt',
        'method debt-risk',
        'claim uranium enrichment',
        'sources stale',
        'model limits',
        'corrections',
        'replay 2026-06-15',
        'guide treasuries',
        'opacity private-credit',
        'scenario hormuz',
        'mcp tools',
        'curl risk',
        'whoami',
        'clear',
        'open risk-diff',
        'open black-box',
        'open api',
        'open mcp',
        'open sources',
        'open guides',
      ];

      var history = [];
      var historyIndex = 0;

      function normalize(raw) {
        return String(raw || '').trim().toLowerCase().replace(/\s+/g, ' ');
      }

      function safeHref(href) {
        return typeof href === 'string' && href.charAt(0) === '/' && href.indexOf('//') !== 0;
      }

      function isIsoDate(value) {
        var match = /^(\d{4})-(\d{2})-(\d{2})$/.exec(value);
        if (!match) return false;
        var year = Number(match[1]);
        var month = Number(match[2]);
        var day = Number(match[3]);
        if (year < 2000 || year > 2100 || month < 1 || month > 12 || day < 1 || day > 31) return false;
        var date = new Date(Date.UTC(year, month - 1, day));
        return date.getUTCFullYear() === year && date.getUTCMonth() === month - 1 && date.getUTCDate() === day;
      }

      function appendLine(className, writer) {
        var p = document.createElement('p');
        p.className = className || 'out';
        writer(p);
        screen.appendChild(p);
        prune();
        return p;
      }

      function textLine(text, className) {
        appendLine(className || 'out', function (p) {
          p.textContent = text;
        });
      }

      function preBlock(lines) {
        var pre = document.createElement('pre');
        pre.className = 'terminal-pre';
        pre.textContent = lines.join('\n');
        screen.appendChild(pre);
        prune();
      }

      function promptLine(command) {
        appendLine('', function (p) {
          var promptSpan = document.createElement('span');
          var cmdSpan = document.createElement('span');
          promptSpan.className = 'prompt';
          promptSpan.textContent = 'bluetouff@l0g:~$';
          cmdSpan.className = 'cmd';
          cmdSpan.textContent = command;
          p.appendChild(promptSpan);
          p.appendChild(document.createTextNode(' '));
          p.appendChild(cmdSpan);
        });
      }

      function linkLine(label, href, detail) {
        appendLine('out', function (p) {
          var anchor = document.createElement('a');
          anchor.textContent = label;
          if (safeHref(href)) anchor.setAttribute('href', href);
          p.appendChild(anchor);
          if (detail) {
            p.appendChild(document.createTextNode('  ' + detail));
          }
        });
      }

      function section(title, lines) {
        textLine(title, 'out section-title');
        lines.forEach(function (line) {
          if (typeof line === 'string') {
            textLine(line);
          } else if (line && line.href) {
            linkLine(line.label, line.href, line.detail);
          }
        });
      }

      function prune() {
        while (screen.children.length > MAX_LINES) {
          screen.removeChild(screen.firstElementChild);
        }
      }

      function scrollToEnd() {
        screen.scrollTop = screen.scrollHeight;
      }

      function printMan() {
        preBlock([
          ' _  ___             __       ',
          '| |/ _ \\ __ _      / _|_ __ ',
          '| | | | / _` |____| |_| \'__|',
          '| | |_| | (_| |____|  _| |   ',
          '|_|\\___/ \\__, |    |_| |_|   ',
          '         |___/               ',
        ]);
        section('NOM', ['l0g-terminal - interface clavier pour explorer les risques publics l0g']);
        section('SYNOPSIS', [
          'risk today',
          'risk regime',
          'risk diff 1d | 7d | 30d',
          'proof map',
          'freshness check',
          'integrity hash',
          'signal history',
          'source debt',
          'method debt-risk',
          'claim uranium enrichment',
          'sources stale',
          'model limits',
          'corrections',
          'replay YYYY-MM-DD',
          'guide treasuries',
          'opacity private-credit',
          'scenario hormuz',
          'mcp tools',
          'open <cible>',
        ]);
        section('DESCRIPTION', [
          'Ce terminal ne parle pas au système. Il sert de routeur clavier vers les pages, endpoints et dossiers de preuve publiés par l0g.',
          'Les commandes sont allowlistées, les arguments sont validés, la sortie est échappée et aucun HTML utilisateur n’est injecté.',
        ]);
        section('CLAVIER', [
          'Entrée exécute la commande.',
          '↑ et ↓ parcourent l’historique local.',
          'Tab complète vers une commande connue.',
          'Ctrl+L lance clear.',
        ]);
      }

      function printLs() {
        section('ESPACES', [
          { label: '/risk-diff/', href: '/risk-diff/', detail: 'changements de risque sur 1, 7 et 30 jours' },
          { label: '/black-box/', href: '/black-box/', detail: 'frames point-in-time hashées' },
          { label: '/mcp/', href: '/mcp/', detail: 'serveur MCP public en lecture seule' },
          { label: '/api/', href: '/api/', detail: 'contrats JSON, XML, NDJSON et catalogue' },
          { label: '/agents/', href: '/agents/', detail: 'mode d’emploi pour agents' },
          { label: '/methodologie/', href: '/methodologie/', detail: 'formules, seuils et limites' },
          { label: '/sources/', href: '/sources/', detail: 'institutions primaires' },
          { label: '/guides/', href: '/guides/', detail: 'guides de marché' },
          { label: '/preuves/', href: '/preuves/', detail: 'artefacts, changelog, intégrité' },
        ]);
      }

      function printManifesto() {
        section('MANIFESTE', [
          'sources primaires avant agrégateurs',
          'méthodes visibles avant scores séduisants',
          'code ouvert quand le calcul compte',
          'pas de cookie, pas de pixel, pas de conseil en investissement',
          { label: '/manifeste/', href: '/manifeste/', detail: 'pacte de lecture complet' },
        ]);
      }

      function printRiskToday() {
        section('RISK TODAY', [
          'Lecture du dernier état public publié. Ce n’est pas un flux de prix en temps réel.',
          { label: '/api/v1/risk.json', href: '/api/v1/risk.json', detail: 'snapshot canonique de risque' },
          { label: '/api/v1/debt-risk.json', href: '/api/v1/debt-risk.json', detail: 'score dette US canonique' },
          { label: '/api/v1/signals/current.json', href: '/api/v1/signals/current.json', detail: 'signaux courants' },
          { label: '/donnees/', href: '/donnees/', detail: 'inventaire des datasets et limites de fraîcheur' },
          { label: '/status/', href: '/status/', detail: 'statut public des artefacts' },
        ]);
      }

      function printRiskRegime() {
        section('RISK REGIME', [
          'Lit le risque comme un régime daté : niveau, seuils, transitions, historique et confiance, pas comme une vérité instantanée.',
          { label: '/api/v1/signals/current.json', href: '/api/v1/signals/current.json', detail: 'état courant par instrument' },
          { label: '/api/v1/signals/history.json', href: '/api/v1/signals/history.json', detail: 'observations et changements de niveau' },
          { label: '/backtests/', href: '/backtests/', detail: 'lecture point-in-time et limites anti look-ahead' },
          { label: '/risk-diff/', href: '/risk-diff/', detail: 'mouvement des signaux, sources et modèles' },
          { label: '/methodologie/', href: '/methodologie/', detail: 'définition des seuils et limites' },
        ]);
      }

      function printRiskDiff(windowName) {
        section('RISK DIFF ' + windowName.toUpperCase(), [
          'Compare le risque publié par fenêtre, en séparant signaux, sources, claims, modèles, articles et confiance.',
          { label: '/risk-diff/', href: '/risk-diff/', detail: 'page de lecture humaine' },
          { label: '/api/v1/risk-diff.json', href: '/api/v1/risk-diff.json', detail: 'contrat machine 1d, 7d, 30d' },
          { label: '/api/v1/changes.ndjson', href: '/api/v1/changes.ndjson', detail: 'flux de changements' },
        ]);
      }

      function printProofMap() {
        section('PROOF MAP', [
          'Carte de preuve l0g : un article utile doit relier affirmation, source, méthode, fraîcheur et correction possible.',
          { label: '/api/v1/claims.json', href: '/api/v1/claims.json', detail: 'claims typées, sourcées et reliées aux articles' },
          { label: '/api/v1/evidence-graph.json', href: '/api/v1/evidence-graph.json', detail: 'graphe articles, claims, références, hôtes, sources' },
          { label: '/protocole-editorial/', href: '/protocole-editorial/', detail: 'niveaux de preuve et chaîne éditoriale' },
          { label: '/changelog-editorial/', href: '/changelog-editorial/', detail: 'changements de protocole et corrections' },
          { label: '/preuves/', href: '/preuves/', detail: 'artefacts publics et vérification' },
        ]);
      }

      function printFreshnessCheck() {
        section('FRESHNESS CHECK', [
          'Distingue publication, observation, récupération, calcul, indexation, expiration et couverture.',
          { label: '/api/v1/freshness.json', href: '/api/v1/freshness.json', detail: 'fraîcheur du corpus et des signaux' },
          { label: '/status/', href: '/status/', detail: 'état public du build et des snapshots' },
          { label: '/donnees/', href: '/donnees/', detail: 'inventaire, cadence, limites de fraîcheur' },
          { label: '/api/v1/sources.json', href: '/api/v1/sources.json', detail: 'registre sources et hôtes cités' },
        ]);
      }

      function printIntegrityHash() {
        section('INTEGRITY HASH', [
          'Suit les empreintes et les changements publiés pour savoir si une surface a bougé.',
          { label: '/api/v1/integrity.json', href: '/api/v1/integrity.json', detail: 'hashes SHA-256 canoniques des surfaces agents' },
          { label: '/api/v1/changes.json', href: '/api/v1/changes.json', detail: 'changefeed JSON avec diff et version' },
          { label: '/api/v1/changes.ndjson', href: '/api/v1/changes.ndjson', detail: 'changefeed ligne à ligne' },
          { label: '/black-box/', href: '/black-box/', detail: 'frames point-in-time hashées' },
          { label: '/preuves/', href: '/preuves/', detail: 'preuves, commits, artefacts' },
        ]);
      }

      function printSignalHistory() {
        section('SIGNAL HISTORY', [
          'Historique exploitable sans reconstruire après coup : observations, dates, niveaux, couverture et exports.',
          { label: '/api/v1/signals/history.json', href: '/api/v1/signals/history.json', detail: 'historique structuré' },
          { label: '/api/v1/signals/history.ndjson', href: '/api/v1/signals/history.ndjson', detail: 'streaming ligne à ligne' },
          { label: '/api/v1/signals/history.csv', href: '/api/v1/signals/history.csv', detail: 'table pour pandas, R, DuckDB ou tableur' },
          { label: '/api/v1/signals/schema.json', href: '/api/v1/signals/schema.json', detail: 'contrat machine des lignes' },
          { label: '/backtests/', href: '/backtests/', detail: 'lecture humaine des backtests' },
        ]);
      }

      function printDebtSources() {
        section('SOURCE DEBT', [
          'Dossier dette US : déficit, cash balance, auctions, TIC, CBO, conditions de marché et méthodes l0g.',
          { label: '/sources/treasury-fiscal-data/', href: '/sources/treasury-fiscal-data/', detail: 'Daily Treasury Statement, Debt to the Penny, auctions' },
          { label: '/sources/treasury-tic/', href: '/sources/treasury-tic/', detail: 'détention étrangère et flux transfrontaliers' },
          { label: '/sources/congress-govinfo-cbo/', href: '/sources/congress-govinfo-cbo/', detail: 'scoring budgétaire et documents politiques' },
          { label: '/sources/federal-reserve-fred/', href: '/sources/federal-reserve-fred/', detail: 'taux, spreads, liquidité, conditions financières' },
          { label: '/methodologie/debt-risk-radar/', href: '/methodologie/debt-risk-radar/', detail: 'méthode du radar dette' },
        ]);
      }

      function printDebtMethod() {
        section('METHOD DEBT-RISK', [
          'Le radar dette sépare le stress courant des vulnérabilités structurelles de long terme.',
          { label: '/methodologie/debt-risk-radar/', href: '/methodologie/debt-risk-radar/', detail: 'pondérations, familles, imputation, limites' },
          { label: '/api/v1/debt-risk.json', href: '/api/v1/debt-risk.json', detail: 'snapshot canonique dette US' },
          { label: '/sources/treasury-fiscal-data/', href: '/sources/treasury-fiscal-data/', detail: 'données fiscales rapides du Trésor' },
          { label: '/sources/congress-govinfo-cbo/', href: '/sources/congress-govinfo-cbo/', detail: 'projections et contexte structurel CBO' },
