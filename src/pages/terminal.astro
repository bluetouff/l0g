      function reject(command, reason) {
        promptLine(command || '[empty]');
        textLine(reason, 'out error');
        textLine('tapez man pour le manuel complet', 'out muted');
      }

      function run(raw) {
        var command = normalize(raw);
        if (!command) return;

        if (command.length > MAX_COMMAND_LENGTH || !SAFE_COMMAND.test(command)) {
          reject(command.slice(0, MAX_COMMAND_LENGTH), 'commande rejetée : caractères ou longueur non autorisés');
          return;
        }

        if (command === 'clear') {
          screen.replaceChildren();
          return;
        }

        promptLine(command);

        if (command === 'man' || command === 'help' || command === 'man l0g' || command === 'man terminal') {
          printMan();
          return;
        }
        if (command === 'ls') {
          printLs();
          return;
        }
        if (command === 'cat manifeste') {
          printManifesto();
          return;
        }
        if (command === 'risk today') {
          printRiskToday();
          return;
        }
        if (command === 'risk regime') {
          printRiskRegime();
          return;
        }
        if (/^risk diff (1d|7d|30d)$/.test(command)) {
          printRiskDiff(command.replace('risk diff ', ''));
          return;
        }
        if (command === 'proof map' || command === 'evidence graph') {
          printProofMap();
          return;
        }
        if (command === 'freshness check' || command === 'freshness') {
          printFreshnessCheck();
          return;
        }
        if (command === 'integrity hash' || command === 'integrity') {
          printIntegrityHash();
          return;
        }
        if (command === 'signal history' || command === 'signals history') {
          printSignalHistory();
          return;
        }
        if (command === 'source debt') {
          printDebtSources();
          return;
        }
        if (command === 'method debt-risk' || command === 'method debt') {
          printDebtMethod();
          return;
        }
        if (command === 'claim uranium enrichment' || command === 'claim uranium') {
          printUraniumClaim();
          return;
        }
        if (command === 'sources stale' || command === 'source stale') {
          printSourcesStale();
          return;
        }
        if (command === 'model limits' || command === 'score limits') {
          printModelLimits();
          return;
        }
        if (command === 'corrections' || command === 'correction log') {
          printCorrections();
          return;
        }
        if (/^replay \d{4}-\d{2}-\d{2}$/.test(command)) {
          var replayDate = command.replace('replay ', '');
          if (!isIsoDate(replayDate)) {
            textLine('date invalide : ' + replayDate, 'out error');
            textLine('format attendu : replay YYYY-MM-DD, date réelle uniquement', 'out muted');
            return;
          }
          printReplay(replayDate);
          return;
        }
        if (command === 'guide treasuries') {
          printTreasuriesGuide();
          return;
        }
        if (command === 'opacity private-credit' || command === 'opacity private credit') {
          printPrivateCredit();
          return;
        }
        if (command === 'scenario hormuz') {
          printHormuzScenario();
          return;
        }
        if (command === 'mcp tools') {
          printMcpTools();
          return;
        }
        if (command === 'curl risk') {
          printCurlRisk();
          return;
        }
        if (command === 'whoami') {
          printWhoami();
          return;
        }
        if (command.indexOf('open ') === 0) {
          var target = command.replace(/^open\s+/, '').trim();
          var href = routes[target];
          if (safeHref(href)) {
            linkLine('open ' + href, href, 'navigation interne allowlistée');
            window.setTimeout(function () {
              window.location.assign(href);
            }, 120);
          } else {
            textLine('cible inconnue : ' + target, 'out error');
            textLine('cibles : ' + Object.keys(routes).join(', '), 'out muted');
          }
          return;
        }

        textLine('commande inconnue : ' + command, 'out error');
        textLine('essayez : man · risk regime · proof map · freshness check · integrity hash', 'out muted');
      }

      function remember(command) {
        if (!command) return;
        if (history[history.length - 1] !== command) {
          history.push(command);
          if (history.length > MAX_HISTORY) history.shift();
        }
        historyIndex = history.length;
      }

      form.addEventListener('submit', function (event) {
        event.preventDefault();
        var command = input.value;
        remember(normalize(command));
        run(command);
        input.value = '';
        scrollToEnd();
      });

      input.addEventListener('keydown', function (event) {
        if (event.key === 'ArrowUp') {
          event.preventDefault();
          if (history.length) {
            historyIndex = Math.max(0, historyIndex - 1);
            input.value = history[historyIndex] || '';
          }
        } else if (event.key === 'ArrowDown') {
          event.preventDefault();
          if (history.length) {
            historyIndex = Math.min(history.length, historyIndex + 1);
            input.value = history[historyIndex] || '';
          }
        } else if (event.key === 'Tab') {
          event.preventDefault();
          var current = normalize(input.value);
          var matches = suggestions.filter(function (item) { return item.indexOf(current) === 0; });
          if (matches.length === 1) {
            input.value = matches[0];
          } else if (matches.length > 1 && current) {
            textLine(matches.slice(0, 8).join(' · '), 'out muted');
            scrollToEnd();
          }
        } else if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === 'l') {
          event.preventDefault();
          run('clear');
        }
      });

      document.addEventListener('keydown', function (event) {
        var target = event.target;
        var tag = target && target.tagName ? target.tagName.toLowerCase() : '';
        if (event.key === '/' && tag !== 'input' && tag !== 'textarea' && tag !== 'select') {
          event.preventDefault();
          input.focus();
        }
      });

      shell.addEventListener('click', function () {
        input.focus();
      });

      document.querySelectorAll('[data-command]').forEach(function (button) {
        button.addEventListener('click', function () {
          var command = button.getAttribute('data-command') || '';
          input.value = command;
          remember(normalize(command));
          run(command);
          input.value = '';
          scrollToEnd();
          input.focus();
        });
      });

      window.setTimeout(function () {
        input.focus();
      }, 80);
    })();
  </script>

