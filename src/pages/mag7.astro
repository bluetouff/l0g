---
import BaseLayout from '../layouts/BaseLayout.astro';
import SymbolOverview from '../components/SymbolOverview.astro';
import Heatmap from '../components/Heatmap.astro';
---

<BaseLayout title="Mag7" description="Dashboard des Magnificent 7 : Apple, Microsoft, Nvidia, Alphabet, Amazon, Meta, Tesla.">
  <section class="mb-4">
    <p class="mono-label">// dashboard</p>
    <h1 class="mt-2 font-display text-5xl leading-none tracking-wider glow sm:text-6xl">Mag7</h1>
    <p class="mt-3 max-w-2xl text-muted">
      Les sept valeurs qui portent (ou plombent) les indices américains : Apple,
      Microsoft, Nvidia, Alphabet, Amazon, Meta, Tesla.
    </p>
  </section>

  <h2 class="mono-label glow mb-1">// comparaison</h2>
  <SymbolOverview
    symbols={[
      { label: 'Apple', ticker: 'NASDAQ:AAPL' },
      { label: 'Microsoft', ticker: 'NASDAQ:MSFT' },
      { label: 'Nvidia', ticker: 'NASDAQ:NVDA' },
      { label: 'Alphabet', ticker: 'NASDAQ:GOOGL' },
      { label: 'Amazon', ticker: 'NASDAQ:AMZN' },
      { label: 'Meta', ticker: 'NASDAQ:META' },
      { label: 'Tesla', ticker: 'NASDAQ:TSLA' },
    ]}
    height={460}
  />

  <h2 class="mono-label glow mb-1 mt-8">// heatmap Nasdaq 100</h2>
  <Heatmap kind="stock" dataSource="NASDAQ100" height={500} />
</BaseLayout>
