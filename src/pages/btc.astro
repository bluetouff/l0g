---
import BaseLayout from '../layouts/BaseLayout.astro';
import TradingViewChart from '../components/TradingViewChart.astro';
import SymbolOverview from '../components/SymbolOverview.astro';
import Heatmap from '../components/Heatmap.astro';
---

<BaseLayout title="BTC" description="Dashboard Bitcoin : prix, majors crypto, dominance et heatmap du marché.">
  <section class="mb-4">
    <p class="mono-label">// dashboard</p>
    <h1 class="mt-2 font-display text-5xl leading-none tracking-wider glow sm:text-6xl">BTC</h1>
    <p class="mt-3 max-w-2xl text-muted">
      Prix du bitcoin, comparaison avec les principales crypto, dominance et vue
      d'ensemble du marché.
    </p>
  </section>



  <h2 class="mono-label glow mb-1 mt-8">// majors &amp; dominance</h2>
  <SymbolOverview
    symbols={[
      { label: 'BTC', ticker: 'BINANCE:BTCUSDT' },
      { label: 'ETH', ticker: 'BINANCE:ETHUSDT' },
      { label: 'SOL', ticker: 'BINANCE:SOLUSDT' },
      { label: 'Dominance BTC', ticker: 'CRYPTOCAP:BTC.D' },
      { label: 'Total market cap', ticker: 'CRYPTOCAP:TOTAL' },
    ]}
    height={420}
  />

  <h2 class="mono-label glow mb-1 mt-8">// heatmap crypto</h2>
  <Heatmap kind="crypto" height={480} />
</BaseLayout>
