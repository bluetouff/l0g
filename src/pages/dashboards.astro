---
import BaseLayout from '../layouts/BaseLayout.astro';
import { dashboards } from '../config/sidebar.ts';

const accentVar: Record<string, string> = {
  teal: 'var(--color-signal)',
  blue: '#7aa2f7',
  pink: 'var(--color-accent)',
  amber: 'var(--color-amber)',
};
---

<BaseLayout
  title="Dashboards & moniteurs"
  description="Les outils de monitoring du risque en accès libre : macro US, macro zone euro, carry trade yen, stress énergétique. Données publiques, architecture snapshot, code ouvert. Par Bluetouff."
  sidebar={false}
>
  <section data-pagefind-ignore>
    <p class="mono-label glow" style="color: var(--color-signal)">// dashboards</p>
    <h1 class="mt-3 font-display text-4xl leading-none tracking-wider glow sm:text-5xl">
      Dashboards <span style="color: var(--color-accent)">&amp;</span> moniteurs
    </h1>
    <p class="mt-4 max-w-2xl text-paper">
      Des outils de monitoring du risque sur données publiques. Le serveur récupère les
      sources, écrit un instantané, et votre navigateur ne contacte aucun tiers : pas de CDN,
      pas de tracker, aucune clé exposée. Chaque outil est documenté et son code est ouvert.
    </p>
  </section>

  <div class="mt-9 grid gap-5 sm:grid-cols-2">
    {
      dashboards.map((d) => (
        <article
          id={d.slug}
          class="fiche card flex flex-col overflow-hidden"
          style={`--a:${accentVar[d.accent]}`}
        >
          <div class="fiche-preview">
            <span class="mono-label">// aperçu</span>
            {d.preview ? (
              <img src={d.preview} alt={`Aperçu — ${d.label}`} loading="lazy" decoding="async" />
            ) : (
              <span class="fiche-glyph" aria-hidden="true">{d.glyph}</span>
            )}
          </div>

          <div class="flex flex-1 flex-col p-5">
            <header class="flex items-center gap-3">
              <span class="fiche-tile flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg text-lg">
                {d.glyph}
              </span>
              <span class="min-w-0">
                <span class="block text-[0.98rem] font-semibold text-bright">{d.label}</span>
                <span class="block text-xs text-muted">{d.sub}</span>
              </span>
            </header>

            <p class="fiche-q mt-4">{d.question}</p>

            <dl class="fiche-meta mt-4">
              <div>
                <dt>Sources</dt>
                <dd>{d.sources.join(' · ')}</dd>
              </div>
              <div>
                <dt>Mise à jour</dt>
                <dd>{d.cadence}</dd>
              </div>
              <div>
                <dt>Stack</dt>
                <dd>{d.stack}</dd>
              </div>
            </dl>

            <footer class="mt-auto flex items-center gap-5 pt-5">
              <a href={d.href} target="_blank" rel="noopener" class="fiche-cta">
                Ouvrir l'outil <span aria-hidden="true">›</span>
              </a>
              {d.repo && (
                <a href={d.repo} target="_blank" rel="noopener" class="link-term text-xs">
                  code
                </a>
              )}
            </footer>
          </div>
        </article>
      ))
    }
  </div>

  <p class="mt-8 max-w-2xl text-xs leading-relaxed text-muted" data-pagefind-ignore>
    Architecture commune : le serveur interroge les sources publiques et publie un fichier
    statique. Aucune donnée du visiteur n'est collectée, aucun appel à un tiers n'est émis
    depuis le navigateur. Le détail méthodologique de chaque indicateur est sur la
    <a href="/methodologie/" class="link-term" style="color: var(--color-signal)">page méthodologie</a>.
  </p>
  <p class="mt-3 text-xs" style="color: var(--color-accent)" data-pagefind-ignore>
    Ceci n'est pas un conseil en investissement.
  </p>

  <style>
    .fiche {
      --a: var(--color-signal);
      border-top: 2px solid color-mix(in srgb, var(--a) 60%, transparent);
    }
    .fiche:hover { border-top-color: var(--a); }

    .fiche-preview {
      position: relative;
      height: 132px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      border-bottom: 1px solid var(--color-line);
      background: radial-gradient(120% 150% at 50% 0%, color-mix(in srgb, var(--a) 13%, transparent), transparent 68%);
    }
    .fiche-preview img { width: 100%; height: 100%; object-fit: cover; }
    .fiche-preview .mono-label {
      position: absolute; top: 0.6rem; left: 0.8rem;
      color: color-mix(in srgb, var(--a) 70%, var(--color-muted));
    }
    .fiche-glyph {
      font-size: 3.2rem; line-height: 1; opacity: 0.55;
      filter: drop-shadow(0 0 20px color-mix(in srgb, var(--a) 45%, transparent));
    }

    .fiche-tile {
      border: 1px solid color-mix(in srgb, var(--a) 35%, transparent);
      background: color-mix(in srgb, var(--a) 10%, transparent);
    }

    .fiche-q {
      font-family: var(--font-read);
      font-size: 1.02rem;
      line-height: 1.45;
      color: var(--color-bright);
    }

    .fiche-meta { display: grid; gap: 0.55rem; }
    .fiche-meta > div { display: flex; gap: 0.7rem; }
    .fiche-meta dt {
      flex: 0 0 5.2rem;
      font-family: var(--font-mono);
      font-size: 0.6rem;
      letter-spacing: 0.11em;
      text-transform: uppercase;
      color: var(--color-muted);
      padding-top: 0.18rem;
    }
    .fiche-meta dd { margin: 0; font-size: 0.82rem; color: var(--color-paper); }

    .fiche-cta {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--a);
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
    }
    .fiche-cta span { transition: transform 0.2s; }
    .fiche:hover .fiche-cta span { transform: translateX(3px); }

    @media (prefers-reduced-motion: reduce) {
      .fiche-cta span { transition: none; }
    }
  </style>
</BaseLayout>
