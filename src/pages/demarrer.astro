---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Démarrer';
const description =
  "Comment utiliser l0g : par où commencer selon votre profil, comment lire un chiffre, et la carte complète du projet, du livre fondateur aux agents IA.";

const profils = [
  {
    k: 'lecteur',
    t: 'Vous découvrez le sujet',
    d: "Commencez par le manifeste pour comprendre l’intention du projet, puis parcourez le journal. Le glossaire décode chaque terme technique au fil de la lecture, sans prérequis.",
    links: [
      ['/manifeste/', 'manifeste'],
      ['/', 'journal'],
      ['/glossaire/', 'glossaire'],
    ],
  },
  {
    k: 'analyste',
    t: 'Vous cherchez à décider',
    d: "Les sujets regroupent les dossiers par thème, les guides expliquent comment lire une donnée officielle, les dashboards et la confluence fournissent les instruments. La méthodologie et les preuves permettent de tout revérifier.",
    links: [
      ['/sujets/', 'sujets'],
      ['/guides/', 'guides'],
      ['/dashboards/', 'dashboards'],
      ['/confluence/', 'confluence'],
    ],
  },
  {
    k: 'machine',
    t: 'Vous êtes un agent',
    d: "l0g expose une surface lisible par machine : un point d’entrée pour agents, un serveur MCP public, un corpus llms.txt et une API versionnée reliant chaque affirmation à sa source.",
    links: [
      ['/agents/', 'agents'],
      ['/mcp/', 'mcp'],
      ['/llms.txt', 'llms.txt'],
      ['/api/', 'api'],
    ],
  },
];

const briques = [
  {
    h: 'fondations',
    d: "L’origine intellectuelle et le contrat de départ.",
    items: [
      ['https://bluetouff.com/auditer-l-opacite.html', 'le livre : Auditer l’opacité', true],
      ['/manifeste/', 'manifeste', false],
      ['/about/', 'à propos', false],
    ],
  },
  {
    h: 'analyses',
    d: "Le travail éditorial : dossiers, articles et vocabulaire.",
    items: [
      ['/', 'journal', false],
      ['/sujets/', 'sujets', false],
      ['/guides/', 'guides', false],
      ['/glossaire/', 'glossaire', false],
    ],
  },
  {
    h: 'instruments',
    d: "Les outils de monitoring, en accès libre.",
    items: [
      ['/dashboards/', 'dashboards', false],
      ['/confluence/', 'confluence', false],
      ['/terminal/', 'terminal', false],
    ],
  },
  {
    h: 'vérifier',
    d: "Ce qui rend chaque chiffre contestable et refaisable.",
    items: [
      ['/methodologie/', 'méthodologie', false],
      ['/protocole-editorial/', 'protocole éditorial', false],
      ['/sources/', 'sources primaires', false],
      ['/sites-reference/', 'sites de référence', false],
      ['/preuves/', 'preuves', false],
      ['/backtests/', 'backtests', false],
    ],
  },
  {
    h: 'surface machine',
    d: "Le même corpus, exposé pour les agents et le code.",
    items: [
      ['/donnees/', 'données', false],
      ['/api/', 'api', false],
      ['/mcp/', 'mcp', false],
      ['/agents/', 'agents', false],
      ['/llms.txt', 'llms.txt', false],
      ['/status/', 'status', false],
    ],
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://l0g.fr/demarrer/#page',
  name: 'Démarrer sur l0g',
  description,
  inLanguage: 'fr',
  isAccessibleForFree: true,
  isPartOf: { '@id': 'https://l0g.fr/#website' },
  publisher: { '@id': 'https://l0g.fr/#org' },
  url: 'https://l0g.fr/demarrer/',
};
---

<BaseLayout
  title={title}
  description={description}
  ogImageAlt="Démarrer sur l0g : par où commencer, comment lire un chiffre, carte du projet"
  sidebar={false}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

  <article class="start-page rise" data-pagefind-body>
    <section class="start-hero" data-pagefind-ignore>
      <p class="mono-label glow" style="color: var(--color-signal)">// démarrer</p>
      <h1 class="start-title font-display glow">
        Comment utiliser <span>l0g</span>.
      </h1>
      <p class="start-lede">
        l0g se lit à plusieurs niveaux. Un lecteur curieux, un analyste qui doit décider
        et un agent logiciel n’y cherchent pas la même chose, mais tous accèdent au même
        corpus sourcé. Cette page donne la carte, du livre fondateur aux agents IA.
      </p>
    </section>

    <section class="start-section">
      <p class="mono-label glow">// par où commencer</p>
      <div class="profil-grid">
        {profils.map((p) => (
          <article class="profil">
            <span class="profil-k">{p.k}</span>
            <h2>{p.t}</h2>
            <p>{p.d}</p>
            <div class="profil-links">
              {p.links.map(([href, label]) => (
                <a href={href} class="chip">{label}</a>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="start-section">
      <p class="mono-label glow">// la carte en couches</p>
      <p class="start-p">
        Le projet s’empile du sol vers le plafond. Tout part d’une idée éditoriale et d’un
        essai ; tout finit exposé pour des machines. Chaque étage réutilise le même socle de
        données publiques, sans le réécrire.
      </p>

      <figure class="start-fig">
        <svg viewBox="0 0 720 476" role="img" aria-labelledby="map-t map-d" class="start-svg">
          <title id="map-t">Les cinq couches de l0g</title>
          <desc id="map-d">
            De bas en haut : fondations, analyses, instruments, vérification, surface machine.
            Une flèche monte des fondations vers la surface machine, du livre aux agents IA.
          </desc>

          <!-- flèche verticale : du livre aux agents IA -->
          <line x1="26" y1="430" x2="26" y2="46" class="map-arrow" />
          <path d="M26 40 l-6 12 h12 z" class="map-arrow-head" />
          <text x="15" y="238" class="map-axis" transform="rotate(-90 15 238)">du livre aux agents IA</text>

          <!-- couche 1 : surface machine (haut) -->
          <g>
            <rect x="60" y="30" width="640" height="72" rx="8" class="map-band" />
            <rect x="60" y="30" width="4" height="72" rx="2" class="edge-signal" />
            <text x="80" y="58" class="map-h">surface machine</text>
            <text x="80" y="82" class="map-list">données · api · mcp · agents · llms.txt</text>
          </g>

          <!-- couche 2 : vérifier -->
          <g>
            <rect x="60" y="116" width="640" height="72" rx="8" class="map-band" />
            <rect x="60" y="116" width="4" height="72" rx="2" class="edge-rose" />
            <text x="80" y="144" class="map-h">vérifier</text>
            <text x="80" y="168" class="map-list">méthodologie · protocole · sources · preuves</text>
          </g>

          <!-- couche 3 : instruments -->
          <g>
            <rect x="60" y="202" width="640" height="72" rx="8" class="map-band" />
            <rect x="60" y="202" width="4" height="72" rx="2" class="edge-signal" />
            <text x="80" y="230" class="map-h">instruments</text>
            <text x="80" y="254" class="map-list">dashboards · confluence · terminal</text>
          </g>

          <!-- couche 4 : analyses -->
          <g>
            <rect x="60" y="288" width="640" height="72" rx="8" class="map-band" />
            <rect x="60" y="288" width="4" height="72" rx="2" class="edge-amber" />
            <text x="80" y="316" class="map-h">analyses</text>
            <text x="80" y="340" class="map-list">journal · sujets · guides · glossaire</text>
          </g>

          <!-- couche 5 : fondations (bas) -->
          <g>
            <rect x="60" y="374" width="640" height="72" rx="8" class="map-band" />
            <rect x="60" y="374" width="4" height="72" rx="2" class="edge-amber" />
            <text x="80" y="402" class="map-h">fondations</text>
            <text x="80" y="426" class="map-list">le livre · manifeste · à propos</text>
          </g>
        </svg>
        <figcaption class="start-cap">
          Un même socle de données publiques, lu de cinq façons. Rien n’est réécrit d’un étage à l’autre.
        </figcaption>
      </figure>
    </section>

    <section class="start-section">
      <p class="mono-label glow">// les briques du site</p>
      <div class="brique-grid">
        {briques.map((b) => (
          <article class="brique">
            <h2 class="brique-h">{b.h}</h2>
            <p class="brique-d">{b.d}</p>
            <ul class="brique-list">
              {b.items.map(([href, label, ext]) => (
                <li>
                  {ext ? (
                    <a href={href} target="_blank" rel="noopener" class="brique-link">
                      {label}<span class="ext" aria-hidden="true">↗</span>
                    </a>
                  ) : (
                    <a href={href} class="brique-link">{label}</a>
                  )}
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="start-section">
      <p class="mono-label glow">// lire un chiffre sur l0g</p>
      <p class="start-p">
        La règle de lecture est la même partout. Un chiffre n’a de valeur que rattaché à sa
        source primaire, à la méthode qui le produit et aux limites qui l’encadrent. Quand
        l’un de ces trois éléments manque, le chiffre reste une opinion.
      </p>

      <figure class="start-fig">
        <svg viewBox="0 0 720 156" role="img" aria-labelledby="read-t read-d" class="start-svg">
          <title id="read-t">La chaîne de lecture d’un chiffre</title>
          <desc id="read-d">
            Un chiffre mène à sa source primaire, puis à sa méthode publiée, puis à ses limites datées.
          </desc>

          <g>
            <rect x="8" y="40" width="150" height="60" rx="8" class="step-box" />
            <text x="83" y="66" class="step-h">un chiffre</text>
            <text x="83" y="86" class="step-s">ce que vous lisez</text>
          </g>
          <path d="M164 70 h30" class="step-arrow" />
          <path d="M196 70 l-9 -5 v10 z" class="step-arrow-head" />

          <g>
            <rect x="200" y="40" width="150" height="60" rx="8" class="step-box" />
            <text x="275" y="66" class="step-h">sa source</text>
            <text x="275" y="86" class="step-s">institution, filing</text>
          </g>
          <path d="M356 70 h30" class="step-arrow" />
          <path d="M388 70 l-9 -5 v10 z" class="step-arrow-head" />

          <g>
            <rect x="392" y="40" width="150" height="60" rx="8" class="step-box" />
            <text x="467" y="66" class="step-h">sa méthode</text>
            <text x="467" y="86" class="step-s">formule publiée</text>
          </g>
          <path d="M548 70 h30" class="step-arrow" />
          <path d="M580 70 l-9 -5 v10 z" class="step-arrow-head" />

          <g>
            <rect x="584" y="40" width="128" height="60" rx="8" class="step-box step-box-end" />
            <text x="648" y="66" class="step-h">ses limites</text>
            <text x="648" y="86" class="step-s">datées, assumées</text>
          </g>
        </svg>
        <figcaption class="start-cap">
          Retirez un maillon et le chiffre perd sa valeur probante. Les pages méthodologie et preuves rendent cette chaîne visible.
        </figcaption>
      </figure>
    </section>

    <section class="start-section start-pact">
      <p class="mono-label glow">// ce que vous pouvez attendre</p>
      <div class="pact-grid">
        <div class="pact">
          <span>sources</span>
          <p>Un chiffre important pointe vers une source primaire, pas vers un agrégateur.</p>
        </div>
        <div class="pact">
          <span>méthode</span>
          <p>Quand une formule peut être publiée, elle l’est. Les seuils et les limites aussi.</p>
        </div>
        <div class="pact">
          <span>indépendance</span>
          <p>Aucun conseil en investissement. Le site expose des instruments, pas des ordres.</p>
        </div>
        <div class="pact">
          <span>hygiène</span>
          <p>Site statique, auto-hébergé, sans cookie ni tracker maison. Voir le manifeste et le rgpd.</p>
        </div>
      </div>
    </section>

    <section class="start-section start-cta">
      <p class="mono-label glow">// commencer maintenant</p>
      <div class="cta-grid">
        <a href="/manifeste/" class="cta-link">
          <span>lire</span>
          <strong>le manifeste</strong>
        </a>
        <a href="/" class="cta-link">
          <span>parcourir</span>
          <strong>le journal</strong>
        </a>
        <a href="/glossaire/" class="cta-link">
          <span>décoder</span>
          <strong>le glossaire</strong>
        </a>
        <a href="/agents/" class="cta-link">
          <span>brancher</span>
          <strong>un agent</strong>
        </a>
      </div>
    </section>
  </article>

  <style>
    .start-page { max-width: 60rem; }

    .start-hero {
      padding-bottom: 2.4rem;
      border-bottom: 1px solid var(--color-line);
    }

    .start-title {
      margin-top: 1rem;
      font-size: clamp(2rem, 4.6vw, 3.1rem);
      line-height: 1.14;
      letter-spacing: 0.02em;
      color: var(--color-bright);
    }
    .start-title span { color: var(--color-signal); }

    .start-lede {
      margin-top: 1.25rem;
      max-width: 46rem;
      border-left: 2px solid var(--color-signal);
      padding-left: 1rem;
      font-family: var(--font-read);
      font-size: clamp(1.06rem, 2vw, 1.2rem);
      line-height: 1.68;
      color: var(--color-paper);
    }

    .start-section { margin-top: 3.4rem; }

    .start-p {
      margin-top: 0.9rem;
      max-width: 46rem;
      font-family: var(--font-read);
      line-height: 1.72;
      color: var(--color-paper);
    }

    /* profils */
    .profil-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.9rem;
      margin-top: 1.1rem;
    }
    @media (min-width: 820px) {
      .profil-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    }
    .profil {
      display: flex;
      flex-direction: column;
      border: 1px solid var(--color-line);
      border-top: 2px solid color-mix(in srgb, var(--color-signal) 55%, transparent);
      border-radius: 8px;
      padding: 1rem 1.1rem;
      background: color-mix(in srgb, var(--color-surface) 36%, transparent);
    }
    .profil-k {
      font-family: var(--font-mono);
      font-size: 0.62rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--color-signal);
    }
    .profil h2 {
      margin-top: 0.6rem;
      font-family: var(--font-display);
      font-size: 1.08rem;
      line-height: 1.35;
      color: var(--color-bright);
    }
    .profil p {
      margin-top: 0.55rem;
      font-family: var(--font-read);
      font-size: 0.94rem;
      line-height: 1.6;
      color: var(--color-muted);
      flex: 1;
    }
    .profil-links {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin-top: 0.9rem;
    }
    .chip {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.02em;
      color: var(--color-signal);
      border: 1px solid color-mix(in srgb, var(--color-signal) 30%, var(--color-line));
      border-radius: 6px;
      padding: 0.2rem 0.5rem;
      background: color-mix(in srgb, var(--color-signal) 6%, transparent);
      transition: border-color 0.16s, background 0.16s;
    }
    .chip:hover {
      border-color: color-mix(in srgb, var(--color-signal) 55%, transparent);
      background: color-mix(in srgb, var(--color-signal) 12%, transparent);
    }

    /* figures */
    .start-fig {
      margin: 1.3rem 0 0;
      padding-bottom: 1.75rem;
    }
    .start-svg {
      display: block;
      width: 100%;
      height: auto;
      border: 1px solid var(--color-line);
      border-radius: 10px;
      background: color-mix(in srgb, var(--color-surface) 40%, transparent);
      padding: 0.6rem;
    }
    .start-cap {
      margin-top: 0.7rem;
      font-family: var(--font-mono);
      font-size: 0.72rem;
      line-height: 1.5;
      color: var(--color-muted);
    }

    /* svg carte */
    .map-band { fill: color-mix(in srgb, var(--color-surface) 70%, transparent); stroke: var(--color-line); stroke-width: 1; }
    .map-h { fill: var(--color-bright); font-family: var(--font-display); font-size: 17px; letter-spacing: 0.02em; }
    .map-list { fill: var(--color-muted); font-family: var(--font-mono); font-size: 13px; }
    .map-arrow { stroke: color-mix(in srgb, var(--color-signal) 70%, transparent); stroke-width: 2; }
    .map-arrow-head { fill: var(--color-signal); }
    .map-axis { fill: var(--color-signal); font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; }
    .edge-signal { fill: var(--color-signal); }
    .edge-rose { fill: var(--color-accent); }
    .edge-amber { fill: var(--color-amber); }

    /* svg chaîne de lecture */
    .step-box { fill: color-mix(in srgb, var(--color-surface) 70%, transparent); stroke: var(--color-line); stroke-width: 1; }
    .step-box-end { stroke: color-mix(in srgb, var(--color-accent) 45%, var(--color-line)); }
    .step-h { fill: var(--color-bright); font-family: var(--font-display); font-size: 15px; text-anchor: middle; }
    .step-s { fill: var(--color-muted); font-family: var(--font-mono); font-size: 11px; text-anchor: middle; }
    .step-arrow { stroke: color-mix(in srgb, var(--color-signal) 70%, transparent); stroke-width: 2; }
    .step-arrow-head { fill: var(--color-signal); }

    /* briques */
    .brique-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.9rem;
      margin-top: 1.1rem;
    }
    @media (min-width: 640px) {
      .brique-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    @media (min-width: 960px) {
      .brique-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    }
    .brique {
      border: 1px solid var(--color-line);
      border-radius: 8px;
      padding: 1rem 1.1rem;
      background: color-mix(in srgb, var(--color-surface) 34%, transparent);
    }
    .brique-h {
      font-family: var(--font-mono);
      font-size: 0.66rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--color-signal);
    }
    .brique-d {
      margin-top: 0.5rem;
      font-family: var(--font-read);
      font-size: 0.9rem;
      line-height: 1.55;
      color: var(--color-muted);
    }
    .brique-list {
      display: grid;
      gap: 0.35rem;
      margin-top: 0.9rem;
      padding-top: 0.8rem;
      border-top: 1px solid var(--color-line);
    }
    .brique-link {
      font-family: var(--font-mono);
      font-size: 0.86rem;
      color: var(--color-paper);
      transition: color 0.15s;
    }
    .brique-link:hover { color: var(--color-signal); }
    .ext { margin-left: 0.3rem; color: var(--color-muted); font-size: 0.78rem; }

    /* pacte */
    .pact-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.75rem;
      margin-top: 1.1rem;
    }
    @media (min-width: 720px) {
      .pact-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    .pact {
      border: 1px solid var(--color-line);
      border-left: 2px solid color-mix(in srgb, var(--color-signal) 50%, transparent);
      border-radius: 8px;
      padding: 0.9rem 1rem;
      background: color-mix(in srgb, var(--color-surface) 30%, transparent);
    }
    .pact span {
      font-family: var(--font-mono);
      font-size: 0.62rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-signal);
    }
    .pact p {
      margin-top: 0.4rem;
      font-family: var(--font-read);
      font-size: 0.92rem;
      line-height: 1.6;
      color: var(--color-paper);
    }

    /* cta */
    .start-cta {
      border-top: 1px solid var(--color-line);
      padding-top: 1.7rem;
    }
    .cta-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.75rem;
      margin-top: 1rem;
    }
    @media (min-width: 720px) {
      .cta-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    }
    .cta-link {
      display: flex;
      min-height: 5.4rem;
      flex-direction: column;
      justify-content: space-between;
      border: 1px solid var(--color-line);
      border-radius: 8px;
      padding: 0.9rem;
      background: color-mix(in srgb, var(--color-signal) 5%, transparent);
      transition: border-color 0.16s, background 0.16s, transform 0.16s;
    }
    .cta-link span {
      font-family: var(--font-mono);
      font-size: 0.62rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-signal);
    }
    .cta-link strong {
      margin-top: 0.6rem;
      color: var(--color-paper);
      font-size: 0.95rem;
      line-height: 1.3;
    }
    .cta-link:hover {
      border-color: color-mix(in srgb, var(--color-signal) 45%, transparent);
      background: color-mix(in srgb, var(--color-signal) 9%, transparent);
      transform: translateY(-1px);
    }
    @media (prefers-reduced-motion: reduce) {
      .cta-link { transition: border-color 0.16s, background 0.16s; }
      .cta-link:hover { transform: none; }
    }
  </style>
</BaseLayout>
