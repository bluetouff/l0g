---
import BaseLayout from '../../layouts/BaseLayout.astro';

// --- Structured data : l'API publique decrite comme jeu de donnees citable ---
const ASITE = (Astro.site?.toString() ?? 'https://l0g.fr/').replace(/\/$/, '');
const datasetLd = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  '@id': `${ASITE}/api/#dataset`,
  name: 'Indices de risque l0g',
  description:
    "Indices de risque consolides de l0g (US Macro, EU Macro, Yen Carry, Energie), snapshot canonique Dette US et synthese de confluence 13FLOW, exposes en JSON, avec un flux Atom des changements de niveau.",
  url: `${ASITE}/api/`,
  inLanguage: 'fr',
  license: 'https://creativecommons.org/licenses/by/4.0/',
  isAccessibleForFree: true,
  creator: { '@id': `${ASITE}/#org` },
  keywords: ['risque macro', 'yen carry', 'energie', 'dette US', 'confluence 13F', 'indices de risque'],
  distribution: [
    {
      '@type': 'DataDownload',
      encodingFormat: 'application/json',
      contentUrl: `${ASITE}/api/v1/risk.json`,
    },
    {
      '@type': 'DataDownload',
      encodingFormat: 'application/json',
      contentUrl: `${ASITE}/api/v1/debt-risk.json`,
    },
    {
      '@type': 'DataDownload',
      encodingFormat: 'application/json',
      contentUrl: `${ASITE}/agents.json`,
    },
    {
      '@type': 'DataDownload',
      encodingFormat: 'application/json',
      contentUrl: `${ASITE}/openapi.json`,
    },
    {
      '@type': 'DataDownload',
      encodingFormat: 'application/json',
      contentUrl: `${ASITE}/api/v1/claims.json`,
    },
    {
      '@type': 'DataDownload',
      encodingFormat: 'application/json',
      contentUrl: `${ASITE}/api/v1/evidence-graph.json`,
    },
    {
      '@type': 'DataDownload',
      encodingFormat: 'application/x-ndjson',
      contentUrl: `${ASITE}/api/v1/catalog.ndjson`,
    },
    {
      '@type': 'DataDownload',
      encodingFormat: 'application/x-ndjson',
      contentUrl: `${ASITE}/api/v1/claims.ndjson`,
    },
    {
      '@type': 'DataDownload',
      encodingFormat: 'application/json',
      contentUrl: `${ASITE}/api/v1/integrity.json`,
    },
    {
      '@type': 'DataDownload',
      encodingFormat: 'application/json',
      contentUrl: `${ASITE}/api/v1/changes.json`,
    },
    {
      '@type': 'DataDownload',
      encodingFormat: 'application/atom+xml',
      contentUrl: `${ASITE}/api/v1/risk.xml`,
    },
  ],
};
---

<BaseLayout
  title="API publique"
  description="API publique l0g : signaux de risque (US Macro, EU Macro, Yen Carry, Énergie), snapshot Dette US et synthèse 13FLOW au format JSON, plus un flux Atom des changements de niveau. CORS ouvert, licence CC BY 4.0."
  sidebar={false}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(datasetLd)} />
  <section data-pagefind-ignore>
    <p class="mono-label glow" style="color: var(--color-signal)">// api</p>
    <h1 class="mt-3 font-display text-4xl leading-none tracking-wider glow sm:text-5xl">
      API <span style="color: var(--color-accent)">publique</span>
    </h1>
    <p class="mt-4 max-w-2xl text-paper">
      Les signaux de risque l0g sont exposés en JSON, avec un endpoint canonique séparé pour
      Dette US, et leurs changements de niveau en flux Atom. Les scores 0-100 sont normalisés par instrument : ils ne forment
      pas un indice global ni une probabilité comparable. De quoi les intégrer dans vos propres dashboards de veille, vos bots
      d'alerte (Matrix, Signal, Telegram) ou un SIEM. CORS ouvert, aucune clé, aucune
      authentification, aucun pistage.
    </p>

    <div id="api-status" class="api-status" hidden>
      <span class="api-dot" aria-hidden="true"></span>
      <span id="api-status-text"></span>
    </div>
  </section>

  <section class="mt-10 space-y-8" data-pagefind-ignore>
    <div>
      <h2 class="mono-label glow" style="color: var(--color-signal)">// endpoints</h2>
      <p class="mt-3 text-paper">
        Les points d'accès publics, sans clé ni authentification :
      </p>
      <div class="ep-list mt-4">
        <a class="ep card" href="/agents.json" target="_blank" rel="noopener" style="--t: var(--color-signal)">
          <span class="ep-method">GET</span>
          <code class="ep-path">/agents.json</code>
          <span class="ep-type">JSON</span>
          <span class="ep-desc">Manifeste de découverte pour agents : capacités, endpoints, règles d'usage et politique de preuve.</span>
        </a>
        <a class="ep card" href="/openapi.json" target="_blank" rel="noopener" style="--t: var(--color-accent)">
          <span class="ep-method">GET</span>
          <code class="ep-path">/openapi.json</code>
          <span class="ep-type">OPENAPI</span>
          <span class="ep-desc">Contrat OpenAPI 3.1 des endpoints M2M de l0g.</span>
        </a>
        <a class="ep card" href="/api/v1/claims.json" target="_blank" rel="noopener" style="--t: #7aa2f7">
          <span class="ep-method">GET</span>
          <code class="ep-path">/api/v1/claims.json</code>
          <span class="ep-type">JSON</span>
          <span class="ep-desc">Graphe affirmation-source : claims typées, références cliquables, datées quand détectable.</span>
        </a>
        <a class="ep card" href="/api/v1/evidence-graph.json" target="_blank" rel="noopener" style="--t: var(--color-signal)">
          <span class="ep-method">GET</span>
          <code class="ep-path">/api/v1/evidence-graph.json</code>
          <span class="ep-type">JSON</span>
          <span class="ep-desc">Evidence graph : articles, claims, références, hôtes, sources primaires et datasets en nœuds/arêtes.</span>
        </a>
        <a class="ep card" href="/api/v1/catalog.ndjson" target="_blank" rel="noopener" style="--t: var(--color-accent)">
          <span class="ep-method">GET</span>
          <code class="ep-path">/api/v1/catalog.ndjson</code>
          <span class="ep-type">NDJSON</span>
          <span class="ep-desc">Catalogue complet ligne à ligne pour ingestion streaming, RAG ou indexation incrémentale.</span>
        </a>
        <a class="ep card" href="/api/v1/claims.ndjson" target="_blank" rel="noopener" style="--t: #7aa2f7">
          <span class="ep-method">GET</span>
          <code class="ep-path">/api/v1/claims.ndjson</code>
          <span class="ep-type">NDJSON</span>
          <span class="ep-desc">Claims typées en flux NDJSON, avec références embarquées.</span>
        </a>
        <a class="ep card" href="/api/v1/evidence-graph.ndjson" target="_blank" rel="noopener" style="--t: var(--color-signal)">
          <span class="ep-method">GET</span>
          <code class="ep-path">/api/v1/evidence-graph.ndjson</code>
          <span class="ep-type">NDJSON</span>
          <span class="ep-desc">Evidence graph ligne à ligne : nœuds puis arêtes.</span>
        </a>
        <a class="ep card" href="/api/v1/sources.json" target="_blank" rel="noopener" style="--t: var(--color-amber)">
          <span class="ep-method">GET</span>
          <code class="ep-path">/api/v1/sources.json</code>
          <span class="ep-type">JSON</span>
          <span class="ep-desc">Sources primaires et hôtes effectivement cités par le corpus.</span>
        </a>
        <a class="ep card" href="/api/v1/freshness.json" target="_blank" rel="noopener" style="--t: var(--color-signal)">
          <span class="ep-method">GET</span>
          <code class="ep-path">/api/v1/freshness.json</code>
          <span class="ep-type">JSON</span>
          <span class="ep-desc">Fraîcheur du corpus et des signaux : dates utiles, expiration et couverture.</span>
        </a>
        <a class="ep card" href="/api/v1/integrity.json" target="_blank" rel="noopener" style="--t: #7aa2f7">
          <span class="ep-method">GET</span>
          <code class="ep-path">/api/v1/integrity.json</code>
          <span class="ep-type">JSON</span>
          <span class="ep-desc">Empreintes SHA-256 canoniques des surfaces Agent Surface, pour vérifier un snapshot.</span>
        </a>
        <a class="ep card" href="/api/v1/changes.json" target="_blank" rel="noopener" style="--t: var(--color-amber)">
          <span class="ep-method">GET</span>
          <code class="ep-path">/api/v1/changes.json</code>
          <span class="ep-type">JSON</span>
          <span class="ep-desc">Changefeed machine : versions, hashes courants, statut de diff et changements sémantiques.</span>
        </a>
        <a class="ep card" href="/api/v1/changes.ndjson" target="_blank" rel="noopener" style="--t: var(--color-amber)">
          <span class="ep-method">GET</span>
          <code class="ep-path">/api/v1/changes.ndjson</code>
          <span class="ep-type">NDJSON</span>
          <span class="ep-desc">Changefeed en flux ligne à ligne, avec métadonnées de version pour watchers.</span>
        </a>
        <a class="ep card" href="/api/v1/catalog.json" target="_blank" rel="noopener" style="--t: var(--color-accent)">
          <span class="ep-method">GET</span>
          <code class="ep-path">/api/v1/catalog.json</code>
          <span class="ep-type">JSON</span>
          <span class="ep-desc">Catalogue machine complet : articles, guides, sources, glossaire et protocole.</span>
        </a>
        <a class="ep card" href="/api/v1/risk.json" target="_blank" rel="noopener" style="--t: var(--color-signal)">
          <span class="ep-method">GET</span>
          <code class="ep-path">/api/v1/risk.json</code>
          <span class="ep-type">JSON</span>
          <span class="ep-desc">État courant des dashboards historiques et synthèse confluence.</span>
        </a>
        <a class="ep card" href="/api/v1/debt-risk.json" target="_blank" rel="noopener" style="--t: #7aa2f7">
          <span class="ep-method">GET</span>
          <code class="ep-path">/api/v1/debt-risk.json</code>
          <span class="ep-type">JSON</span>
          <span class="ep-desc">Snapshot canonique Dette US importé depuis Debt Risk Radar latest.json : score, buckets, sources et top signaux.</span>
        </a>
        <a class="ep card" href="/api/v1/risk.xml" target="_blank" rel="noopener" style="--t: var(--color-accent)">
          <span class="ep-method">GET</span>
          <code class="ep-path">/api/v1/risk.xml</code>
          <span class="ep-type">Atom</span>
          <span class="ep-desc">Flux des changements de niveau, pour bots d'alerte et SIEM.</span>
        </a>
        <a class="ep card" href="/api/v1/history.csv" target="_blank" rel="noopener" style="--t: var(--color-amber)">
          <span class="ep-method">GET</span>
          <code class="ep-path">/api/v1/history.csv</code>
          <span class="ep-type">CSV</span>
          <span class="ep-desc">Historique complet à plat, prêt pour pandas / R / Excel.</span>
        </a>
        <a class="ep card" href="/api/v1/history.ndjson" target="_blank" rel="noopener" style="--t: var(--color-amber)">
          <span class="ep-method">GET</span>
          <code class="ep-path">/api/v1/history.ndjson</code>
          <span class="ep-type">NDJSON</span>
          <span class="ep-desc">Historique, une ligne JSON par snapshot.</span>
        </a>
        <a class="ep card" href="/api/v1/history/index.json" target="_blank" rel="noopener" style="--t: #7aa2f7">
          <span class="ep-method">GET</span>
          <code class="ep-path">/api/v1/history/index.json</code>
          <span class="ep-type">JSON</span>
          <span class="ep-desc">Manifest : couverture, colonnes, nombre de lignes.</span>
        </a>
      </div>
    </div>

    <div>
      <h2 class="mono-label glow" style="color: var(--color-signal)">// exemple</h2>
      <div class="codeblock">
        <button class="copy-btn" type="button" aria-label="Copier le code">copier</button>
        <pre class="apipre"><code>curl -s https://l0g.fr/api/v1/risk.json</code></pre>
      </div>
      <div class="codeblock">
        <button class="copy-btn" type="button" aria-label="Copier le code">copier</button>
        <pre class="apipre"><code>curl -s https://l0g.fr/api/v1/debt-risk.json</code></pre>
      </div>
      <div class="codeblock">
        <button class="copy-btn" type="button" aria-label="Copier le code">copier</button>
        <pre class="apipre"><code>{`{
  "version": "1",
  "generated": "2026-06-18T08:00:00Z",
  "snapshot": "2026-06-16T08:16:13Z",
  "indices": {
    "us":      { "value": 58, "scale": 100, "level": "Élevé",  "tone": "elevated", "label": "US Macro Dashboard", "source": "https://us.l0g.fr" },
    "eu":      { "value": 47, "scale": 100, "level": "Modéré", "tone": "moderate", "label": "EU Macro Dashboard", "source": "https://euro.l0g.fr" },
    "yen":     { "value": 41, "scale": 100, "level": "Modéré", "tone": "moderate", "label": "Yen Carry Monitor",  "source": "https://yct.l0g.fr" },
    "energie": { "value": 58, "scale": 100, "level": "Tendu",  "tone": "elevated", "label": "Energie Monitor",    "source": "https://energie.l0g.fr" }
  },
  "scaleCaveat": { "title": "Normalisation d’affichage, pas indice unique" },
  "precisionGuard": { "title": "Illusion de précision" },
  "confluence": { "updated": "...", "count": 15, "conviction": 1, "top": { "ticker": "TSM", "score": 90, "quadrant": "divergent" } },
  "license": "CC BY 4.0", "attribution": "l0g.fr"
}`}</code></pre>
      </div>
    </div>

    <div>
      <h2 class="mono-label glow" style="color: var(--color-signal)">// historique &amp; backtest</h2>
      <p class="mt-3 text-paper">
        L'historique est <strong class="text-bright">point-in-time</strong> : chaque snapshot publié
        est figé, jamais révisé a posteriori. Vous backtestez sur ce qui était réellement affiché à
        l'instant T, sans look-ahead bias.
      </p>
      <div class="codeblock">
        <button class="copy-btn" type="button" aria-label="Copier le code">copier</button>
        <pre class="apipre"><code>{`import pandas as pd
df = pd.read_csv("https://l0g.fr/api/v1/history.csv", parse_dates=["snapshot"])
df = df.set_index("snapshot").sort_index()`}</code></pre>
      </div>
      <p class="mt-3 text-muted">
        Les colonnes <code class="apic">conf_*</code> (synthèse 13FLOW) sont vides sur les premiers
        points, antérieurs à l'intégration de la confluence dans le snapshot. Chaque nouveau
        sous-signal démarre à sa date d'intégration.
      </p>
    </div>

    <div>
      <h2 class="mono-label glow" style="color: var(--color-signal)">// champs</h2>
      <ul class="api-list mt-3">
        <li><code class="apic">indices.&lt;clé&gt;.value</code> — valeur du signal (0 à <code class="apic">scale</code>, généralement 100), normalisée par instrument.</li>
        <li><code class="apic">/api/v1/debt-risk.json</code> — source canonique du signal Dette US : <code class="apic">signal.value</code> est l'arrondi de <code class="apic">provenance.scoreRaw</code>, lui-même repris de <code class="apic">https://debt.l0g.fr/latest.json</code>. Les clients doivent utiliser cet endpoint pour la dette, même si certains snapshots consolidés exposent aussi <code class="apic">indices.debt</code>.</li>
        <li><code class="apic">scaleCaveat</code> et <code class="apic">precisionGuard</code> — limites de lecture : normalisation d’affichage, couverture, fraîcheur, incertitude et reproductibilité.</li>
        <li><code class="apic">level</code> — libellé lisible (Détendu, Modéré, Élevé/Tendu, Crise).</li>
        <li><code class="apic">tone</code> — code machine : <code class="apic">calm</code>, <code class="apic">moderate</code>, <code class="apic">elevated</code>, <code class="apic">crisis</code>.</li>
        <li><code class="apic">snapshot</code> — horodatage (ISO 8601 UTC) des données ; <code class="apic">generated</code> — date de génération du fichier.</li>
        <li><code class="apic">confluence</code> — synthèse 13FLOW : nombre de titres, quadrant conviction, meilleur score.</li>
      </ul>
      <p class="mt-3 text-muted">
        Pas d'« indice global » : on n'expose que les sous-signaux réellement mesurés par chaque
        outil. Agréger les signaux en un seul chiffre serait un nombre dérivé non mesuré — on ne le
        fait pas.
      </p>
    </div>

    <div>
      <h2 class="mono-label glow" style="color: var(--color-signal)">// notes</h2>
      <ul class="api-list mt-3">
        <li><strong class="text-bright">CORS</strong> : <code class="apic">Access-Control-Allow-Origin: *</code> — consommable depuis n'importe quel domaine.</li>
        <li><strong class="text-bright">Cadence</strong> : régénéré à chaque snapshot des outils. Ce n'est pas du temps réel strict ; fiez-vous au champ <code class="apic">snapshot</code>.</li>
        <li><strong class="text-bright">Versionnement</strong> : la forme de <code class="apic">/v1/</code> reste stable ; toute rupture passera par <code class="apic">/v2/</code>.</li>
        <li><strong class="text-bright">Licence</strong> : CC BY 4.0. Réutilisation libre avec attribution à l0g.fr.</li>
      </ul>
    </div>
  </section>

  <p class="mt-8 text-xs" style="color: var(--color-accent)" data-pagefind-ignore>
    Best-effort. Ceci n'est pas un conseil en investissement.
  </p>

  <style>
    .apic {
      font-family: var(--font-mono);
      font-size: 0.86em;
      color: var(--color-signal);
      background: color-mix(in srgb, var(--color-signal) 10%, transparent);
      padding: 0.05rem 0.35rem;
      border-radius: 5px;
    }
    .api-list { display: flex; flex-direction: column; gap: 0.5rem; }
    .api-list li { padding-left: 1rem; position: relative; color: var(--color-paper); }
    .api-list li::before { content: '·'; position: absolute; left: 0; color: var(--color-signal); }
    .apipre {
      margin-top: 0;
      padding: 1rem 1.1rem;
      border: 1px solid var(--color-line);
      border-radius: 12px;
      background: var(--color-surface);
      overflow-x: auto;
      font-family: var(--font-mono);
      font-size: 0.82rem;
      line-height: 1.5;
      color: var(--color-paper);
    }

    /* Ligne d'état live (alimentée en same-origin) */
    .api-status {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 1.25rem;
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.05em;
      color: var(--color-muted);
      border: 1px solid var(--color-line);
      border-radius: 999px;
      padding: 0.3rem 0.85rem;
    }
    .api-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--color-signal);
      box-shadow: 0 0 10px var(--color-signal);
    }
    @media (prefers-reduced-motion: no-preference) {
      .api-dot { animation: apipulse 2.4s ease-in-out infinite; }
    }
    @keyframes apipulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

    /* Cartes endpoints */
    .ep-list { display: flex; flex-direction: column; gap: 0.6rem; }
    .ep {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 0.7rem;
      padding: 0.7rem 0.9rem;
    }
    .ep-method {
      font-family: var(--font-mono); font-size: 0.66rem; font-weight: 700; letter-spacing: 0.08em;
      color: var(--color-ink); background: var(--color-signal);
      border-radius: 5px; padding: 2px 7px;
    }
    .ep-path { font-family: var(--font-mono); font-size: 0.92rem; color: var(--color-bright); }
    .ep-type {
      font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--t);
      border: 1px solid color-mix(in srgb, var(--t) 45%, transparent);
      background: color-mix(in srgb, var(--t) 10%, transparent);
      border-radius: 5px; padding: 1px 6px;
    }
    .ep-desc { grid-column: 1 / -1; color: var(--color-muted); font-size: 0.86rem; }
    .ep:hover .ep-path { color: var(--color-signal); }

    /* Bloc de code + bouton copier */
    .codeblock { position: relative; margin-top: 0.75rem; }
    .copy-btn {
      position: absolute; top: 0.5rem; right: 0.5rem;
      font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.05em;
      color: var(--color-muted);
      background: color-mix(in srgb, var(--color-ink) 65%, transparent);
      border: 1px solid var(--color-line); border-radius: 6px;
      padding: 2px 8px; cursor: pointer;
      opacity: 0.55; transition: opacity 0.15s, color 0.15s, border-color 0.15s;
    }
    .codeblock:hover .copy-btn, .copy-btn:focus-visible { opacity: 1; }
    .copy-btn:hover, .copy-btn.copied {
      color: var(--color-signal);
      border-color: color-mix(in srgb, var(--color-signal) 50%, transparent);
    }
  </style>

  <script is:inline>
    (() => {
      // Boutons « copier »
      document.querySelectorAll('.copy-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const block = btn.closest('.codeblock');
          const code = block && block.querySelector('code');
          if (!code) return;
          try {
            await navigator.clipboard.writeText(code.textContent.trim());
            const old = btn.textContent;
            btn.textContent = 'copié';
            btn.classList.add('copied');
            setTimeout(() => { btn.textContent = old; btn.classList.remove('copied'); }, 1200);
          } catch (e) { /* presse-papier indisponible */ }
        });
      });

      // Ligne d'état live, alimentée par l'API elle-même (same-origin)
      const box = document.getElementById('api-status');
      const txt = document.getElementById('api-status-text');
      if (!box || !txt) return;
      const fmt = (iso) => {
        try {
          return new Intl.DateTimeFormat('fr-FR', {
            day: 'numeric', month: 'short', year: 'numeric',
            hour: '2-digit', minute: '2-digit', timeZone: 'UTC',
          }).format(new Date(iso));
        } catch (e) { return iso; }
      };
      (async () => {
        try {
          const r = await fetch('/api/v1/risk.json', { cache: 'no-store' });
          if (!r.ok) return;
          const data = await r.json();
          const n = data.indices ? Object.keys(data.indices).length : 0;
          let line = 'live · snapshot ' + fmt(data.snapshot) + ' UTC · ' + n + ' indices';
          try {
            const h = await fetch('/api/v1/history/index.json', { cache: 'no-store' });
            if (h.ok) {
              const m = await h.json();
              if (m && m.rows) {
                const since = (m.coverage && m.coverage.first) ? fmt(m.coverage.first) : null;
                line += ' · historique ' + m.rows + ' points' + (since ? ' depuis le ' + since : '');
              }
            }
          } catch (e) { /* historique indisponible */ }
          txt.textContent = line;
          box.hidden = false;
        } catch (e) { /* hors-ligne ou preview local : on laisse caché */ }
      })();
    })();
  </script>
</BaseLayout>
