---
import BaseLayout from '../layouts/BaseLayout.astro';
import { serializeInlineScriptData } from '../lib/security.ts';

const title = 'Visite guidée';
const description =
  "Un onboarding visuel et doux pour comprendre l0g : lire les analyses, utiliser les dashboards, vérifier les sources et réutiliser les données sans être spécialiste de la finance.";

const intents = [
  {
    eyebrow: 'comprendre',
    title: 'Je bloque sur un mot',
    text: 'Passe par le glossaire : définitions courtes, notions voisines et liens vers les analyses reliées.',
    href: '/glossaire/',
    cta: 'ouvrir le glossaire',
  },
  {
    eyebrow: 'lire',
    title: 'Je veux une analyse',
    text: 'Commence par le journal ou les sujets : tu lis un dossier sans devoir connaître toute la tuyauterie.',
    href: '/sujets/',
    cta: 'voir les sujets',
  },
  {
    eyebrow: 'surveiller',
    title: 'Je veux voir un risque',
    text: 'Les dashboards servent d’instruments : ils signalent une tension, une détente ou une anomalie à creuser.',
    href: '/dashboards/',
    cta: 'voir les dashboards',
  },
  {
    eyebrow: 'vérifier',
    title: 'Je veux contrôler un chiffre',
    text: 'Remonte la chaîne : source primaire, méthode, limite, preuve et date de publication.',
    href: '/preuves/',
    cta: 'voir les preuves',
  },
  {
    eyebrow: 'changement',
    title: 'Je veux savoir ce qui bouge',
    text: 'Risk Diff résume ce qui a changé dans les signaux, les sources et les claims sur 1, 7 ou 30 jours.',
    href: '/risk-diff/',
    cta: 'ouvrir risk diff',
  },
  {
    eyebrow: 'machine',
    title: 'Je veux brancher une IA',
    text: 'Agents, MCP, API et llms.txt exposent le même corpus pour des outils, sans clé et sans pistage.',
    href: '/agents/',
    cta: 'voir agents',
  },
];

const tourSteps = [
  {
    n: '01',
    verb: 'Situer',
    title: 'Comprendre le contrat de lecture',
    text: 'l0g ne vend pas une certitude. Le site cartographie des signaux de risque, publie ses limites et sépare les faits des hypothèses.',
    href: '/manifeste/',
    cta: 'manifeste',
  },
  {
    n: '02',
    verb: 'Décoder',
    title: 'Traduire les mots techniques',
    text: 'Le glossaire sert de rampe : chaque terme devient une porte vers des articles, guides, sources et concepts voisins.',
    href: '/glossaire/',
    cta: 'glossaire',
  },
  {
    n: '03',
    verb: 'Lire',
    title: 'Entrer par les analyses',
    text: 'Le journal suit les narratifs économiques dans le temps. Les sujets regroupent les fils longs pour éviter l’effet flux infini.',
    href: '/sujets/',
    cta: 'sujets',
  },
  {
    n: '04',
    verb: 'Observer',
    title: 'Utiliser les dashboards comme des instruments',
    text: 'Un score 0-100 facilite la lecture, mais deux scores ne mesurent pas forcément le même risque ni le même horizon.',
    href: '/dashboards/',
    cta: 'dashboards',
  },
  {
    n: '05',
    verb: 'Croiser',
    title: 'Repérer les confluences',
    text: 'Confluence 13F × Form 4 ne donne pas une recommandation. Elle signale une zone où deux populations d’acteurs méritent examen.',
    href: '/confluence/',
    cta: 'confluence',
  },
  {
    n: '06',
    verb: 'Vérifier',
    title: 'Revenir aux preuves',
    text: 'Méthodologie, sources, preuves, backtests et Black Box permettent de comprendre d’où vient un signal et ce qu’il ne dit pas.',
    href: '/methodologie/',
    cta: 'méthode',
  },
  {
    n: '07',
    verb: 'Réutiliser',
    title: 'Passer du site au corpus machine',
    text: 'Données, API, MCP, agents et llms.txt exposent les contenus pour qu’un humain ou un outil puisse citer, contrôler et rejouer.',
    href: '/donnees/',
    cta: 'données',
  },
];

const featureGroups = [
  {
    name: 'comprendre',
    hint: 'La rampe pour ne pas se sentir exclu.',
    features: [
      {
        title: 'Démarrer',
        href: '/demarrer/',
        use: 'La carte générale du projet.',
        look: 'Les profils lecteur, analyste, machine et les grandes couches.',
        avoid: 'Le lire comme une documentation exhaustive.',
      },
      {
        title: 'Glossaire',
        href: '/glossaire/',
        use: 'Le dictionnaire vivant du site.',
        look: 'Définition, concepts voisins, analyses reliées, sources.',
        avoid: 'Croire qu’un mot financier n’a qu’un seul sens.',
      },
      {
        title: 'Guides',
        href: '/guides/',
        use: 'Les fiches longues pour apprendre une notion durable.',
        look: 'Méthode de lecture, source primaire, limites.',
        avoid: 'Les confondre avec de l’actualité chaude.',
      },
      {
        title: 'Recherche',
        href: '/recherche/',
        use: 'Retrouver un terme, une page ou un article.',
        look: 'Les résultats issus du site, indexés localement.',
        avoid: 'Chercher un ticker comme dans une plateforme de trading.',
      },
    ],
  },
  {
    name: 'lire',
    hint: 'Les entrées éditoriales.',
    features: [
      {
        title: 'Journal',
        href: '/',
        use: 'Le flux des analyses publiées.',
        look: 'Date, fraîcheur, tags, thèse, sources.',
        avoid: 'Le lire comme un fil de conseils d’investissement.',
      },
      {
        title: 'Sujets',
        href: '/sujets/',
        use: 'Les dossiers thématiques suivis dans la durée.',
        look: 'Macro, énergie, crédit privé, crypto, géopolitique.',
        avoid: 'Se perdre dans le flux au lieu de suivre un fil.',
      },
      {
        title: 'Sources primaires',
        href: '/sources/',
        use: 'Comprendre d’où viennent les données importantes.',
        look: 'Institutions, filings, séries, fréquences.',
        avoid: 'Traiter un résumé comme une preuve.',
      },
    ],
  },
  {
    name: 'surveiller',
    hint: 'Les instruments de monitoring.',
    features: [
      {
        title: 'Dashboards',
        href: '/dashboards/',
        use: 'La porte d’entrée vers les moniteurs de risque.',
        look: 'Score, date, fréquence, méthode et source.',
        avoid: 'Comparer deux scores 0-100 comme s’ils mesuraient la même chose.',
      },
      {
        title: 'US Macro',
        href: 'https://us.l0g.fr/',
        use: 'Suivre le risque macro américain.',
        look: 'Croissance, inflation, emploi, conditions financières.',
        avoid: 'Le confondre avec une prévision de PIB.',
      },
      {
        title: 'EU Macro',
        href: 'https://euro.l0g.fr/',
        use: 'Suivre la zone euro.',
        look: 'Activité, chômage, spreads, conditions financières.',
        avoid: 'Comparer directement avec le dashboard US sans lire la méthode.',
      },
      {
        title: 'Yen Carry',
        href: 'https://yct.l0g.fr/',
        use: 'Lire le risque de débouclage autour du yen.',
        look: 'Positionnement, changes, stress, carry.',
        avoid: 'Le lire comme un signal de change isolé.',
      },
      {
        title: 'Énergie',
        href: 'https://energie.l0g.fr/',
        use: 'Suivre le stress pétrole, gaz, électricité.',
        look: 'Prix, stocks, tensions physiques, volatilité.',
        avoid: 'Réduire l’énergie au seul prix du baril.',
      },
      {
        title: 'Debt Risk',
        href: 'https://debt.l0g.fr/',
        use: 'Observer la tension sur dette, taux et spreads.',
        look: 'Dette souveraine, charge d’intérêt, crédit, refinancement.',
        avoid: 'Confondre dette élevée et crise immédiate.',
      },
      {
        title: 'Orbit',
        href: 'https://orbit.l0g.fr/',
        use: 'Lire la heatmap crypto temps réel.',
        look: 'Mouvements, anomalies, concentration, décrochages.',
        avoid: 'Confondre volatilité instantanée et thèse fondamentale.',
      },
    ],
  },
  {
    name: 'vérifier',
    hint: 'La couche anti-magie noire.',
    features: [
      {
        title: 'Méthodologie',
        href: '/methodologie/',
        use: 'Comprendre comment les signaux sont construits.',
        look: 'Question couverte, formule, sources, limites.',
        avoid: 'Croire qu’un score est objectif parce qu’il est chiffré.',
      },
      {
        title: 'Preuves',
        href: '/preuves/',
        use: 'Contrôler les fichiers, snapshots et surfaces publiées.',
        look: 'Fraîcheur, chemins, artefacts, intégrité.',
        avoid: 'Oublier la date d’un snapshot.',
      },
      {
        title: 'Risk Diff',
        href: '/risk-diff/',
        use: 'Voir ce qui a changé récemment.',
        look: 'Différences 1 jour, 7 jours, 30 jours.',
        avoid: 'Le lire comme une prédiction.',
      },
      {
        title: 'Black Box',
        href: '/black-box/',
        use: 'Rejouer ce que l0g savait à une date donnée.',
        look: 'Scores, sources, hashes, méthode, signaux déclenchés.',
        avoid: 'Reconstruire le passé avec les données d’aujourd’hui.',
      },
      {
        title: 'Backtests',
        href: '/backtests/',
        use: 'Tester les signaux sur historique publié.',
        look: 'Fenêtre, hypothèse, biais, limites.',
        avoid: 'Prendre un backtest pour une garantie.',
      },
    ],
  },
  {
    name: 'réutiliser',
    hint: 'La surface pour outils, agents et développeurs.',
    features: [
      {
        title: 'Données',
        href: '/donnees/',
        use: 'Trouver les fichiers publics réutilisables.',
        look: 'JSON, CSV, NDJSON, catalogues, limites.',
        avoid: 'Ignorer la fraîcheur ou la licence.',
      },
      {
        title: 'API',
        href: '/api/',
        use: 'Accéder au corpus en lecture machine.',
        look: 'Claims, evidence graph, snapshots, endpoints.',
        avoid: 'Inventer une donnée absente de l’API.',
      },
      {
        title: 'Agents',
        href: '/agents/',
        use: 'Guider une IA pour lire l0g correctement.',
        look: 'Ordre recommandé : fraîcheur, catalogue, preuves, citations.',
        avoid: 'Demander une synthèse sans exiger les sources.',
      },
      {
        title: 'MCP',
        href: '/mcp/',
        use: 'Brancher des outils IA sur les surfaces publiques.',
        look: 'Tools read-only, catalogues, changefeed, intégrité.',
        avoid: 'Confondre interface outil et vérité automatique.',
      },
    ],
  },
];

const quickIndex = [
  {
    group: 'privacy first',
    items: [
      ['RGPD', '/rgpd/', 'Traitements limités, mesure locale, aucun cookie et aucune ressource tierce chargée automatiquement.'],
      ['Statut', '/status/', 'État vérifiable du build, des données, des endpoints et de l’hygiène front.'],
      ['Preuves', '/preuves/', 'Fichiers, contrats et contrôles qui rendent les garanties auditables.'],
      ['Manifeste', '/manifeste/', 'Refus de la capture de l’attention et dépendances navigateur réduites au strict nécessaire.'],
    ],
  },
  {
    group: 'méthodes par instrument',
    items: [
      ['13FLOW', '/methodologie/13flow/', 'Méthode de la confluence entre filings 13F et achats d’initiés Form 4.'],
      ['Yen Carry', '/methodologie/yen-carry/', 'Méthode du suivi du risque de débouclage du carry trade yen.'],
      ['Énergie', '/methodologie/energie/', 'Méthode du stress énergie : pétrole, gaz, électricité et contraintes physiques.'],
      ['Debt Risk', '/methodologie/debt-risk-radar/', 'Méthode du radar dette : souverain, spreads, charge d’intérêt et refinancement.'],
      ['Euro Macro', '/methodologie/euro-macro/', 'Méthode du dashboard macro zone euro.'],
      ['US Macro', '/methodologie/us-macro/', 'Méthode du dashboard macro américain.'],
    ],
  },
  {
    group: 'comprendre & gouvernance',
    items: [
      ['Manifeste', '/manifeste/', 'Pourquoi l0g existe et quel contrat de lecture il propose.'],
      ['Protocole éditorial', '/protocole-editorial/', 'Règles de rédaction : faits, sources, hypothèses, corrections et limites.'],
      ['Changelog éditorial', '/changelog-editorial/', 'Historique des changements de méthode éditoriale et de traçabilité.'],
      ['À propos', '/about/', 'Contexte du projet, auteur, périmètre et indépendance.'],
      ['Sites de référence', '/sites-reference/', 'Catalogue de lieux utiles pour vérifier ou prolonger une recherche.'],
      ['RGPD', '/rgpd/', 'Mentions légales, hygiène privacy et absence de tracking.'],
    ],
  },
  {
    group: 'outils annexes',
    items: [
      ['Terminal', '/terminal/', 'Navigation clavier façon shell, utile pour explorer rapidement les surfaces publiques.'],
      ['Statut', '/status/', 'État du site, génération statique, endpoints et fraîcheur des surfaces.'],
      ['RSS', '/rss.xml', 'Flux des publications pour suivre le journal sans réseau social.'],
      ['llms.txt', '/llms.txt', 'Point d’entrée compact pour agents et modèles de langage.'],
      ['GitHub', 'https://github.com/bluetouff', 'Dépôts publics, code, méthodes et artefacts open source reliés au projet.'],
    ],
  },
];

const reminders = [
  'Un dashboard n’est pas une prédiction.',
  'Un score n’est pas un conseil.',
  'Un chiffre sans date est fragile.',
  'Une source primaire vaut mieux qu’un résumé.',
  'Deux scores 0-100 ne sont pas forcément comparables.',
  'Risk Diff montre ce qui change, pas ce qui va arriver.',
  'Black Box rejoue le passé publié, elle ne reconstruit pas après coup.',
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://l0g.fr/visite-guidee/#page',
  name: 'Visite guidée l0g',
  description,
  inLanguage: 'fr',
  isAccessibleForFree: true,
  isPartOf: { '@id': 'https://l0g.fr/#website' },
  publisher: { '@id': 'https://l0g.fr/#org' },
  url: 'https://l0g.fr/visite-guidee/',
};
---

<BaseLayout
  title={title}
  description={description}
  ogImageAlt="Visite guidée de l0g : comprendre, lire, surveiller, vérifier et réutiliser"
  alternateLinks={[
    { hreflang: 'fr', href: new URL('/visite-guidee/', Astro.site).toString() },
    { hreflang: 'en', href: new URL('/en/tour/', Astro.site).toString() },
    { hreflang: 'x-default', href: new URL('/visite-guidee/', Astro.site).toString() },
  ]}
  sidebar={false}
>
  <script type="application/ld+json" is:inline set:html={serializeInlineScriptData(jsonLd)} />

  <article class="tour-page rise" data-pagefind-body>
    <section class="tour-hero" data-pagefind-ignore>
      <div class="tour-hero-copy">
        <p class="mono-label glow">// visite guidée</p>
        <h1 class="tour-title font-display glow">
          Le mode d’emploi humain de <span>l0g</span>.
        </h1>
        <p class="tour-lede">
          Une rampe douce pour les lecteurs qui ne vivent pas dans les filings, les spreads
          et les dashboards. On part d’une question simple, puis on apprend où cliquer,
          quoi regarder et quelle erreur éviter.
        </p>
        <div class="tour-actions" aria-label="Accès rapides">
          <a href="#besoin" class="tour-btn tour-btn-primary">choisir mon besoin</a>
          <a href="#fonctionnalites" class="tour-btn">voir toutes les features</a>
        </div>
      </div>

      <div class="tour-console" aria-label="Résumé de la visite guidée">
        <div class="console-top">
          <span></span><span></span><span></span>
          <strong>onboarding.soft</strong>
        </div>
        <ol class="route-list">
          <li><span>01</span> comprendre</li>
          <li><span>02</span> lire</li>
          <li><span>03</span> surveiller</li>
          <li><span>04</span> vérifier</li>
          <li><span>05</span> réutiliser</li>
        </ol>
      </div>
    </section>

    <section class="tour-strip" aria-label="Principe de lecture">
      <div>
        <strong>pas un oracle</strong>
        <span>des instruments datés</span>
      </div>
      <div>
        <strong>pas un conseil</strong>
        <span>des signaux à vérifier</span>
      </div>
      <div>
        <strong>pas une boîte noire</strong>
        <span>sources, méthode, limites</span>
      </div>
    </section>

    <section id="besoin" class="tour-section">
      <div class="section-head">
        <p class="mono-label glow">// choisis ton besoin</p>
        <h2>Pas besoin de connaître le jargon pour commencer.</h2>
        <p>
          La bonne entrée dépend de la question du moment. Chaque carte t’envoie vers la
          fonctionnalité la plus utile, avec une promesse simple.
        </p>
      </div>

      <div class="intent-grid">
        {intents.map((item) => (
          <a href={item.href} class="intent-card">
            <span class="intent-eyebrow">{item.eyebrow}</span>
            <strong>{item.title}</strong>
            <p>{item.text}</p>
            <em>{item.cta} →</em>
          </a>
        ))}
      </div>
    </section>

    <section class="tour-section">
      <div class="section-head">
        <p class="mono-label glow">// visite en 7 étapes</p>
        <h2>Le parcours conseillé, du plus doux au plus technique.</h2>
        <p>
          Tu peux le lire en diagonale. L’idée n’est pas de tout maîtriser, mais de savoir
          quelle surface utiliser quand une question apparaît.
        </p>
      </div>

      <div class="timeline">
        {tourSteps.map((step) => (
          <article class="timeline-card">
            <div class="timeline-num">{step.n}</div>
            <div>
              <span>{step.verb}</span>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
              <a href={step.href}>{step.cta} →</a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="tour-section score-section">
      <div class="score-card" aria-label="Lire un score l0g sans se tromper">
        <div class="score-orb">
          <span>55</span>
          <small>/100</small>
        </div>
        <div class="score-copy">
          <p class="mono-label glow">// lire un score</p>
          <h2>Un score est un panneau de signalisation, pas une destination.</h2>
          <p>
            La valeur affichée attire l’œil. La lecture sérieuse commence après : quel
            instrument ? quelle date ? quelle source ? quelle méthode ? quelle limite ?
          </p>
          <ul>
            <li>Regarde d’abord le nom du dashboard.</li>
            <li>Vérifie la date de mise à jour.</li>
            <li>Remonte à la source primaire.</li>
            <li>Lis la méthode avant de comparer.</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="fonctionnalites" class="tour-section">
      <div class="section-head">
        <p class="mono-label glow">// toutes les fonctionnalités</p>
        <h2>La carte complète, traduite en langage humain.</h2>
        <p>
          Chaque fonctionnalité répond à trois questions : à quoi ça sert, quoi regarder,
          et quelle mauvaise lecture éviter.
        </p>
      </div>

      <div class="feature-groups">
        {featureGroups.map((group) => (
          <section class="feature-group" aria-labelledby={`group-${group.name}`}>
            <div class="group-head">
              <h3 id={`group-${group.name}`}>{group.name}</h3>
              <p>{group.hint}</p>
            </div>
            <div class="feature-grid">
              {group.features.map((feature) => (
                <article class="feature-card">
                  <div class="feature-top">
                    <h4>{feature.title}</h4>
                    <a href={feature.href}>ouvrir →</a>
                  </div>
                  <dl>
                    <div>
                      <dt>sert à</dt>
                      <dd>{feature.use}</dd>
                    </div>
                    <div>
                      <dt>regarder</dt>
                      <dd>{feature.look}</dd>
                    </div>
                    <div>
                      <dt>éviter</dt>
                      <dd>{feature.avoid}</dd>
                    </div>
                  </dl>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>
    </section>

    <section class="tour-section">
      <div class="section-head">
        <p class="mono-label glow">// index rapide du footer</p>
        <h2>Les autres portes du site, sans vocabulaire inutile.</h2>
        <p>
          Ce bloc reprend les entrées plus spécialisées du footer : marchés, méthodes par
          instrument, gouvernance éditoriale et petits outils de navigation.
        </p>
      </div>

      <div class="quick-index">
        {quickIndex.map((group) => (
          <article class="quick-group">
            <h3>{group.group}</h3>
            <div class="quick-list">
              {group.items.map(([label, href, text]) => (
                <a href={href}>
                  <strong>{label}</strong>
                  <span>{text}</span>
                </a>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="tour-section proof-section">
      <div class="proof-copy">
        <p class="mono-label glow">// chaîne de preuve</p>
        <h2>Quand tu lis une affirmation, remonte la chaîne.</h2>
        <p>
          Une analyse solide ne s’arrête pas à une phrase convaincante. Elle doit pouvoir
          revenir vers une source, une méthode et une limite datée.
        </p>
      </div>
      <div class="proof-chain" aria-label="Article, affirmation, source, méthode, limite, preuve">
        <span>article</span>
        <span>affirmation</span>
        <span>source primaire</span>
        <span>méthode</span>
        <span>limite</span>
        <span>preuve</span>
      </div>
    </section>

    <section class="tour-section reminder-section">
      <div class="section-head compact">
        <p class="mono-label glow">// à garder en tête</p>
        <h2>Les phrases qui évitent 80 % des contresens.</h2>
      </div>
      <div class="reminder-grid">
        {reminders.map((r) => <p>{r}</p>)}
      </div>
    </section>

    <section class="tour-section tour-cta">
      <p class="mono-label glow">// commencer doucement</p>
      <h2>Choisis une première porte, pas tout le bâtiment.</h2>
      <div class="cta-row">
        <a href="/glossaire/">je découvre les mots</a>
        <a href="/guides/">j’apprends une notion</a>
        <a href="/dashboards/">je regarde les instruments</a>
        <a href="/risk-diff/">je vois ce qui a changé</a>
      </div>
    </section>
  </article>

  <style>
    .tour-page {
      max-width: 68rem;
    }

    .tour-hero {
      position: relative;
      display: grid;
      gap: 1.5rem;
      align-items: stretch;
      overflow: hidden;
      border: 1px solid var(--color-line);
      border-radius: 18px;
      padding: clamp(1.2rem, 3vw, 2rem);
      background:
        radial-gradient(circle at 12% 8%, color-mix(in srgb, var(--color-signal) 18%, transparent), transparent 34%),
        radial-gradient(circle at 88% 16%, color-mix(in srgb, var(--color-accent) 15%, transparent), transparent 32%),
        linear-gradient(135deg, color-mix(in srgb, var(--color-surface) 78%, transparent), color-mix(in srgb, var(--color-ink) 92%, transparent));
    }
    .tour-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      opacity: 0.24;
      background-image:
