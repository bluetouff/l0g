---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { readingTime } from '../../lib/reading-time.ts';

// Familles de guides : ordre d'affichage, libellé, dossier (label terminal) et couleur de charte.
const CATEGORIES = [
  { key: 'macro',   label: 'Données macro',                 dir: 'macro',   accent: 'var(--color-signal)' },
  { key: 'fed',     label: 'Fed, dette & liquidité',        dir: 'fed',     accent: 'var(--color-amber)' },
  { key: 'marches', label: 'Marchés, SEC & positionnement', dir: 'marches', accent: 'var(--color-muted)' },
  { key: 'crypto',  label: 'Crypto & régulation',           dir: 'crypto',  accent: 'var(--color-accent)' },
];

const all = (await getCollection('guides', ({ data }) => !data.draft)).sort((a, b) => {
  const da = (a.data.updatedDate ?? a.data.pubDate).getTime();
  const db = (b.data.updatedDate ?? b.data.pubDate).getTime();
  return db - da;
});

type GuideEntry = CollectionEntry<'guides'>;

const toItem = (g: GuideEntry) => ({
  id: g.id,
  title: g.data.title,
  description: g.data.description,
  date: g.data.updatedDate ?? g.data.pubDate,
  rt: readingTime(g.body),
});

const groups = CATEGORIES
  .map((c) => ({ ...c, items: all.filter((g) => g.data.category === c.key).map(toItem) }))
  .filter((g) => g.items.length > 0);

// Filet de sécurité : tout guide sans famille connue est regroupé en fin de page.
const known = new Set(CATEGORIES.map((c) => c.key));
const others = all.filter((g) => !g.data.category || !known.has(g.data.category)).map(toItem);
if (others.length) {
  groups.push({ key: 'autres', label: 'Autres', dir: 'autres', accent: 'var(--color-muted)', items: others });
}

const total = all.length;
const englishTotal = (await getCollection('guidesEn', ({ data }) => !data.draft)).length;
---

<BaseLayout
  title="Guides de référence"
  description="Guides de référence l0g : des pages piliers longues et sourcées, conçues pour être la source canonique citée par les agents et les moteurs de réponse. Rangées par famille : données macro, Fed et liquidité, marchés et SEC, crypto et régulation."
>
  <section class="rise border-b border-dashed border-line pb-10">
    <p class="mono-label" style="color: var(--color-signal)">$ ls /guides</p>
    <h1 class="mt-5 font-display text-[clamp(2.1rem,5vw,3.2rem)] leading-tight tracking-wider glow">
      Guides de <span style="color: var(--color-accent)">référence</span>
    </h1>
    <p class="mt-5 max-w-xl text-muted">
      Des pages longues, sourcées sur données primaires, pensées pour durer.
      Là où un article date un événement, un guide définit une notion et la
      tient à jour : la source que l'on garde en favori, et que les agents
      citent. {total} guides, rangés par famille, chacun daté de sa dernière
      révision.
    </p>

    <div class="guide-en-callout" data-pagefind-ignore>
      <div>
        <p class="mono-label" style="color: var(--color-signal)">$ cd /en/guides</p>
        <p class="guide-en-title">English versions available</p>
        <p class="guide-en-text">
          Les guides de référence l0g commencent à être traduits en anglais.
          Le reste du site reste volontairement en français pour le moment.
          {englishTotal} {englishTotal > 1 ? 'guides anglais publiés' : 'guide anglais publié'}.
        </p>
      </div>
      <a class="guide-en-link link-term" href="/en/guides/">Browse English guides →</a>
    </div>
  </section>

  {
    groups.length === 0 ? (
      <p class="mt-10 text-muted">Aucun guide publié pour l'instant.</p>
    ) : (
      groups.map((cat) => (
        <section class="cat rise">
          <header class="cat-head">
            <p class="mono-label cat-cmd" style={`color:${cat.accent}`}>
              $ ls /guides/{cat.dir}
            </p>
            <span class="mono-label cat-count">
              {cat.items.length} {cat.items.length > 1 ? 'guides' : 'guide'}
            </span>
          </header>
          <p class="cat-label">{cat.label}</p>
          {cat.items.map((g, i) => (
            <PostCard
              url={`/guides/${g.id}/`}
              title={g.title}
              description={g.description}
              pubDate={g.date}
              readingTime={g.rt}
              index={i + 1}
              accent={cat.accent}
              accentLabel="guide"
            />
          ))}
        </section>
      ))
    )
  }
</BaseLayout>

<style>
  .cat { padding-top: 2.6rem; }
  .cat-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  .cat-count { color: var(--color-muted); }
  .cat-label {
    margin: 0.35rem 0 0.4rem;
    padding-bottom: 0.7rem;
    border-bottom: 1px dashed var(--color-line);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    color: var(--color-muted);
  }
  .guide-en-callout {
    margin-top: 1.8rem;
    padding: 1rem 1.1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.2rem;
    border: 1px dashed var(--color-line);
    border-radius: 14px;
    background: color-mix(in srgb, var(--color-signal) 7%, transparent);
  }
  .guide-en-title {
    margin-top: 0.35rem;
    font-weight: 700;
    color: var(--color-bright);
  }
  .guide-en-text {
    margin-top: 0.25rem;
    max-width: 46rem;
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.55;
  }
  .guide-en-link {
    flex: 0 0 auto;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    white-space: nowrap;
  }
  @media (max-width: 720px) {
    .guide-en-callout { display: block; }
    .guide-en-link { display: inline-block; margin-top: 0.85rem; }
  }
</style>
