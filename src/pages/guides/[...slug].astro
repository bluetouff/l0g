---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CitationBox from '../../components/CitationBox.astro';
import FreshnessBadge from '../../components/FreshnessBadge.astro';
import TrustBar from '../../components/TrustBar.astro';
import { authorEntity, organizationEntity } from '../../config/entities.ts';
import { topicForTag } from '../../config/topics.ts';
import { readingTime } from '../../lib/reading-time.ts';

export async function getStaticPaths() {
  const guides = await getCollection('guides', ({ data }) => !data.draft);
  return guides.map((guide) => ({
    params: { slug: guide.id },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const ogImage = guide.data.ogImage ?? `/og/${guide.id}.png`;
const { Content } = await render(guide);

const fmt = (d: Date) =>
  d.toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' });
const updated = guide.data.updatedDate ?? guide.data.pubDate;
const updatedLabel = fmt(updated);
const isoPub = guide.data.pubDate.toISOString();
const isoUpd = updated.toISOString();
const rt = readingTime(guide.body);

const url = new URL(`/guides/${guide.id}/`, Astro.site).toString();
const englishGuides = await getCollection('guidesEn', ({ data }) => !data.draft);
const englishGuide = englishGuides.find((entry) => entry.data.sourceGuide === guide.id);
const englishUrl = englishGuide ? new URL(`/en/guides/${englishGuide.id}/`, Astro.site).toString() : null;
const alternateLinks = englishUrl
  ? [
      { hreflang: 'fr', href: url },
      { hreflang: 'en', href: englishUrl },
      { hreflang: 'x-default', href: url },
    ]
  : [
      { hreflang: 'fr', href: url },
      { hreflang: 'x-default', href: url },
    ];

// Partage : URL absolue + textes encodes. Liens HTML purs, aucun script tiers.
const shareTitle = guide.data.title;
const u = encodeURIComponent(url);
const t = encodeURIComponent(shareTitle);
const share = {
  x: `https://twitter.com/intent/tweet?text=${t}&url=${u}`,
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${u}`,
  linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${u}`,
  bluesky: `https://bsky.app/intent/compose?text=${t}%20${u}`,
};
const trustItems = [
  { label: 'révision datée', note: updatedLabel },
  { label: 'page canonique', href: `/guides/${guide.id}/` },
  { label: 'sources primaires', href: '/sites-reference/' },
  { label: 'aucun tracker', href: '/rgpd/' },
];

// JSON-LD honnête : décrit ce qu'est la page, sans note ni HowTo fabriqués.
const ld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      headline: guide.data.title,
      description: guide.data.description,
      datePublished: isoPub,
      dateModified: isoUpd,
      inLanguage: 'fr',
      author: authorEntity,
      publisher: organizationEntity,
      mainEntityOfPage: url,
      ...(guide.data.summary
        ? { about: { '@type': 'DefinedTerm', name: guide.data.title, description: guide.data.summary } }
        : {}),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Accueil', item: new URL('/', Astro.site).toString() },
        { '@type': 'ListItem', position: 2, name: 'Guides', item: new URL('/guides/', Astro.site).toString() },
        { '@type': 'ListItem', position: 3, name: guide.data.title, item: url },
      ],
    },
  ],
};
const safeLd = JSON.stringify(ld).replace(/</g, '\\u003c');
---

<BaseLayout
  title={guide.data.title}
  description={guide.data.description}
  ogType="article"
  ogImage={ogImage}
  alternateLinks={alternateLinks}
>
  <script type="application/ld+json" is:inline set:html={safeLd} />

  <div class="read-progress" aria-hidden="true"><span></span></div>

  <article class="rise max-w-2xl" data-pagefind-body>
    <header class="post-head mb-10">
      <p class="mono-label glow post-kicker">// guide de référence</p>

      <h1 class="post-title mt-3 font-display text-[clamp(1.9rem,4.5vw,3rem)] leading-tight tracking-wider glow">
        {guide.data.title}
      </h1>

      <p class="post-lede mt-5">{guide.data.description}</p>

      <div class="post-meta mono-label mt-6">
        <a href="/about/#bluetouff" rel="author" class="link-term">Par Bluetouff</a>
        <span class="sep" aria-hidden="true">·</span>
        <time datetime={isoUpd} data-pagefind-meta="date">dernière révision le {updatedLabel}</time>
        <span class="sep" aria-hidden="true">·</span>
        <span>{rt} min de lecture</span>
        <span class="sep" aria-hidden="true">·</span>
        <FreshnessBadge date={updated} />
        {guide.data.tags.length > 0 && <span class="sep" aria-hidden="true">·</span>}
        <span class="post-tags">
          {guide.data.tags.map((tag) => {
            const slug = topicForTag(tag);
            return slug
              ? <a href={`/sujet/${slug}/`} class="link-term text-signal">#{tag}</a>
              : <span class="text-signal">#{tag}</span>;
          })}
        </span>
      </div>

      <TrustBar items={trustItems} variant="compact" />
      {englishGuide && (
        <p class="translation-link mono-label" data-pagefind-ignore>
          <a href={`/en/guides/${englishGuide.id}/`} class="link-term">English version available →</a>
        </p>
      )}
      <div class="post-rule" aria-hidden="true"></div>
    </header>

    <div class="prose">
      <Content />
    </div>

    <div class="share mt-14" data-pagefind-ignore>
      <span class="mono-label share-label">// partager</span>
      <div class="share-row">
        <a class="share-btn" href={share.x} target="_blank" rel="noopener nofollow" aria-label="Partager sur X" title="Partager sur X">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          <span>X</span>
        </a>
        <a class="share-btn" href={share.bluesky} target="_blank" rel="noopener nofollow" aria-label="Partager sur Bluesky" title="Partager sur Bluesky">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.479 0-.688-.139-1.86-.902-2.203-.659-.299-1.664-.621-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z"/></svg>
          <span>Bluesky</span>
        </a>
        <a class="share-btn" href={share.linkedin} target="_blank" rel="noopener nofollow" aria-label="Partager sur LinkedIn" title="Partager sur LinkedIn">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.55V9h3.57zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/></svg>
          <span>LinkedIn</span>
        </a>
        <a class="share-btn" href={share.facebook} target="_blank" rel="noopener nofollow" aria-label="Partager sur Facebook" title="Partager sur Facebook">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07C0 18.1 4.39 23.1 10.13 24v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.69.24 2.69.24v2.97h-1.52c-1.49 0-1.96.93-1.96 1.89v2.25h3.33l-.53 3.49h-2.8V24C19.61 23.1 24 18.1 24 12.07z"/></svg>
          <span>Facebook</span>
        </a>
        <button class="share-btn" type="button" data-copy-url={url} aria-label="Copier le lien" title="Copier le lien">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1"/></svg>
          <span data-copy-label>Copier le lien</span>
        </button>
      </div>
    </div>

    <p class="post-disclaimer" data-pagefind-ignore>
      <em>Cet article ne constitue en aucun cas un conseil en investissement.</em>
    </p>

    <CitationBox
      title={guide.data.title}
      url={url}
      kind="guide"
      published={guide.data.pubDate}
      updated={updated}
    />

    <hr class="hairline mt-12" />
    <a href="/glossaire/" class="mono-label link-term mt-6 inline-block">$ cd ../glossaire</a>
  </article>

  <script>
    // @ts-nocheck -- script navigateur autonome, validé sur le DOM construit.
    (function () {
      var bar = document.querySelector('.read-progress > span');
      if (!bar) return;
      var ticking = false;
      function update() {
        var h = document.documentElement;
        var max = h.scrollHeight - h.clientHeight;
        var p = max > 0 ? h.scrollTop / max : 0;
        bar.style.transform = 'scaleX(' + p.toFixed(4) + ')';
        ticking = false;
      }
      function onScroll() { if (!ticking) { ticking = true; requestAnimationFrame(update); } }
      document.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll);
      update();
    })();
  </script>

  <script>
    // @ts-nocheck -- script navigateur autonome, validé sur le DOM construit.
    document.querySelectorAll('[data-copy-url]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var u = btn.getAttribute('data-copy-url');
        var label = btn.querySelector('[data-copy-label]');
        var flash = function (text) {
          if (!label) return;
          var original = label.textContent;
          label.textContent = text;
          setTimeout(function () { label.textContent = original; }, 1800);
        };
        if (!u || !window.isSecureContext || !navigator.clipboard || !navigator.clipboard.writeText) {
          flash('Copie indisponible');
          return;
        }
        navigator.clipboard.writeText(u)
          .then(function () { flash('Lien copié'); })
          .catch(function () { flash('Copie indisponible'); });
      });
    });
  </script>

  <style>
    .read-progress { position: fixed; top: 0; left: 0; right: 0; height: 2px; z-index: 60; pointer-events: none; background: transparent; }
    .read-progress > span {
      display: block; height: 100%; width: 100%;
      transform: scaleX(0); transform-origin: 0 50%;
      background: linear-gradient(90deg, var(--color-signal), color-mix(in srgb, var(--color-signal) 45%, var(--color-accent)));
      box-shadow: 0 0 8px color-mix(in srgb, var(--color-signal) 50%, transparent);
    }
    .post-kicker { color: var(--color-signal); }
    .post-lede {
      font-size: 1.18rem; line-height: 1.6; color: var(--color-paper);
      border-left: 2px solid color-mix(in srgb, var(--color-signal) 45%, transparent);
      padding-left: 0.9rem;
    }
    .post-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 0.6rem; color: var(--color-muted); }
    .post-meta .sep { opacity: 0.45; }
    .post-tags { display: inline-flex; flex-wrap: wrap; gap: 0.7rem; }
    .post-rule { margin-top: 1.5rem; height: 2px; width: 72px; border-radius: 2px; background: linear-gradient(90deg, var(--color-signal), transparent); }
    .share { border-top: 1px solid var(--color-line); padding-top: 1.2rem; }
    .share-label { color: var(--color-signal); display: block; margin-bottom: 0.7rem; }
    .post-disclaimer { margin-top: 1.6rem; color: var(--color-accent); font-size: 0.92rem; line-height: 1.5; }
    .share-row { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .share-btn {
      display: inline-flex; align-items: center; gap: 0.45rem;
      font-family: var(--font-mono); font-size: 0.8rem;
      color: var(--color-muted); background: transparent;
      border: 1px solid var(--color-line); border-radius: 8px;
      padding: 0.4rem 0.7rem; cursor: pointer; text-decoration: none;
      transition: color 0.15s, border-color 0.15s, background 0.15s;
    }
    .share-btn:hover {
      color: var(--color-signal); border-color: var(--color-signal);
      background: color-mix(in srgb, var(--color-signal) 8%, transparent);
    }
    .translation-link { margin-top: 0.9rem; }
  </style>
</BaseLayout>
