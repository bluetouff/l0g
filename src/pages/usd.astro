---
import BaseLayout from '../layouts/BaseLayout.astro';
import TradingViewChart from '../components/TradingViewChart.astro';
import SymbolOverview from '../components/SymbolOverview.astro';
---

<BaseLayout title="USD" description="Dashboard dollar : paires majeures.">
  <section class="mb-4">
    <p class="mono-label">// dashboard</p>
    <h1 class="mt-2 font-display text-5xl leading-none tracking-wider glow sm:text-6xl">USD</h1>
    <p class="mt-3 max-w-2xl text-muted">
      Principales paires de change.
    </p>
  </section>


  <h2 class="mono-label glow mb-1 mt-8">// paires majeures</h2>
  <SymbolOverview
    symbols={[
      { label: 'EUR/USD', ticker: 'FX:EURUSD' },
      { label: 'USD/JPY', ticker: 'FX:USDJPY' },
      { label: 'GBP/USD', ticker: 'FX:GBPUSD' },
    ]}
    height={400}
  />
</BaseLayout>
