---
import BaseLayout from '../layouts/BaseLayout.astro';
import TradingViewChart from '../components/TradingViewChart.astro';
---

<BaseLayout
  title="Indices US"
  description="S&P 500 et Nasdaq 100 — graphes journaliers en chandeliers."
  sidebar={false}
>
  <section class="mb-6">
    <p class="mono-label">// dashboard</p>
    <h1 class="mt-2 font-display text-5xl leading-none tracking-wider glow sm:text-6xl">Indices US</h1>
    <p class="mt-3 max-w-2xl text-muted">
      S&amp;P 500 et Nasdaq 100, en chandeliers journaliers.
    </p>
  </section>

  <h2 class="mono-label glow mb-1">// S&amp;P 500</h2>
  <TradingViewChart symbol="SP:SPX" interval="D" height={700} />

  <h2 class="mono-label glow mb-1 mt-10">// Nasdaq 100</h2>
  <TradingViewChart symbol="NASDAQ:NDX" interval="D" height={700} />
</BaseLayout>
