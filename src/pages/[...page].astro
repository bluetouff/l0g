---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import PostHero from '../components/PostHero.astro';
import RiskBand from '../components/RiskBand.astro';
import { readingTime } from '../lib/reading-time.ts';
import { accentForTags, topicLabelForTags } from '../config/topics.ts';

type PostEntry = CollectionEntry<'posts'>;
type PaginatedPosts = {
  data: PostEntry[];
  start: number;
  currentPage: number;
  lastPage: number;
  total: number;
  url: {
    prev?: string;
    next?: string;
  };
};

export async function getStaticPaths({ paginate }: { paginate: (data: PostEntry[], options: { pageSize: number }) => unknown }) {
  const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
  );
  return paginate(posts, { pageSize: 10 });
}

const { page } = Astro.props as { page: PaginatedPosts };
const isFirst = page.currentPage === 1;

const items = page.data.map((post: PostEntry, i: number) => ({
  post,
  absIndex: page.start + i + 1,
  accent: accentForTags(post.data.tags || []),
  accentLabel: topicLabelForTags(post.data.tags || []),
  rt: readingTime(post.body),
}));
const hero = isFirst ? items[0] : null;
const feed = isFirst ? items.slice(1) : items;
---

<BaseLayout
  title="l0g : les angles morts de la finance"
  description="Enquêtes sur les mécanismes financiers invisibles : bilans, collatéral, crédit privé, levier et chaînes de contagion."
>
  {isFirst && (
    <section class="rise">
      <p class="mono-label" style="color: var(--color-signal)">$ cat /risque | cartographie</p>
      <h1 class="mt-5 font-display text-[clamp(2.2rem,5.5vw,3.5rem)] leading-tight tracking-wider glow">
        l0g : les angles morts de la finance
      </h1>
      <p class="mt-5 max-w-xl text-muted">
        Enquêtes sur les mécanismes financiers invisibles : bilans, collatéral, crédit privé, levier et chaînes de contagion.
      </p>
    </section>
  )}

  {isFirst && (
    <div
      class="rise mt-12"
      aria-hidden="true"
      style="height: 4px; width: 100%; opacity: 0.7; background: linear-gradient(90deg, transparent 0%, color-mix(in srgb, var(--color-signal) 55%, transparent) 28%, color-mix(in srgb, var(--color-accent) 50%, transparent) 50%, color-mix(in srgb, var(--color-amber) 55%, transparent) 72%, transparent 100%);"
    >
    </div>
  )}

  {isFirst && <RiskBand />}

  {hero && (
    <PostHero
      url={`/posts/${hero.post.id}/`}
      title={hero.post.data.title}
      description={hero.post.data.description}
      pubDate={hero.post.data.pubDate}
      updatedDate={hero.post.data.updatedDate}
      readingTime={hero.rt}
      accent={hero.accent}
      accentLabel={hero.accentLabel}
    />
  )}

  <section class="pb-4 pt-2">
    <p class="mono-label mb-3">page {page.currentPage} / {page.lastPage} · {page.total} entrées</p>
    {
      feed.map((it: (typeof items)[number]) => (
        <PostCard
          url={`/posts/${it.post.id}/`}
          title={it.post.data.title}
          description={it.post.data.description}
          pubDate={it.post.data.pubDate}
          updatedDate={it.post.data.updatedDate}
          tags={it.post.data.tags}
          readingTime={it.rt}
          index={it.absIndex}
          accent={it.accent}
          accentLabel={it.accentLabel}
        />
      ))
    }
  </section>

  <!-- Pagination -->
  <nav class="mono-label flex items-center justify-between border-t border-dashed border-line py-6">
    {page.url.prev ? (
      <a href={page.url.prev} class="link-term">← précédent</a>
    ) : (
      <span class="text-muted opacity-40">← précédent</span>
    )}
    <span class="text-muted">{page.currentPage} / {page.lastPage}</span>
    {page.url.next ? (
      <a href={page.url.next} class="link-term">suivant →</a>
    ) : (
      <span class="text-muted opacity-40">suivant →</span>
    )}
  </nav>
</BaseLayout>
