---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import AnalysisPagination from '../components/AnalysisPagination.astro';
import HomeSidebar from '../components/HomeSidebar.astro';
import L0gGlyph, { type GlyphName } from '../components/L0gGlyph.astro';
import PostCard from '../components/PostCard.astro';
import PostHero from '../components/PostHero.astro';
import RiskBand from '../components/RiskBand.astro';
import SectionSignature from '../components/SectionSignature.astro';
import { readingTime } from '../lib/reading-time.ts';
import { accentForTags, topicLabelForTags, topics } from '../config/topics.ts';

type PostEntry = CollectionEntry<'posts'>;
type PaginatedPosts = {
  data: PostEntry[];
  start: number;
  currentPage: number;
  lastPage: number;
  total: number;
  url: {
    prev?: string;
    next?: string;
  };
};

export async function getStaticPaths({ paginate }: { paginate: (data: PostEntry[], options: { pageSize: number }) => unknown }) {
  const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
  );
  return paginate(posts, { pageSize: 10 });
}

const { page } = Astro.props as { page: PaginatedPosts };
const isFirst = page.currentPage === 1;
const pageTitle = isFirst
  ? 'l0g : les angles morts de la finance'
  : `Analyses financières — page ${page.currentPage}`;
const pageDescription = isFirst
  ? 'Enquêtes sur les mécanismes financiers invisibles : bilans, collatéral, crédit privé, levier et chaînes de contagion.'
  : `Archives des analyses l0g sur la finance, la macroéconomie, le crédit et les risques systémiques — page ${page.currentPage} sur ${page.lastPage}.`;

const items = page.data.map((post: PostEntry, i: number) => ({
  post,
  absIndex: page.start + i + 1,
  accent: accentForTags(post.data.tags || []),
  accentLabel: topicLabelForTags(post.data.tags || []),
  rt: readingTime(post.body),
}));
const hero = isFirst ? items[0] : null;
const feed = isFirst ? items.slice(1) : items;
const pageHref = (n: number) => (n <= 1 ? '/' : `/${n}/`);
const followedTopics = topics.slice(0, 6);
const needCards = [
  {
    glyph: 'understand' as GlyphName,
    eyebrow: 'comprendre',
    title: 'Comprendre un sujet',
    text: 'Partir d’une question, puis relier guides, définitions et analyses datées.',
    href: '/sujets/',
    cta: 'Explorer les sujets',
  },
  {
    glyph: 'observe' as GlyphName,
    eyebrow: 'observer',
    title: 'Suivre un risque',
    text: 'Voir comment un choc se transmet, puis ouvrir les instruments qui le mesurent.',
    href: '/radar/',
    cta: 'Ouvrir le Radar',
  },
  {
    glyph: 'verify' as GlyphName,
    eyebrow: 'vérifier',
    title: 'Vérifier un chiffre',
    text: 'Remonter à la source, à la méthode, à la date et aux limites publiées.',
    href: '/preuves/',
    cta: 'Contrôler les preuves',
  },
  {
    glyph: 'retrieve' as GlyphName,
    eyebrow: 'retrouver',
    title: 'Retrouver une analyse',
    text: 'Chercher dans les articles, les guides, les méthodes et le glossaire.',
    href: '/recherche/',
    cta: 'Lancer une recherche',
  },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
>
  {isFirst && <HomeSidebar slot="sidebar" />}

  {isFirst && (
    <section class="rise home-intro">
      <div class="home-kicker">
        <p class="mono-label">// économie · marchés · risques</p>
        <span aria-hidden="true"><i></i><b></b></span>
      </div>
      <h1 class="mt-5 font-display text-[clamp(2.2rem,5.5vw,3.5rem)] leading-tight tracking-wider glow">
        l<span style="color: var(--color-signal)">0</span>g <span style="color: var(--color-accent)">:</span> les angles morts de <span class="home-title-gradient">la finance</span>
      </h1>
      <p class="home-promise">
        l0g décrypte les changements de l’économie et des marchés,
        avec les chiffres, les sources et leurs limites.
      </p>
      <div class="home-actions">
        <a href="/demarrer/" class="home-action primary">Découvrir l0g</a>
        <a href="#dernieres-analyses" class="home-action">Lire les dernières analyses</a>
      </div>
    </section>
  )}

  {isFirst && (
    <section class="home-risk" aria-label="Les signaux de risque">
      <RiskBand />
    </section>
  )}

  {isFirst && (
    <section class="home-needs rise" aria-labelledby="home-needs-title">
      <SectionSignature index="02" eyebrow="choisir une entrée" title="Que cherchez-vous ?" id="home-needs-title" />
      <div class="need-grid">
        {needCards.map((card, index) => (
          <a href={card.href} class="need-card instrument-plate">
            <span class="need-card-top">
              <span class="need-index">{String(index + 1).padStart(2, '0')}</span>
              <L0gGlyph name={card.glyph} size="lg" />
            </span>
            <span class="need-eyebrow">{card.eyebrow}</span>
            <strong>{card.title}</strong>
            <p>{card.text}</p>
            <small>{card.cta} <i aria-hidden="true">›</i></small>
          </a>
        ))}
      </div>
    </section>
  )}

  {!isFirst && (
    <header class="rise border-b border-dashed border-line pb-8">
      <p class="mono-label" style="color: var(--color-signal)">$ ls /analyses | page {page.currentPage}</p>
      <h1 class="mt-4 font-display text-[clamp(2rem,5vw,3rem)] leading-tight tracking-wider glow">
        Analyses financières <span style="color: var(--color-accent)">— page {page.currentPage}</span>
      </h1>
      <p class="mt-4 max-w-xl text-muted">
        Archives des enquêtes l0g, de la plus récente à la plus ancienne.
      </p>
    </header>
  )}

  {hero && (
    <section class="home-featured" aria-labelledby="featured-title">
      {isFirst
        ? <SectionSignature index="03" eyebrow="à la une" title="L’analyse à retenir" id="featured-title" />
        : <>
            <p class="mono-label" style="color: var(--color-signal)">// à la une</p>
            <h2 id="featured-title" class="section-title">L’analyse à retenir</h2>
          </>
      }
      <PostHero
        url={`/posts/${hero.post.id}/`}
        title={hero.post.data.title}
        description={hero.post.data.description}
        pubDate={hero.post.data.pubDate}
        updatedDate={hero.post.data.updatedDate}
        readingTime={hero.rt}
        accent={hero.accent}
        accentLabel={hero.accentLabel}
      />
    </section>
  )}

  {isFirst && (
    <section class="home-topics" aria-labelledby="followed-topics-title">
      <SectionSignature
        index="04"
        eyebrow="dossiers"
        title="Les sujets suivis"
        id="followed-topics-title"
        href="/sujets/"
        linkLabel="Tous les sujets"
      />
      <div class="topic-grid">
        {followedTopics.map((topic, index) => (
          <a href={`/sujet/${topic.slug}/`} class="topic-card" style={`--topic-accent:${topic.accent === 'pink' ? 'var(--color-accent)' : topic.accent === 'amber' ? 'var(--color-amber)' : topic.accent === 'blue' ? '#7aa2f7' : 'var(--color-signal)'}`}>
            <span class="topic-index" aria-hidden="true">{String(index + 1).padStart(2, '0')}<i></i><b></b></span>
            <strong>{topic.label}</strong>
            <p>{topic.question}</p>
            <span class="topic-cta">Ouvrir le dossier ›</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="pb-4 latest-feed" id="dernieres-analyses">
    {isFirst
      ? <SectionSignature index="05" eyebrow="chronologie" title="Les dernières analyses" description={`${page.total} entrées publiées, de la plus récente à la plus ancienne.`} />
      : <div class="section-heading feed-heading">
          <div>
            <p class="mono-label" style="color: var(--color-signal)">// archives</p>
            <h2 class="section-title">Page {page.currentPage}</h2>
          </div>
          <p class="mono-label">{page.total} entrées</p>
        </div>
    }
    {
      feed.map((it: (typeof items)[number]) => (
        <PostCard
          url={`/posts/${it.post.id}/`}
          title={it.post.data.title}
          description={it.post.data.description}
          pubDate={it.post.data.pubDate}
          updatedDate={it.post.data.updatedDate}
          tags={it.post.data.tags}
          readingTime={it.rt}
          index={it.absIndex}
          accent={it.accent}
          accentLabel={it.accentLabel}
        />
      ))
    }
  </section>

  <AnalysisPagination
    currentPage={page.currentPage}
    totalPages={page.lastPage}
    pageHref={pageHref}
    ariaLabel="Pages des analyses"
    previousLabel="Précédent"
    nextLabel="Suivant"
  />
</BaseLayout>

<style>
  .home-intro { padding: 1.1rem 0 0.4rem; }
  .home-kicker {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .home-kicker > p { color: var(--color-signal); }
  .home-kicker > span {
    display: grid;
    grid-template-columns: minmax(2.5rem, 7rem) auto;
    align-items: center;
    gap: 0.35rem;
    flex: 1;
    max-width: 8rem;
  }
  .home-kicker i {
    height: 1px;
    background: linear-gradient(90deg, var(--color-signal), color-mix(in srgb, var(--color-signal) 12%, transparent));
  }
  .home-kicker b {
    width: 0.42rem;
    height: 0.42rem;
    border: 1px solid var(--color-signal);
    border-radius: 50%;
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-signal) 6%, transparent);
  }
  .home-title-gradient {
    color: var(--color-bright);
    background: linear-gradient(
      90deg,
      var(--color-signal),
      var(--color-accent) 48%,
      var(--color-amber)
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: 0 0 16px color-mix(in srgb, var(--color-accent) 16%, transparent);
  }
  .home-promise {
    max-width: 40rem;
    margin-top: 1.2rem;
    border-left: 2px solid var(--color-signal);
    padding-left: 1rem;
    color: var(--color-paper);
    font-family: var(--font-read);
    font-size: clamp(1.08rem, 2.1vw, 1.28rem);
    line-height: 1.65;
  }
  .home-actions { display: flex; flex-wrap: wrap; gap: 0.65rem; margin-top: 1.35rem; }
  .home-action {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-line-strong);
    border-radius: 999px;
    padding: 0.55rem 0.95rem;
    color: var(--color-paper);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    transition: transform 0.16s, border-color 0.16s, background 0.16s;
  }
  .home-action:hover { transform: translateY(-1px); border-color: var(--color-signal); }
  .home-action.primary { border-color: transparent; color: var(--color-ink); background: var(--color-signal); }
  :root[data-theme='light'] .home-action.primary { color: #fff; }
  .home-needs,
  .home-featured,
  .home-topics,
  .home-risk,
  .latest-feed { margin-top: 3.4rem; }
  .section-title {
    margin-top: 0.35rem;
    color: var(--color-bright);
    font-family: var(--font-display);
    font-size: clamp(1.55rem, 3vw, 2.15rem);
    line-height: 1.12;
  }
  .need-grid { display: grid; grid-template-columns: 1fr; gap: 0.7rem; }
  .need-card {
    display: flex;
    min-height: 15rem;
    flex-direction: column;
    padding: 0.95rem 1rem 1rem;
    transition: border-color 0.16s, background 0.16s, transform 0.16s, box-shadow 0.16s;
  }
  .need-card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--color-signal) 48%, var(--color-line));
    box-shadow:
      inset 0 1px 0 var(--edge-highlight),
      0 22px 58px color-mix(in srgb, #000 23%, transparent);
  }
  .need-card-top {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.8rem;
  }
  .need-index {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: color-mix(in srgb, var(--color-signal) 65%, var(--color-muted));
    font-family: var(--font-mono);
    font-size: 0.64rem;
    letter-spacing: 0.1em;
  }
  .need-index::after {
    content: '';
    width: 1.8rem;
    height: 1px;
    background: color-mix(in srgb, var(--color-signal) 35%, transparent);
  }
  .need-eyebrow {
    color: var(--color-signal);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .need-card > strong { margin-top: 0.5rem; color: var(--color-bright); font-size: 1.02rem; }
  .need-card > p { margin-top: 0.55rem; color: var(--color-muted); font-family: var(--font-read); font-size: 0.82rem; line-height: 1.55; }
  .need-card > small {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 0.85rem;
    color: var(--color-paper);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.045em;
    text-transform: uppercase;
  }
  .need-card > small i { color: var(--color-signal); font-size: 1rem; font-style: normal; }
  .home-featured :global(.post-hero) { margin-top: 0; }
  .section-heading {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 0.75rem 1rem;
  }
  .section-heading > a {
    color: var(--color-signal);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .topic-grid { display: grid; grid-template-columns: 1fr; gap: 0.65rem; }
  .topic-card {
    display: block;
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: 13px 4px 13px 13px;
    padding: 0.85rem 0.9rem 0.95rem;
    background: color-mix(in srgb, var(--color-surface) 45%, transparent);
    box-shadow: inset 0 1px 0 var(--edge-highlight);
    transition: border-color 0.16s, background 0.16s, transform 0.16s;
  }
  .topic-card:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--topic-accent) 55%, var(--color-line));
    background: color-mix(in srgb, var(--topic-accent) 5%, transparent);
  }
  .topic-card::after {
    content: '';
    position: absolute;
    top: -1px;
    right: -1px;
    width: 0.7rem;
    height: 0.7rem;
    border-bottom: 1px solid color-mix(in srgb, var(--topic-accent) 45%, var(--color-line));
    border-left: 1px solid color-mix(in srgb, var(--topic-accent) 45%, var(--color-line));
    background: var(--color-ink);
  }
  .topic-index {
    display: grid;
    grid-template-columns: auto minmax(1.4rem, 3.5rem) auto;
    align-items: center;
    gap: 0.35rem;
    width: min(7.2rem, 65%);
    margin-bottom: 0.65rem;
    color: var(--topic-accent);
    font-family: var(--font-mono);
    font-size: 0.59rem;
    letter-spacing: 0.08em;
  }
  .topic-index i { height: 1px; background: color-mix(in srgb, var(--topic-accent) 45%, transparent); }
  .topic-index b { width: 0.34rem; height: 0.34rem; border: 1px solid var(--topic-accent); border-radius: 50%; }
  .topic-card strong { color: var(--color-bright); font-size: 0.92rem; }
  .topic-card p {
    display: -webkit-box;
    overflow: hidden;
    margin-top: 0.45rem;
    color: var(--color-muted);
    font-family: var(--font-read);
    font-size: 0.76rem;
    line-height: 1.45;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }
  .topic-card .topic-cta {
    display: block;
    margin-top: 0.65rem;
    color: var(--topic-accent);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .home-risk {
    margin-top: 1.65rem;
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    padding: 1.15rem 0 1.2rem;
  }
  .home-risk :global(.rise) { margin-top: 0; margin-bottom: 0; }
  .feed-heading { margin-bottom: 0.9rem; }
  .feed-heading > p { color: var(--color-muted); }
  @media (min-width: 560px) {
    .need-grid,
    .topic-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (min-width: 880px) {
    .need-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    .topic-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  @media (max-width: 520px) {
    .home-actions { display: grid; grid-template-columns: 1fr; }
    .home-action { width: 100%; }
  }
  @media (prefers-reduced-motion: reduce) {
    .home-action:hover,
    .need-card:hover,
    .topic-card:hover { transform: none; }
  }
</style>
