    .history-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.75rem;
      margin-top: 1.2rem;
      max-width: 48rem;
    }
    @media (min-width: 760px) {
      .history-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    .history-card {
      display: grid;
      gap: 0.4rem;
      min-height: 8.8rem;
      border: 1px solid var(--color-line);
      border-radius: 8px;
      padding: 0.95rem 1rem;
      background: color-mix(in srgb, var(--color-surface) 42%, transparent);
      transition: border-color 0.16s, background 0.16s, transform 0.16s;
    }
    .history-card:hover {
      border-color: color-mix(in srgb, var(--color-signal) 50%, transparent);
      background: color-mix(in srgb, var(--color-signal) 6%, transparent);
      transform: translateY(-1px);
    }
    .history-card span {
      font-family: var(--font-mono);
      font-size: 0.66rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-signal);
    }
    .history-card strong {
      color: var(--color-bright);
      font-family: var(--font-mono);
      font-size: 0.84rem;
      overflow-wrap: anywhere;
    }
    .history-card em {
      color: var(--color-muted);
      font-size: 0.88rem;
      font-style: normal;
      line-height: 1.5;
    }

    /* Indices en cartes */
    .idx-list { display: flex; flex-direction: column; gap: 0.8rem; margin-top: 1.4rem; max-width: 46rem; }
    .idx {
      padding: 1.1rem 1.2rem;
      box-shadow: inset 3px 0 0 color-mix(in srgb, var(--c) 55%, transparent);
    }
    .idx:hover { box-shadow: inset 3px 0 0 var(--c); }
    .idx-h {
      font-family: var(--font-mono); font-size: 0.72rem; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase; color: var(--c);
    }
    .idx-d { margin-top: 0.55rem; color: var(--color-paper); font-size: 0.95rem; line-height: 1.6; }

    .formula {
      margin: 0.8rem 0 0;
      padding: 0.9rem 1rem;
      border: 1px solid var(--color-line);
      border-radius: 10px;
      background: var(--color-surface);
      overflow-x: auto;
      font-family: var(--font-mono);
      font-size: 0.78rem;
      line-height: 1.5;
      color: var(--color-paper);
    }
    .formula + .idx-d { margin-top: 0.8rem; }

    /* Sous-titres */
    .m-sub {
      margin-top: 1.8rem;
      font-family: var(--font-display);
      font-weight: 600;
      font-size: 1.1rem;
      color: var(--color-bright);
    }
    .m-sub::before { content: '› '; color: var(--color-signal); }

    /* Listes */
    .m-list { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 0.85rem; max-width: 42rem; }
    .m-list li { position: relative; padding-left: 1.1rem; color: var(--color-paper); line-height: 1.55; }
    .m-list li::before { content: '·'; position: absolute; left: 0; color: var(--color-signal); font-weight: 700; }

    /* Exemples en cartes */
    .ex-list { display: grid; grid-template-columns: 1fr; gap: 0.8rem; margin-top: 1.1rem; max-width: 46rem; }
    @media (min-width: 640px) { .ex-list { grid-template-columns: 1fr 1fr; } }
    .ex { padding: 1rem 1.1rem; }
    .ex-head { display: flex; align-items: center; gap: 0.6rem; }
    .ex-ticker { font-family: var(--font-display); font-weight: 700; font-size: 1.15rem; color: var(--color-bright); }
    .ex-quad {
      font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--c);
      border: 1px solid color-mix(in srgb, var(--c) 45%, transparent);
      background: color-mix(in srgb, var(--c) 10%, transparent);
      border-radius: 999px; padding: 1px 7px;
    }
    .ex-score { margin-left: auto; font-family: var(--font-mono); font-size: 0.8rem; color: var(--c); }
    .ex-d { margin-top: 0.65rem; color: var(--color-muted); font-size: 0.88rem; line-height: 1.55; }

    /* Encadré limites + disclaimer */
    .m-note {
      margin-top: 1rem; max-width: 46rem;
      padding: 0.95rem 1.15rem;
      border: 1px solid var(--color-line);
      border-left: 2px solid color-mix(in srgb, var(--color-amber) 60%, transparent);
      border-radius: 0 10px 10px 0;
      background: color-mix(in srgb, var(--color-amber) 5%, transparent);
      color: var(--color-muted); font-size: 0.92rem; line-height: 1.6;
    }
    .m-disclaimer {
      margin-top: 2.5rem; max-width: 42rem;
      color: var(--color-muted); font-size: 0.88rem; line-height: 1.6;
      border-top: 1px solid var(--color-line); padding-top: 1.2rem;
    }
  </style>
</BaseLayout>
