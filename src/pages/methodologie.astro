    }
    .tool-card:hover { border-top-color: var(--c); }
    .tool-k {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.11em;
      text-transform: uppercase;
      color: var(--c);
    }
    .tool-t {
      margin-top: 0.7rem;
      font-family: var(--font-read);
      font-size: 0.98rem;
      line-height: 1.5;
      color: var(--color-paper);
    }
    .tool-a {
      margin-top: auto;
      padding-top: 1rem;
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.09em;
      text-transform: uppercase;
      color: var(--color-muted);
    }
