---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import TopicSidebar from '../../components/TopicSidebar.astro';
import { topics, postMatchesTopic, ACCENT_HEX, topicLabelForTags } from '../../config/topics.ts';
import { readingTime } from '../../lib/reading-time.ts';
import { serializeInlineScriptData } from '../../lib/security.ts';

export async function getStaticPaths() {
  const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
  );
  return topics.map((topic) => ({
    params: { slug: topic.slug },
    props: { topic, matched: posts.filter((p) => postMatchesTopic(p.data.tags, topic)) },
  }));
}

const { topic, matched } = Astro.props;
const topicAccent = ACCENT_HEX[topic.accent] ?? ACCENT_HEX.teal;
const canonical = new URL(`/sujet/${topic.slug}/`, Astro.site).toString();
const topicJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${canonical}#dossier`,
  url: canonical,
  name: topic.label,
  description: topic.blurb,
  about: {
    '@type': 'Thing',
    name: topic.label,
    description: topic.question,
  },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: [
      ...topic.entryPoints.map((entry, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: entry.label,
        url: new URL(entry.href, Astro.site).toString(),
      })),
      ...matched.map((post, index) => ({
        '@type': 'ListItem',
        position: topic.entryPoints.length + index + 1,
        name: post.data.title,
        url: new URL(`/posts/${post.id}/`, Astro.site).toString(),
      })),
    ],
  },
};
---

<BaseLayout title={`${topic.label} — sujet`} description={topic.blurb}>
  <TopicSidebar slot="sidebar" topic={topic} analysisCount={matched.length} />

  <script type="application/ld+json" is:inline set:html={serializeInlineScriptData(topicJsonLd)} />

  <section class="rise" data-topic-pillar={topic.slug}>
    <p class="mono-label">
      <a href="/sujets/" class="link-term" style="color: var(--color-signal)">// sujets</a>
      <span class="text-muted"> / {topic.label}</span>
    </p>
    <h1 class="mt-3 font-display text-4xl leading-none tracking-wider glow sm:text-5xl">
      {topic.label}
    </h1>
    <p class="mt-4 max-w-2xl text-muted">{topic.blurb}</p>
    <p class="mt-4 max-w-2xl text-bright">
      <strong>Question directrice :</strong> {topic.question}
    </p>
    <p class="mono-label mt-3 text-muted">
      {topic.entryPoints.length} référence{topic.entryPoints.length > 1 ? 's' : ''}
      <span aria-hidden="true"> · </span>
      {matched.length} analyse{matched.length > 1 ? 's' : ''} datée{matched.length > 1 ? 's' : ''}
    </p>
  </section>

  <section class="pt-8" aria-labelledby="parcours">
    <p class="mono-label" style="color: var(--color-signal)">// hiérarchie éditoriale</p>
    <h2 id="parcours" class="mt-2 font-display text-2xl tracking-wider text-bright">Commencer ici</h2>
    <p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted">
      Ce dossier est la page-pilier du sujet. Les guides exposent les mécanismes durables,
      le glossaire fixe les définitions, les méthodologies documentent les calculs et les
      analyses ci-dessous traitent des événements à leur date.
    </p>
    <div class="mt-5 grid gap-3 sm:grid-cols-2">
      {topic.entryPoints.map((entry) => (
        <a
          href={entry.href}
          class="pillar-card block rounded-xl border border-line p-4"
          style={`--topic-accent:${topicAccent}`}
        >
          <span class="mono-label" style="color: var(--topic-accent)">// {entry.kind}</span>
          <h3 class="mt-2 font-semibold text-bright">{entry.label}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted">{entry.detail}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="pb-4 pt-10" aria-labelledby="analyses-datees">
    <p class="mono-label" style="color: var(--color-signal)">// chronologie</p>
    <h2 id="analyses-datees" class="mt-2 font-display text-2xl tracking-wider text-bright">
      Analyses datées
    </h2>
    {
      matched.map((post, i) => (
        <PostCard
          url={`/posts/${post.id}/`}
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          updatedDate={post.data.updatedDate}
          tags={post.data.tags}
          readingTime={readingTime(post.body)}
          index={i + 1}
          accent={topicAccent}
          accentLabel={topicLabelForTags(post.data.tags || [])}
        />
      ))
    }
    {matched.length === 0 && <p class="text-muted">Aucun article pour l'instant.</p>}
  </section>

  <nav class="mono-label border-t border-dashed border-line py-6">
    <a href="/sujets/" class="link-term">← tous les sujets</a>
  </nav>

  <style>
    .pillar-card {
      transition: border-color 0.2s, background 0.2s, transform 0.2s;
    }
    .pillar-card:hover {
      border-color: color-mix(in srgb, var(--topic-accent) 60%, transparent);
      background: color-mix(in srgb, var(--topic-accent) 6%, transparent);
      transform: translateY(-1px);
    }
  </style>
</BaseLayout>
