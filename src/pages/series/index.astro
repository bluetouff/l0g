---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustBar from '../../components/TrustBar.astro';
import FreshnessBadge from '../../components/FreshnessBadge.astro';
import { buildSignalHistorySurface } from '../../lib/signal-history.ts';

const history = buildSignalHistorySurface();
const chartWidth = 920;
const chartHeight = 330;
const chartPadX = 50;
const chartPadY = 32;
const chartBottom = 42;
const colors: Record<string, string> = {
  us: '#5eead4',
  eu: '#7aa2f7',
  yen: '#ffd166',
  energie: '#ff8a3d',
  debt: '#ff4d87',
};
const dashPatterns: Record<string, string | undefined> = {
  us: undefined,
  eu: '10 4',
  yen: '2 4',
  energie: '12 4 2 4',
  debt: '6 3',
};
const dailySeries = history.instruments.map((series) => {
  const byDay = new Map<string, (typeof history.observations)[number]>();
  for (const observation of history.observations
    .filter((item) => item.instrument === series.key && typeof item.value === 'number')
    .sort((left, right) => left.seriesDate.localeCompare(right.seriesDate))) {
    byDay.set(observation.seriesDate.slice(0, 10), observation);
  }
  return { series, observations: [...byDay.values()] };
});
const allTimes = dailySeries.flatMap(({ observations }) => observations.map((item) => Date.parse(item.seriesDate)));
const chartMin = allTimes.length ? Math.min(...allTimes) : 0;
const chartMax = allTimes.length ? Math.max(...allTimes) : 1;
const chartSpan = Math.max(1, chartMax - chartMin);
const chartLines = dailySeries.map(({ series, observations }) => {
  const points = observations.map((item) => ({
    item,
    x: chartPadX + ((Date.parse(item.seriesDate) - chartMin) / chartSpan) * (chartWidth - chartPadX * 2),
    y: chartHeight - chartBottom - ((item.value as number) / 100) * (chartHeight - chartPadY - chartBottom),
  }));
  return {
    series,
    color: colors[series.key],
    dashPattern: dashPatterns[series.key],
    points,
    path: points.map((point, index) => `${index ? 'L' : 'M'} ${point.x.toFixed(2)} ${point.y.toFixed(2)}`).join(' '),
  };
});
const site = (Astro.site?.toString() ?? 'https://l0g.fr/').replace(/\/$/, '');
const trustItems = [
  { label: 'archive append-only', href: '/black-box/' },
  { label: 'méthodes versionnées', href: '/changelog-editorial/' },
  { label: 'CSV par série', href: '#series' },
  { label: 'CC BY 4.0', href: 'https://creativecommons.org/licenses/by/4.0/' },
];
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${site}/series/#collection`,
  name: 'Séries de risque l0g',
  description: 'Registre public des séries de risque l0g nommées, datées, téléchargeables et reliées à une méthodologie versionnée.',
  url: `${site}/series/`,
  inLanguage: 'fr',
  isAccessibleForFree: true,
  license: 'https://creativecommons.org/licenses/by/4.0/',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: history.instruments.map((series, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: series.name,
      url: series.page,
    })),
  },
};
---

<BaseLayout
  title="Séries de risque l0g"
  description="Séries de risque l0g nommées, datées, téléchargeables et reliées à une méthodologie versionnée et une archive append-only."
  sidebar={false}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')} />

  <article class="series-page rise" data-pagefind-body>
    <section class="series-hero">
      <p class="mono-label glow">// séries l0g</p>
      <h1 class="series-title font-display glow">Un signal nommé peut devenir une référence.</h1>
      <p class="series-lede">
        Chaque jauge du tableau consolidé possède désormais un identifiant stable, un nom citable,
        une série datée et ses propres exports. La continuité vient du journal opérationnel
        réellement publié ; les frames Black Box ajoutent un niveau de preuve attesté. Aucun
        point absent n’est interpolé.
      </p>
      <TrustBar items={trustItems} />
    </section>

    <section class="series-metrics" aria-label="Couverture des séries">
      <div><span>séries nommées</span><strong>{history.instruments.length}</strong></div>
      <div><span>points publiés</span><strong>{history.coverage.observations}</strong></div>
      <div><span>points append-only</span><strong>{history.coverage.appendOnlyVerifiedObservations}</strong></div>
      <div>
        <span>début disponible</span>
        <strong class="date">
          {history.coverage.firstSeriesDate ? <FreshnessBadge date={new Date(history.coverage.firstSeriesDate)} compact /> : 'n/a'}
        </strong>
      </div>
    </section>

    <section class="series-section" aria-labelledby="history-chart-title">
      <p class="mono-label glow">// variations comparées</p>
      <h2 id="history-chart-title" class="chart-title">Cinq courbes quotidiennes, une lecture de 0 à 100.</h2>
      <p class="chart-subtitle">
        Dernier snapshot publié de chaque jour UTC, du {new Date(chartMin).toISOString().slice(0, 10)} au {new Date(chartMax).toISOString().slice(0, 10)}.
      </p>
      <div class="history-chart">
        {allTimes.length ? (
          <svg viewBox={`0 0 ${chartWidth} ${chartHeight}`} role="img" aria-label="Historique quotidien comparé des cinq signaux de risque l0g, de 0 à 100">
            {[0, 25, 50, 75, 100].map((tick) => {
              const y = chartHeight - chartBottom - (tick / 100) * (chartHeight - chartPadY - chartBottom);
              return (
                <g>
                  <line x1={chartPadX} y1={y} x2={chartWidth - chartPadX} y2={y} stroke="rgba(154,163,175,.20)" />
                  <text x="8" y={y + 4} fill="#9aa3af" font-size="12" font-family="monospace">{tick}</text>
                </g>
              );
            })}
            {chartLines.map((line) => (
              <g>
                <path d={line.path} fill="none" stroke={line.color} stroke-width="2.6" stroke-dasharray={line.dashPattern} stroke-linejoin="round" stroke-linecap="round" />
                {line.points.map((point) => point.item.evidenceTier === 'current-snapshot' ? (
                  <rect x={point.x - 3.2} y={point.y - 3.2} width="6.4" height="6.4" rx=".7" fill={line.color} stroke="var(--color-bright)" stroke-width="1">
                    <title>{`${line.series.shortName} · ${point.item.seriesDate.slice(0, 10)} · ${point.item.value}/100 · ${point.item.evidenceTier}`}</title>
                  </rect>
                ) : (
                  <circle
                    cx={point.x}
                    cy={point.y}
                    r="2.8"
                    fill={point.item.evidenceTier === 'attested-archive' ? line.color : 'var(--color-surface)'}
                    stroke={line.color}
                    stroke-width={point.item.evidenceTier === 'attested-archive' ? '.8' : '1.5'}
                  >
                    <title>{`${line.series.shortName} · ${point.item.seriesDate.slice(0, 10)} · ${point.item.value}/100 · ${point.item.evidenceTier}`}</title>
                  </circle>
                ))}
              </g>
            ))}
            <text x={chartPadX} y={chartHeight - 12} fill="#9aa3af" font-size="12" font-family="monospace">
              {new Date(chartMin).toISOString().slice(0, 10)}
            </text>
            <text x={chartWidth - chartPadX} y={chartHeight - 12} text-anchor="end" fill="#9aa3af" font-size="12" font-family="monospace">
              {new Date(chartMax).toISOString().slice(0, 10)}
            </text>
          </svg>
        ) : <p>Aucun point numérique disponible.</p>}
      </div>
      <div class="chart-legend" aria-label="Légende">
        {chartLines.map((line) => (
          <span>
            <svg viewBox="0 0 28 8" aria-hidden="true"><line x1="1" y1="4" x2="27" y2="4" stroke={line.color} stroke-width="2.4" stroke-dasharray={line.dashPattern} /></svg>
            {line.series.shortName}
          </span>
        ))}
      </div>
      <div class="evidence-legend" aria-label="Niveaux de preuve">
        <span><svg viewBox="0 0 12 12" aria-hidden="true"><circle cx="6" cy="6" r="3" fill="var(--color-surface)" stroke="currentColor" stroke-width="1.5" /></svg>historique opérationnel</span>
        <span><svg viewBox="0 0 12 12" aria-hidden="true"><circle cx="6" cy="6" r="3" fill="currentColor" /></svg>archive attestée</span>
        <span><svg viewBox="0 0 12 12" aria-hidden="true"><rect x="2.5" y="2.5" width="7" height="7" rx="1" fill="currentColor" /></svg>point courant</span>
      </div>
      <p class="chart-caption">
        Chaque score est normalisé sur 0-100 selon sa propre méthode : les niveaux sont comparables
        visuellement, pas économiquement. Un point par jour UTC est retenu, toujours le dernier
        snapshot réellement publié ; aucune interpolation entre deux dates.
      </p>
    </section>

    <section class="series-section" id="series">
      <p class="mono-label glow">// registre</p>
      <div class="series-grid">
        {history.instruments.map((series) => {
          const current = history.current[series.key];
          return (
            <article class="series-card">
              <div class="series-card-head">
                <span>{series.seriesId}</span>
                <strong>{current?.value ?? 'n/a'}{current ? `/${current.scale}` : ''}</strong>
              </div>
              <h2><a href={`/series/${series.slug}/`}>{series.name}</a></h2>
              <p>{series.description}</p>
              <dl>
                <div><dt>méthode</dt><dd>{series.methodologyVersion}</dd></div>
                <div><dt>points</dt><dd>{series.coverage.observations}</dd></div>
                <div><dt>append-only</dt><dd>{series.coverage.appendOnlyVerifiedObservations}</dd></div>
              </dl>
              <div class="series-links">
                <a href={`/series/${series.slug}/`}>fiche</a>
                <a href={series.downloads.csv}>CSV</a>
                <a href={series.downloads.json}>JSON</a>
                <a href={series.methodology}>méthode</a>
              </div>
            </article>
          );
        })}
      </div>
    </section>

    <section class="series-section series-note">
      <p class="mono-label glow">// règle de continuité</p>
      <p>
        <code>seriesDate</code> est la date de publication l0g. <code>evidenceTier</code> distingue
        <code>operational-archive</code>, <code>attested-archive</code> et <code>current-snapshot</code>.
        <code>observedAt</code> décrit la date économique amont et peut rester vide. Les points
        antérieurs au lancement du registre méthodologique du 17 juillet 2026 restent marqués
        <code>unversioned-legacy</code> : ils ne sont ni supprimés ni requalifiés rétroactivement.
      </p>
      <p>
        Import opérationnel : <strong>{history.coverage.operationalImport.status}</strong>,
        {` ${history.coverage.operationalImport.rows ?? 0} snapshots bruts → ${history.coverage.operationalImport.dailyObservations} observations quotidiennes.`}
        Le flux brut reste public sur <a href="/api/v1/history.ndjson">/api/v1/history.ndjson</a> ;
        la surface fusionnée et documentée est <a href="/api/v1/signals/history.json">signals/history</a>.
      </p>
    </section>
  </article>

  <style>
    .series-page { max-width: 68rem; }
    .series-hero { padding-bottom: 2.2rem; border-bottom: 1px solid var(--color-line); }
    .series-title { margin-top: 1rem; max-width: 54rem; font-size: clamp(2.1rem, 5vw, 3.5rem); line-height: 1.06; color: var(--color-bright); }
    .series-lede { margin-top: 1.1rem; max-width: 52rem; border-left: 2px solid var(--color-signal); padding-left: 1rem; color: var(--color-paper); font-family: var(--font-read); font-size: 1.12rem; line-height: 1.7; }
    .series-metrics { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .75rem; margin-top: 2rem; }
    @media (min-width: 820px) { .series-metrics { grid-template-columns: repeat(4, minmax(0, 1fr)); } }
    .series-metrics > div, .series-card, .series-note { border: 1px solid var(--color-line); border-radius: 8px; background: color-mix(in srgb, var(--color-surface) 45%, transparent); }
    .series-metrics > div { min-height: 6.5rem; padding: 1rem; }
    .series-metrics span, .series-card-head span, dt { color: var(--color-muted); font-family: var(--font-mono); font-size: .68rem; letter-spacing: .07em; text-transform: uppercase; }
    .series-metrics strong { display: block; margin-top: .45rem; color: var(--color-signal); font-size: 1.6rem; }
    .series-metrics .date { font-size: .85rem; }
    .series-section { margin-top: 3rem; }
    .chart-title { margin-top: .75rem; color: var(--color-bright); font-family: var(--font-display); font-size: 1.45rem; }
    .chart-subtitle { margin-top: .4rem; color: var(--color-muted); font-family: var(--font-mono); font-size: .72rem; }
    .history-chart { margin-top: 1rem; border: 1px solid var(--color-line); border-radius: 8px; padding: .8rem .8rem 1.2rem; overflow-x: auto; background: color-mix(in srgb, var(--color-surface) 45%, transparent); }
    .history-chart svg { display: block; min-width: 48rem; width: 100%; height: auto; }
    .chart-legend { display: flex; flex-wrap: wrap; gap: .55rem 1rem; margin-top: .8rem; }
    .chart-legend span { display: inline-flex; align-items: center; gap: .4rem; color: var(--color-muted); font-family: var(--font-mono); font-size: .7rem; }
    .chart-legend svg { width: 1.5rem; height: .5rem; flex: 0 0 auto; }
    .evidence-legend { display: flex; flex-wrap: wrap; gap: .5rem 1rem; margin-top: .55rem; color: var(--color-muted); font-family: var(--font-mono); font-size: .68rem; }
    .evidence-legend span { display: inline-flex; align-items: center; gap: .35rem; }
    .evidence-legend svg { width: .8rem; height: .8rem; color: var(--color-paper); }
    .chart-caption { margin-top: .75rem; padding-bottom: .35rem; max-width: 58rem; color: var(--color-muted); font-size: .85rem; line-height: 1.6; }
    .series-grid { display: grid; gap: 1rem; margin-top: 1rem; }
    @media (min-width: 820px) { .series-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    .series-card { padding: 1.1rem; }
    .series-card-head { display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
    .series-card-head strong { color: var(--color-amber); font-family: var(--font-mono); }
    .series-card h2 { margin-top: .75rem; color: var(--color-bright); font-family: var(--font-display); font-size: 1.15rem; }
    .series-card h2 a { color: inherit; text-decoration: none; }
    .series-card p { margin-top: .6rem; color: var(--color-muted); line-height: 1.6; }
    .series-card dl { display: grid; grid-template-columns: repeat(3, 1fr); gap: .6rem; margin-top: 1rem; }
    .series-card dl div { border-top: 1px solid var(--color-line); padding-top: .55rem; }
    dd { margin: .2rem 0 0; color: var(--color-paper); font-family: var(--font-mono); font-size: .8rem; }
    .series-links { display: flex; flex-wrap: wrap; gap: .8rem; margin-top: 1rem; }
    .series-links a { color: var(--color-signal); font-family: var(--font-mono); font-size: .72rem; text-transform: uppercase; }
    .series-note { padding: 1rem; }
    .series-note p:not(.mono-label) { margin-top: .65rem; color: var(--color-paper); font-family: var(--font-read); line-height: 1.7; }
    .series-note p + p { margin-top: .75rem; }
    .series-note a { color: var(--color-signal); }
    .series-note code { color: var(--color-amber); }
  </style>
</BaseLayout>
