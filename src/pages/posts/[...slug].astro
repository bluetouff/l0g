---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleEvidence from '../../components/ArticleEvidence.astro';
import CitationBox from '../../components/CitationBox.astro';
import FreshnessBadge from '../../components/FreshnessBadge.astro';
import TrustBar from '../../components/TrustBar.astro';
import { topicForTag } from '../../config/topics.ts';
import { buildArticleEvidence } from '../../lib/article-evidence.ts';
import { readingTime } from '../../lib/reading-time.ts';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const ogImage = post.data.ogImage ?? `/og/${post.id}.png`;
const { Content } = await render(post);

const dateLabel = post.data.pubDate.toLocaleDateString('fr-FR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
const refDate = post.data.updatedDate ?? post.data.pubDate;
const iso = post.data.pubDate.toISOString();
const rt = readingTime(post.body);
const shareUrl = new URL(`/posts/${post.id}/`, Astro.site).toString();
const site = (Astro.site?.toString() ?? 'https://l0g.fr/').replace(/\/$/, '');
const evidence = buildArticleEvidence(post.body ?? '', {
  published: post.data.pubDate,
  updated: post.data.updatedDate,
  url: shareUrl,
  title: post.data.title,
  articleSlug: post.id,
});
const proofBadges = evidence.badges.slice(0, 5);
const proofDepth = evidence.depth;
const evidenceRefs = evidence.claims.flatMap((claim) =>
  claim.references.map((reference) => ({
    ...reference,
    claimId: claim.id,
    claimKind: claim.kind,
    claimText: claim.claim,
    claimDate: claim.claimDateIso ?? claim.dateIso,
    observationDate: claim.observationDateIso ?? claim.dateIso,
    sourcePublicationDate: reference.sourcePublicationDateIso ?? reference.dateIso,
  }))
);
const sourceWorks = Array.from(
  new Map(
    evidenceRefs
      .filter((reference) => reference.href)
      .map((reference) => [
        reference.href,
        {
          '@type': 'CreativeWork',
          '@id': reference.href.startsWith('http') ? reference.href : `${site}${reference.href}`,
          name: reference.label,
          url: reference.href.startsWith('http') ? reference.href : `${site}${reference.href}`,
          datePublished: reference.sourcePublicationDate ?? undefined,
          publisher: reference.host ? { '@type': 'Organization', name: reference.host } : undefined,
          additionalType: reference.kind ?? undefined,
        },
      ])
  ).values()
).slice(0, 24);
const claimReviews = evidence.claims.slice(0, 12).map((claim) => ({
  '@type': 'ClaimReview',
  '@id': `${shareUrl}#claim-review-${claim.id}`,
  url: shareUrl,
  datePublished: claim.dateIso ?? post.data.pubDate.toISOString().slice(0, 10),
  claimReviewed: claim.claim,
  author: { '@id': `${site}/#org` },
  itemReviewed: {
    '@type': 'CreativeWork',
    '@id': `${shareUrl}#claim-${claim.id}`,
    text: claim.claim,
    datePublished: claim.dateIso ?? post.data.pubDate.toISOString().slice(0, 10),
    isPartOf: { '@id': `${shareUrl}#article` },
  },
  reviewAspect: 'relation affirmation-source',
  reviewRating: {
    '@type': 'Rating',
    ratingValue: proofDepth.score,
    bestRating: 5,
    worstRating: 1,
    alternateName: claim.kind,
    ratingExplanation:
      'Score de profondeur de preuve l0g : il décrit la relation entre une affirmation et ses sources, pas une probabilité ni une certification absolue.',
  },
  citation: claim.references.map((reference) =>
    reference.href.startsWith('http') ? reference.href : `${site}${reference.href}`
  ),
}));
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      '@id': `${shareUrl}#article`,
      mainEntityOfPage: { '@id': shareUrl },
      headline: post.data.title,
      description: post.data.description,
      url: shareUrl,
      image: ogImage.startsWith('http') ? ogImage : `${site}${ogImage}`,
      datePublished: post.data.pubDate.toISOString(),
      dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
      inLanguage: 'fr',
      isAccessibleForFree: true,
      license: 'https://creativecommons.org/licenses/by/4.0/',
      author: { '@id': `${site}/#org` },
      publisher: { '@id': `${site}/#org` },
      about: post.data.tags.map((tag) => ({ '@type': 'Thing', name: tag })),
      keywords: post.data.tags,
      wordCount: post.body ? post.body.split(/\s+/).filter(Boolean).length : undefined,
      timeRequired: `PT${rt}M`,
      citation: sourceWorks.map((source) => ({ '@id': source['@id'] })),
      isBasedOn: sourceWorks.map((source) => ({ '@id': source['@id'] })),
      mentions: [
        ...sourceWorks.map((source) => ({ '@id': source['@id'] })),
        ...claimReviews.map((claim) => ({ '@id': claim['@id'] })),
      ],
      additionalProperty: [
        {
          '@type': 'PropertyValue',
          name: 'proofDepth',
          value: proofDepth.label,
          description: proofDepth.detail,
        },
        {
          '@type': 'PropertyValue',
          name: 'proofDepthScore',
          value: proofDepth.score,
        },
      ],
    },
    ...sourceWorks,
    ...claimReviews,
  ],
};
const safeArticleJsonLd = JSON.stringify(articleJsonLd).replace(/</g, '\\u003c');

// Partage : URL absolue + textes encodés. Liens HTML purs, aucun script tiers.
const shareTitle = post.data.title;
const u = encodeURIComponent(shareUrl);
const t = encodeURIComponent(shareTitle);
const share = {
  x: `https://twitter.com/intent/tweet?text=${t}&url=${u}`,
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${u}`,
  linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${u}`,
  bluesky: `https://bsky.app/intent/compose?text=${t}%20${u}`,
};
const trustItems = [
  { label: 'lecture datée', note: dateLabel },
  { label: 'sources citées', href: '/sites-reference/' },
  { label: 'aucun tracker', href: '/rgpd/' },
  { label: 'partage sans script tiers' },
];
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  ogImage={ogImage}
>
  <script type="application/ld+json" is:inline set:html={safeArticleJsonLd} />

  <div class="read-progress" aria-hidden="true"><span></span></div>

  <article class="rise max-w-2xl" data-pagefind-body>
    <header class="post-head mb-10">
      <p class="mono-label glow post-kicker">// analyse</p>

      <h1 class="post-title mt-3 font-display text-[clamp(1.9rem,4.5vw,3rem)] leading-tight tracking-wider glow">
        {post.data.title}
      </h1>

      <p class="post-lede mt-5">{post.data.description}</p>

      <div class="post-meta mono-label mt-6">
        <time datetime={iso} data-pagefind-meta="date">{dateLabel}</time>
        {post.data.updatedDate && (
          <>
            <span class="sep" aria-hidden="true">·</span>
            <time datetime={post.data.updatedDate.toISOString()}>revu le {post.data.updatedDate.toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' })}</time>
          </>
        )}
        <span class="sep" aria-hidden="true">·</span>
        <span>{rt} min de lecture</span>
        <span class="sep" aria-hidden="true">·</span>
        <FreshnessBadge date={refDate} />
        {post.data.tags.length > 0 && <span class="sep" aria-hidden="true">·</span>}
        <span class="post-tags">
          {post.data.tags.map((tag) => {
            const slug = topicForTag(tag);
            return slug
              ? <a href={`/sujet/${slug}/`} class="link-term text-signal">#{tag}</a>
              : <span class="text-signal">#{tag}</span>;
          })}
        </span>
      </div>

      <TrustBar items={trustItems} variant="compact" />
      <div class="proof-strip" aria-label="Niveaux de preuve détectés" data-pagefind-ignore>
        <span class="proof-depth" title={proofDepth.detail}>
          <span aria-hidden="true">{proofDepth.score}</span>
          {proofDepth.label}
        </span>
        {proofBadges.length > 0 && (
          <>
          {proofBadges.map((badge) => (
            <span class={`proof-pill proof-${badge.tone}`} title={badge.detail}>
              <span aria-hidden="true"></span>
              {badge.label}
            </span>
          ))}
          </>
        )}
      </div>
      <div class="post-rule" aria-hidden="true"></div>
    </header>

    <div class="prose">
      <Content />
    </div>

    <ArticleEvidence evidence={evidence} />

    <section class="revision-box" data-pagefind-ignore>
      <p class="mono-label">// historique des révisions</p>
      <ul>
        <li>
          <span>publication</span>
          <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' })}</time>
        </li>
        {post.data.updatedDate ? (
          <li>
            <span>révision</span>
            <time datetime={post.data.updatedDate.toISOString()}>{post.data.updatedDate.toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' })}</time>
          </li>
        ) : (
          <li>
            <span>révision</span>
            <em>aucune révision publiée</em>
          </li>
        )}
      </ul>
      <p>
        Les corrections substantielles suivent la <a href="/protocole-editorial/">politique de correction</a>
        et sont consignées dans le <a href="/changelog-editorial/">changelog éditorial</a>.
      </p>
    </section>

    <CitationBox
      title={post.data.title}
      url={shareUrl}
      kind="analyse"
      published={post.data.pubDate}
      updated={post.data.updatedDate}
    />

    <div class="share mt-14" data-pagefind-ignore>
      <span class="mono-label share-label">// partager</span>
      <div class="share-row">
        <a class="share-btn" href={share.x} target="_blank" rel="noopener nofollow" aria-label="Partager sur X" title="Partager sur X">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          <span>X</span>
        </a>
        <a class="share-btn" href={share.bluesky} target="_blank" rel="noopener nofollow" aria-label="Partager sur Bluesky" title="Partager sur Bluesky">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.479 0-.688-.139-1.86-.902-2.203-.659-.299-1.664-.621-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z"/></svg>
          <span>Bluesky</span>
        </a>
        <a class="share-btn" href={share.linkedin} target="_blank" rel="noopener nofollow" aria-label="Partager sur LinkedIn" title="Partager sur LinkedIn">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.55V9h3.57zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/></svg>
          <span>LinkedIn</span>
        </a>
        <a class="share-btn" href={share.facebook} target="_blank" rel="noopener nofollow" aria-label="Partager sur Facebook" title="Partager sur Facebook">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07C0 18.1 4.39 23.1 10.13 24v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.69.24 2.69.24v2.97h-1.52c-1.49 0-1.96.93-1.96 1.89v2.25h3.33l-.53 3.49h-2.8V24C19.61 23.1 24 18.1 24 12.07z"/></svg>
          <span>Facebook</span>
        </a>
        <button class="share-btn" type="button" data-copy-url={shareUrl} aria-label="Copier le lien" title="Copier le lien">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1"/></svg>
          <span data-copy-label>Copier le lien</span>
        </button>
      </div>
    </div>

    <hr class="hairline mt-12" />
    <a href="/" class="mono-label link-term mt-6 inline-block">$ cd ..</a>
  </article>

  <script is:inline>
    document.querySelectorAll('[data-copy-url]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var url = btn.getAttribute('data-copy-url');
        var label = btn.querySelector('[data-copy-label]');
        var flash = function (text) {
          if (!label) return;
          var original = label.textContent;
          label.textContent = text;
          setTimeout(function () { label.textContent = original; }, 1800);
        };
        if (!url || !window.isSecureContext || !navigator.clipboard || !navigator.clipboard.writeText) {
          flash('Copie indisponible');
          return;
        }
        navigator.clipboard.writeText(url)
          .then(function () { flash('Lien copié'); })
          .catch(function () { flash('Copie indisponible'); });
      });
    });
  </script>

  <script is:inline>
    (function () {
      var bar = document.querySelector('.read-progress > span');
      if (!bar) return;
      var ticking = false;
      function update() {
        var h = document.documentElement;
        var max = h.scrollHeight - h.clientHeight;
        var p = max > 0 ? h.scrollTop / max : 0;
        bar.style.transform = 'scaleX(' + p.toFixed(4) + ')';
        ticking = false;
      }
      function onScroll() {
        if (!ticking) { ticking = true; requestAnimationFrame(update); }
      }
      document.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll);
      update();
    })();
  </script>

  <style>
    /* Barre de progression de lecture */
    .read-progress {
      position: fixed; top: 0; left: 0; right: 0; height: 2px;
      z-index: 60; pointer-events: none; background: transparent;
    }
    .read-progress > span {
      display: block; height: 100%; width: 100%;
      transform: scaleX(0); transform-origin: 0 50%;
      background: linear-gradient(90deg, var(--color-signal), color-mix(in srgb, var(--color-signal) 45%, var(--color-accent)));
      box-shadow: 0 0 8px color-mix(in srgb, var(--color-signal) 50%, transparent);
    }

    /* En-tête d'article */
    .post-kicker { color: var(--color-signal); }
    .post-lede {
      font-size: 1.18rem;
      line-height: 1.6;
      color: var(--color-paper);
      border-left: 2px solid color-mix(in srgb, var(--color-signal) 45%, transparent);
      padding-left: 0.9rem;
    }
    .post-meta {
      display: flex; flex-wrap: wrap; align-items: center; gap: 0.6rem;
      color: var(--color-muted);
    }
    .post-meta .sep { opacity: 0.45; }
    .post-meta time { color: var(--color-muted); }
    .post-tags { display: inline-flex; flex-wrap: wrap; gap: 0.7rem; }
    .post-rule {
      margin-top: 1.5rem; height: 2px; width: 72px; border-radius: 2px;
      background: linear-gradient(90deg, var(--color-signal), transparent);
    }
    .proof-strip {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      margin-top: 1rem;
    }
    .proof-pill {
      --proof-color: var(--color-muted);
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      border: 1px solid color-mix(in srgb, var(--proof-color) 38%, transparent);
      border-radius: 999px;
      background: color-mix(in srgb, var(--proof-color) 8%, transparent);
      color: var(--proof-color);
      font-family: var(--font-mono);
      font-size: 0.66rem;
      letter-spacing: 0.08em;
      line-height: 1;
      padding: 0.35rem 0.58rem;
      text-transform: uppercase;
    }
    .proof-depth {
      display: inline-flex;
      align-items: center;
      gap: 0.42rem;
      border: 1px solid color-mix(in srgb, var(--color-signal) 45%, transparent);
      border-radius: 999px;
      background: color-mix(in srgb, var(--color-signal) 9%, transparent);
      color: var(--color-signal);
      font-family: var(--font-mono);
      font-size: 0.66rem;
      letter-spacing: 0.08em;
      line-height: 1;
      padding: 0.35rem 0.58rem;
      text-transform: uppercase;
    }
    .proof-depth span {
      display: grid;
      place-items: center;
      width: 1rem;
      height: 1rem;
      border-radius: 999px;
      background: color-mix(in srgb, var(--color-signal) 18%, transparent);
      color: var(--color-bright);
      font-size: 0.58rem;
    }
    .proof-pill span {
      width: 0.38rem;
      height: 0.38rem;
      border-radius: 999px;
      background: var(--proof-color);
      box-shadow: 0 0 9px color-mix(in srgb, var(--proof-color) 45%, transparent);
    }
    .proof-strong { --proof-color: var(--color-signal); }
    .proof-data { --proof-color: #7aa2f7; }
    .proof-secondary { --proof-color: var(--color-muted); }
    .proof-scenario { --proof-color: var(--color-amber); }
    .proof-context { --proof-color: var(--color-accent); }

    .revision-box {
      margin-top: 2rem;
      border: 1px solid var(--color-line);
      border-radius: 8px;
      background: color-mix(in srgb, var(--color-surface) 42%, transparent);
      padding: 1rem;
    }
    .revision-box .mono-label {
      color: var(--color-signal);
    }
    .revision-box ul {
      display: grid;
      gap: 0.5rem;
      margin-top: 0.75rem;
      padding: 0;
      list-style: none;
    }
    .revision-box li {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      justify-content: space-between;
      border-bottom: 1px solid var(--color-line);
      padding-bottom: 0.5rem;
    }
    .revision-box li:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }
    .revision-box span,
    .revision-box time,
    .revision-box em {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      font-style: normal;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .revision-box span { color: var(--color-signal); }
    .revision-box time,
    .revision-box em { color: var(--color-muted); }
    .revision-box p:not(.mono-label) {
      margin-top: 0.8rem;
      color: var(--color-muted);
      font-size: 0.82rem;
      line-height: 1.55;
    }
    .revision-box a { color: var(--color-signal); }

    .share { border-top: 1px solid var(--color-line); padding-top: 1.2rem; }
    .share-label { color: var(--color-signal); display: block; margin-bottom: 0.7rem; }
    .share-row { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .share-btn {
      display: inline-flex; align-items: center; gap: 0.45rem;
      font-family: var(--font-mono); font-size: 0.8rem;
      color: var(--color-muted); background: transparent;
      border: 1px solid var(--color-line); border-radius: 8px;
      padding: 0.4rem 0.7rem; cursor: pointer; text-decoration: none;
      transition: color 0.15s, border-color 0.15s, background 0.15s;
    }
    .share-btn:hover {
      color: var(--color-signal); border-color: var(--color-signal);
      background: color-mix(in srgb, var(--color-signal) 8%, transparent);
    }
  </style>
</BaseLayout>
