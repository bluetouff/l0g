---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { topicForTag } from '../../config/topics.ts';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const dateLabel = post.data.pubDate.toLocaleDateString('fr-FR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
const iso = post.data.pubDate.toISOString();
---

<BaseLayout title={post.data.title} description={post.data.description} ogType="article">
  <article class="rise max-w-2xl" data-pagefind-body>
    <header class="mb-10">
      <div class="mono-label flex flex-wrap items-center gap-3">
        <time datetime={iso} data-pagefind-meta="date">{dateLabel}</time>
        {post.data.tags.map((t) => {
          const slug = topicForTag(t);
          return slug
            ? <a href={`/sujet/${slug}/`} class="link-term text-signal">#{t}</a>
            : <span class="text-signal">#{t}</span>;
        })}
      </div>
      <h1 class="mt-4 font-display text-5xl leading-none tracking-wider glow sm:text-6xl">
        {post.data.title}
      </h1>
      <p class="mt-4 text-lg text-muted">{post.data.description}</p>
    </header>

    <div class="prose">
      <Content />
    </div>

    <hr class="hairline mt-14" />
    <a href="/" class="mono-label link-term mt-6 inline-block">$ cd ..</a>
  </article>
</BaseLayout>
