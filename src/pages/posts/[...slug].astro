---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { topicForTag } from '../../config/topics.ts';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const ogImage = post.data.ogImage ?? `/og/${post.id}.png`;
const { Content } = await render(post);

const dateLabel = post.data.pubDate.toLocaleDateString('fr-FR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
const iso = post.data.pubDate.toISOString();

// Partage : URL absolue + textes encodés. Liens HTML purs, aucun script tiers.
const shareUrl = new URL(`/posts/${post.id}/`, Astro.site).toString();
const shareTitle = post.data.title;
const u = encodeURIComponent(shareUrl);
const t = encodeURIComponent(shareTitle);
const share = {
  x: `https://twitter.com/intent/tweet?text=${t}&url=${u}`,
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${u}`,
  linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${u}`,
  bluesky: `https://bsky.app/intent/compose?text=${t}%20${u}`,
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  ogImage={ogImage}
>
  <article class="rise max-w-2xl" data-pagefind-body>
    <header class="mb-10">
      <div class="mono-label flex flex-wrap items-center gap-3">
        <time datetime={iso} data-pagefind-meta="date">{dateLabel}</time>
        {post.data.tags.map((t) => {
          const slug = topicForTag(t);
          return slug
            ? <a href={`/sujet/${slug}/`} class="link-term text-signal">#{t}</a>
            : <span class="text-signal">#{t}</span>;
        })}
      </div>
      <h1 class="mt-4 font-display text-5xl leading-none tracking-wider glow sm:text-6xl">
        {post.data.title}
      </h1>
      <p class="mt-4 text-lg text-muted">{post.data.description}</p>
    </header>

    <div class="prose">
      <Content />
    </div>

    <div class="share mt-14" data-pagefind-ignore>
      <span class="mono-label share-label">// partager</span>
      <div class="share-row">
        <a class="share-btn" href={share.x} target="_blank" rel="noopener nofollow" aria-label="Partager sur X" title="Partager sur X">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          <span>X</span>
        </a>
        <a class="share-btn" href={share.bluesky} target="_blank" rel="noopener nofollow" aria-label="Partager sur Bluesky" title="Partager sur Bluesky">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.479 0-.688-.139-1.86-.902-2.203-.659-.299-1.664-.621-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z"/></svg>
          <span>Bluesky</span>
        </a>
        <a class="share-btn" href={share.linkedin} target="_blank" rel="noopener nofollow" aria-label="Partager sur LinkedIn" title="Partager sur LinkedIn">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.55V9h3.57zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/></svg>
          <span>LinkedIn</span>
        </a>
        <a class="share-btn" href={share.facebook} target="_blank" rel="noopener nofollow" aria-label="Partager sur Facebook" title="Partager sur Facebook">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07C0 18.1 4.39 23.1 10.13 24v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.69.24 2.69.24v2.97h-1.52c-1.49 0-1.96.93-1.96 1.89v2.25h3.33l-.53 3.49h-2.8V24C19.61 23.1 24 18.1 24 12.07z"/></svg>
          <span>Facebook</span>
        </a>
        <button class="share-btn" type="button" data-copy-url={shareUrl} aria-label="Copier le lien" title="Copier le lien">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1"/></svg>
          <span data-copy-label>Copier le lien</span>
        </button>
      </div>
    </div>

    <hr class="hairline mt-12" />
    <a href="/" class="mono-label link-term mt-6 inline-block">$ cd ..</a>
  </article>

  <script is:inline>
    document.querySelectorAll('[data-copy-url]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var url = btn.getAttribute('data-copy-url');
        var label = btn.querySelector('[data-copy-label]');
        var done = function () {
          if (label) { var o = label.textContent; label.textContent = 'Lien copié'; setTimeout(function () { label.textContent = o; }, 1800); }
        };
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(url).then(done).catch(done);
        } else {
          var ta = document.createElement('textarea');
          ta.value = url; document.body.appendChild(ta); ta.select();
          try { document.execCommand('copy'); } catch (e) {}
          document.body.removeChild(ta); done();
        }
      });
    });
  </script>

  <style>
    .share { border-top: 1px solid var(--color-line); padding-top: 1.2rem; }
    .share-label { color: var(--color-signal); display: block; margin-bottom: 0.7rem; }
    .share-row { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .share-btn {
      display: inline-flex; align-items: center; gap: 0.45rem;
      font-family: var(--font-mono); font-size: 0.8rem;
      color: var(--color-muted); background: transparent;
      border: 1px solid var(--color-line); border-radius: 8px;
      padding: 0.4rem 0.7rem; cursor: pointer; text-decoration: none;
      transition: color 0.15s, border-color 0.15s, background 0.15s;
    }
    .share-btn:hover {
      color: var(--color-signal); border-color: var(--color-signal);
      background: color-mix(in srgb, var(--color-signal) 8%, transparent);
    }
  </style>
</BaseLayout>
