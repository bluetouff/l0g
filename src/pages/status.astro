---
import { getCollection } from 'astro:content';
import { existsSync, readFileSync, statSync } from 'node:fs';
import { join } from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';
import { serializeInlineScriptData } from '../lib/security.ts';
import TrustBar from '../components/TrustBar.astro';

const site = (Astro.site?.toString() ?? 'https://l0g.fr/').replace(/\/$/, '');
const buildTime = new Date();

const posts = await getCollection('posts', ({ data }) => !data.draft);
const guides = await getCollection('guides', ({ data }) => !data.draft);

function readJSON<T>(rel: string, fallback: T): T {
  try {
    return JSON.parse(readFileSync(join(process.cwd(), rel), 'utf-8')) as T;
  } catch {
    return fallback;
  }
}

function fileStatus(rel: string) {
  const abs = join(process.cwd(), rel);
  if (!existsSync(abs)) return { rel, ok: false, size: null, updated: null };
  const st = statSync(abs);
  return {
    rel,
    ok: true,
    size: st.size,
    updated: st.mtime,
  };
}

function iso(value?: string | Date | null) {
  if (!value) return 'n/a';
  const d = value instanceof Date ? value : new Date(value);
  if (Number.isNaN(d.getTime())) return 'n/a';
  return d.toISOString().replace(/\.\d{3}Z$/, 'Z');
}

function fr(value?: string | Date | null) {
  if (!value) return 'n/a';
  const d = value instanceof Date ? value : new Date(value);
  if (Number.isNaN(d.getTime())) return 'n/a';
  return d.toLocaleString('fr-FR', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
    timeZone: 'Europe/Paris',
  });
}

function bytes(n: number | null) {
  if (n == null) return 'n/a';
  if (n < 1024) return `${n} o`;
  if (n < 1024 * 1024) return `${(n / 1024).toFixed(1)} Ko`;
  return `${(n / 1024 / 1024).toFixed(1)} Mo`;
}

const risk = readJSON<{ updated?: string; indices?: Array<{ key: string; value: number; level: string; tone: string }> }>(
  'public/risk.json',
  { indices: [] }
);
const confluence = readJSON<{ updated?: string; items?: Array<{ ticker: string; score: number; quadrant: string }> }>(
  'public/confluence.json',
  { items: [] }
);
const events = readJSON<{ updated?: string; events?: unknown[] }>('public/risk-events.json', { events: [] });
const lock = readJSON<{ packages?: Record<string, { version?: string }> }>('package-lock.json', { packages: {} });
const astroVersion = lock.packages?.['node_modules/astro']?.version ?? 'n/a';

const artifacts = [
  fileStatus('public/risk.json'),
  fileStatus('public/confluence.json'),
  fileStatus('public/risk-events.json'),
  fileStatus('public/og-default.png'),
  fileStatus('public/og-status.png'),
];

const endpoints = [
  { href: '/api/v1/risk.json', label: 'risk.json', type: 'JSON', role: 'signaux normalisés par instrument' },
  { href: '/api/v1/catalog.json', label: 'catalog.json', type: 'JSON', role: 'catalogue articles, guides, méthodes' },
  { href: '/api/v1/risk.xml', label: 'risk.xml', type: 'Atom', role: 'changements de niveau' },
  { href: '/llms.txt', label: 'llms.txt', type: 'TXT', role: 'carte agents IA' },
  { href: '/llms-full.txt', label: 'llms-full.txt', type: 'TXT', role: 'corpus texte complet' },
  { href: '/.well-known/security.txt', label: 'security.txt', type: 'TXT', role: 'contact vulnérabilités' },
  { href: '/rss.xml', label: 'rss.xml', type: 'RSS', role: 'flux éditorial' },
];

const trustItems = [
  { label: 'build statique', href: '/terminal/' },
  { label: 'zéro tracker maison', href: '/rgpd/' },
  { label: 'api publique', href: '/api/' },
  { label: 'corpus machine', href: '/llms.txt' },
];

const checks = [
  { label: 'Build', value: 'OK', detail: `généré le ${fr(buildTime)}`, tone: 'ok' },
  { label: 'Astro', value: astroVersion, detail: 'version lockfile', tone: 'ok' },
  { label: 'Articles', value: String(posts.length), detail: 'analyses publiées', tone: 'ok' },
  { label: 'Guides', value: String(guides.length), detail: 'références maintenues', tone: 'ok' },
  { label: 'Risk snapshot', value: risk.updated ? 'présent' : 'absent', detail: fr(risk.updated), tone: risk.updated ? 'ok' : 'warn' },
  { label: 'Confluence', value: `${confluence.items?.length ?? 0} lignes`, detail: fr(confluence.updated), tone: confluence.items?.length ? 'ok' : 'warn' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${site}/status/#integrity`,
  name: 'Statut & intégrité l0g',
  description:
    'État statique de l0g.fr : build, snapshots publics, endpoints, corpus machine, hygiène de tracking et intégrité éditoriale.',
  inLanguage: 'fr',
  isAccessibleForFree: true,
  dateModified: buildTime.toISOString(),
  publisher: { '@id': `${site}/#org` },
  url: `${site}/status/`,
};
---

<BaseLayout
  title="Statut & intégrité"
  description="État statique de l0g.fr : build, snapshots publics, endpoints, corpus machine, hygiène de tracking et intégrité éditoriale."
  ogImage="/og-status.png"
  ogImageAlt="Statut et intégrité l0g : build statique, API publique, zéro tracker"
  sidebar={false}
>
  <script type="application/ld+json" is:inline set:html={serializeInlineScriptData(jsonLd)} />

  <article class="status-page rise" data-pagefind-body>
    <section class="status-hero" data-pagefind-ignore>
      <p class="mono-label glow">// statut & intégrité</p>
      <h1 class="status-title font-display glow">
        État public du site, des données et des garanties.
      </h1>
      <p class="status-lede">
        Cette page expose ce qui peut être vérifié côté lecteur : génération statique,
        artefacts publics, endpoints disponibles, corpus machine et hygiène de tracking.
      </p>
      <TrustBar items={trustItems} />
      <p class="status-build mono-label">build observé : <time datetime={iso(buildTime)}>{fr(buildTime)}</time></p>
    </section>

    <section class="status-section">
      <p class="mono-label glow">// contrôle rapide</p>
      <div class="check-grid">
        {checks.map((check) => (
          <article class={`check-card ${check.tone}`}>
            <span class="check-label">{check.label}</span>
            <strong>{check.value}</strong>
            <span>{check.detail}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="status-section split">
      <div>
        <p class="mono-label glow">// snapshots publics</p>
        <div class="artifact-list">
          {artifacts.map((file) => (
            <div class="artifact">
              <span class={`dot ${file.ok ? 'ok' : 'warn'}`} aria-hidden="true"></span>
              <code>{file.rel.replace('public/', '/')}</code>
              <span>{file.ok ? bytes(file.size) : 'absent'}</span>
              <time datetime={file.updated ? iso(file.updated) : undefined}>{file.updated ? fr(file.updated) : 'n/a'}</time>
            </div>
          ))}
        </div>
      </div>

      <div>
        <p class="mono-label glow">// dernier signal</p>
        <div class="signal-card">
          <div>
            <span>risk.json</span>
            <strong>{risk.indices?.length ?? 0} indices</strong>
            <em>{fr(risk.updated)}</em>
          </div>
          <div>
            <span>risk-events</span>
            <strong>{events.events?.length ?? 0} événement(s)</strong>
            <em>{fr(events.updated)}</em>
          </div>
          <div>
            <span>confluence</span>
            <strong>{confluence.items?.[0]?.ticker ?? 'n/a'}</strong>
            <em>{confluence.items?.[0] ? `top score ${confluence.items[0].score}` : 'aucune ligne'}</em>
          </div>
        </div>
      </div>
    </section>

    <section class="status-section">
      <p class="mono-label glow">// endpoints vérifiables</p>
      <div class="endpoint-grid">
        {endpoints.map((endpoint) => (
          <a href={endpoint.href} class="endpoint">
            <span>{endpoint.type}</span>
            <strong>{endpoint.label}</strong>
            <em>{endpoint.role}</em>
          </a>
        ))}
      </div>
    </section>

    <section class="status-section split">
      <div class="integrity-note">
        <p class="mono-label glow">// hygiène front</p>
        <ul>
          <li>Site généré statiquement : pas de session applicative côté l0g.fr.</li>
          <li>Recherche locale Pagefind, servie depuis le domaine.</li>
          <li>CSP Apache déclarée : self par défaut, TradingView explicitement isolé.</li>
          <li>Aucun cookie ni tracker maison.</li>
          <li>Les embeds TradingView restent les seuls scripts tiers fonctionnels.</li>
        </ul>
      </div>
      <div class="integrity-note">
        <p class="mono-label glow">// limites</p>
        <ul>
          <li>Les snapshots reflètent la dernière publication disponible, pas du temps réel strict.</li>
          <li>Les fichiers publics peuvent être mis en cache en aval selon le client ou le proxy.</li>
          <li>Cette page prouve l'état du site publié, pas l'état des sources externes.</li>
        </ul>
      </div>
    </section>
  </article>

  <style>
    .status-page { max-width: 64rem; }
    .status-hero {
      padding-bottom: 2.2rem;
      border-bottom: 1px solid var(--color-line);
    }
    .status-title {
      margin-top: 1rem;
      max-width: 48rem;
      font-size: clamp(2rem, 4.5vw, 3rem);
      line-height: 1.14;
      letter-spacing: 0.02em;
      color: var(--color-bright);
    }
    .status-lede {
      margin-top: 1.15rem;
      max-width: 45rem;
      border-left: 2px solid var(--color-signal);
      padding-left: 1rem;
      font-family: var(--font-read);
      font-size: clamp(1.05rem, 2vw, 1.2rem);
      line-height: 1.66;
      color: var(--color-paper);
    }
    .status-build {
      margin-top: 1rem;
      color: var(--color-muted);
    }
    .status-section { margin-top: 3rem; }
    .check-grid,
    .endpoint-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.75rem;
      margin-top: 1rem;
    }
    @media (min-width: 720px) {
      .check-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
      .endpoint-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    }
    .check-card,
    .endpoint,
    .signal-card,
    .integrity-note {
      border: 1px solid var(--color-line);
      border-radius: 8px;
      background: color-mix(in srgb, var(--color-surface) 42%, transparent);
    }
    .check-card {
      display: flex;
      min-height: 8.2rem;
      flex-direction: column;
      justify-content: space-between;
      padding: 1rem;
      border-top: 2px solid color-mix(in srgb, var(--color-signal) 55%, transparent);
    }
    .check-card.warn { border-top-color: var(--color-amber); }
    .check-label,
    .endpoint span,
    .signal-card span {
      font-family: var(--font-mono);
      font-size: 0.62rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-signal);
    }
    .check-card strong,
    .endpoint strong,
    .signal-card strong {
      display: block;
      margin-top: 0.45rem;
      color: var(--color-bright);
      font-size: 1.1rem;
      line-height: 1.25;
    }
    .check-card span:last-child,
    .endpoint em,
    .signal-card em {
      color: var(--color-muted);
      font-size: 0.82rem;
      line-height: 1.45;
      font-style: normal;
    }
    .split {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }
    @media (min-width: 820px) {
      .split { grid-template-columns: 1fr 1fr; }
    }
    .artifact-list {
      margin-top: 1rem;
      border: 1px solid var(--color-line);
      border-radius: 8px;
      overflow: hidden;
    }
    .artifact {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 0.65rem;
      align-items: center;
      padding: 0.72rem 0.85rem;
      border-bottom: 1px solid var(--color-line);
      color: var(--color-muted);
      font-size: 0.78rem;
    }
    .artifact:last-child { border-bottom: 0; }
    .artifact code {
      min-width: 0;
      overflow: hidden;
      color: var(--color-paper);
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .artifact time {
      grid-column: 2 / -1;
      color: var(--color-muted);
      font-size: 0.72rem;
    }
    .dot {
      width: 0.52rem;
      height: 0.52rem;
      border-radius: 50%;
      background: var(--color-muted);
    }
    .dot.ok {
      background: var(--color-signal);
      box-shadow: 0 0 10px color-mix(in srgb, var(--color-signal) 45%, transparent);
    }
    .dot.warn {
      background: var(--color-amber);
      box-shadow: 0 0 10px color-mix(in srgb, var(--color-amber) 45%, transparent);
    }
    .signal-card {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0;
      margin-top: 1rem;
      overflow: hidden;
    }
    .signal-card > div {
      padding: 1rem;
      border-bottom: 1px solid var(--color-line);
    }
    .signal-card > div:last-child { border-bottom: 0; }
    .endpoint {
      min-height: 7.2rem;
      padding: 1rem;
      transition: border-color 0.16s, background 0.16s, transform 0.16s;
    }
    .endpoint:hover {
      border-color: color-mix(in srgb, var(--color-signal) 45%, transparent);
      background: color-mix(in srgb, var(--color-signal) 7%, transparent);
      transform: translateY(-1px);
    }
    .integrity-note {
      padding: 1rem;
    }
    .integrity-note ul {
      display: grid;
      gap: 0.55rem;
      margin-top: 0.85rem;
      font-family: var(--font-read);
      color: var(--color-paper);
    }
    .integrity-note li {
      position: relative;
      padding-left: 1rem;
      line-height: 1.58;
    }
    .integrity-note li::before {
      content: "·";
      position: absolute;
      left: 0;
      color: var(--color-signal);
      font-family: var(--font-mono);
      font-weight: 700;
    }
    @media (prefers-reduced-motion: reduce) {
      .endpoint { transition: border-color 0.16s, background 0.16s; }
      .endpoint:hover { transform: none; }
    }
  </style>
</BaseLayout>
