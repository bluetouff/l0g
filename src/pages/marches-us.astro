---
import BaseLayout from '../layouts/BaseLayout.astro';
import TradingViewChart from '../components/TradingViewChart.astro';
import SymbolOverview from '../components/SymbolOverview.astro';
import Heatmap from '../components/Heatmap.astro';
---

<BaseLayout title="Marchés US" description="Dashboard actions US : S&P 500, indices majeurs, volatilité et heatmap sectorielle.">
  <section class="mb-4">
    <p class="mono-label">// dashboard</p>
    <h1 class="mt-2 font-display text-5xl leading-none tracking-wider glow sm:text-6xl">Marchés US</h1>
    <p class="mt-3 max-w-2xl text-muted">
      Indices actions américains, volatilité, et répartition sectorielle du S&amp;P 500.
    </p>
  </section>


  <h2 class="mono-label glow mb-1 mt-8">// heatmap S&amp;P 500</h2>
  <Heatmap kind="stock" dataSource="SPX500" height={500} />
</BaseLayout>
