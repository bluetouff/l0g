---
import '../styles/global.css';
import { existsSync } from 'node:fs';
import { join } from 'node:path';

type AlternateLink = { hreflang: string; href: string };

interface Props {
  title?: string;
  description?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  ogImageAlt?: string;
  canonical?: string;
  alternateLinks?: AlternateLink[];
}

const {
  title = 'l0g in English',
  description = 'English entry points from l0g.fr: reference guides, methodology, API, MCP and machine-readable risk intelligence.',
  ogType = 'website',
  ogImage = '/og-default.png',
  ogImageAlt,
  canonical = new URL(Astro.url.pathname, Astro.site).toString(),
  alternateLinks = [],
} = Astro.props;

const SITE = (Astro.site?.toString() ?? 'https://l0g.fr/').replace(/\/$/, '');
const ogImageUrl = new URL(ogImage, Astro.site).toString();
const fullTitle = `${title} · l0g.fr`;
const socialImageAlt = ogImageAlt ?? `${fullTitle} — l0g.fr social card`;
const year = new Date().getFullYear();

const hasPage = (path: string) => existsSync(join(process.cwd(), path));
const nav = [
  { href: '/en/', label: 'overview', active: Astro.url.pathname === '/en/' },
  { href: '/en/start/', label: 'start', active: Astro.url.pathname.startsWith('/en/start'), show: hasPage('src/pages/en/start/index.astro') },
  { href: '/en/tour/', label: 'tour', active: Astro.url.pathname.startsWith('/en/tour'), show: hasPage('src/pages/en/tour/index.astro') },
  { href: '/en/guides/', label: 'guides', active: Astro.url.pathname.startsWith('/en/guides'), show: hasPage('src/pages/en/guides/index.astro') },
  { href: '/en/analysis/', label: 'analysis', active: Astro.url.pathname.startsWith('/en/analysis'), show: hasPage('src/pages/en/analysis/index.astro') },
  { href: '/en/methodology/', label: 'method', active: Astro.url.pathname.startsWith('/en/methodology'), show: hasPage('src/pages/en/methodology/index.astro') },
  { href: '/en/sources/', label: 'sources', active: Astro.url.pathname.startsWith('/en/sources'), show: hasPage('src/pages/en/sources/index.astro') },
  { href: '/en/api/', label: 'api', active: Astro.url.pathname.startsWith('/en/api'), show: hasPage('src/pages/en/api/index.astro') },
  { href: '/en/mcp/', label: 'mcp', active: Astro.url.pathname.startsWith('/en/mcp'), show: hasPage('src/pages/en/mcp/index.astro') },
  { href: '/', label: 'fr', active: false, show: true },
].filter((item) => item.show !== false);

const footerLinks = [
  { href: '/en/guides/', label: 'guides', show: hasPage('src/pages/en/guides/index.astro') },
  { href: '/en/analysis/', label: 'analysis', show: hasPage('src/pages/en/analysis/index.astro') },
  { href: '/en/methodology/', label: 'methodology', show: hasPage('src/pages/en/methodology/index.astro') },
  { href: '/en/sources/', label: 'sources', show: hasPage('src/pages/en/sources/index.astro') },
  { href: '/en/api/', label: 'api', show: hasPage('src/pages/en/api/index.astro') },
  { href: '/en/mcp/', label: 'mcp', show: hasPage('src/pages/en/mcp/index.astro') },
  { href: '/en/agent-surface/', label: 'agent surface', show: hasPage('src/pages/en/agent-surface/index.astro') },
  { href: '/', label: 'french site', show: true },
].filter((item) => item.show);

const siteJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${SITE}/#org`,
      name: 'l0g',
      alternateName: 'l0g.fr',
      url: `${SITE}/`,
      logo: `${SITE}/favicon.svg`,
      description: 'Risk intelligence: mapping opaque finance, systemic risk and financial geopolitics with public data.',
      sameAs: ['https://github.com/bluetouff', 'https://x.com/bluetouff'],
    },
    {
      '@type': 'WebSite',
      '@id': `${SITE}/#website`,
      url: `${SITE}/`,
      name: 'l0g',
      inLanguage: 'en',
      publisher: { '@id': `${SITE}/#org` },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="l0g.fr in English" href="/en/rss.xml" />
    <meta name="generator" content={Astro.generator} />

    <script is:inline>
      (function () {
        try {
          var k = 'l0g-theme';
          var s = localStorage.getItem(k);
          var t = (s === 'light' || s === 'dark')
            ? s
            : (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternateLinks.map((link) => (
      <link rel="alternate" hreflang={link.hreflang} href={link.href} />
    ))}

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="l0g.fr" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@bluetouff" />
    <meta name="twitter:creator" content="@bluetouff" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={socialImageAlt} />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(siteJsonLd).replace(/</g, '\\u003c')} />
  </head>

  <body class="en-shell">
    <div class="topbar" aria-hidden="true"></div>
    <div class="en-backdrop" aria-hidden="true"></div>
    <div class="mx-auto max-w-6xl px-5 py-7 sm:py-9">
      <header class="en-header">
        <a href="/en/" class="brand en-brand" aria-label="l0g English home">
          <span class="brand-mark">
            <span class="text-paper">l</span><span class="brand-0 text-signal">0</span><span class="text-paper">g</span><span class="blink text-accent" aria-hidden="true">_</span>
          </span>
          <span class="brand-sep" aria-hidden="true"></span>
          <span class="brand-tag mono-label">risk intelligence · english</span>
        </a>

        <nav class="en-nav" aria-label="English navigation">
          {nav.map((item) => (
            <a href={item.href} class="nav-tab" aria-current={item.active ? 'page' : undefined}>{item.label}</a>
          ))}
        </nav>
      </header>

      <main class="min-w-0 py-8">
        <slot />
      </main>
    </div>

    <footer class="site-footer en-footer">
      <div class="footer-grad" aria-hidden="true"></div>
      <div class="footer-inner mx-auto max-w-6xl px-5">
        <p class="mono-label">// l0g English layer</p>
        <p class="en-footer-text">
          l0g.fr is primarily published in French. The English layer exposes the durable, reusable parts of the project: reference guides, methodology, sources, machine-readable APIs and selected risk tools.
        </p>
        <p class="en-footer-links">
          {footerLinks.map((link, index) => (
            <>
              {index > 0 && <span aria-hidden="true"> · </span>}
              <a href={link.href} class="link-term">{link.label}</a>
            </>
          ))}
        </p>
        <p class="mono-label en-copy">© {year} l0g.fr · CC BY 4.0 unless stated otherwise</p>
      </div>
    </footer>
  </body>
</html>

<style>
  .en-shell { position: relative; }
  .en-backdrop {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(circle at 16% 6%, color-mix(in srgb, var(--color-signal) 18%, transparent), transparent 29rem),
      radial-gradient(circle at 88% 4%, color-mix(in srgb, var(--color-accent) 16%, transparent), transparent 28rem),
      radial-gradient(circle at 60% 92%, color-mix(in srgb, var(--color-amber) 8%, transparent), transparent 24rem),
      linear-gradient(180deg, color-mix(in srgb, var(--color-surface) 31%, transparent), transparent 34rem);
  }
  .en-header {
    display: grid;
    gap: 1rem;
    align-items: end;
  }
  .en-brand { text-decoration: none; }
  .en-nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 1.05rem;
  }
  .en-nav .nav-tab[aria-current='page'] {
    color: var(--color-signal);
    text-shadow: 0 0 18px color-mix(in srgb, var(--color-signal) 35%, transparent);
  }
  .en-footer-text {
    margin-top: 0.45rem;
    max-width: 48rem;
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }
  .en-footer-links { margin-top: 0.75rem; font-family: var(--font-mono); font-size: 0.75rem; }
  .en-copy { margin-top: 1.2rem; color: var(--color-muted); }
  @media (min-width: 860px) {
    .en-header { grid-template-columns: auto 1fr; }
    .en-nav { justify-content: flex-end; }
  }
</style>
