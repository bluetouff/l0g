---
import '../styles/global.css';
import { existsSync } from 'node:fs';

const hasPage = (relativePath: string) => existsSync(new URL(relativePath, import.meta.url));

type AlternateLink = { hreflang: string; href: string };

interface Props {
  title?: string;
  description?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  ogImageAlt?: string;
  canonical?: string;
  alternateLinks?: AlternateLink[];
}

const {
  title = 'l0g in English',
  description = 'English entry points from l0g.fr: reference guides, methodology, sources, API, MCP and machine-readable risk data.',
  ogType = 'website',
  ogImage = '/og-default.png',
  ogImageAlt,
  canonical = new URL(Astro.url.pathname, Astro.site).toString(),
  alternateLinks = [],
} = Astro.props;

const SITE = (Astro.site?.toString() ?? 'https://l0g.fr/').replace(/\/$/, '');
const ogImageUrl = new URL(ogImage, Astro.site).toString();
const fullTitle = `${title} · l0g.fr`;
const socialImageAlt = ogImageAlt ?? `${fullTitle} — l0g.fr social card`;
const year = new Date().getFullYear();
const path = Astro.url.pathname;
const norm = (s: string) => (s.length > 1 ? s.replace(/\/$/, '') : s);
const isCurrentHref = (href: string) => {
  const p = norm(path);
  const h = norm(href);
  return h === '/' ? p === '/' : p === h || p.startsWith(h + '/');
};

const navItems = [
  { href: '/en/', label: 'overview' },
  { href: '/en/start/', label: 'start' },
  { href: '/en/about/', label: 'about' },
  { href: '/en/methodology/', label: 'methodology' },
  { href: '/en/sources/', label: 'sources' },
  { href: '/en/guides/', label: 'guides' },
  ...(hasPage('../pages/en/api/index.astro') ? [{ href: '/en/api/', label: 'api' }] : []),
  ...(hasPage('../pages/en/mcp/index.astro') ? [{ href: '/en/mcp/', label: 'mcp' }] : []),
  ...(hasPage('../pages/en/agent-surface/index.astro') ? [{ href: '/en/agent-surface/', label: 'agent surface' }] : []),
];

const siteJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${SITE}/#org`,
      name: 'l0g',
      alternateName: 'l0g.fr',
      url: `${SITE}/`,
      logo: `${SITE}/favicon.svg`,
      description: 'Risk intelligence: mapping opaque finance, systemic risk and financial geopolitics with public data.',
      sameAs: ['https://github.com/bluetouff', 'https://x.com/bluetouff'],
    },
    {
      '@type': 'WebSite',
      '@id': `${SITE}/#website`,
      url: `${SITE}/`,
      name: 'l0g',
      inLanguage: 'en',
      publisher: { '@id': `${SITE}/#org` },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <script is:inline>
      (function () {
        try {
          var k = 'l0g-theme';
          var s = localStorage.getItem(k);
          var t = (s === 'light' || s === 'dark')
            ? s
            : (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternateLinks.map((link) => (
      <link rel="alternate" hreflang={link.hreflang} href={link.href} />
    ))}

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="l0g.fr" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@bluetouff" />
    <meta name="twitter:creator" content="@bluetouff" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={socialImageAlt} />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(siteJsonLd).replace(/</g, '\\u003c')} />
  </head>

  <body>
    <div class="topbar" aria-hidden="true"></div>
    <div class="mx-auto max-w-6xl px-5 py-7 sm:py-9">
      <header>
        <div class="header-top">
          <a href="/en/" class="brand" aria-label="l0g in English">
            <span class="brand-mark">
              <span class="text-paper">l</span><span class="brand-0 text-signal">0</span><span class="text-paper">g</span><span class="blink text-accent" aria-hidden="true">_</span>
            </span>
            <span class="brand-sep" aria-hidden="true"></span>
            <span class="brand-tag mono-label">risk intelligence · english</span>
          </a>
        </div>

        <nav class="main-nav mt-6 flex flex-wrap items-center gap-x-5 gap-y-1 sm:gap-x-6" aria-label="English navigation">
          {navItems.map((item) => (
            <a href={item.href} class="nav-tab" aria-current={isCurrentHref(item.href) ? 'page' : undefined}>{item.label}</a>
          ))}
          <a href="/" class="nav-tab">french site</a>
        </nav>
      </header>

      <main class="min-w-0 py-8">
        <slot />
      </main>
    </div>

    <footer class="site-footer">
      <div class="footer-grad" aria-hidden="true"></div>
      <div class="footer-inner mx-auto max-w-6xl px-5">
        <p class="mono-label">// l0g in English</p>
        <p class="en-footer-text">
          l0g.fr is primarily published in French. This English section covers the durable reference layer:
          guides, methodology, sources, editorial protocol and machine-readable access.
        </p>
        <p class="en-footer-links">
          <a href="/en/start/" class="link-term">Start</a>
          <span aria-hidden="true"> · </span>
          <a href="/en/guides/" class="link-term">English guides</a>
          <span aria-hidden="true"> · </span>
          <a href="/en/methodology/" class="link-term">Methodology</a>
          <span aria-hidden="true"> · </span>
          <a href="/en/sources/" class="link-term">Sources</a>
          <span aria-hidden="true"> · </span>
          <a href="/" class="link-term">l0g.fr</a>
        </p>
        <p class="mono-label en-copy">© {year} l0g.fr</p>
      </div>
    </footer>
  </body>
</html>

<style>
  .en-footer-text {
    margin-top: 0.45rem;
    max-width: 48rem;
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }
  .en-footer-links { margin-top: 0.75rem; font-family: var(--font-mono); font-size: 0.75rem; }
  .en-copy { margin-top: 1.2rem; color: var(--color-muted); }
</style>
