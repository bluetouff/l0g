---
import '../styles/global.css';
import { existsSync } from 'node:fs';
import { join } from 'node:path';

type AlternateLink = { hreflang: string; href: string };

type NavTab = { href: string; label: string; show?: boolean };

interface Props {
  title?: string;
  description?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  ogImageAlt?: string;
  canonical?: string;
  alternateLinks?: AlternateLink[];
}

const {
  title = 'English',
  description = 'English entry points for l0g.fr: guides, methodology, API, MCP, risk surfaces and machine-readable data.',
  ogType = 'website',
  ogImage = '/og-default.png',
  ogImageAlt,
  canonical = new URL(Astro.url.pathname, Astro.site).toString(),
  alternateLinks = [],
} = Astro.props;

const SITE = (Astro.site?.toString() ?? 'https://l0g.fr/').replace(/\/$/, '');
const ogImageUrl = new URL(ogImage, Astro.site).toString();
const fullTitle = `${title} · l0g.fr`;
const socialImageAlt = ogImageAlt ?? `${fullTitle} — l0g.fr social card`;
const year = new Date().getFullYear();
const pageExists = (path: string) => existsSync(join(process.cwd(), 'src/pages', path));

const navTabs: NavTab[] = [
  { href: '/en/', label: 'overview' },
  { href: '/en/start/', label: 'start', show: pageExists('en/start/index.astro') },
  { href: '/en/tour/', label: 'tour', show: pageExists('en/tour/index.astro') },
  { href: '/en/about/', label: 'about', show: pageExists('en/about/index.astro') },
  { href: '/en/manifesto/', label: 'manifesto', show: pageExists('en/manifesto/index.astro') },
  { href: '/en/methodology/', label: 'methodology', show: pageExists('en/methodology/index.astro') },
  { href: '/en/sources/', label: 'sources', show: pageExists('en/sources/index.astro') },
  { href: '/en/editorial-protocol/', label: 'protocol', show: pageExists('en/editorial-protocol/index.astro') },
  { href: '/en/guides/', label: 'guides', show: pageExists('en/guides/index.astro') },
  { href: '/en/glossary/', label: 'glossary', show: pageExists('en/glossary/index.astro') },
  { href: '/en/dashboards/', label: 'dashboards', show: pageExists('en/dashboards/index.astro') },
  { href: '/en/risk-diff/', label: 'risk diff', show: pageExists('en/risk-diff/index.astro') },
  { href: '/en/black-box/', label: 'black box', show: pageExists('en/black-box/index.astro') },
  { href: '/en/api/', label: 'api', show: pageExists('en/api/index.astro') },
  { href: '/en/mcp/', label: 'mcp', show: pageExists('en/mcp/index.astro') },
  { href: '/en/agent-surface/', label: 'agent surface', show: pageExists('en/agent-surface/index.astro') },
].filter((tab) => tab.show !== false);

const norm = (s: string) => (s.length > 1 ? s.replace(/\/$/, '') : s);
function isActive(href: string): boolean {
  const p = norm(Astro.url.pathname);
  const h = norm(href);
  return h === '/en' ? p === '/en' : p === h || p.startsWith(h + '/');
}

const siteJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${SITE}/#org`,
      name: 'l0g',
      alternateName: 'l0g.fr',
      url: `${SITE}/`,
      logo: `${SITE}/favicon.svg`,
      description: 'Risk intelligence: mapping opaque finance, systemic risk and financial geopolitics with public data.',
      sameAs: ['https://github.com/bluetouff', 'https://x.com/bluetouff'],
    },
    {
      '@type': 'WebSite',
      '@id': `${SITE}/#website`,
      url: `${SITE}/`,
      name: 'l0g',
      inLanguage: 'en',
      publisher: { '@id': `${SITE}/#org` },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <script is:inline>
      (function () {
        try {
          var k = 'l0g-theme';
          var s = localStorage.getItem(k);
          var t = (s === 'light' || s === 'dark')
            ? s
            : (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternateLinks.map((link) => (
      <link rel="alternate" hreflang={link.hreflang} href={link.href} />
    ))}

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="l0g.fr" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@bluetouff" />
    <meta name="twitter:creator" content="@bluetouff" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={socialImageAlt} />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(siteJsonLd).replace(/</g, '\\u003c')} />
  </head>

  <body>
    <div class="topbar" aria-hidden="true"></div>
    <div class="mx-auto max-w-6xl px-5 py-7 sm:py-9">
      <header>
        <div class="header-top">
          <a href="/en/" class="brand" aria-label="l0g English">
            <span class="brand-mark">
              <span class="text-paper">l</span><span class="brand-0 text-signal">0</span><span class="text-paper">g</span><span class="blink text-accent" aria-hidden="true">_</span>
            </span>
            <span class="brand-sep" aria-hidden="true"></span>
            <span class="brand-tag mono-label">risk intelligence · english</span>
          </a>
        </div>

        <nav class="main-nav mt-6 flex flex-wrap items-center gap-x-5 gap-y-1 sm:gap-x-6" aria-label="English navigation">
          {navTabs.map((tab) => (
            <a href={tab.href} class="nav-tab" aria-current={isActive(tab.href) ? 'page' : undefined}>{tab.label}</a>
          ))}
          <a href="/" class="nav-tab">french site</a>
        </nav>
      </header>

      <main class="min-w-0 py-8">
        <slot />
      </main>
    </div>

    <footer class="site-footer">
      <div class="footer-grad" aria-hidden="true"></div>
      <div class="footer-inner mx-auto max-w-6xl px-5">
        <p class="mono-label">// l0g English</p>
        <p class="en-footer-text">
          l0g.fr is primarily published in French. The English section covers reference guides,
          trust pages, API/MCP documentation and selected machine-readable risk surfaces.
        </p>
        <p class="en-footer-links">
          <a href="/en/" class="link-term">English overview</a>
          <span aria-hidden="true"> · </span>
          <a href="/en/guides/" class="link-term">English guides</a>
          <span aria-hidden="true"> · </span>
          <a href="/en/api/" class="link-term">API</a>
          <span aria-hidden="true"> · </span>
          <a href="/en/mcp/" class="link-term">MCP</a>
          <span aria-hidden="true"> · </span>
          <a href="/" class="link-term">l0g.fr</a>
        </p>
        <p class="mono-label en-copy">© {year} l0g.fr</p>
      </div>
    </footer>
  </body>
</html>

<style>
  .en-footer-text {
    margin-top: 0.45rem;
    max-width: 48rem;
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }
  .en-footer-links { margin-top: 0.75rem; font-family: var(--font-mono); font-size: 0.75rem; }
  .en-copy { margin-top: 1.2rem; color: var(--color-muted); }
</style>
