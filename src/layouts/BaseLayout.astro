---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import SidebarMobile from '../components/SidebarMobile.astro';

interface Props {
  title?: string;
  description?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  sidebar?: boolean;
}

const {
  title = 'l0g.fr',
  description = 'Cartographier le risque des systèmes économiques. Macro, crédit privé, crypto sur données publiques : analyses aux sources primaires et outils de monitoring en accès libre, par Bluetouff.',
  ogType = 'website',
  ogImage = '/og-default.png',
  sidebar = true,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
const fullTitle = title === 'l0g.fr'
  ? 'l0g.fr — Cartographier le risque des systèmes économiques'
  : `${title} — l0g.fr`;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="l0g.fr" />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="l0g.fr" href="/rss.xml" />
  </head>

  <body>
    <div class="mx-auto max-w-6xl px-5 py-7 sm:py-9">
      <!-- Header -->
      <header>
        <div class="flex flex-wrap items-center justify-between gap-x-6 gap-y-3">
          <div class="flex items-baseline gap-3">
            <a href="/" class="text-2xl font-bold tracking-tight">
              <span class="text-paper">l</span><span class="text-signal">0</span><span class="text-paper">g</span><span class="blink text-accent" aria-hidden="true">_</span>
            </a>
            <span class="mono-label hidden sm:inline">cartographier le risque des systèmes économiques</span>
          </div>
          <nav class="mono-label flex items-center gap-4">
            <a href="/" class="link-term">journal</a>
            <a href="/sujets/" class="link-term">sujets</a>
            <a href="/confluence/" class="link-term">confluence</a>
            <a href="/methodologie/" class="link-term">méthodo</a>
            <a href="/glossaire/" class="link-term">glossaire</a>
            <a href="/rss.xml" class="link-term">rss</a>
            <a href="https://github.com/bluetouff" rel="me noopener" class="link-term">github</a>
            <a href="/rgpd/" class="link-term">rgpd</a>
          </nav>
        </div>

        <!-- Nav dashboards -->
        <nav class="mono-label mt-5 flex flex-wrap items-center gap-x-4 gap-y-2 border-y border-line py-3">
          <span style="color: var(--color-accent)">// marchés :</span>
          <a href="/btc/" class="link-term">btc</a>
          <a href="/usd/" class="link-term">usd</a>
          <a href="/marches-us/" class="link-term">marchés us</a>
          <a href="/mag7/" class="link-term">mag7</a>
          <a href="/hard-commodities/" class="link-term">commodities</a>
          <a href="/calendrier-eco/" class="link-term">calendrier éco</a>
          <a href="/about/" class="link-term ml-auto">about</a>
        </nav>
      </header>

      <!-- Contenu (+ colonne de droite selon la prop sidebar) -->
      {sidebar ? (
        <div class="py-8 lg:grid lg:grid-cols-[minmax(0,1fr)_290px] lg:gap-12">
          <main class="min-w-0">
            <slot />
            <div class="lg:hidden">
              <SidebarMobile />
            </div>
          </main>
          <aside class="hidden lg:block">
            <div class="sticky top-8">
              <Sidebar />
            </div>
          </aside>
        </div>
      ) : (
        <main class="min-w-0 py-8">
          <slot />
        </main>
      )}

      <!-- Footer -->
      <footer class="mt-10 border-t border-line pt-5 text-center">
        <p class="mono-label flex flex-wrap items-center justify-center gap-x-4 gap-y-1">
          <a href="/sujets/" class="link-term">sujets</a>
          <a href="/confluence/" class="link-term">confluence</a>
          <a href="/methodologie/" class="link-term">méthodologie</a>
          <a href="/glossaire/" class="link-term">glossaire</a>
          <a href="/about/" class="link-term">about</a>
          <a href="/rgpd/" class="link-term">mentions légales &amp; rgpd</a>
        </p>
        <p class="mono-label mt-2">l0g.fr &copy; {year} · statique · auto-hébergé · aucun cookie · aucun tracker maison</p>
      </footer>
    </div>

    <!-- Recherche Pagefind : 3 ressources, toutes servies par le site (self) -->
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" is:inline />
    <script src="/pagefind/pagefind-ui.js" is:inline></script>
    <script src="/pagefind-init.js" is:inline></script>
  </body>
</html>
