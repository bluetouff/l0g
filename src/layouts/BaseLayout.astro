---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import SiteNavigation from '../components/SiteNavigation.astro';
import SiteFooter from '../components/SiteFooter.astro';
import WebMCPTools from '../components/WebMCPTools.astro';
import CspMeta from '../components/CspMeta.astro';
import { authorEntity, ORGANIZATION_ID, organizationEntity } from '../config/entities.ts';
import { buildSeoMetadata } from '../lib/seo.ts';
import { serializeInlineScriptData } from '../lib/security.ts';

type AlternateLink = { hreflang: string; href: string };

interface Props {
  title?: string;
  description?: string;
  seoTitle?: string;
  seoDescription?: string;
  robots?: 'index,follow' | 'noindex,follow';
  ogType?: 'website' | 'article';
  ogImage?: string;
  ogImageAlt?: string;
  sidebar?: boolean;
  lang?: 'fr' | 'en';
  ogLocale?: 'fr_FR' | 'en_US';
  alternateLinks?: AlternateLink[];
}

const {
  title = 'l0g.fr',
  description = 'Cartographier le risque des systèmes économiques. Macro, crédit privé, crypto sur données publiques : analyses aux sources primaires et outils de monitoring en accès libre, par Bluetouff.',
  seoTitle,
  seoDescription,
  robots = 'index,follow',
  ogType = 'website',
  ogImage = '/og-default.png',
  ogImageAlt,
  sidebar = true,
  lang = 'fr',
  ogLocale = 'fr_FR',
  alternateLinks = [],
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
const seo = buildSeoMetadata(seoTitle || title, seoDescription || description);
const fullTitle = seo.fullTitle;
const metaDescription = seo.description;
const socialImageAlt = ogImageAlt ?? `${fullTitle} — carte sociale l0g.fr`;
const year = new Date().getFullYear();
const path = Astro.url.pathname;
const hasContextSidebar = Astro.slots.has('sidebar');

const SITE = (Astro.site?.toString() ?? 'https://l0g.fr/').replace(/\/$/, '');
const siteJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    organizationEntity,
    authorEntity,
    {
      '@type': 'WebSite',
      '@id': `${SITE}/#website`,
      url: `${SITE}/`,
      name: 'l0g',
      inLanguage: lang,
      creator: { '@id': authorEntity['@id'] },
      publisher: { '@id': ORGANIZATION_ID },
    },
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <CspMeta />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <script>
      // @ts-nocheck
      (function () {
        try {
          var key = 'l0g-theme';
          var stored = localStorage.getItem(key);
          var theme = (stored === 'light' || stored === 'dark')
            ? stored
            : (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (error) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>

    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />
    {alternateLinks.map((link) => <link rel="alternate" hreflang={link.hreflang} href={link.href} />)}

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="l0g.fr" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@bluetouff" />
    <meta name="twitter:creator" content="@bluetouff" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={socialImageAlt} />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="l0g.fr" href="/rss.xml" />
    <script type="application/ld+json" is:inline set:html={serializeInlineScriptData(siteJsonLd)} />
  </head>

  <body>
    <div class="topbar" aria-hidden="true"></div>
    <div class="mx-auto max-w-6xl px-5 py-6 sm:py-8">
      <header>
        <div class="header-top">
          <a href="/" class="brand" aria-label="l0g, Lire les mécanismes avant qu’ils deviennent l’événement">
            <span class="brand-mark">
              <span class="text-paper">l</span><span class="brand-0 text-signal">0</span><span class="text-paper">g</span><span class="brand-cursor blink text-accent" aria-hidden="true">_</span>
            </span>
            <span class="brand-sep" aria-hidden="true"></span>
            <span class="brand-tag" aria-hidden="true">
              <span class="brand-tag-line brand-tag-line-signal">Lire les mécanismes</span>
              <span class="brand-tag-line brand-tag-line-paper">avant qu’ils deviennent l’événement</span>
            </span>
          </a>

          <button type="button" id="theme-toggle" class="theme-toggle" aria-label="Basculer le thème clair ou sombre" title="Thème clair / sombre" aria-pressed="false">
            <svg class="ic-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
            </svg>
            <svg class="ic-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
          </button>

          <div class="header-signal" aria-hidden="true" role="presentation">
            <svg viewBox="0 0 480 46" fill="none" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <linearGradient id="hs-stroke" x1="0" y1="0" x2="480" y2="0" gradientUnits="userSpaceOnUse">
                  <stop offset="0" stop-color="#5eead4" stop-opacity="0"/>
                  <stop offset="0.32" stop-color="#5eead4" stop-opacity="0.85"/>
                  <stop offset="0.68" stop-color="#ff4d87" stop-opacity="0.9"/>
                  <stop offset="1" stop-color="#f5b13d"/>
                </linearGradient>
                <radialGradient id="hs-glow" cx="0.5" cy="0.5" r="0.5">
                  <stop offset="0" stop-color="#f5b13d" stop-opacity="0.9"/>
                  <stop offset="1" stop-color="#f5b13d" stop-opacity="0"/>
                </radialGradient>
                <pattern id="hs-dots" width="22" height="11" patternUnits="userSpaceOnUse">
                  <circle cx="1.4" cy="1.4" r="1.1" fill="#8b909b"/>
                </pattern>
                <linearGradient id="hs-fade" x1="0" y1="0" x2="480" y2="0" gradientUnits="userSpaceOnUse">
                  <stop offset="0" stop-color="#fff" stop-opacity="0"/>
                  <stop offset="0.55" stop-color="#fff" stop-opacity="0.7"/>
                  <stop offset="1" stop-color="#fff"/>
                </linearGradient>
                <mask id="hs-mask"><rect x="0" y="0" width="480" height="46" fill="url(#hs-fade)"/></mask>
              </defs>
              <rect x="0" y="9" width="480" height="30" fill="url(#hs-dots)" opacity="0.13" mask="url(#hs-mask)"/>
              <path d="M2 27 C 56 27 84 15 132 17 S 214 33 274 25 S 360 13 412 21 S 462 25 474 21"
                    stroke="url(#hs-stroke)" stroke-width="1.6" stroke-linecap="round" vector-effect="non-scaling-stroke"/>
              <circle class="hs-glow" cx="474" cy="21" r="10" fill="url(#hs-glow)"/>
              <circle cx="474" cy="21" r="2.4" fill="#f5b13d"/>
            </svg>
          </div>
        </div>

        <SiteNavigation path={path} />
      </header>

      {sidebar ? (
        <div class="py-8 lg:grid lg:grid-cols-[minmax(0,1fr)_290px] lg:gap-12">
          <main class="min-w-0">
            <slot />
          </main>
          <aside class="hidden lg:block" aria-label={hasContextSidebar ? 'Navigation contextuelle' : 'À découvrir'}>
            <div class="sticky top-8">
              {hasContextSidebar ? <slot name="sidebar" /> : <Sidebar path={path} />}
            </div>
          </aside>
        </div>
      ) : (
        <main class="min-w-0 py-8">
          <slot />
        </main>
      )}
    </div>

    <SiteFooter path={path} year={year} />

    {path.startsWith('/recherche') && (
      <>
        <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
        <script src="/pagefind/pagefind-ui.js" defer is:inline></script>
        <script src="/pagefind-init.js" defer is:inline></script>
      </>
    )}

    <script>
      // @ts-nocheck
      (function () {
        var key = 'l0g-theme';
        var button = document.getElementById('theme-toggle');
        if (!button) return;
        function currentTheme() {
          return document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
        }
        button.setAttribute('aria-pressed', currentTheme() === 'light' ? 'true' : 'false');
        button.addEventListener('click', function () {
          var next = currentTheme() === 'light' ? 'dark' : 'light';
          document.documentElement.setAttribute('data-theme', next);
          button.setAttribute('aria-pressed', next === 'light' ? 'true' : 'false');
          try { localStorage.setItem(key, next); } catch (error) {}
        });
      })();
    </script>

    <style>
      .topbar {
        height: 4px;
        width: 100%;
        background: linear-gradient(90deg, transparent, var(--color-signal), var(--color-accent), var(--color-amber), transparent);
        opacity: 0.65;
      }
      .header-top {
        display: grid;
        grid-template-columns: auto auto minmax(0, 1fr);
        grid-template-areas: "brand theme signal";
        align-items: center;
        gap: 1.4rem;
      }
      .brand {
        grid-area: brand;
        display: inline-flex;
        min-width: 0;
        align-items: center;
        gap: 0.7rem;
        text-decoration: none;
      }
      .brand-mark {
        display: inline-flex;
        flex: none;
        align-items: baseline;
        white-space: nowrap;
        font-size: clamp(1.45rem, 3vw, 2rem);
        font-weight: 700;
        letter-spacing: -0.04em;
      }
      .brand-sep {
        width: 1px;
        height: 2rem;
        background: linear-gradient(180deg, transparent, var(--color-line-strong), transparent);
      }
      .brand-tag {
        display: flex;
        min-width: 0;
        max-width: min(34rem, 58vw);
        flex-direction: column;
        gap: 0.08rem;
        font-family: var(--font-mono);
        font-size: clamp(0.68rem, 1.05vw, 0.82rem);
        font-weight: 520;
        letter-spacing: 0.035em;
        line-height: 1.16;
      }
      .brand-tag-line { display: block; white-space: nowrap; }
      .brand-tag-line-signal { color: var(--color-signal); }
      .brand-tag-line-paper {
        color: var(--color-bright);
        background: linear-gradient(90deg, var(--color-signal), var(--color-accent) 48%, var(--color-amber));
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .theme-toggle {
        grid-area: theme;
        display: inline-flex;
        width: 2.15rem;
        height: 2.15rem;
        flex: none;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--color-line);
        border-radius: 8px;
        color: var(--color-muted);
        background: transparent;
        cursor: pointer;
      }
      .theme-toggle:hover,
      .theme-toggle:focus-visible {
        border-color: var(--color-signal);
        color: var(--color-bright);
      }
      .theme-toggle svg { width: 15px; height: 15px; }
      .theme-toggle .ic-moon { display: none; }
      :root[data-theme='light'] .theme-toggle .ic-sun { display: none; }
      :root[data-theme='light'] .theme-toggle .ic-moon { display: block; }
      .header-signal { grid-area: signal; min-width: 0; opacity: 0.74; }
      .header-signal svg { display: block; width: 100%; height: 46px; }
      .header-signal .hs-glow {
        transform-box: fill-box;
        transform-origin: center;
        animation: hs-pulse 2.8s ease-in-out infinite;
      }
      @keyframes hs-pulse {
        0%, 100% { opacity: 0.45; transform: scale(0.92); }
        50% { opacity: 1; transform: scale(1.06); }
      }
      @media (max-width: 680px) {
        .header-top {
          grid-template-columns: minmax(0, 1fr) auto;
          grid-template-areas: "brand theme";
          gap: 0.75rem;
        }
        .header-signal { display: none; }
        .brand { max-width: calc(100vw - 5.5rem); gap: 0.55rem; }
        .brand-tag { max-width: calc(100vw - 9rem); font-size: 0.66rem; letter-spacing: 0.015em; }
      }
      @media (max-width: 360px) {
        .brand-sep,
        .brand-tag { display: none; }
      }
      @media (prefers-reduced-motion: reduce) {
        .header-signal .hs-glow { animation: none; }
      }
    </style>
    <WebMCPTools />
  </body>
</html>
