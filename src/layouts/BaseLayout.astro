      .footer-legal { margin-left: auto; }
      @media (max-width: 520px) { .footer-legal { margin-left: 0; } }

      /* En-tête : lockup de marque */
      .header-top {
        display: flex; flex-wrap: wrap; align-items: center;
        justify-content: space-between; gap: 0.5rem 1.75rem;
      }
      .brand { display: inline-flex; align-items: center; gap: 0.7rem; text-decoration: none; }
      .brand-mark { font-size: 1.7rem; font-weight: 700; letter-spacing: -0.02em; line-height: 1; }
