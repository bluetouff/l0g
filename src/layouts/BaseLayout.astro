---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import SidebarMobile from '../components/SidebarMobile.astro';
import WebMCPTools from '../components/WebMCPTools.astro';
import { methodologyPages, methodologyUrl } from '../config/methodology.ts';

type AlternateLink = { hreflang: string; href: string };

interface Props {
  title?: string;
  description?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  ogImageAlt?: string;
  sidebar?: boolean;
  lang?: 'fr' | 'en';
  ogLocale?: 'fr_FR' | 'en_US';
  alternateLinks?: AlternateLink[];
}

const {
  title = 'l0g.fr',
  description = 'Cartographier le risque des systèmes économiques. Macro, crédit privé, crypto sur données publiques : analyses aux sources primaires et outils de monitoring en accès libre, par Bluetouff.',
  ogType = 'website',
  ogImage = '/og-default.png',
  ogImageAlt,
  sidebar = true,
  lang = 'fr',
  ogLocale = 'fr_FR',
  alternateLinks = [],
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
const fullTitle = title === 'l0g.fr'
  ? 'l0g.fr · Cartographier le risque des systèmes économiques'
  : `${title} · l0g.fr`;
const socialImageAlt = ogImageAlt ?? `${fullTitle} — carte sociale l0g.fr`;
const year = new Date().getFullYear();

// --- Structured data : entite editrice du site (presente sur toutes les pages) ---
// Honnete par construction : decrit l'editeur et le site, sans SearchAction
// (la sitelinks search box de Google est depreciee depuis novembre 2024).
const SITE = (Astro.site?.toString() ?? 'https://l0g.fr/').replace(/\/$/, '');
const siteJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${SITE}/#org`,
      name: 'l0g',
      alternateName: 'l0g.fr',
      url: `${SITE}/`,
      logo: `${SITE}/favicon.svg`,
      description:
        "Risk intelligence : mettre en donnees la finance opaque, le risque systemique et la geopolitique financiere.",
      sameAs: ['https://github.com/bluetouff', 'https://x.com/bluetouff'],
    },
    {
      '@type': 'WebSite',
      '@id': `${SITE}/#website`,
      url: `${SITE}/`,
      name: 'l0g',
      inLanguage: lang,
      publisher: { '@id': `${SITE}/#org` },
    },
  ],
};

// --- Navigation (éditable ici) ---------------------------------------
type Tab = { href: string; label: string; match?: string[] };

const mainTabs: Tab[] = [
  { href: '/', label: 'journal' },
  { href: '/demarrer/', label: 'démarrer' },
  { href: '/sujets/', label: 'sujets', match: ['/sujets', '/sujet'] },
  { href: '/dashboards/', label: 'dashboards' },
  { href: '/confluence/', label: 'confluence' },
  { href: '/methodologie/', label: 'méthodologie' },
  { href: '/glossaire/', label: 'glossaire' },
  { href: '/guides/', label: 'guides' },
  { href: '/recherche/', label: 'recherche' },
];


const path = Astro.url.pathname;
const norm = (s: string) => (s.length > 1 ? s.replace(/\/$/, '') : s);
function isActive(tab: Tab): boolean {
  const p = norm(path);
  if (tab.href === '/') return p === '/' || /^\/\d+$/.test(p) || p.startsWith('/posts');
  const bases = (tab.match ?? [tab.href]).map(norm);
  return bases.some((b) => p === b || p.startsWith(b + '/'));
}
function isCurrentHref(href: string): boolean {
  const p = norm(path);
  const h = norm(href);
  return h === '/' ? p === '/' : p === h || p.startsWith(h + '/');
}
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    {/* Thème clair/sombre : résolution avant le premier paint (anti-flash). */}
    <script is:inline>
      (function () {
        try {
          var k = 'l0g-theme';
          var s = localStorage.getItem(k);
          var t = (s === 'light' || s === 'dark')
            ? s
            : (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternateLinks.map((link) => (
      <link rel="alternate" hreflang={link.hreflang} href={link.href} />
    ))}

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="l0g.fr" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@bluetouff" />
    <meta name="twitter:creator" content="@bluetouff" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={socialImageAlt} />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="l0g.fr" href="/rss.xml" />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(siteJsonLd)} />
  </head>

  <body>
    <div class="topbar" aria-hidden="true"></div>
    <div class="mx-auto max-w-6xl px-5 py-7 sm:py-9">
      <!-- Header -->
      <header>
        <!-- Marque -->
        <div class="header-top">
          <a href="/" class="brand" aria-label="l0g, accueil">
            <span class="brand-mark">
