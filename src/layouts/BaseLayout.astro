            </span>
            <span class="brand-sep" aria-hidden="true"></span>
            <span class="brand-tag mono-label">risk intelligence</span>
          </a>

          <a href="/terminal/" class="header-terminal" aria-current={isCurrentHref('/terminal/') ? 'page' : undefined}>
            <span aria-hidden="true">$</span> terminal
          </a>

          <button type="button" id="theme-toggle" class="theme-toggle" aria-label="Basculer le thème clair ou sombre" title="Thème clair / sombre" aria-pressed="false">
            <svg class="ic-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
            </svg>
            <svg class="ic-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
          </button>

          <div class="header-signal" aria-hidden="true" role="presentation">
            <svg viewBox="0 0 480 46" fill="none" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <linearGradient id="hs-stroke" x1="0" y1="0" x2="480" y2="0" gradientUnits="userSpaceOnUse">
                  <stop offset="0" stop-color="#5eead4" stop-opacity="0"/>
                  <stop offset="0.32" stop-color="#5eead4" stop-opacity="0.85"/>
                  <stop offset="0.68" stop-color="#ff4d87" stop-opacity="0.9"/>
                  <stop offset="1" stop-color="#f5b13d"/>
                </linearGradient>
                <radialGradient id="hs-glow" cx="0.5" cy="0.5" r="0.5">
                  <stop offset="0" stop-color="#f5b13d" stop-opacity="0.9"/>
                  <stop offset="1" stop-color="#f5b13d" stop-opacity="0"/>
                </radialGradient>
                <pattern id="hs-dots" width="22" height="11" patternUnits="userSpaceOnUse">
                  <circle cx="1.4" cy="1.4" r="1.1" fill="#8b909b"/>
                </pattern>
                <linearGradient id="hs-fade" x1="0" y1="0" x2="480" y2="0" gradientUnits="userSpaceOnUse">
                  <stop offset="0" stop-color="#fff" stop-opacity="0"/>
                  <stop offset="0.55" stop-color="#fff" stop-opacity="0.7"/>
                  <stop offset="1" stop-color="#fff"/>
                </linearGradient>
                <mask id="hs-mask"><rect x="0" y="0" width="480" height="46" fill="url(#hs-fade)"/></mask>
              </defs>
              <rect x="0" y="9" width="480" height="30" fill="url(#hs-dots)" opacity="0.13" mask="url(#hs-mask)"/>
              <path d="M2 27 C 56 27 84 15 132 17 S 214 33 274 25 S 360 13 412 21 S 462 25 474 21"
                    stroke="url(#hs-stroke)" stroke-width="1.6" stroke-linecap="round" vector-effect="non-scaling-stroke"/>
              <circle class="hs-glow" cx="474" cy="21" r="10" fill="url(#hs-glow)"/>
              <circle cx="474" cy="21" r="2.4" fill="#f5b13d"/>
            </svg>
          </div>
        </div>

        <!-- Menu principal : onglets -->
        <nav class="main-nav mt-6 flex flex-wrap items-center gap-x-5 gap-y-1 sm:gap-x-6" aria-label="Navigation principale">
          {
            mainTabs.map((t) => (
              <a href={t.href} class="nav-tab" aria-current={isActive(t) ? 'page' : undefined}>
                {t.label}
              </a>
            ))
          }
          <a href="/en/" class="nav-tab nav-en nav-right" aria-current={Astro.url.pathname.startsWith('/en') ? 'page' : undefined}>
            en
          </a>
          <a href="/api/" class="nav-tab nav-api" aria-current={Astro.url.pathname.startsWith('/api') ? 'page' : undefined}>
            api
          </a>
        </nav>
      </header>

      <!-- Contenu (+ colonne de droite selon la prop sidebar) -->
      {sidebar ? (
        <div class="py-8 lg:grid lg:grid-cols-[minmax(0,1fr)_290px] lg:gap-12">
          <main class="min-w-0">
            <slot />
            <div class="lg:hidden">
              <SidebarMobile />
            </div>
          </main>
          <aside class="hidden lg:block">
            <div class="sticky top-8">
              <Sidebar />
            </div>
          </aside>
        </div>
      ) : (
        <main class="min-w-0 py-8">
          <slot />
        </main>
      )}

