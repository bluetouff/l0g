---
// Défense autonome de l'artefact statique. Cette politique s'applique en
// intersection avec l'en-tête Apache et reste donc stricte même si le vhost
// n'a pas encore reçu la dernière configuration versionnée.
const policy = [
  "default-src 'self'",
  "script-src 'self' 'wasm-unsafe-eval' https://s3.tradingview.com https://*.tradingview.com",
  "script-src-attr 'none'",
  "style-src 'self' 'unsafe-inline'",
  "img-src 'self' data: https://*.tradingview.com",
  "font-src 'self'",
  "connect-src 'self' https://*.tradingview.com https://*.tradingview-widget.com wss://*.tradingview.com",
  "frame-src 'self' https://*.tradingview.com https://*.tradingview-widget.com",
  "worker-src 'self' blob:",
  "manifest-src 'self'",
  "media-src 'self'",
  "object-src 'none'",
  "base-uri 'self'",
  "form-action 'self'",
  'upgrade-insecure-requests',
].join('; ');
---

<meta http-equiv="Content-Security-Policy" content={policy} />
