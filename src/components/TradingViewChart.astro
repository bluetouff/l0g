---
import { serializeInlineScriptData } from '../lib/security.ts';

/**
 * Graphique TradingView (embed officiel « Advanced Chart »).
 * Usage dans un .mdx :
 *   import TradingViewChart from '../../components/TradingViewChart.astro';
 *   <TradingViewChart symbol="BINANCE:BTCUSDT" interval="240" caption="BTC/USDT — 4h" />
 *
 * Note : l'embed officiel charge un script depuis s3.tradingview.com et
 * transmet l'IP du visiteur à TradingView (choix assumé). La CSP Apache
 * autorise *.tradingview.com en conséquence.
 */
interface Props {
  symbol?: string;
  interval?: string;
  theme?: 'dark' | 'light';
  height?: number;
  studies?: string[];
  caption?: string;
}

const {
  symbol = 'BINANCE:BTCUSDT',
  interval = 'D',
  theme = 'dark',
  height = 480,
  studies = [],
  caption,
} = Astro.props;

const config = {
  autosize: true,
  symbol,
  interval,
  timezone: 'Europe/Paris',
  theme,
  style: '1',
  locale: 'fr',
  enable_publishing: false,
  hide_side_toolbar: false,
  allow_symbol_change: true,
  studies,
  support_host: 'https://www.tradingview.com',
};

const symbolPath = symbol.replace(':', '-');
---

<figure class="tv-embed" style={`--h:${height}px`}>
  <div class="tradingview-widget-container" style="height:var(--h);width:100%">
    <div class="tradingview-widget-container__widget" style="height:calc(100% - 28px);width:100%"></div>
    <div class="tv-attr mono-label">
      <a href={`https://www.tradingview.com/symbols/${symbolPath}/`} rel="noopener nofollow" target="_blank">graphique par TradingView</a>
    </div>
    <script
      type="text/javascript"
      src="https://s3.tradingview.com/external-embedding/embed-widget-advanced-chart.js"
      async
      is:inline
      set:html={serializeInlineScriptData(config)}
    />
  </div>
  {caption && <figcaption class="mono-label tv-caption">{caption}</figcaption>}
</figure>

<style>
  .tv-embed {
    margin: 2em 0;
    border: 1px solid var(--color-line);
    border-radius: 0;
    overflow: hidden;
    background: var(--color-surface);
  }
  .tv-attr {
    height: 28px;
    display: flex;
    align-items: center;
    padding: 0 0.9em;
    border-top: 1px solid var(--color-line);
  }
  .tv-attr a {
    color: var(--color-muted);
  }
  .tv-caption {
    padding: 0.7em 0.9em;
    border-top: 1px solid var(--color-line);
    color: var(--color-muted);
  }
</style>
