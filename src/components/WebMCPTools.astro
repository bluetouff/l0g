---
/*
 * WebMCPTools.astro
 * Expose les capacités de l0g.fr comme « tools » WebMCP (navigator.modelContext),
 * pour que des agents IA puissent les appeler directement plutôt que de scraper la page.
 *
 * Spec : W3C Web Machine Learning CG, WebMCP (Draft Community Group Report, 2026).
 * API utilisée : navigator.modelContext.registerTool / unregisterTool.
 * On n'utilise PAS window.agent ni provideContext() (dépréciés / retirés en 2026).
 *
 * Sans effet pour les visiteurs humains : tout est encapsulé dans un test de
 * disponibilité (navigator.modelContext + SecureContext). Le bundle Pagefind est
 * chargé paresseusement à la première invocation (aucun coût au chargement de page,
 * dégradation propre en dev où /pagefind/ n'existe pas encore).
 *
 * Tools :
 *   - search_content        : recherche plein texte (Pagefind, index local).
 *   - list_recent_analyses  : derniers articles, depuis le frontmatter (données fiables).
 * Les tools suivants (get_article, search_by_topic) s'ajoutent sur le même modèle.
 */
import { getCollection, type CollectionEntry } from 'astro:content';
import { topics, postMatchesTopic } from '../config/topics.ts';

const site = (Astro.site?.toString() ?? 'https://l0g.fr/').replace(/\/$/, '');

// Articles publiés, même tri et même filtre que la home (pubDate desc, hors brouillons).
const published = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const dateOf = (p: CollectionEntry<'posts'>) => p.data.pubDate.toISOString().slice(0, 10);

// Liste des dernières analyses (avec description) pour list_recent_analyses.
const recent = published.slice(0, 20).map((p) => ({
  title: p.data.title,
  url: `${site}/posts/${p.id}/`,
  date: dateOf(p),
  description: p.data.description,
  tags: p.data.tags ?? [],
}));

// Sujets canoniques et articles rattachés (même logique que les hubs /sujets/).
// Réfs légères (sans description) pour ne pas alourdir chaque page ; la description
// complète reste disponible via list_recent_analyses ou get_article.
const topicsList = topics.map((t) => ({ slug: t.slug, label: t.label, blurb: t.blurb }));
const byTopic = Object.fromEntries(
  topics.map((t) => [
    t.slug,
    published
      .filter((p) => postMatchesTopic(p.data.tags ?? [], t))
      .map((p) => ({ title: p.data.title, url: `${site}/posts/${p.id}/`, date: dateOf(p) })),
  ])
);

// Allowlist de slugs : get_article ne récupère qu'un article connu, jamais une URL arbitraire.
const articleSlugs = published.map((p) => p.id);
---

<script is:inline define:vars={{ site, recent, topicsList, byTopic, articleSlugs }}>
  (function () {
    if (typeof navigator === 'undefined') return;
    // WebMCP n'existe qu'en contexte sécurisé (HTTPS) et sur navigateur compatible.
    if (!('modelContext' in navigator) || !window.isSecureContext) return;
    const mc = navigator.modelContext;
    if (!mc || typeof mc.registerTool !== 'function') return;

    // --- Pagefind : import dynamique paresseux, mémoïsé ---
    let pagefindPromise = null;
    function loadPagefind() {
      if (!pagefindPromise) {
        pagefindPromise = import('/pagefind/pagefind.js').catch(function () { return null; });
      }
      return pagefindPromise;
    }

    // --- helpers ---
    function stripTags(s) {
      return String(s || '').replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();
    }
    // Réponse au format « content blocks » MCP, le plus interopérable pour la distillation.
    function reply(payload) {
      return { content: [{ type: 'text', text: JSON.stringify(payload) }] };
    }

    // --- Tool : recherche plein texte ---
    try {
      mc.registerTool({
        name: 'search_content',
        description:
          "Recherche plein texte dans tout l0g.fr : analyses, guides de référence et glossaire. " +
          "Renvoie les meilleurs résultats avec titre, URL absolue, extrait et sous-sections pertinentes. " +
          "Index local Pagefind, sans service tiers. Exemples de requêtes : « crédit privé », « GENIUS Act », « OFAC », « liquidité du Trésor ».",
        inputSchema: {
          type: 'object',
          properties: {
            query: {
              type: 'string',
              description: 'Termes de recherche en français ou en anglais.'
            },
            limit: {
              type: 'integer',
              description: 'Nombre maximum de résultats à renvoyer (1 à 10).',
              minimum: 1,
              maximum: 10,
              default: 5
            }
          },
          required: ['query']
        },
        annotations: { readOnlyHint: true },
        execute: async function (input) {
          // Entrées agent = non fiables : on borne tout.
          const q = String((input && input.query) || '').trim().slice(0, 200);
          let limit = parseInt((input && input.limit) || 5, 10);
          if (!Number.isFinite(limit)) limit = 5;
          limit = Math.max(1, Math.min(10, limit));
          if (!q) return reply({ query: '', count: 0, results: [], note: 'requête vide' });

          const pf = await loadPagefind();
          if (!pf || typeof pf.search !== 'function') {
            return reply({ query: q, count: 0, results: [], note: 'index de recherche indisponible' });
          }

          let search;
          try {
            search = await pf.search(q);
          } catch (e) {
            return reply({ query: q, count: 0, results: [], note: 'erreur de recherche' });
          }

          const slice = (search.results || []).slice(0, limit);
          const data = await Promise.all(slice.map(function (r) { return r.data(); }));
          const results = data.map(function (d) {
            return {
              title: (d.meta && d.meta.title) || stripTags(d.excerpt).slice(0, 80),
              url: site + (d.url || ''),
              excerpt: stripTags(d.excerpt),
              sections: (d.sub_results || []).slice(0, 3).map(function (s) {
                return {
                  title: s.title,
                  url: site + (s.url || ''),
                  excerpt: stripTags(s.excerpt)
                };
              })
            };
          });

          return reply({ query: q, count: results.length, results: results });
        }
      });
    } catch (e) {
      // L'enregistrement d'un tool ne doit jamais casser la page.
    }

    // --- Tool : derniers articles ---
    try {
      mc.registerTool({
        name: 'list_recent_analyses',
        description:
          "Liste les analyses (articles) les plus récentes de l0g.fr, de la plus récente à la plus ancienne, " +
          "avec titre, URL absolue, date de publication (AAAA-MM-JJ), description et thèmes. " +
          "Ne couvre pas les guides de référence ni le glossaire ; utiliser search_content pour ceux-ci.",
        inputSchema: {
          type: 'object',
          properties: {
            limit: {
              type: 'integer',
              description: "Nombre d'analyses à renvoyer (1 à 20).",
              minimum: 1,
              maximum: 20,
              default: 5
            }
          }
        },
        annotations: { readOnlyHint: true },
        execute: async function (input) {
          let limit = parseInt((input && input.limit) || 5, 10);
          if (!Number.isFinite(limit)) limit = 5;
          limit = Math.max(1, Math.min(20, limit));
          const analyses = (recent || []).slice(0, limit);
          return reply({ count: analyses.length, analyses: analyses });
        }
      });
    } catch (e) {
      // idem : ne jamais casser la page.
    }

    // --- Tool : contenu complet d'un article ---
    try {
      mc.registerTool({
        name: 'get_article',
        description:
          "Renvoie le contenu texte complet d'une analyse de l0g.fr à partir de son slug " +
          "(le dernier segment de l'URL /posts/.../, par ex. « clarity-act-trump-obstacle-conflit-interets »). " +
          "Récupérer les slugs via list_recent_analyses, search_content ou search_by_topic.",
        inputSchema: {
          type: 'object',
          properties: {
            slug: { type: 'string', description: "Slug de l'article, dernier segment de son URL." }
          },
          required: ['slug']
        },
        annotations: { readOnlyHint: true },
        execute: async function (input) {
          // Normalisation puis allowlist stricte : jamais de fetch d'URL arbitraire.
          var slug = String((input && input.slug) || '')
            .trim().replace(/^https?:\/\/[^/]+/i, '').replace(/^\/+|\/+$/g, '').replace(/^posts\//, '');
          if (articleSlugs.indexOf(slug) === -1) {
            return reply({ error: 'slug inconnu', slug: slug, note: 'utiliser list_recent_analyses ou search_content pour obtenir un slug valide' });
          }
          var url = site + '/posts/' + slug + '/';
          try {
            var res = await fetch('/posts/' + slug + '/', { credentials: 'omit' });
            if (!res.ok) return reply({ error: 'article introuvable', slug: slug, url: url });
            var doc = new DOMParser().parseFromString(await res.text(), 'text/html');
            var titleEl = doc.querySelector('article h1') || doc.querySelector('h1');
            var bodyEl = doc.querySelector('.prose') || doc.querySelector('[data-pagefind-body]') || doc.querySelector('article');
            var body = stripTags(bodyEl ? bodyEl.textContent : '');
            var MAX = 16000;
            var truncated = body.length > MAX;
            if (truncated) body = body.slice(0, MAX);
            return reply({
              slug: slug,
              url: url,
              title: titleEl ? stripTags(titleEl.textContent) : slug,
              words: body ? body.split(/\s+/).length : 0,
              truncated: truncated,
              text: body
            });
          } catch (e) {
            return reply({ error: 'erreur de récupération', slug: slug, url: url });
          }
        }
      });
    } catch (e) {
      // idem.
    }

    // --- Tool : articles d'un sujet (hub thématique) ---
    try {
      var topicCatalog = topicsList.map(function (t) { return t.slug + ' : ' + t.label; }).join(' ; ');
      mc.registerTool({
        name: 'search_by_topic',
        description:
          "Liste les analyses rattachées à un sujet (hub thématique) de l0g.fr, du plus récent au plus ancien, " +
          "avec titre, URL et date. Sujets disponibles (slug : libellé) : " + topicCatalog + ". " +
          "Accepte le slug exact ou un libellé approchant.",
        inputSchema: {
          type: 'object',
          properties: {
            topic: { type: 'string', description: "Slug ou libellé du sujet, par ex. « crypto », « credit-prive », « géopolitique »." },
            limit: { type: 'integer', description: "Nombre maximum d'analyses (1 à 20).", minimum: 1, maximum: 20, default: 10 }
          },
          required: ['topic']
        },
        annotations: { readOnlyHint: true },
        execute: async function (input) {
          var raw = String((input && input.topic) || '').trim().toLowerCase();
          var limit = parseInt((input && input.limit) || 10, 10);
          if (!Number.isFinite(limit)) limit = 10;
          limit = Math.max(1, Math.min(20, limit));
          if (!raw) return reply({ error: 'sujet vide', topics: topicsList });
          // Résolution : slug exact, sinon rapprochement par libellé ou slug.
          var match = topicsList.find(function (t) { return t.slug === raw; });
          if (!match) {
            match = topicsList.find(function (t) {
              var lbl = t.label.toLowerCase();
              return lbl.indexOf(raw) !== -1 || t.slug.indexOf(raw) !== -1 || raw.indexOf(t.slug) !== -1;
            });
          }
          if (!match) return reply({ error: 'sujet inconnu', requested: raw, topics: topicsList });
          var analyses = (byTopic[match.slug] || []).slice(0, limit);
          return reply({ topic: match.slug, label: match.label, count: analyses.length, analyses: analyses });
        }
      });
    } catch (e) {
      // idem.
    }
  })();
</script>
