---
/*
 * WebMCPTools.astro
 * Expose les capacités de l0g.fr comme « tools » WebMCP (navigator.modelContext),
 * pour que des agents IA puissent les appeler directement plutôt que de scraper la page.
 *
 * Spec : W3C Web Machine Learning CG, WebMCP (Draft Community Group Report, 2026).
 * API utilisée : navigator.modelContext.registerTool / unregisterTool.
 * On n'utilise PAS window.agent ni provideContext() (dépréciés / retirés en 2026).
 *
 * Sans effet pour les visiteurs humains : tout est encapsulé dans un test de
 * disponibilité (navigator.modelContext + SecureContext). L'index statique partagé
 * est chargé paresseusement à la première invocation.
 *
 * Tools :
 *   - search_content        : recherche dans l'index canonique Agent Surface.
 *   - list_recent_analyses  : derniers articles FR/EN du même index.
 *   - get_agent_manifest    : manifeste agents.json.
 *   - get_freshness         : fraîcheur du corpus et derniers contenus.
 *   - get_risk_diff         : diff du risque par fenêtre 1, 7 ou 30 jours.
 *   - get_black_box         : replay point-in-time des frames de risque.
 *   - get_claims            : claims typées et références datées.
 *   - get_evidence_graph    : sous-graphe articles, claims et sources.
 * Les tools suivants (get_article, search_by_topic) s'ajoutent sur le même modèle.
 */
import { topics } from '../config/topics.ts';

const site = (Astro.site?.toString() ?? 'https://l0g.fr/').replace(/\/$/, '');

const topicsList = topics.map((t) => ({ slug: t.slug, label: t.label, blurb: t.blurb }));
---

<script is:inline define:vars={{ site, topicsList }}>
  (function () {
    if (typeof navigator === 'undefined') return;
    // WebMCP n'existe qu'en contexte sécurisé (HTTPS) et sur navigateur compatible.
    if (!('modelContext' in navigator) || !window.isSecureContext) return;
    const mc = navigator.modelContext;
    if (!mc || typeof mc.registerTool !== 'function') return;

    // --- Index canonique partagé avec Agent Surface et MCP serveur ---
    let searchIndexPromise = null;
    function loadSearchIndex() {
      if (!searchIndexPromise) {
        searchIndexPromise = readPublicJson('/api/v1/search-index.json').catch(function () { return null; });
      }
      return searchIndexPromise;
    }

    // --- helpers ---
    function stripTags(s) {
      return String(s || '').replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();
    }
    // Réponse au format « content blocks » MCP, le plus interopérable pour la distillation.
    function reply(payload) {
      return { content: [{ type: 'text', text: JSON.stringify(payload) }] };
    }
    function clampLimit(value, fallback, max) {
      var limit = parseInt(value || fallback, 10);
      if (!Number.isFinite(limit)) limit = fallback;
      return Math.max(1, Math.min(max, limit));
    }
    async function readPublicJson(path) {
      var res = await fetch(path, { credentials: 'omit' });
      if (!res.ok) throw new Error('fetch failed');
      return res.json();
    }
    function normalize(value) {
      return String(value || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
    }
    function rankDocument(document, tokens) {
      var title = normalize(document.title);
      var meta = normalize([].concat(document.tags || [], document.topics || []).join(' '));
      var description = normalize(document.description);
      var body = normalize(document.text);
      var score = 0;
      tokens.forEach(function (token) {
        if (title.indexOf(token) !== -1) score += 30;
        if (meta.indexOf(token) !== -1) score += 12;
        if (description.indexOf(token) !== -1) score += 8;
        if (body.indexOf(token) !== -1) score += 1;
      });
      return score;
    }

    // --- Tool : recherche plein texte ---
    try {
      mc.registerTool({
        name: 'search_content',
        description:
          "Recherche plein texte dans tout l0g.fr : analyses, guides de référence et glossaire. " +
          "Renvoie les meilleurs résultats avec titre, URL absolue, extrait et sous-sections pertinentes. " +
          "Index statique partagé avec Agent Surface et MCP serveur, sans service tiers. Exemples : « crédit privé », « GENIUS Act », « OFAC », « Treasury liquidity ».",
        inputSchema: {
          type: 'object',
          properties: {
            query: {
              type: 'string',
              description: 'Termes de recherche en français ou en anglais.'
            },
            language: {
              type: 'string',
              enum: ['fr', 'en'],
              description: 'Langue optionnelle. Sans filtre, la recherche est bilingue.'
            },
            limit: {
              type: 'integer',
              description: 'Nombre maximum de résultats à renvoyer (1 à 10).',
              minimum: 1,
              maximum: 10,
              default: 5
            }
          },
          required: ['query']
        },
        annotations: { readOnlyHint: true },
        execute: async function (input) {
          // Entrées agent = non fiables : on borne tout.
          const q = String((input && input.query) || '').trim().slice(0, 200);
          let limit = parseInt((input && input.limit) || 5, 10);
          if (!Number.isFinite(limit)) limit = 5;
          limit = Math.max(1, Math.min(10, limit));
          if (!q) return reply({ query: '', count: 0, results: [], note: 'requête vide' });
          const language = input && (input.language === 'fr' || input.language === 'en') ? input.language : '';
          const index = await loadSearchIndex();
          if (!index || !Array.isArray(index.documents)) {
            return reply({ query: q, count: 0, results: [], note: 'index de recherche indisponible' });
          }
          const tokens = normalize(q).split(/[^a-z0-9]+/).filter(function (token) { return token.length > 1; }).slice(0, 12);
          const results = index.documents
            .filter(function (document) { return !language || document.language === language; })
            .map(function (document) { return { document: document, score: rankDocument(document, tokens) }; })
            .filter(function (item) { return item.score > 0; })
            .sort(function (a, b) { return b.score - a.score || String(b.document.date || '').localeCompare(String(a.document.date || '')); })
            .slice(0, limit)
            .map(function (item) {
              var document = item.document;
              var text = stripTags(document.text || document.description || '');
              return {
                canonicalId: document.canonicalId,
                language: document.language,
                translationStatus: document.translationStatus,
                type: document.type,
                title: document.title,
                url: document.url,
                description: document.description,
                excerpt: text.slice(0, 420),
                score: item.score
              };
            });

          return reply({ query: q, language: language || null, backend: 'shared-agent-search-index', count: results.length, results: results });
        }
      });
    } catch (e) {
      // L'enregistrement d'un tool ne doit jamais casser la page.
    }

    // --- Tool : derniers articles ---
    try {
      mc.registerTool({
        name: 'list_recent_analyses',
        description:
          "Liste les analyses (articles) les plus récentes de l0g.fr, de la plus récente à la plus ancienne, " +
          "avec titre, URL absolue, date de publication (AAAA-MM-JJ), description et thèmes. " +
          "Ne couvre pas les guides de référence ni le glossaire ; utiliser search_content pour ceux-ci.",
        inputSchema: {
          type: 'object',
          properties: {
            language: { type: 'string', enum: ['fr', 'en'], description: 'Langue optionnelle. Sans filtre, liste bilingue.' },
            limit: {
              type: 'integer',
              description: "Nombre d'analyses à renvoyer (1 à 20).",
              minimum: 1,
              maximum: 20,
              default: 5
            }
          }
        },
        annotations: { readOnlyHint: true },
        execute: async function (input) {
          let limit = parseInt((input && input.limit) || 5, 10);
          if (!Number.isFinite(limit)) limit = 5;
          limit = Math.max(1, Math.min(20, limit));
          const language = input && (input.language === 'fr' || input.language === 'en') ? input.language : '';
          const index = await loadSearchIndex();
          if (!index || !Array.isArray(index.documents)) return reply({ error: 'index de recherche indisponible' });
          const analyses = index.documents
            .filter(function (document) { return document.type === 'article' && (!language || document.language === language); })
            .sort(function (a, b) { return String(b.date || '').localeCompare(String(a.date || '')); })
            .slice(0, limit)
            .map(function (document) {
              return {
                canonicalId: document.canonicalId,
                language: document.language,
                translationStatus: document.translationStatus,
                title: document.title,
                url: document.url,
                date: document.date,
                description: document.description,
                tags: document.tags
              };
            });
          return reply({ language: language || null, count: analyses.length, analyses: analyses });
        }
      });
    } catch (e) {
      // idem : ne jamais casser la page.
    }

    // --- Tool : manifeste Agent Surface ---
    try {
      mc.registerTool({
        name: 'get_agent_manifest',
        description:
          "Renvoie le manifeste Agent Surface de l0g.fr : capacités, endpoints, règles d'usage, attribution et politique de preuve.",
        inputSchema: { type: 'object', properties: {} },
        annotations: { readOnlyHint: true },
        execute: async function () {
          try {
            var manifest = await readPublicJson('/agents.json');
            return reply(manifest);
          } catch (e) {
            return reply({ error: 'manifeste indisponible', url: site + '/agents.json' });
          }
        }
      });
    } catch (e) {
      // idem.
    }

    // --- Tool : fraîcheur du corpus ---
    try {
      mc.registerTool({
        name: 'get_freshness',
        description:
          "Renvoie la fraîcheur du corpus l0g : derniers contenus, compteurs, endpoints disponibles et politique de fraîcheur.",
        inputSchema: {
          type: 'object',
          properties: {
            limit: { type: 'integer', description: 'Nombre de contenus récents à renvoyer (1 à 20).', minimum: 1, maximum: 20, default: 10 }
          }
        },
        annotations: { readOnlyHint: true },
        execute: async function (input) {
          var limit = clampLimit(input && input.limit, 10, 20);
          try {
            var freshness = await readPublicJson('/api/v1/freshness.json');
            return reply({
              schema: freshness.schema,
              version: freshness.version,
              generated: freshness.generated,
              latest: (freshness.latest || []).slice(0, limit),
              corpus: freshness.corpus,
              endpoints: freshness.endpoints,
              freshnessPolicy: freshness.freshnessPolicy
            });
          } catch (e) {
            return reply({ error: 'freshness indisponible', url: site + '/api/v1/freshness.json' });
          }
        }
      });
    } catch (e) {
      // idem.
    }

    // --- Tool : Risk Diff ---
    try {
      mc.registerTool({
        name: 'get_risk_diff',
        description:
          "Renvoie le Risk Diff l0g : signaux, sources, claims, modèles, articles et confiance sur 1, 7 ou 30 jours.",
        inputSchema: {
          type: 'object',
          properties: {
            window: { type: 'string', enum: ['1d', '7d', '30d'], description: 'Fenêtre optionnelle : 1d, 7d ou 30d.' }
          }
        },
        annotations: { readOnlyHint: true },
        execute: async function (input) {
          try {
            var surface = await readPublicJson('/api/v1/risk-diff.json');
            var windowValue = String((input && input.window) || '').trim();
            var windows = Array.isArray(surface.windows) ? surface.windows : [];
            if (windowValue) {
              var selectedWindow = windows.find(function (item) { return item.window === windowValue; }) || null;
              return reply({
                generated: surface.generated,
                anchorDate: surface.anchorDate,
                filters: { window: windowValue },
                selectedWindow: selectedWindow,
                limitations: surface.limitations
              });
            }
            return reply({
              generated: surface.generated,
              anchorDate: surface.anchorDate,
              windows: windows,
              limitations: surface.limitations
            });
          } catch (e) {
            return reply({ error: 'risk diff indisponible', url: site + '/api/v1/risk-diff.json' });
          }
        }
      });
    } catch (e) {
      // idem.
    }

    // --- Tool : Black Box Recorder ---
    try {
      mc.registerTool({
        name: 'get_black_box',
        description:
          "Renvoie le Black Box Recorder l0g : frames point-in-time hashées des signaux de risque. Avec date, rejoue la dernière frame publiée avant ou le jour demandé.",
        inputSchema: {
          type: 'object',
          properties: {
            date: { type: 'string', description: 'Date à rejouer au format YYYY-MM-DD.' },
            limitFrames: { type: 'integer', minimum: 1, maximum: 30, default: 5 }
          }
        },
        annotations: { readOnlyHint: true },
        execute: async function (input) {
          try {
            var surface = await readPublicJson('/api/v1/black-box.json');
            var frames = Array.isArray(surface.frames) ? surface.frames.slice() : [];
            frames.sort(function (a, b) { return String(a.date).localeCompare(String(b.date)); });
            var requestedDate = String((input && input.date) || '').trim().slice(0, 10);
            if (requestedDate) {
              var frame = frames.filter(function (item) { return String(item.date) <= requestedDate; }).pop() || null;
              return reply({
                generated: surface.generated,
                coverage: surface.coverage,
                replay: surface.replay,
                requestedDate: requestedDate,
                replayable: Boolean(frame),
                frame: frame,
                policy: surface.policy
              });
            }
            var limit = clampLimit(input && input.limitFrames, 5, 30);
            return reply({
              generated: surface.generated,
              coverage: surface.coverage,
              replay: surface.replay,
              latestFrame: frames[frames.length - 1] || null,
              frames: frames.slice(-limit),
              policy: surface.policy
            });
          } catch (e) {
            return reply({ error: 'black box indisponible', url: site + '/api/v1/black-box.json' });
          }
        }
      });
    } catch (e) {
      // idem.
    }

    // --- Tool : claims sourcées ---
    try {
      mc.registerTool({
        name: 'get_claims',
        description:
          "Renvoie les claims typées de l0g.fr, filtrables par article, type de claim ou requête texte, avec références cliquables, datées quand détectable.",
        inputSchema: {
          type: 'object',
          properties: {
            articleSlug: { type: 'string', description: "Slug d'article facultatif." },
            language: { type: 'string', enum: ['fr', 'en'], description: 'Langue du slug. Les claims restent canoniques en français.' },
            kind: { type: 'string', description: 'fait, estimation, inférence, scénario ou unclassified-assertion.' },
            query: { type: 'string', description: 'Filtre texte facultatif.' },
            limit: { type: 'integer', minimum: 1, maximum: 50, default: 10 }
          }
        },
        annotations: { readOnlyHint: true },
        execute: async function (input) {
          var articleSlug = String((input && input.articleSlug) || '').trim().slice(0, 120);
          var language = input && (input.language === 'fr' || input.language === 'en') ? input.language : '';
          var kind = String((input && input.kind) || '').trim().toLowerCase().slice(0, 40);
          var query = String((input && input.query) || '').trim().toLowerCase().slice(0, 200);
          var limit = clampLimit(input && input.limit, 10, 50);
          try {
            var surface = await readPublicJson('/api/v1/claims.json');
            var claims = Array.isArray(surface.claims) ? surface.claims : [];
            if (articleSlug) {
              var index = await loadSearchIndex();
              var document = index && Array.isArray(index.documents) ? index.documents.find(function (item) {
                return item.type === 'article' && item.slug === articleSlug && (!language || item.language === language);
              }) : null;
              var canonicalSlug = document && String(document.canonicalId || '').replace(/^article:/, '') || articleSlug;
              claims = claims.filter(function (claim) { return claim.articleSlug === canonicalSlug; });
            }
            if (kind) claims = claims.filter(function (claim) { return String(claim.kind || '').toLowerCase() === kind; });
            if (query) {
              claims = claims.filter(function (claim) {
                return [claim.claim, claim.articleTitle, claim.articleSlug].join(' ').toLowerCase().indexOf(query) !== -1;
              });
            }
            return reply({
              generated: surface.generated,
              count: Math.min(claims.length, limit),
              totalMatches: claims.length,
              claims: claims.slice(0, limit)
            });
          } catch (e) {
            return reply({ error: 'claims indisponibles', url: site + '/api/v1/claims.json' });
          }
        }
      });
    } catch (e) {
      // idem.
    }

    // --- Tool : evidence graph ---
    try {
      mc.registerTool({
        name: 'get_evidence_graph',
        description:
          "Renvoie un sous-graphe de preuve : articles, claims, références, hôtes, sources primaires et datasets. Filtrage possible par slug d'article ou type de nœud.",
        inputSchema: {
          type: 'object',
          properties: {
            articleSlug: { type: 'string', description: "Slug d'article facultatif." },
            language: { type: 'string', enum: ['fr', 'en'], description: 'Langue du slug. Le graphe reste canonique en français.' },
            nodeType: { type: 'string', description: 'article, claim, reference, host, primarySource ou dataset.' },
            limit: { type: 'integer', minimum: 1, maximum: 120, default: 40 }
          }
        },
        annotations: { readOnlyHint: true },
        execute: async function (input) {
          var articleSlug = String((input && input.articleSlug) || '').trim().slice(0, 120);
          var language = input && (input.language === 'fr' || input.language === 'en') ? input.language : '';
          var nodeType = String((input && input.nodeType) || '').trim().slice(0, 40);
          var limit = clampLimit(input && input.limit, 40, 120);
          try {
            var graph = await readPublicJson('/api/v1/evidence-graph.json');
            var nodes = Array.isArray(graph.nodes) ? graph.nodes : [];
            var edges = Array.isArray(graph.edges) ? graph.edges : [];
            if (articleSlug) {
              var index = await loadSearchIndex();
              var document = index && Array.isArray(index.documents) ? index.documents.find(function (item) {
                return item.type === 'article' && item.slug === articleSlug && (!language || item.language === language);
              }) : null;
              articleSlug = document && String(document.canonicalId || '').replace(/^article:/, '') || articleSlug;
            }
            var articleId = articleSlug ? 'article:' + articleSlug : '';
            if (articleSlug) {
              var keep = new Set([articleId]);
              edges.forEach(function (edge) {
                if (edge.from === articleId || edge.to === articleId || keep.has(edge.from) || keep.has(edge.to)) {
                  keep.add(edge.from);
                  keep.add(edge.to);
                }
              });
              edges.forEach(function (edge) {
                if (keep.has(edge.from) || keep.has(edge.to)) {
                  keep.add(edge.from);
                  keep.add(edge.to);
                }
              });
              nodes = nodes.filter(function (node) { return keep.has(node.id); });
              edges = edges.filter(function (edge) { return keep.has(edge.from) && keep.has(edge.to); });
            }
            if (nodeType) nodes = nodes.filter(function (node) { return node.type === nodeType; });
            var candidateIds = new Set(nodes.map(function (node) { return node.id; }));
            var candidateEdges = edges.filter(function (edge) { return candidateIds.has(edge.from) && candidateIds.has(edge.to); });
            var nodeIds = new Set();
            var keptEdges = [];
            if (!nodeType && candidateEdges.length) {
              function rank(edge) {
                if (articleId && (edge.from === articleId || edge.to === articleId)) return 0;
                if (edge.type === 'contains') return 1;
                if (edge.type === 'cites') return 2;
                if (edge.type === 'hostedBy') return 3;
                if (edge.type === 'matchesPrimarySource') return 4;
                return 5;
              }
              candidateEdges.sort(function (a, b) { return rank(a) - rank(b); }).forEach(function (edge) {
                if (nodeIds.size >= limit) return;
                nodeIds.add(edge.from);
                nodeIds.add(edge.to);
                keptEdges.push(edge);
              });
              nodes = nodes.filter(function (node) { return nodeIds.has(node.id); });
            } else {
              nodes = nodes.slice(0, limit);
              nodeIds = new Set(nodes.map(function (node) { return node.id; }));
              keptEdges = candidateEdges.filter(function (edge) { return nodeIds.has(edge.from) && nodeIds.has(edge.to); });
            }
            keptEdges = keptEdges.slice(0, limit * 2);
            return reply({
              generated: graph.generated,
              returned: { nodes: nodeIds.size, edges: keptEdges.length },
              nodes: nodes.slice(0, limit),
              edges: keptEdges
            });
          } catch (e) {
            return reply({ error: 'evidence graph indisponible', url: site + '/api/v1/evidence-graph.json' });
          }
        }
      });
    } catch (e) {
      // idem.
    }

    // --- Tool : contenu complet d'un article ---
    try {
      mc.registerTool({
        name: 'get_article',
        description:
          "Renvoie le contenu texte complet d'une analyse ou d'un guide français ou anglais à partir de son slug " +
          "(le dernier segment de /posts/, /guides/, /en/analysis/ ou /en/guides/). " +
          "Récupérer les slugs via list_recent_analyses, search_content ou search_by_topic.",
        inputSchema: {
          type: 'object',
          properties: {
            slug: { type: 'string', description: "Slug ou URL de l'analyse ou du guide." },
            language: { type: 'string', enum: ['fr', 'en'], description: 'Langue optionnelle. Une URL /en/... permet aussi de l’inférer.' }
          },
          required: ['slug']
        },
        annotations: { readOnlyHint: true },
        execute: async function (input) {
          var raw = String((input && input.slug) || '').trim();
          var slug = raw.replace(/^https?:\/\/[^/]+/i, '').replace(/[?#].*$/, '').replace(/^\/+|\/+$/g, '').replace(/^(?:posts|guides|en\/analysis|en\/guides)\//, '');
          var language = input && (input.language === 'fr' || input.language === 'en') ? input.language : (/\/?en\/(?:analysis|guides)\//.test(raw) ? 'en' : '');
          var index = await loadSearchIndex();
          var documents = index && Array.isArray(index.documents) ? index.documents : [];
          var matches = documents.filter(function (document) {
            return (document.type === 'article' || document.type === 'guide') && document.slug === slug && (!language || document.language === language);
          });
          var document = matches.find(function (item) { return item.language === 'fr'; }) || matches[0];
          if (!document) {
            return reply({ error: 'slug inconnu', slug: slug, note: 'utiliser list_recent_analyses ou search_content pour obtenir un slug valide' });
          }
          var parsedUrl = new URL(document.url, site);
          if (parsedUrl.origin !== new URL(site).origin || !/^\/(?:posts|guides|en\/analysis|en\/guides)\/[a-z0-9][a-z0-9-]*\/$/.test(parsedUrl.pathname)) {
            return reply({ error: 'route de contenu invalide', slug: slug });
          }
          var url = parsedUrl.toString();
          try {
            var res = await fetch(parsedUrl.pathname, { credentials: 'omit' });
            if (!res.ok) return reply({ error: 'article introuvable', slug: slug, url: url });
            var doc = new DOMParser().parseFromString(await res.text(), 'text/html');
            var titleEl = doc.querySelector('article h1') || doc.querySelector('h1');
            var bodyEl = doc.querySelector('.prose') || doc.querySelector('[data-pagefind-body]') || doc.querySelector('article');
            var body = stripTags(bodyEl ? bodyEl.textContent : '');
            var MAX = 16000;
            var truncated = body.length > MAX;
            if (truncated) body = body.slice(0, MAX);
            return reply({
              slug: slug,
              canonicalId: document.canonicalId,
              language: document.language,
              translationStatus: document.translationStatus,
              type: document.type,
              url: url,
              title: titleEl ? stripTags(titleEl.textContent) : slug,
              words: body ? body.split(/\s+/).length : 0,
              truncated: truncated,
              text: body
            });
          } catch (e) {
            return reply({ error: 'erreur de récupération', slug: slug, url: url });
          }
        }
      });
    } catch (e) {
      // idem.
    }

    // --- Tool : articles d'un sujet (hub thématique) ---
    try {
      var topicCatalog = topicsList.map(function (t) { return t.slug + ' : ' + t.label; }).join(' ; ');
      mc.registerTool({
        name: 'search_by_topic',
        description:
          "Liste les analyses rattachées à un sujet (hub thématique) de l0g.fr, du plus récent au plus ancien, " +
          "avec titre, URL et date. Sujets disponibles (slug : libellé) : " + topicCatalog + ". " +
          "Accepte le slug exact ou un libellé approchant.",
        inputSchema: {
          type: 'object',
          properties: {
            topic: { type: 'string', description: "Slug ou libellé du sujet, par ex. « crypto », « credit-prive », « géopolitique »." },
            language: { type: 'string', enum: ['fr', 'en'], description: 'Langue optionnelle. Sans filtre, recherche bilingue.' },
            limit: { type: 'integer', description: "Nombre maximum d'analyses (1 à 20).", minimum: 1, maximum: 20, default: 10 }
          },
          required: ['topic']
        },
        annotations: { readOnlyHint: true },
        execute: async function (input) {
          var raw = String((input && input.topic) || '').trim().toLowerCase();
          var limit = parseInt((input && input.limit) || 10, 10);
          if (!Number.isFinite(limit)) limit = 10;
          limit = Math.max(1, Math.min(20, limit));
          if (!raw) return reply({ error: 'sujet vide', topics: topicsList });
          // Résolution : slug exact, sinon rapprochement par libellé ou slug.
          var match = topicsList.find(function (t) { return t.slug === raw; });
          if (!match) {
            match = topicsList.find(function (t) {
              var lbl = t.label.toLowerCase();
              return lbl.indexOf(raw) !== -1 || t.slug.indexOf(raw) !== -1 || raw.indexOf(t.slug) !== -1;
            });
          }
          if (!match) return reply({ error: 'sujet inconnu', requested: raw, topics: topicsList });
          var language = input && (input.language === 'fr' || input.language === 'en') ? input.language : '';
          var index = await loadSearchIndex();
          var documents = index && Array.isArray(index.documents) ? index.documents : [];
          var analyses = documents
            .filter(function (document) {
              return document.type === 'article' && (!language || document.language === language) && (document.topics || []).indexOf(match.slug) !== -1;
            })
            .sort(function (a, b) { return String(b.date || '').localeCompare(String(a.date || '')); })
            .slice(0, limit)
            .map(function (document) {
              return {
                canonicalId: document.canonicalId,
                language: document.language,
                translationStatus: document.translationStatus,
                title: document.title,
                url: document.url,
                date: document.date,
                description: document.description
              };
            });
          return reply({ topic: match.slug, label: match.label, language: language || null, count: analyses.length, analyses: analyses });
        }
      });
    } catch (e) {
      // idem.
    }
  })();
</script>
