---
// Barres horizontales étiquetées, à la charte l0g. Couvre les comparaisons et
// les parts (ex. "2,72 M$ vs 1,1 M$", "marché total vs sliver immobilier").
// Les valeurs sont mises à l'échelle du max (ou de `max` si fourni).
import Infographic from './Infographic.astro';

type Tone = 'signal' | 'amber' | 'accent' | 'blue' | 'muted';

interface Item {
  label: string;
  value: number;
  valueLabel?: string;
  tone?: Tone;
}

interface Props {
  title: string;
  subtitle?: string;
  items: Item[];
  max?: number;
  note?: string;
  notes?: string[];
  source?: string;
  caption?: string;
}

const TONES: Record<Tone, string> = {
  signal: '#5eead4',
  amber: '#f5b13d',
  accent: '#ff4d87',
  blue: '#7aa2f7',
  muted: '#8b909b',
};

const { title, subtitle, items, max, note, notes = [], source, caption } = Astro.props;

const W = 720;
const x0 = 40;
const barW = W - 2 * x0;
const trackH = 26;
const maxV = max ?? Math.max(...items.map((i) => i.value), 0.0001);

let y = subtitle ? 84 : 66;
const rows = items.map((it) => {
  const labelY = y;
  const barTop = y + 8;
  y = barTop + trackH + 20;
  const w = it.value > 0 ? Math.max(4, Math.round((it.value / maxV) * barW)) : 0;
  const inside = w > barW * 0.5;
  return {
    label: it.label,
    valueLabel: it.valueLabel,
    color: TONES[it.tone ?? 'signal'],
    labelY,
    barTop,
    w,
    inside,
  };
});

let dividerY: number | null = null;
if (note || notes.length) {
  dividerY = y - 8;
  y += 12;
}
let noteY: number | null = null;
if (note) {
  noteY = y;
  y += 24;
}
const noteLines = notes.map((t) => {
  const lineY = y;
  y += 22;
  return { t, lineY };
});
let sourceY: number | null = null;
if (source) {
  y += 8;
  sourceY = y;
  y += 4;
}
const H = y + 12;
---
<Infographic caption={caption}>
  <svg
    viewBox={`0 0 ${W} ${H}`}
    role="img"
    aria-label={title}
    xmlns="http://www.w3.org/2000/svg"
    style="width:100%;height:auto;font-family:ui-monospace,monospace"
  >
    <rect width={W} height={H} fill="#0c0d10"></rect>
    <text x="32" y="38" fill="#f5f6f8" font-size="17" font-weight="700">{title}</text>
    {subtitle && <text x="32" y="59" fill="#8b909b" font-size="12">{subtitle}</text>}

    {rows.map((r) => (
      <>
        <text x={x0} y={r.labelY} fill="#d6d9df" font-size="12">{r.label}</text>
        <rect x={x0} y={r.barTop} width={barW} height={trackH} fill="#2a2c33"></rect>
        <rect x={x0} y={r.barTop} width={r.w} height={trackH} fill={r.color} opacity="0.9"></rect>
        {r.valueLabel && (r.inside ? (
          <text x={x0 + r.w - 12} y={r.barTop + 18} fill="#0c0d10" font-size="12" font-weight="700" text-anchor="end">{r.valueLabel}</text>
        ) : (
          <text x={x0 + r.w + 10} y={r.barTop + 18} fill={r.color} font-size="12" font-weight="700">{r.valueLabel}</text>
        ))}
      </>
    ))}

    {dividerY !== null && (
      <line x1={x0} y1={dividerY} x2={W - x0} y2={dividerY} stroke="#2a2c33" stroke-width="1"></line>
    )}
    {noteY !== null && (
      <text x={x0} y={noteY} fill="#ff4d87" font-size="13" font-weight="700">{note}</text>
    )}
    {noteLines.map((n) => (
      <text x={x0} y={n.lineY} fill="#d6d9df" font-size="12">{n.t}</text>
    ))}
    {sourceY !== null && (
      <text x={x0} y={sourceY} fill="#8b909b" font-size="11">{source}</text>
    )}
  </svg>
</Infographic>
