---
// OrbitCard.astro — carte de mise en avant vers orbit.l0g.fr
// À déposer dans src/components/ puis à insérer dans la home (voir README).
// Styles scopés Astro -> compilés en CSS externe, compatibles CSP style-src 'self'.
const href = "https://orbit.l0g.fr";
---

<a class="orbit-card" href={href} aria-label="Orbit — heatmap crypto temps réel">
  <span class="mark" aria-hidden="true">
    <svg viewBox="0 0 48 48" width="48" height="48">
      <ellipse class="ring" cx="24" cy="24" rx="20" ry="8"
               transform="rotate(-28 24 24)" fill="none" stroke="currentColor"
               stroke-width="1.6" opacity="0.85"></ellipse>
      <circle class="glow" cx="24" cy="24" r="9" fill="currentColor" opacity="0.18"></circle>
      <circle class="dot"  cx="24" cy="24" r="4.6" fill="currentColor"></circle>
    </svg>
  </span>

  <span class="body">
    <span class="eyebrow">// orbit</span>
    <span class="title">Orbit <span class="badge">nouveau</span></span>
    <span class="desc">Heatmap crypto temps réel — top&nbsp;1000, favoris, signaux de divergence &amp; anomalies.</span>
  </span>

  <span class="cta">ouvrir&nbsp;<span class="chev">›</span></span>
</a>

<style>
  .orbit-card{
    --gold:#e8b04b;
    --ink:#eef2f6;
    --dim:#93a0b0;
    --bg:#0c0f15;
    --line:rgba(255,255,255,.10);
    display:flex; align-items:center; gap:18px;
    padding:18px 20px;
    background:
      radial-gradient(120% 140% at 12% 0%, rgba(232,176,75,.06), transparent 60%),
      var(--bg);
    border:1px solid var(--line);
    border-radius:16px;
    text-decoration:none;
    color:var(--ink);
    font-family:ui-monospace,"JetBrains Mono","IBM Plex Mono",SFMono-Regular,Menlo,monospace;
    transition:border-color .18s ease, transform .18s ease, box-shadow .18s ease;
  }
  .orbit-card:hover{
    border-color:rgba(232,176,75,.55);
    transform:translateY(-1px);
    box-shadow:0 10px 34px rgba(0,0,0,.45);
  }
  .mark{
    flex:0 0 auto; color:var(--gold);
    display:grid; place-items:center;
    width:56px; height:56px;
    border:1px dotted rgba(232,176,75,.4); border-radius:13px;
    background:rgba(232,176,75,.04);
  }
  .orbit-card:hover .ring{ transform-box:fill-box; animation:spin 9s linear infinite; transform-origin:center; }
  @keyframes spin{ from{transform:rotate(-28deg)} to{transform:rotate(332deg)} }
  @media (prefers-reduced-motion:reduce){ .orbit-card:hover .ring{ animation:none } }

  .body{ display:flex; flex-direction:column; gap:3px; min-width:0; flex:1 1 auto; }
  .eyebrow{ color:var(--gold); font-size:11px; letter-spacing:.06em; opacity:.85; }
  .title{
    display:flex; align-items:center; gap:9px;
    font-size:19px; font-weight:700; letter-spacing:.01em; line-height:1.1;
  }
  .badge{
    font-size:9.5px; font-weight:700; letter-spacing:.08em; text-transform:uppercase;
    color:#0a0a0a; background:var(--gold);
    padding:2px 6px; border-radius:999px;
  }
  .desc{ color:var(--dim); font-size:12.5px; line-height:1.45; }

  .cta{
    flex:0 0 auto; align-self:center;
    color:var(--gold); font-size:13px; font-weight:600;
    padding:9px 14px; border:1px solid rgba(232,176,75,.35); border-radius:11px;
    white-space:nowrap;
    transition:background .18s ease;
  }
  .orbit-card:hover .cta{ background:rgba(232,176,75,.10); }
  .orbit-card:hover .chev{ margin-left:2px; }
  .chev{ transition:margin-left .18s ease; }

  @media (max-width:560px){
    .orbit-card{ flex-wrap:wrap; gap:14px; }
    .body{ flex:1 1 60%; }
    .cta{ flex:1 1 100%; text-align:center; order:3; }
  }
</style>
