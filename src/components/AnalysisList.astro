---
export interface AnalysisItem {
  id: string;
  title: string;
  description: string;
  date: Date;
  tag?: string;
  rt: number;
  index: number;
}

interface Props {
  items: AnalysisItem[];
  currentPage: number;
  totalPages: number;
}

const { items, currentPage, totalPages } = Astro.props;

const fmt = (d: Date) => d.toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' });
const pageHref = (n: number) => (n <= 1 ? '/en/analysis/' : `/en/analysis/page/${n}/`);
const pages = Array.from({ length: totalPages }, (_, i) => i + 1);
---

<section class="cat rise">
  {items.map((p) => (
    <a href={`/en/analysis/${p.id}/`} class="en-guide-card">
      <span class="en-guide-index mono-label" aria-hidden="true">{String(p.index).padStart(2, '0')}</span>
      <span class="en-guide-rail" aria-hidden="true"></span>
      <span class="en-guide-body">
        <span class="en-guide-meta mono-label">
          <time datetime={p.date.toISOString()}>{fmt(p.date)}</time>
          <span aria-hidden="true">·</span>
          <span>{p.rt} min read</span>
          {p.tag && <span class="topic-chip">{p.tag}</span>}
        </span>
        <span class="en-guide-title">{p.title}</span>
        <span class="en-guide-desc">{p.description}</span>
      </span>
      <span class="en-guide-arrow" aria-hidden="true">›</span>
    </a>
  ))}
</section>

{
  totalPages > 1 && (
    <nav class="pager rise" aria-label="Analysis pages">
      {currentPage > 1 ? (
        <a class="pager-step" href={pageHref(currentPage - 1)} rel="prev">‹ Prev</a>
      ) : (
        <span class="pager-step is-disabled" aria-disabled="true">‹ Prev</span>
      )}
      <span class="pager-nums">
        {pages.map((n) =>
          n === currentPage ? (
            <span class="pager-num is-current" aria-current="page">{n}</span>
          ) : (
            <a class="pager-num" href={pageHref(n)}>{n}</a>
          )
        )}
      </span>
      {currentPage < totalPages ? (
        <a class="pager-step" href={pageHref(currentPage + 1)} rel="next">Next ›</a>
      ) : (
        <span class="pager-step is-disabled" aria-disabled="true">Next ›</span>
      )}
    </nav>
  )
}

<style>
  .cat { padding-top: 2.6rem; }
  .en-guide-card {
    --a: var(--color-signal);
    display: grid;
    grid-template-columns: auto 2px 1fr auto;
    align-items: start;
    column-gap: 1rem;
    padding: 1.45rem 0.85rem 1.45rem 0.25rem;
    border-bottom: 1px solid var(--color-line);
    border-radius: 8px;
    transition: background 0.16s;
  }
  .en-guide-card:hover { background: color-mix(in srgb, var(--a) 7%, transparent); }
  .en-guide-index {
    min-width: 1.8rem;
    padding-top: 0.2rem;
    color: var(--color-line-strong);
    font-variant-numeric: tabular-nums;
    transition: color 0.16s;
  }
  .en-guide-card:hover .en-guide-index { color: var(--a); }
  .en-guide-rail {
    align-self: stretch;
    border-radius: 999px;
    background: color-mix(in srgb, var(--a) 30%, transparent);
    transition: background 0.16s;
  }
  .en-guide-card:hover .en-guide-rail { background: var(--a); }
  .en-guide-body { min-width: 0; }
  .en-guide-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 0.55rem; color: var(--a); }
  .topic-chip {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--a);
    padding: 0.1rem 0.45rem;
    border: 1px solid color-mix(in srgb, var(--a) 35%, transparent);
    background: color-mix(in srgb, var(--a) 12%, transparent);
    border-radius: 999px;
  }
  .en-guide-title {
    display: block;
    margin-top: 0.6rem;
    font-size: 1.18rem;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: var(--color-bright);
    transition: color 0.16s;
  }
  .en-guide-card:hover .en-guide-title { color: var(--a); }
  .en-guide-desc {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-top: 0.5rem;
    font-size: 0.88rem;
    line-height: 1.55;
    color: var(--color-muted);
  }
  .en-guide-arrow {
    align-self: center;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--color-line-strong);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.16s, transform 0.16s, color 0.16s;
  }
  .en-guide-card:hover .en-guide-arrow { opacity: 1; transform: translateX(0); color: var(--a); }
  @media (max-width: 640px) {
    .en-guide-card { grid-template-columns: auto 2px 1fr; }
    .en-guide-arrow { display: none; }
  }

  .pager {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2.4rem;
    padding-top: 1.6rem;
    border-top: 1px dashed var(--color-line);
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }
  .pager-step {
    color: var(--color-signal);
    text-decoration: none;
    padding: 0.35rem 0.7rem;
    border: 1px solid color-mix(in srgb, var(--color-signal) 35%, transparent);
    border-radius: 6px;
    transition: background 0.16s, color 0.16s;
    white-space: nowrap;
  }
  .pager-step:hover { background: color-mix(in srgb, var(--color-signal) 12%, transparent); }
  .pager-step.is-disabled {
    color: var(--color-line-strong);
    border-color: var(--color-line);
    pointer-events: none;
    opacity: 0.55;
  }
  .pager-nums { display: flex; flex-wrap: wrap; align-items: center; gap: 0.3rem; }
  .pager-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.9rem;
    height: 1.9rem;
    padding: 0 0.4rem;
    color: var(--color-muted);
    text-decoration: none;
    border-radius: 6px;
    font-variant-numeric: tabular-nums;
    transition: background 0.16s, color 0.16s;
  }
  .pager-num:hover { color: var(--color-bright); background: color-mix(in srgb, var(--color-signal) 10%, transparent); }
  .pager-num.is-current {
    color: var(--color-bg, #0c0d10);
    background: var(--color-signal);
    font-weight: 700;
  }
  @media (max-width: 480px) {
    .pager { flex-wrap: wrap; justify-content: center; }
  }
</style>
