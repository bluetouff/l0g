---
import type { ArticleEvidence } from '../lib/article-evidence.ts';
import { primarySourceUrl } from '../config/primary-sources.ts';

interface Props {
  evidence: ArticleEvidence;
}

const { evidence } = Astro.props;
const primaryShown = evidence.primary.slice(0, 6);
const secondaryShown = evidence.secondary.slice(0, 8);
const dataShown = evidence.internalData.slice(0, 6);
const contextShown = evidence.context.slice(0, 10);
const claimsShown = evidence.claims.slice(0, 12);
const badges = evidence.badges;
const depth = evidence.depth;
const claimTone: Record<string, string> = {
  fait: 'claim-fact',
  estimation: 'claim-estimate',
  inférence: 'claim-inference',
  scénario: 'claim-scenario',
};
---

<aside class="evidence-box" aria-labelledby="evidence-title" data-pagefind-ignore>
  <div class="evidence-head">
    <div>
      <p id="evidence-title" class="mono-label">// preuves utilisées</p>
      <p class="evidence-note">
        Backfill automatique des passages référencés : chaque ligne relie une affirmation
        à une ou plusieurs sources cliquables, datées quand détectable.
      </p>
    </div>
    <div class="evidence-counts" aria-label="Résumé de traçabilité">
      <span>{evidence.stats.primarySources} primaires</span>
      <span>{evidence.stats.externalLinks} externes</span>
      <span>{evidence.stats.internalLinks} internes</span>
      <span>{evidence.stats.claimRelations} relations</span>
    </div>
  </div>

  <div class="evidence-badges" aria-label="Niveaux de preuve détectés">
    <span class="depth-badge" title={depth.detail}>
      <span aria-hidden="true">{depth.score}</span>
      profondeur : {depth.label}
    </span>
    {badges.length > 0 && (
      <>
      {badges.map((badge) => (
        <span class={`proof-badge proof-${badge.tone}`} title={badge.detail}>
          <span aria-hidden="true"></span>
          {badge.label}
        </span>
      ))}
      </>
    )}
  </div>

  <p class="depth-note">
    Profondeur automatique : {depth.detail}. Les niveaux “preuve directe” et “reproduction”
    demandent une relation structurée entre une affirmation précise et sa source.
  </p>

  <section class="claim-section">
    <h2 class="evidence-h">Affirmations sourcées</h2>
    {claimsShown.length > 0 ? (
      <ol class="claim-list">
        {claimsShown.map((claim) => (
          <li class={`claim-item ${claimTone[claim.kind]}`}>
            <div class="claim-top">
              <span>{claim.kind}</span>
              <time datetime={claim.dateIso}>{claim.dateLabel}</time>
            </div>
            <p>{claim.claim}</p>
            <div class="claim-refs">
              {claim.references.map((ref) => (
                <a href={ref.href} target={ref.href.startsWith('http') ? '_blank' : undefined} rel={ref.href.startsWith('http') ? 'noopener' : undefined}>
                  <span>{ref.kind ?? ref.host ?? 'référence'}</span>
                  <strong>{ref.label}</strong>
                  {ref.sourcePublicationDateIso || ref.dateIso ? (
                    <time datetime={ref.sourcePublicationDateIso ?? ref.dateIso}>{ref.sourcePublicationDateLabel ?? ref.dateLabel}</time>
                  ) : (
                    <span>{ref.sourcePublicationDateLabel ?? ref.dateLabel ?? 'date source non détectée'}</span>
                  )}
                </a>
              ))}
            </div>
          </li>
        ))}
      </ol>
    ) : (
      <p class="evidence-empty">Aucune relation affirmation-source détectée automatiquement.</p>
    )}
  </section>

  <div class="evidence-grid">
    <section class="evidence-panel">
      <h2 class="evidence-h">Sources primaires</h2>
      {primaryShown.length > 0 ? (
        <ul class="evidence-list">
          {primaryShown.map((item) => (
            <li>
              <a href={primarySourceUrl(item.source.slug)}>{item.source.shortName}</a>
              <span>source liée à au moins une référence cliquable</span>
              {item.links.length > 0 && (
                <span class="primary-links">
                  {item.links.map((link) => (
                    <a href={link.href} target="_blank" rel="noopener">
                      <span>{link.label}</span>
                      {link.dateLabel && <time datetime={link.dateIso}>{link.dateLabel}</time>}
                    </a>
                  ))}
                </span>
              )}
            </li>
          ))}
        </ul>
      ) : (
        <p class="evidence-empty">Aucune institution primaire du registre l0g détectée automatiquement.</p>
      )}
    </section>

    <section class="evidence-panel">
      <h2 class="evidence-h">Sources secondaires</h2>
      {secondaryShown.length > 0 ? (
        <ul class="evidence-list">
          {secondaryShown.map((link) => (
            <li>
              <a href={link.href} target="_blank" rel="noopener">{link.host ?? link.label}</a>
              <span>{link.label}</span>
              {link.dateLabel && <time datetime={link.dateIso}>{link.dateLabel}</time>}
            </li>
          ))}
        </ul>
      ) : (
        <p class="evidence-empty">Pas de source secondaire externe isolée.</p>
      )}
    </section>

    <section class="evidence-panel">
      <h2 class="evidence-h">Données internes</h2>
      {dataShown.length > 0 ? (
        <ul class="evidence-list">
          {dataShown.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
              <span>{link.kind}</span>
              {link.dateLabel && <time datetime={link.dateIso}>{link.dateLabel}</time>}
            </li>
          ))}
        </ul>
      ) : (
        <p class="evidence-empty">Aucun dataset ou dashboard l0g lié explicitement.</p>
      )}
    </section>

    <section class="evidence-panel">
      <h2 class="evidence-h">Contexte l0g</h2>
      {contextShown.length > 0 ? (
        <ul class="evidence-list">
          {contextShown.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
              <span>{link.kind}</span>
              {link.dateLabel && <time datetime={link.dateIso}>{link.dateLabel}</time>}
            </li>
          ))}
        </ul>
      ) : (
        <p class="evidence-empty">Aucun renvoi interne de contexte détecté.</p>
      )}
    </section>
  </div>
</aside>

<style>
  .evidence-box {
    margin-top: 3rem;
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    padding: 1.2rem 0;
  }
  .evidence-head {
    display: grid;
    gap: 0.9rem;
  }
  @media (min-width: 720px) {
    .evidence-head {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: start;
    }
  }
  .evidence-head .mono-label {
    color: var(--color-signal);
  }
  .evidence-note {
    margin-top: 0.45rem;
    color: var(--color-muted);
    font-size: 0.88rem;
    line-height: 1.55;
  }
  .evidence-counts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  @media (min-width: 720px) {
    .evidence-counts {
      justify-content: flex-end;
      max-width: 14rem;
    }
  }
  .evidence-counts span {
    border: 1px solid color-mix(in srgb, var(--color-signal) 34%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-signal) 7%, transparent);
    color: var(--color-signal);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    padding: 0.28rem 0.55rem;
    text-transform: uppercase;
  }
  .evidence-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 1rem;
  }
  .depth-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    border: 1px solid color-mix(in srgb, var(--color-signal) 45%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-signal) 9%, transparent);
    color: var(--color-signal);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    line-height: 1;
    padding: 0.35rem 0.58rem;
    text-transform: uppercase;
  }
  .depth-badge span {
    display: grid;
    place-items: center;
    width: 1rem;
    height: 1rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-signal) 18%, transparent);
    color: var(--color-bright);
    font-size: 0.58rem;
  }
  .depth-note {
    max-width: 48rem;
    margin-top: 0.65rem;
    color: var(--color-muted);
    font-size: 0.78rem;
    line-height: 1.55;
  }
  .proof-badge {
    --proof-color: var(--color-muted);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border: 1px solid color-mix(in srgb, var(--proof-color) 38%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--proof-color) 8%, transparent);
    color: var(--proof-color);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    line-height: 1;
    padding: 0.35rem 0.58rem;
    text-transform: uppercase;
  }
  .proof-badge span {
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: var(--proof-color);
    box-shadow: 0 0 9px color-mix(in srgb, var(--proof-color) 45%, transparent);
  }
  .proof-strong { --proof-color: var(--color-signal); }
  .proof-data { --proof-color: #7aa2f7; }
  .proof-secondary { --proof-color: var(--color-muted); }
  .proof-scenario { --proof-color: var(--color-amber); }
  .proof-context { --proof-color: var(--color-accent); }
  .claim-section {
    margin-top: 1rem;
    border: 1px solid var(--color-line);
    border-radius: 8px;
    background: color-mix(in srgb, var(--color-surface) 42%, transparent);
    padding: 0.8rem;
  }
  .claim-list {
    display: grid;
    gap: 0.7rem;
    margin-top: 0.7rem;
    padding: 0;
    list-style: none;
  }
  .claim-item {
    border-top: 1px solid var(--color-line);
    padding-top: 0.7rem;
  }
  .claim-item:first-child {
    border-top: 0;
    padding-top: 0;
  }
  .claim-top {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }
  .claim-top span,
  .claim-top time,
  .claim-refs span,
  .claim-refs time {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-style: normal;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .claim-top span {
    color: var(--color-signal);
  }
  .claim-estimate .claim-top span { color: var(--color-amber); }
  .claim-inference .claim-top span { color: var(--color-accent); }
  .claim-scenario .claim-top span { color: #7aa2f7; }
  .claim-top time {
    color: var(--color-muted);
  }
  .claim-item p {
    margin-top: 0.4rem;
    color: var(--color-paper);
    font-size: 0.88rem;
    line-height: 1.55;
  }
  .claim-refs {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.45rem;
    margin-top: 0.65rem;
  }
  @media (min-width: 680px) {
    .claim-refs { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  .claim-refs a {
    display: grid;
    gap: 0.2rem;
    border: 1px solid var(--color-line);
    border-radius: 8px;
    padding: 0.55rem 0.65rem;
    text-decoration: none;
    background: color-mix(in srgb, var(--color-bg) 35%, transparent);
    transition: border-color 0.16s, background 0.16s;
  }
  .claim-refs a:hover {
    border-color: color-mix(in srgb, var(--color-signal) 45%, transparent);
    background: color-mix(in srgb, var(--color-signal) 5%, transparent);
  }
  .claim-refs span {
    color: var(--color-signal);
  }
  .claim-refs strong {
    color: var(--color-paper);
    font-size: 0.82rem;
    line-height: 1.35;
    overflow-wrap: anywhere;
  }
  .claim-refs time {
    color: var(--color-muted);
  }
  .evidence-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    margin-top: 1rem;
  }
  @media (min-width: 760px) {
    .evidence-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  .evidence-panel {
    border: 1px solid var(--color-line);
    border-radius: 8px;
    background: color-mix(in srgb, var(--color-surface) 42%, transparent);
    padding: 0.8rem;
  }
  .evidence-h {
    color: var(--color-bright);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .evidence-list {
    display: grid;
    gap: 0.55rem;
    margin-top: 0.7rem;
    padding: 0;
    list-style: none;
  }
  .evidence-list li {
    display: grid;
    gap: 0.18rem;
  }
  .evidence-list a {
    color: var(--color-signal);
    font-size: 0.88rem;
    line-height: 1.35;
    overflow-wrap: anywhere;
  }
  .evidence-list span,
  .evidence-list time,
  .evidence-empty {
    color: var(--color-muted);
    font-size: 0.78rem;
    line-height: 1.45;
  }
  .evidence-list time,
  .primary-links time {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-style: normal;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .evidence-empty {
    margin-top: 0.7rem;
  }
  .primary-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .primary-links a {
    display: inline-grid;
    gap: 0.1rem;
    color: var(--color-muted);
    font-size: 0.72rem;
  }
  .primary-links span {
    color: inherit;
    font-size: inherit;
  }
  .primary-links time {
    color: var(--color-muted);
  }
</style>
