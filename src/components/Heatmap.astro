---
import { serializeInlineScriptData } from '../lib/security.ts';

/**
 * Heatmap TradingView.
 *   <Heatmap kind="crypto" />
 *   <Heatmap kind="stock" dataSource="SPX500" />
 */
interface Props {
  kind?: 'crypto' | 'stock';
  dataSource?: string; // pour kind="stock" : SPX500, NASDAQ100, etc.
  height?: number;
}
const { kind = 'crypto', dataSource = 'SPX500', height = 480 } = Astro.props;

const isCrypto = kind === 'crypto';
const src = isCrypto
  ? 'https://s3.tradingview.com/external-embedding/embed-widget-crypto-coins-heatmap.js'
  : 'https://s3.tradingview.com/external-embedding/embed-widget-stock-heatmap.js';

const config = isCrypto
  ? {
      dataSource: 'Crypto',
      blockSize: 'market_cap_calc',
      blockColor: 'change',
      locale: 'fr',
      symbolUrl: '',
      colorTheme: 'dark',
      isTransparent: false,
      hasTopBar: false,
      isDataSetEnabled: false,
      isZoomEnabled: true,
      hasSymbolTooltip: true,
      isMonosize: false,
      width: '100%',
      height: '100%',
    }
  : {
      dataSource,
      blockSize: 'market_cap_basic',
      blockColor: 'change',
      grouping: 'sector',
      locale: 'fr',
      symbolUrl: '',
      colorTheme: 'dark',
      isTransparent: false,
      hasTopBar: false,
      isDataSetEnabled: false,
      isZoomEnabled: true,
      hasSymbolTooltip: true,
      width: '100%',
      height: '100%',
    };
---

<div class="tv-widget" style={`--h:${height}px`}>
  <div class="tradingview-widget-container">
    <div class="tradingview-widget-container__widget"></div>
    <script type="text/javascript" src={src} async is:inline set:html={serializeInlineScriptData(config)} />
  </div>
</div>

<style>
  .tv-widget {
    margin: 1.5em 0;
    border: 1px solid var(--color-line);
    background: var(--color-surface);
    min-height: var(--h);
    height: var(--h);
    overflow: hidden;
  }
  .tv-widget .tradingview-widget-container,
  .tv-widget .tradingview-widget-container__widget { height: 100%; width: 100%; }
</style>
