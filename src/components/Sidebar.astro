---
import L0gGlyph, { type GlyphName } from './L0gGlyph.astro';
import SearchForm from './SearchForm.astro';

interface Props {
  path?: string;
}

interface SidebarLink {
  href: string;
  label: string;
  detail: string;
}

interface Context {
  eyebrow: string;
  title: string;
  description: string;
  glyph: GlyphName;
  accent: string;
  links: SidebarLink[];
}

const { path = '/' } = Astro.props;

const contexts: Record<string, Context> = {
  understand: {
    eyebrow: 'carte de lecture',
    title: 'Construire ses repères.',
    description: 'Un dossier pour suivre un fil, un guide pour apprendre, une définition pour débloquer un mot.',
    glyph: 'understand',
    accent: 'var(--color-signal)',
    links: [
      { href: '/sujets/', label: 'Sujets suivis', detail: 'Les fils longs du journal' },
      { href: '/guides/', label: 'Guides de référence', detail: 'Les notions qui durent' },
      { href: '/glossaire/', label: 'Atlas du glossaire', detail: 'Définitions et concepts voisins' },
    ],
  },
  verify: {
    eyebrow: 'chaîne de preuve',
    title: 'Vérifier avant de conclure.',
    description: 'Revenir à la source, comprendre le calcul et lire les limites avant d’utiliser un signal.',
    glyph: 'verify',
    accent: 'var(--color-accent)',
    links: [
      { href: '/methodologie/', label: 'Méthodologie', detail: 'Formules, seuils et limites' },
      { href: '/sources/', label: 'Sources primaires', detail: 'Institutions et cadences' },
      { href: '/preuves/', label: 'Preuves publiques', detail: 'Artefacts et traçabilité' },
    ],
  },
  data: {
    eyebrow: 'surface publique',
    title: 'Passer du récit aux données.',
    description: 'Inventaires, séries et contrats machine restent accessibles, citables et rejouables.',
    glyph: 'source',
    accent: '#7aa2f7',
    links: [
      { href: '/donnees/', label: 'Jeux de données', detail: 'Formats, licences et fraîcheur' },
      { href: '/series/', label: 'Séries de risque', detail: 'Historique nommé et daté' },
      { href: '/api/', label: 'API publique', detail: 'Contrats et points d’accès' },
    ],
  },
  read: {
    eyebrow: 'navigation éditoriale',
    title: 'Trouver le bon point d’entrée.',
    description: 'Lire l’analyse récente, reprendre un sujet dans la durée ou décoder une notion.',
    glyph: 'read',
    accent: 'var(--color-amber)',
    links: [
      { href: '/', label: 'Dernières analyses', detail: 'Le journal, du plus récent au plus ancien' },
      { href: '/sujets/', label: 'Sujets suivis', detail: 'Les dossiers dans la durée' },
      { href: '/hebdo/', label: 'Synthèse hebdo', detail: 'Ce qui mérite d’être retenu' },
    ],
  },
};

const contextKey =
  path.startsWith('/sujet') || path.startsWith('/guides') || path.startsWith('/glossaire') || path.startsWith('/demarrer')
    ? 'understand'
    : path.startsWith('/methodologie') || path.startsWith('/sources') || path.startsWith('/preuves') ||
        path.startsWith('/status') || path.startsWith('/black-box') || path.startsWith('/protocole')
      ? 'verify'
      : path.startsWith('/donnees') || path.startsWith('/api') || path.startsWith('/mcp') ||
          path.startsWith('/agents') || path.startsWith('/series') || path.startsWith('/backtests')
        ? 'data'
        : 'read';

const context = contexts[contextKey];
---

<div class="context-sidebar">
  <section>
    <h2>// recherche</h2>
    <SearchForm compact />
  </section>

  <section
    class="context-card instrument-plate"
    style={`--context-accent:${context.accent};--plate-accent:${context.accent}`}
  >
    <div class="context-head">
      <p>{context.eyebrow}</p>
      <L0gGlyph name={context.glyph} />
    </div>
    <h2>{context.title}</h2>
    <p class="context-copy">{context.description}</p>
  </section>

  <nav class="context-links" aria-label="Accès associés">
    <h2>// poursuivre</h2>
    {context.links.map((link, index) => (
      <a href={link.href} aria-current={path === link.href ? 'page' : undefined}>
        <span>{String(index + 1).padStart(2, '0')}</span>
        <strong>{link.label}</strong>
        <small>{link.detail}</small>
        <b aria-hidden="true">↗</b>
      </a>
    ))}
  </nav>

  <p class="context-note">
    Sources citées · limites visibles<br />
    aucun cookie · aucun tracker
  </p>
</div>

<style>
  .context-sidebar { display: grid; gap: 1.45rem; }
  .context-sidebar > section > h2,
  .context-links > h2 {
    margin-bottom: 0.7rem;
    color: var(--color-signal);
    font-family: var(--font-mono);
    font-size: 0.67rem;
    font-weight: 650;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .context-card {
    --context-accent: var(--color-signal);
    padding: 1rem;
    background:
      radial-gradient(100% 120% at 0 0, color-mix(in srgb, var(--context-accent) 9%, transparent), transparent 70%),
      var(--surface-elevated);
  }
  .context-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .context-head :global(.l0g-glyph) { --glyph-color: var(--context-accent); }
  .context-head p {
    color: var(--context-accent);
    font-family: var(--font-mono);
    font-size: 0.61rem;
    font-weight: 650;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }
  .context-card > h2 {
    max-width: 14ch;
    margin-top: 0.85rem;
    color: var(--color-bright);
    font-family: var(--font-display);
    font-size: 1.22rem;
    line-height: 1.2;
  }
  .context-copy {
    margin-top: 0.6rem;
    color: var(--color-muted);
    font-family: var(--font-read);
    font-size: 0.79rem;
    line-height: 1.58;
  }
  .context-links { display: grid; gap: 0.35rem; }
  .context-links > h2 { margin-bottom: 0.25rem; }
  .context-links a {
    position: relative;
    display: grid;
    grid-template-columns: 1.65rem minmax(0, 1fr) auto;
    grid-template-rows: auto auto;
    gap: 0.08rem 0.55rem;
    border-bottom: 1px solid var(--color-line);
    padding: 0.65rem 0.1rem;
  }
  .context-links a > span {
    grid-row: 1 / 3;
    padding-top: 0.12rem;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.06em;
  }
  .context-links strong {
    color: var(--color-paper);
    font-size: 0.83rem;
    line-height: 1.3;
  }
  .context-links small {
    color: var(--color-muted);
    font-size: 0.67rem;
    line-height: 1.4;
  }
  .context-links b {
    grid-column: 3;
    grid-row: 1 / 3;
    align-self: center;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 400;
    transition: color 0.16s, transform 0.16s;
  }
  .context-links a:hover strong,
  .context-links a[aria-current='page'] strong { color: var(--color-signal); }
  .context-links a:hover b { color: var(--color-signal); transform: translate(2px, -2px); }
  .context-note {
    border-left: 1px solid var(--color-line);
    padding-left: 0.7rem;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.59rem;
    line-height: 1.65;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  @media (prefers-reduced-motion: reduce) {
    .context-links a:hover b { transform: none; }
  }
</style>
