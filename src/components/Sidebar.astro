---
/**
 * Colonne de droite — DESKTOP. Boutons vers les apps l0g (cartes terminal,
 * accent par application). Contenu dans src/config/sidebar.ts.
 */
import { dashboards, sidebarAbout } from '../config/sidebar.ts';
import SearchForm from './SearchForm.astro';

const accentVar: Record<string, string> = {
  teal: 'var(--color-signal)',
  blue: '#7aa2f7',
  pink: 'var(--color-accent)',
  amber: 'var(--color-amber)',
};
---

<div class="space-y-6">
  <section>
    <h2 class="mono-label glow mb-3">// recherche</h2>
    <SearchForm compact />
  </section>

  <section>
    <a href="/dashboards/" class="group mb-3 flex items-baseline justify-between gap-2">
      <h2 class="mono-label glow">// dashboards</h2>
      <span class="text-xs text-muted transition-colors group-hover:text-bright">tout voir ›</span>
    </a>
    <div class="space-y-2.5">
      {
        dashboards.map((d) => (
          <a
            href={d.href}
            target="_blank"
            rel="noopener"
            class="dash-card group flex items-center gap-3 rounded-xl border border-line p-3"
            style={`--a:${accentVar[d.accent]}`}
          >
            <span class="dash-tile flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg text-lg">
              {d.glyph}
            </span>
            <span class="min-w-0 flex-1">
              <span class="flex items-center gap-1.5">
                <span class="truncate text-[0.92rem] font-semibold text-bright">{d.label}</span>
                {d.beta && <span class="sb-beta flex-shrink-0">beta</span>}
              </span>
              <span class="block truncate text-xs text-muted">{d.sub}</span>
            </span>
            <span class="dash-chevron text-muted transition-transform group-hover:translate-x-0.5">›</span>
          </a>
        ))
      }
    </div>
  </section>

  <section data-pagefind-ignore>
    <a
      href="https://13flow.eu/dashboard.html#confluence"
      target="_blank"
      rel="noopener"
      class="conf-head group mb-3 flex items-baseline justify-between gap-2"
    >
      <h2 class="mono-label glow">// confluence</h2>
      <span class="text-xs text-muted transition-colors group-hover:text-bright">13F &times; Form 4 ›</span>
    </a>
    <div class="space-y-1.5" data-confluence>
      {
        [0, 1, 2, 3, 4].map((i) => (
          <a
            href="https://13flow.eu/dashboard.html#confluence"
            target="_blank"
            rel="noopener"
            class="conf-row flex items-center gap-2 rounded-lg border border-line px-2.5 py-1.5"
            data-slot={i}
            style="display:none"
          >
            <span class="conf-ticker text-sm font-semibold tabular-nums text-bright" data-ticker>
              —
            </span>
            <span class="conf-ctx ml-auto truncate text-xs text-muted" data-ctx />
            <span class="conf-score font-display text-lg leading-none glow" data-score />
          </a>
        ))
      }
    </div>
  </section>

  <section>
    <h2 class="mono-label glow mb-3">// publication</h2>
    <a
      href="https://bluetouff.com/auditer-l-opacite.html"
      target="_blank"
      rel="noopener"
      class="pub-link card group flex items-center gap-3 p-3"
      aria-label="Auditer l'opacité — l'essai de Bluetouff"
    >
      <img
        src="/auditer-opacite.jpg"
        alt="Auditer l'opacité — Anatomie d'une crise qu'on ne veut pas voir, par Bluetouff"
        class="pub-cover"
        width="600"
        height="894"
        loading="lazy"
        decoding="async"
      />
      <span class="min-w-0 flex-1">
        <span class="block text-[0.92rem] font-semibold leading-tight text-bright">Auditer l'opacité</span>
        <span class="mt-0.5 block text-xs leading-snug text-muted">Anatomie d'une crise qu'on ne veut pas voir</span>
        <span class="mt-1.5 block text-[0.7rem] leading-tight text-muted">Printemps 2026</span>
        <span class="block text-[0.7rem] leading-tight text-muted">Par Bluetouff</span>
        <span class="pub-cta mt-1.5 block text-xs">Lire l'essai →</span>
      </span>
    </a>
  </section>

  <section>
    <div class="mb-2 flex items-center justify-between gap-2">
      <h2 class="mono-label glow">// about</h2>
      <div class="flex items-center gap-3">
        <a href="https://x.com/bluetouff" target="_blank" rel="me noopener" aria-label="X (Twitter) — @bluetouff" class="social-link">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
        </a>
        <a href="https://github.com/bluetouff" target="_blank" rel="me noopener" aria-label="GitHub — bluetouff" class="social-link">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
          </svg>
        </a>
      </div>
    </div>
    <p class="text-sm leading-relaxed text-muted text-justify">{sidebarAbout}</p>
    <p class="mt-3 text-xs leading-relaxed" style="color: var(--color-accent)">
      Les contenus de ce site ne constituent en aucun cas un conseil en investissement.
    </p>
  </section>
</div>

<script src="/confluence.js" defer is:inline></script>

<style>
  .conf-head:hover .mono-label { color: var(--color-signal); }
  .conf-row { transition: border-color 0.2s, background 0.2s; }
  .conf-row:hover {
    border-color: color-mix(in srgb, var(--color-signal) 45%, transparent);
    background: color-mix(in srgb, var(--color-signal) 6%, transparent);
  }
  .conf-score { color: var(--color-signal); }
  .dash-card { transition: border-color 0.2s, background 0.2s; }
  .dash-card:hover {
    border-color: color-mix(in srgb, var(--a) 55%, transparent);
    background: color-mix(in srgb, var(--a) 6%, transparent);
  }
  .dash-tile {
    border: 1px solid color-mix(in srgb, var(--a) 35%, transparent);
    background: color-mix(in srgb, var(--a) 10%, transparent);
  }
  .dash-chevron { color: var(--a); }

  .sb-beta {
    font-family: var(--font-mono);
    font-size: 0.52rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-amber);
    border: 1px solid color-mix(in srgb, var(--color-amber) 55%, transparent);
    background: color-mix(in srgb, var(--color-amber) 12%, transparent);
    border-radius: 5px;
    padding: 0.06rem 0.32rem;
    line-height: 1.3;
  }

  .social-link {
    color: var(--color-muted);
    transition: color 0.2s, transform 0.2s;
    display: inline-flex;
  }
  .social-link:hover { color: var(--color-signal); transform: translateY(-1px); }

  .pub-link { display: flex; }
  .pub-cover {
    flex: 0 0 auto;
    width: 78px;
    height: auto;
    border-radius: 4px;
    filter: grayscale(0.55) brightness(0.82) contrast(0.96);
    transition: transform 0.3s, filter 0.3s;
  }
  .pub-cta { color: var(--color-signal); transition: color 0.2s; }
  .pub-link:hover .pub-cover {
    transform: scale(1.015);
    filter: grayscale(0) brightness(1) contrast(1);
  }
  @media (prefers-reduced-motion: reduce) {
    .pub-link:hover .pub-cover { transform: none; }
  }
</style>
