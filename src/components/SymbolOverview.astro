---
/**
 * Comparateur multi-symboles (« Symbol Overview »).
 *   <SymbolOverview symbols={[{label:'BTC', ticker:'BINANCE:BTCUSDT'}, ...]} />
 */
interface Sym { label?: string; ticker: string }
interface Props {
  symbols: Sym[];
  height?: number;
  range?: '1D' | '1M' | '3M' | '12M' | '60M' | 'ALL';
}
const { symbols, height = 420, range = '12M' } = Astro.props;

const config = {
  symbols: symbols.map((s) => (s.label ? [s.label, `${s.ticker}|${range}`] : [`${s.ticker}|${range}`])),
  chartOnlySymbolId: '',
  width: '100%',
  height: '100%',
  locale: 'fr',
  colorTheme: 'dark',
  isTransparent: true,
  autosize: true,
  showVolume: false,
  showMA: false,
  fontColor: 'rgba(184,255,245,0.6)',
  gridLineColor: 'rgba(0,240,208,0.12)',
  lineWidth: 2,
  dateRanges: ['1d|1', '1m|30', '3m|60', '12m|1D', '60m|1W', 'all|1M'],
};
---

<div class="tv-widget" style={`--h:${height}px`}>
  <div class="tradingview-widget-container">
    <div class="tradingview-widget-container__widget"></div>
    <script
      type="text/javascript"
      src="https://s3.tradingview.com/external-embedding/embed-widget-symbol-overview.js"
      async
      is:inline
      set:html={JSON.stringify(config)}
    />
  </div>
</div>

<style>
  .tv-widget {
    margin: 1.5em 0;
    border: 1px solid var(--color-line);
    background: var(--color-surface);
    min-height: var(--h);
    height: var(--h);
    overflow: hidden;
  }
  .tv-widget .tradingview-widget-container,
  .tv-widget .tradingview-widget-container__widget { height: 100%; width: 100%; }
</style>
