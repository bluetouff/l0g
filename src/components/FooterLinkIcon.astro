  )}
  {name === 'status' && (
    <>
      <path d="M4 13h4l2-6 4 11 2-5h4" />
      <path d="M4 4h16v16H4z" />
    </>
  )}
  {name === 'privacy' && (
    <>
      <path d="M12 3l7 3v5c0 4.6-2.8 8-7 10-4.2-2-7-5.4-7-10V6z" />
      <path d="M9.5 12l1.7 1.7 3.6-4" />
