    </>
  )}
  {name === 'api' && (
    <>
      <path d="M8 4c-2 0-2.5 1-2.5 3v1.8c0 1.2-1 2.2-2.2 2.2 1.2 0 2.2 1 2.2 2.2V17c0 2 .5 3 2.5 3" />
      <path d="M16 4c2 0 2.5 1 2.5 3v1.8c0 1.2 1 2.2 2.2 2.2-1.2 0-2.2 1-2.2 2.2V17c0 2-.5 3-2.5 3" />
    </>
  )}
  {name === 'mcp' && (
    <>
      <circle cx="6" cy="6" r="2.4" />
      <circle cx="18" cy="6" r="2.4" />
      <circle cx="12" cy="18" r="2.4" />
      <path d="M7.7 7.7 10.6 16M16.3 7.7 13.4 16M8.4 6h7.2" />
    </>
  )}
  {name === 'agents' && (
    <>
      <path d="M12 3v4" />
      <rect x="6" y="7" width="12" height="9" rx="2" />
      <path d="M8 20h8M10 16v4M14 16v4" />
      <circle cx="10" cy="11.5" r="0.8" fill="currentColor" stroke="none" />
      <circle cx="14" cy="11.5" r="0.8" fill="currentColor" stroke="none" />
    </>
  )}
  {name === 'about' && (
    <>
      <circle cx="12" cy="12" r="9" />
