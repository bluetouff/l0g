---
import { serializeInlineScriptData } from '../lib/security.ts';

/**
 * Calendrier économique (« Events »).
 *   <EconomicCalendar countries="us,eu,fr,gb,jp,cn" />
 */
interface Props {
  height?: number;
  countries?: string;
  importanceFilter?: string; // "-1,0,1" du moins au plus important
}
const { height = 600, countries = 'us,eu,fr,gb,jp,cn', importanceFilter = '0,1' } = Astro.props;

const config = {
  colorTheme: 'dark',
  isTransparent: false,
  locale: 'fr',
  countryFilter: countries,
  importanceFilter,
  width: '100%',
  height: '100%',
};
---

<div class="tv-widget" style={`--h:${height}px`}>
  <div class="tradingview-widget-container">
    <div class="tradingview-widget-container__widget"></div>
    <script
      type="text/javascript"
      src="https://s3.tradingview.com/external-embedding/embed-widget-events.js"
      async
      is:inline
      set:html={serializeInlineScriptData(config)}
    />
  </div>
</div>

<style>
  .tv-widget {
    margin: 1.5em 0;
    border: 1px solid var(--color-line);
    background: var(--color-surface);
    min-height: var(--h);
    height: var(--h);
    overflow: hidden;
  }
  .tv-widget .tradingview-widget-container,
  .tv-widget .tradingview-widget-container__widget { height: 100%; width: 100%; }
</style>
