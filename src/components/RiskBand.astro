---
/**
 * Tableau de bord consolidé de signaux : valeurs reprises des dashboards.
 * Les valeurs sont lues côté navigateur dans /risk.json et /debt-latest.json
 * (origine self, aucun appel externe). Couleur par niveau de risque pour que
 * ça saute aux yeux.
 */
const items = [
  { key: 'us', label: 'US Macro', href: 'https://us.l0g.fr' },
  { key: 'eu', label: 'EU Macro', href: 'https://euro.l0g.fr' },
  { key: 'yen', label: 'Yen Carry', href: 'https://yct.l0g.fr' },
  { key: 'energie', label: 'Énergie', href: 'https://energie.l0g.fr' },
  { key: 'debt', label: 'Dette US', href: 'https://debt.l0g.fr' },
];
---

<section class="rise my-8" data-pagefind-ignore>
  <div class="mb-3 flex items-baseline justify-between gap-3">
    <h2 class="mono-label glow">// signaux de risque</h2>
    <a class="mono-label risk-history-link" href="/series/">historique & provenance</a>
  </div>

  <div class="grid grid-cols-2 gap-3 lg:grid-cols-5">
    {
      items.map((it) => (
        <a
          href={it.href}
          target="_blank"
          rel="noopener"
          class="risk-tile card group block p-4"
          data-risk={it.key}
        >
          <div class="flex items-center justify-between">
            <span class="mono-label">{it.label}</span>
            <span class="risk-arrow text-muted transition-transform group-hover:translate-x-0.5">›</span>
          </div>
          <div class="risk-reading mt-3 flex items-baseline gap-2">
            <span class="risk-value font-display leading-none glow" data-value>—</span>
            <span class="risk-level mono-label" data-level></span>
          </div>
          <div class="risk-track mt-3"><div class="risk-fill" data-fill></div></div>
          <div class="risk-status" data-status>source en attente</div>
        </a>
      ))
    }
  </div>
  <p class="risk-caveat">
    Scores 0-100 normalisés par instrument : ils ne mesurent ni le même phénomène,
    ni le même horizon. À lire comme un tableau de bord consolidé de signaux, pas comme un
    indice unique de risque systémique. Collecte best effort : chaque carte date sa source et
    signale tout repli. <span id="risk-updated"></span>
  </p>
</section>

<script src="/risk.js?v=20260630-debt" defer is:inline></script>

<style>
  .risk-track {
    height: 6px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    overflow: hidden;
  }
  .risk-fill {
    height: 100%;
    width: 0;
    border-radius: 999px;
    background: var(--color-muted);
    transition: width 0.6s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .risk-reading {
    min-height: 2.3rem;
  }
  .risk-value {
    color: var(--color-muted);
    font-size: 2rem;
  }
  .risk-level {
    font-size: 0.68rem;
    line-height: 1.35;
  }
  .risk-caveat {
    margin-top: 0.75rem;
    max-width: 48rem;
    color: var(--color-muted);
    font-size: 0.78rem;
    line-height: 1.55;
  }
  .risk-status {
    min-height: 1.9rem;
    margin-top: 0.55rem;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    line-height: 1.45;
  }
  .risk-history-link {
    color: var(--color-signal);
    text-decoration: none;
  }
  .risk-tile[data-degraded='true'] {
    border-color: color-mix(in srgb, var(--color-amber) 50%, var(--color-line));
  }
</style>
