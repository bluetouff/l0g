---
import L0gGlyph, { type GlyphName } from './L0gGlyph.astro';

interface Props {
  fact: string;
  importance: string;
  uncertainty: string;
  readingTime: number;
}

const { fact, importance, uncertainty, readingTime } = Astro.props;
const rows: Array<{ index: string; label: string; value: string; glyph: GlyphName }> = [
  { index: '01', label: 'Le fait', value: fact, glyph: 'source' },
  { index: '02', label: 'Pourquoi cela compte', value: importance, glyph: 'impact' },
  { index: '03', label: 'Ce qui reste incertain', value: uncertainty, glyph: 'uncertainty' },
];
---

<aside class="quick-take instrument-plate" aria-labelledby="quick-take-title" data-pagefind-ignore>
  <div class="quick-head">
    <div>
      <L0gGlyph name="read" size="sm" />
      <p id="quick-take-title">// en 30 secondes</p>
    </div>
    <span>avant les {readingTime} min d’analyse</span>
  </div>
  <dl>
    {rows.map((row) => (
      <div>
        <dt>
          <span class="quick-index" aria-hidden="true">{row.index}</span>
          <L0gGlyph name={row.glyph} size="sm" />
          <span>{row.label}</span>
        </dt>
        <dd>{row.value}</dd>
      </div>
    ))}
  </dl>
</aside>

<style>
  .quick-take {
    --plate-accent: var(--color-signal);
    margin: 0 0 2.1rem;
    border: 1px solid color-mix(in srgb, var(--color-signal) 32%, var(--color-line));
  }
  .quick-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.35rem 1rem;
    border-bottom: 1px solid var(--color-line);
    padding: 0.85rem 1rem;
  }
  .quick-head > div {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .quick-head p {
    color: var(--color-signal);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .quick-head span {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .quick-take dl { display: grid; margin: 0; }
  .quick-take dl > div {
    display: grid;
    grid-template-columns: minmax(11rem, 0.42fr) 1fr;
    align-items: start;
    gap: 0.7rem 1rem;
    padding: 0.85rem 1rem;
  }
  .quick-take dl > div + div { border-top: 1px solid var(--color-line); }
  .quick-take dt {
    display: grid;
    grid-template-columns: 1.4rem auto 1fr;
    align-items: center;
    gap: 0.55rem;
    color: var(--color-bright);
    font-family: var(--font-mono);
    font-size: 0.67rem;
    font-weight: 600;
    letter-spacing: 0.065em;
    text-transform: uppercase;
  }
  .quick-take dd {
    margin: 0;
    color: var(--color-paper);
    font-family: var(--font-read);
    font-size: 0.9rem;
    line-height: 1.55;
  }
  .quick-index {
    color: color-mix(in srgb, var(--color-signal) 60%, var(--color-muted));
    font-family: var(--font-mono);
    font-size: 0.59rem;
    letter-spacing: 0.08em;
  }
  @media (max-width: 560px) {
    .quick-take dl > div {
      grid-template-columns: 1fr;
      gap: 0.55rem;
    }
  }
</style>
