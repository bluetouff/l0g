---
interface Props {
  currentPage: number;
  totalPages: number;
  pageHref: (page: number) => string;
  ariaLabel: string;
  previousLabel: string;
  nextLabel: string;
}

const {
  currentPage,
  totalPages,
  pageHref,
  ariaLabel,
  previousLabel,
  nextLabel,
} = Astro.props;

const pages = Array.from({ length: totalPages }, (_, i) => i + 1);
---

{
  totalPages > 1 && (
    <nav class="pager rise" aria-label={ariaLabel}>
      {currentPage > 1 ? (
        <a class="pager-step" href={pageHref(currentPage - 1)} rel="prev">‹ {previousLabel}</a>
      ) : (
        <span class="pager-step is-disabled" aria-disabled="true">‹ {previousLabel}</span>
      )}
      <span class="pager-nums">
        {pages.map((page) =>
          page === currentPage ? (
            <span class="pager-num is-current" aria-current="page">{page}</span>
          ) : (
            <a class="pager-num" href={pageHref(page)}>{page}</a>
          )
        )}
      </span>
      {currentPage < totalPages ? (
        <a class="pager-step" href={pageHref(currentPage + 1)} rel="next">{nextLabel} ›</a>
      ) : (
        <span class="pager-step is-disabled" aria-disabled="true">{nextLabel} ›</span>
      )}
    </nav>
  )
}

<style>
  .pager {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2.4rem;
    padding-top: 1.6rem;
    border-top: 1px dashed var(--color-line);
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }
  .pager-step {
    color: var(--color-signal);
    text-decoration: none;
    padding: 0.35rem 0.7rem;
    border: 1px solid color-mix(in srgb, var(--color-signal) 35%, transparent);
    border-radius: 6px;
    transition: background 0.16s, color 0.16s;
    white-space: nowrap;
  }
  .pager-step:hover { background: color-mix(in srgb, var(--color-signal) 12%, transparent); }
  .pager-step.is-disabled {
    color: var(--color-line-strong);
    border-color: var(--color-line);
    pointer-events: none;
    opacity: 0.55;
  }
  .pager-nums { display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 0.3rem; }
  .pager-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.9rem;
    height: 1.9rem;
    padding: 0 0.4rem;
    color: var(--color-muted);
    text-decoration: none;
    border-radius: 6px;
    font-variant-numeric: tabular-nums;
    transition: background 0.16s, color 0.16s;
  }
  .pager-num:hover { color: var(--color-bright); background: color-mix(in srgb, var(--color-signal) 10%, transparent); }
  .pager-num.is-current {
    color: var(--color-bg, #0c0d10);
    background: var(--color-signal);
    font-weight: 700;
  }
  @media (max-width: 480px) {
    .pager { flex-wrap: wrap; justify-content: center; }
    .pager-nums { order: 3; width: 100%; }
  }
</style>
