---
interface Props {
  url: string;
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
}
const { url, title, description, pubDate, tags = [] } = Astro.props;
const dateLabel = pubDate.toLocaleDateString('fr-FR', {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
});
const iso = pubDate.toISOString();
---

<article class="group border-t border-dashed border-line py-8 first:border-t-0">
  <a href={url} class="block">
    <div class="flex flex-col gap-1.5 sm:flex-row sm:items-baseline sm:gap-6">
      <time datetime={iso} class="mono-label shrink-0 sm:w-28">{dateLabel}</time>
      <div class="min-w-0">
        <h2
          class="font-display text-2xl font-medium leading-tight tracking-tight text-paper transition-colors group-hover:text-signal sm:text-3xl"
        >
          {title}
        </h2>
        <p class="mt-2 max-w-2xl text-muted">{description}</p>
        {
          tags.length > 0 && (
            <ul class="mt-3 flex flex-wrap gap-2">
              {tags.map((t) => (
                <li class="mono-label border border-line px-2 py-0.5">{t}</li>
              ))}
            </ul>
          )
        }
      </div>
    </div>
  </a>
</article>
