---
interface Props {
  url: string;
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  readingTime?: number;
  index?: number;
  accent?: string;
  accentLabel?: string;
}
const {
  url, title, description, pubDate, tags = [],
  readingTime, index, accent = 'var(--color-signal)', accentLabel,
} = Astro.props;
const dateLabel = pubDate.toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' });
const iso = pubDate.toISOString();
const nn = index != null ? String(index).padStart(2, '0') : null;
---

<a href={url} class="feed-item group" style={`--a:${accent}`}>
  {nn && <span class="feed-index mono-label" aria-hidden="true">{nn}</span>}
  <span class="feed-rail" aria-hidden="true"></span>
  <span class="feed-body">
    <span class="feed-meta">
      <time datetime={iso} class="mono-label feed-date">{dateLabel}</time>
      {readingTime && <span class="mono-label text-muted">· {readingTime} min</span>}
      {accentLabel && <span class="topic-chip">{accentLabel}</span>}
    </span>
    <span class="feed-title">{title}</span>
    <span class="feed-desc">{description}</span>
  </span>
  <span class="feed-arrow" aria-hidden="true">&rsaquo;</span>
</a>

<style>
  .feed-item {
    --a: var(--color-signal);
    display: grid;
    grid-template-columns: auto 2px 1fr auto;
    align-items: start;
    column-gap: 1rem;
    padding: 1.05rem 0.75rem 1.05rem 0.25rem;
    border-bottom: 1px solid var(--color-line);
    border-radius: 8px;
    transition: background 0.16s;
  }
  .feed-item:hover { background: color-mix(in srgb, var(--a) 7%, transparent); }

  .feed-index {
    min-width: 1.8rem;
    padding-top: 0.15rem;
    color: var(--color-line-strong);
    font-variant-numeric: tabular-nums;
    transition: color 0.16s;
  }
  .feed-item:hover .feed-index { color: var(--a); }

  .feed-rail {
    align-self: stretch;
    border-radius: 999px;
    background: color-mix(in srgb, var(--a) 30%, transparent);
    transition: background 0.16s;
  }
  .feed-item:hover .feed-rail { background: var(--a); }

  .feed-body { min-width: 0; }
  .feed-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem; }
  .feed-date { color: var(--a); }

  .topic-chip {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--a);
    padding: 0.1rem 0.45rem;
    border: 1px solid color-mix(in srgb, var(--a) 35%, transparent);
    background: color-mix(in srgb, var(--a) 12%, transparent);
    border-radius: 999px;
  }

  .feed-title {
    display: block;
    margin-top: 0.45rem;
    font-size: 1.18rem;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-bright);
    transition: color 0.16s;
  }
  .feed-item:hover .feed-title { color: var(--a); }

  .feed-desc {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-top: 0.35rem;
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--color-muted);
  }

  .feed-arrow {
    align-self: center;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--color-line-strong);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.16s, transform 0.16s, color 0.16s;
  }
  .feed-item:hover .feed-arrow { opacity: 1; transform: translateX(0); color: var(--a); }

  @media (max-width: 640px) {
    .feed-desc { -webkit-line-clamp: 2; }
    .feed-arrow { display: none; }
  }
  @media (hover: none) {
    .feed-rail { background: color-mix(in srgb, var(--a) 55%, transparent); }
  }
  @media (prefers-reduced-motion: reduce) {
    .feed-arrow { transition: opacity 0.16s; transform: none; }
  }
</style>
