---
interface Props {
  url: string;
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
}
const { url, title, description, pubDate, tags = [] } = Astro.props;
const dateLabel = pubDate.toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' });
const iso = pubDate.toISOString();
---

<a href={url} class="card group mb-3 block p-5">
  <div class="flex items-center gap-3">
    <time datetime={iso} class="mono-label" style="color: var(--color-signal)">{dateLabel}</time>
    {tags.map((t) => <span class="badge">{t}</span>)}
  </div>
  <h2 class="mt-3 text-xl font-bold leading-snug tracking-tight text-bright transition-colors group-hover:text-signal sm:text-[1.4rem]">
    {title}
  </h2>
  <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-muted">{description}</p>
</a>
