{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://l0g.fr/schemas/editorial-protocol/1.0/evidence-pack.schema.json",
  "title": "l0g Editorial Protocol evidence pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "protocolVersion",
    "articleId",
    "generatedAt",
    "license",
    "attribution",
    "evidence",
    "limitations"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "protocolVersion": { "const": "1.0.0" },
    "articleId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "license": { "const": "CC-BY-4.0" },
    "attribution": { "type": "string", "minLength": 12 },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "claimIds",
          "kind",
          "proofDepth",
          "publisher",
          "title",
          "url",
          "retrievedAt",
          "locator",
          "supports"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^evidence-[a-z0-9-]+$" },
          "claimIds": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^claim-[a-z0-9-]+$" }
          },
          "kind": { "enum": ["primary", "public-data", "secondary", "internal"] },
          "proofDepth": {
            "enum": ["mention", "reference", "linked-source", "direct-proof", "reproduction"]
          },
          "publisher": { "type": "string", "minLength": 2 },
          "title": { "type": "string", "minLength": 8 },
          "url": { "type": "string", "format": "uri", "pattern": "^https://" },
          "publishedAt": { "type": ["string", "null"], "format": "date" },
          "retrievedAt": { "type": "string", "format": "date" },
          "locator": { "type": "string", "minLength": 8 },
          "supports": { "type": "string", "minLength": 20 }
        }
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 20 }
    }
  }
}
